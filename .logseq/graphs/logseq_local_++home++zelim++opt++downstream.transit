15",[377,"^U",171,536870916]],["^15",[377,"^U",312,536870916]],["^15",[377,"^U",313,536870916]],["^15",[377,"^U",344,536870916]],["^15",[377,"^U",345,536870916]],["^15",[377,"^U",346,536870916]],["^15",[377,"^;","~u679c5d78-ec5d-4bf0-a005-c34abe50915f",536870916]],["^15",[378,"^3","- #[[collector's fallacy]] #[[procrastination/sophisticated procrastination]]\n\t- Я собрал...\n\t\t- почти 220 000 слов в заметках.\n\t\t\t- Для сравнения в Улиссе 268 170 слов, в Каренине - 353 250.\n\t\t- более 26 000 книг и комиксов на Чердаке.\n\t\t\t- Прочитал около двухсот.\n\t\t- почти 25 000 файлов в Ранце.\n\t\t\t- Ничего не прочитано.\n\t\t- 450 фильмов в Movies.\n\t\t\t- 200 из них в To watch.\n\t\t- более 50 покупок в Стиме.\n\t\t\t- Играл по сути в девять игр.\n\t\t- в каталогах\n\t\t\t- около 770 фильмов. С учётом того, что эти, подлежащие к просмотру, у меня отдельно от моей коллекции и вовсе незалогенных, то это единственный пункт, где я получил хоть какую-то пользу.\n\t\t\t- около 450 видеоигр.\n\t\t\t\t- Поиграл примерно в пятнадцать.\n\t\t\t- 370 настольных.\n\t\t\t\t- Поиграл более двух раз в четыре.\n\t\t\t- кучу сериалов, музыки, лекций и прочего.\n\t- Я их постоянно организовывал, переименовывал и классифицировал.",536883949]],["^15",[378,"^16",1738300792606,536870916]],["^15",[378,"^18","~m1742307255602",536883948]],["^15",[378,"^Z","journals/2023_10_17.md",536870916]],["^15",[379,"^K",1738300792605,536870916]],["^15",[379,"^[",378,536870916]],["^15",[379,"^N",20231017,536870916]],["^15",[379,"^@",true,536870916]],["^15",[379,"^Y","oct 17th, 2023",536870916]],["^15",[379,"^11","Oct 17th, 2023",536870916]],["^15",[379,"^B",1738300792605,536870916]],["^15",[379,"^;","~u679c5d78-5b74-4085-8153-6396155bf82d",536870916]],["^15",[380,"^K",1738300792813,536870916]],["^15",[380,"^O","^17",536883937]],["^15",[380,"^@",false,536870916]],["^15",[380,"^Y","procrastination/sophisticated procrastination",536883941]],["^15",[380,"^A",414,536883946]],["^15",[380,"^11","procrastin