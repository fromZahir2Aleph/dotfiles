,"^X",651,536870916]],["^15",[843,"^V",791,536870916]],["^15",[843,"^U",651,536870916]],["^15",[843,"^;","~u679c5d79-46a2-4b5a-afa8-3d68eaf76afa",536870916]],["^15",[844,"^Q","Однако постепенно он забил на сопровождение кода - люди стали плодиться в геометрической прогрессии, как впрочем и баги.",536870916]],["^15",[844,"^O","^17",536870916]],["^15",[844,"^F",750,536870916]],["^15",[844,"^X",651,536870916]],["^15",[844,"^V",750,536870916]],["^15",[844,"^U",651,536870916]],["^15",[844,"^;","~u679c5d79-52e7-422e-8c7c-a7cdd1d29dc5",536870916]],["^15",[845,"^3","- ![The Philosopher's Toolkit_ A Compendium of - Peter S. Fosl.pdf](../assets/The_Philosopher's_Toolkit_A_Compendium_of_-_Peter_S._Fosl_1694722392332_0.pdf)\n- Argument\n\t- Deduction\n\t\t- Follows from premises with necessity\n\t- Induction\n\t\t- Follows from premises with probability, because the following is not conclusive\n\t\t\t- Most X have Y\n\t\t\t  This is X\n\t\t\t  Therefore, this X has Y\n\t\t- Is mostly but not necessarily in form of generalization\n\t\t- Limitations\n\t\t\t- Future\n\t\t\t- Intractable past\n\t\t\t- Unobservable nature and universe\n\t\t\t- Extent of human observation: cognition, memory, etc.\n\t- Validity and soundness\n\t\t- Validity is the topic-neutral property of argument's structure. Basically \"if the premise is true\", the conclusion of which can be:\n\t\t\t- Probable\n\t\t\t  collapsed:: true\n\t\t\t\t- If I get flush on river, I probably will win.\n\t\t\t\t  I got flush.\n\t\t\t\t  I probably won\n\t\t\t- Certain\n\t\t\t  collapsed:: true\n\t\t\t\t- If the lines are parallel, they don't intersect.\n\t\t\t\t- The lines are parallel.\n\t\t\t\t- They don't intersect.\n\t\t- If the premise of a valid argument is actually true it's sound.\n\t- Refutations of an argument\n\t\t- The argument is invalid\n\t\t- One or more of the premises are false\n\t\t- The conclusion is false as in *reductio ad absurdum*\n\t\t\t- Just shows that the conclusion must be false but doesn't refute the argument itself, because it doesn't indicate *what* is wrong with the argument, only that *something* must be wrong with it.\n\t- Abduction or inference to the best explanation\n\t  collapsed:: true\n\t\t- Similarity to Induction\n\t\t\t- Doesn't necessarily follow from the premises like deduction does\n\t\t- Difference from Induction\n\t\t\t- Appeals implicitly or explicitly to additional reasoning whereas induction *only* appeals to frequency or statistics\n\t- Hypothetico‐deductive method\n\t\t- Start with a hypothesis\n\t\t  logseq.order-list-type:: number\n\t\t- Deduce which facts follow\n\t\t  logseq.order-list-type:: number\n\t\t- Make an experiment to test them\n\t\t  logseq.order-list-type:: number\n\t\t- Make a deduction whether the hypothesis is true or false\n\t\t  logseq.order-list-type:: number\n\t-\n- Paragraph markers\n  id:: 65677c5b-9d97-4bc0-b2b7-75c75bd7dca6\n\t- Explication\n\t\t- XPL\n\t- In other words\n\t\t- IE\n\t- Example\n\t\t- EG\n\t- My commentary\n\t\t- Commetary",536870916]],["^15",[845,"^16",1738300793282,536870916]],["^15",[845,"^Z","pages/Philosopher's Toolkit.md",536870916]],["^15",[846,"^Q","In other words",536870916]],["^15",[846,"^O","^17",536870916]],["^15",[846,"^F",876,536870916]],["^15",[846,"^X",653,536870916]],["^15",[846,"^V",882,536870916]],["^15",[846,"^U",653,536870916]],["^15",[846,"^;","~u679c5d79-c230-4366-8ce8-80c4bf3410e9",536870916]],["^15",[847,"^Q","If I get flush on river, I probably will win.\nI got flush.\nI probably won",536870916]],["^15",[847,"^O","^17",536870916]],["^15",[847,"^F",877,536870916]],["^15",[847,"^X",653,536870916]],["^15",[847,"^V",877,536870916]],["^15",[847,"^U",653,536870916]],["^15",[847,"^;","~u679c5d79-2db3-4cc3-9fa3-6cfc10f95721",536870916]],["^15",[848,"^Q","Make a deduction whether the hypothesis is true or false\nlogseq.order-list-type:: number",536870916]],["^15",[848,"^O","^17",536870916]],["^15",[848,"^F",864,536870916]],["^15",[848,"^X",653,536870916]],["^15",[848,"^V",86