,536887720]],["^15",[2418,"^X",235,536887720]],["^15",[2418,"^V",2414,536887720]],["^15",[2418,"^U",235,536888787]],["^15",[2418,"^;","~u679c5d7c-6299-46c7-adfe-670cb4214d24",536887720]],["^15",[2419,"^M",false,536888024]],["^15",[2419,"^Q","Олимп и человечество",536888133]],["^15",[2419,"^O","^17",536887720]],["^15",[2419,"^F",2414,536887720]],["^15",[2419,"^X",235,536887720]],["^15",[2419,"^V",1739,536887720]],["^15",[2419,"^U",235,536888787]],["^15",[2419,"^;","~u679c5d7c-a80d-4ff0-a7b0-0a565e94e541",536887720]],["^15",[2420,"^Q","Гефест и Прометей",536887720]],["^15",[2420,"^O","^17",536887720]],["^15",[2420,"^F",2419,536887720]],["^15",[2420,"^X",235,536887720]],["^15",[2420,"^V",2419,536887720]],["^15",[2420,"^U",235,536888787]],["^15",[2420,"^;","~u679c5d7c-ae4b-4e48-9b8d-a41abcb96a2a",536887720]],["^15",[2421,"^Q","Гефест",536887720]],["^15",[2421,"^O","^17",536887720]],["^15",[2421,"^F",2420,536887720]],["^15",[2421,"^X",235,536887720]],["^15",[2421,"^V",2420,536887720]],["^15",[2421,"^U",235,536888787]],["^15",[2421,"^;","~u679c5d7c-7494-488c-a1fe-ac54d93dfd44",536887720]],["^15",[2422,"^Q","Легенда об Эрихтонии - это сокрытие инцеста Посейдона и Афины. Образ девственно зачатой и девственной дочери важен для Зевса. Поэтому испугавшись гнева Зевса, Посейдон и Гера назначают козлом отпущения Гефеста. Он и сам на это соглашаются, так как Афродита обещают ему своё руку, но не сердце, как мы узнаём позже. Не потому ли его столкнули с Олимпа.",536887720]],["^15",[2422,"^O","^17",536887720]],["^15",[2422,"^F",2421,536887720]],["^15",[2422,"^X",235,536887720]],["^15",[2422,"^V",2421,536887720]],["^15",[2422,"^U",235,536888787]],["^15",[2422,"^;","~u679c5d7c-604a-4c2b-a95b-756b82e58a5d",536887720]],["^15",[2423,"^Q","Прометей",536887720]],["^15",[2423,"^O","^17",536887720]],["^15",[2423,"^F",2421,536887720]],["^15",[2423,"^X",235,536887720]],["^15",[2423,"^V",2420,536887720]],["^15",[2423,"^U",235,536888787]],["^15",[2423,"^;","~u679c5d7c-c4f0-4af0-b623-ae443dccb5a1",536887720]],["^15",[2424,"^Q","\"Я сын Прометея, который (длинная серия придаточных предложений). Я дочь Прометея, который (длинная серия придаточных предложений).\"",536887720]],["^15",[2424,"^O","^17",536887720]],["^15",[2424,"^F",2423,536887720]],["^15",[2424,"^X",235,536887720]],["^15",[2424,"^V",2423,536887720]],["^15",[2424,"^U",235,536888787]],["^15",[2424,"^;","~u679c5d7c-ea29-4f9a-aa7f-7fe042e8db6b",536887720]],["^15",[2425,"^Q","Важно, чтобы человечество знало, что он страдает. Поначалу он даже получал удовольствие от своих мучений.",536887720]],["^15",[2425,"^O","^17",536887720]],["^15",[2425,"^F",2424,536887720]],["^15",[2425,"^X",235,536887720]],["^15",[2425,"^V",2423,536887720]],["^15",[2425,"^U",235,536888787]],["^15",[2425,"^;","~u679c5d7c-a057-4822-ada7-440b915cdf8f",536887720]],["^15",[2426,"^Q","((66d3325b-6610-42cf-9cca-88c34afc0264))",536887720]],["^15",[2426,"^O","^17",536887720]],["^15",[2426,"^F",2420,536887720]],["^15",[2426,"^X",235,536887720]],["^15",[2426,"^V",2419,536887720]],["^15",[2426,"^U",235,536888787]],["^15",[2426,"^U",746,536888787]],["^15",[2426,"^H",746,536888133]],["^15",[2426,"^;","~u679c5d7c-8036-4570-b7b2-0184b495f4c1",536887720]],["^15",[2427,"^K",1743627604282,536887730]],["^15",[2427,"^O","^17",536887730]],["^15",[2427,"^N",20250403,536887730]],["^15",[2427,"^@",true,536887730]],["^15",[2427,"^Y","apr 3rd, 2025",536887730]],["^15",[2427,"^11","Apr 3rd, 2025",536887730]],["^15",[2427,"^B",1743627604282,536887730]],["^15",[2427,"^;","~u67eda554-5a6e-4a5e-a43b-9d9acbac8086",536887730]],["^15",[2428,"^Q","",536887731]],["^15",[2428,"^O","^17",536887731]],["^15",[2428,"^N",20250403,536887731]],["^15",[2428,"^@",true,536887731]],["^15",[2428,"^F",2427,536887731]],["^15",[2428,"^X",2427,536887731]],["^15",[2428,"^V",2427,536887731]],["^15",[2428,"^U",2427,536887732]],["^15",[2428,"^?",["^ "],536887731]],["^15",[2428,"^;","~u67eda554-84bc-4ad5-a8ff-63c6545fbb48",536887731]],["^15",[2429,"^12",2,536887797]],["^15",[2430,"^K",