gy:: Greece\n.transcription:: /dɛː.mɛ̌ː.tɛːr/\n.translation:: Деметра\n.flags:: Olympian",536870916]],["^15",[752,"^O","^17",536870916]],["^15",[752,"^F",782,536870916]],["^15",[752,"^X",651,536870916]],["^15",[752,"^V",723,536870916]],["^15",[752,"^U",651,536870916]],["^15",[752,"^U",670,536870916]],["^15",[752,"^U",671,536870916]],["^15",[752,"^U",674,536870916]],["^15",[752,"^U",676,536870916]],["^15",[752,"^U",678,536870916]],["^15",[752,"^U",679,536870916]],["^15",[752,"^?",["^ ","^1Q","","^1R","god","^1S","Greece","^1T","/dɛː.mɛ̌ː.tɛːr/","^1U","Деметра","^1V","Olympian"],536870916]],["^15",[752,"^J",["^1Q","^1R","^1S","^1T","^1U","^1V"],536870916]],["^15",[752,"^4",["^ ","^1Q","","^1R","god","^1S","Greece","^1T","/dɛː.mɛ̌ː.tɛːr/","^1U","Деметра","^1V","Olympian"],536870916]],["^15",[752,"^H",670,536870916]],["^15",[752,"^H",671,536870916]],["^15",[752,"^H",674,536870916]],["^15",[752,"^H",676,536870916]],["^15",[752,"^H",678,536870916]],["^15",[752,"^H",679,536870916]],["^15",[752,"^;","~u679c5d79-8814-43ac-ada0-f5e94795a3ec",536870916]],["^15",[753,"^Q","Циклопы в Одиссее",536870916]],["^15",[753,"^O","^17",536870916]],["^15",[753,"^F",757,536870916]],["^15",[753,"^X",651,536870916]],["^15",[753,"^V",702,536870916]],["^15",[753,"^U",651,536870916]],["^15",[753,"^;","~u679c5d79-8f56-4aa7-9190-53ee0f87d190",536870916]],["^15",[754,"^Q","Бронзовый век",536870916]],["^15",[754,"^O","^17",536870916]],["^15",[754,"^F",680,536870916]],["^15",[754,"^X",651,536870916]],["^15",[754,"^V",746,536870916]],["^15",[754,"^U",651,536870916]],["^15",[754,"^;","~u679c5d79-aad6-4a36-9cc5-a05e795249a1",536870916]],["^15",[755,"^Q","Под её горячую руку часто попадали любовницы и незаконнорождённые мужа, например, Лето, [Дионис](((2f675fa9-98a6-470c-93e3-a065e08759ef))) и [Геракл](((67411a44-35d2-43c4-911e-359e8e34c7b9))).",536870916]],["^15",[755,"^O","^17",536870916]],["^15",[755,"^F",701,536870916]],["^15",[755,"^X",651,536870916]],["^15",[755,"^V",797,536870916]],["^15",[755,"^U",651,536870916]],["^15",[755,"^U",670,536870916]],["^15",[755,"^U",671,536870916]],["^15",[755,"^U",674,536870916]],["^15",[755,"^U",676,536870916]],["^15",[755,"^U",678,536870916]],["^15",[755,"^U",679,536870916]],["^15",[755,"^H",815,536870916]],["^15",[755,"^H",817,536870916]],["^15",[755,"^;","~u679c5d79-cb47-48f7-8543-9accb8c39486",536870916]],["^15",[756,"^Q","Талос",536870916]],["^15",[756,"^O","^17",536870916]],["^15",[756,"^F",842,536870916]],["^15",[756,"^X",651,536870916]],["^15",[756,"^V",842,536870916]],["^15",[756,"^U",651,536870916]],["^15",[756,"^;","~u679c5d79-a6db-451c-bba5-5a30544d7e2b",536870916]],["^15",[757,"^Q","Участники Гигантомахии\nid:: 64b4613c-6f4b-4166-929c-b7711cb73c7d",536870916]],["^15",[757,"^O","^17",536870916]],["^15",[757,"^F",702,536870916]],["^15",[757,"^X",651,536870916]],["^15",[757,"^V",702,536870916]],["^15",[757,"^U",651,536870916]],["^15",[757,"^?",["^ ","^1?","64b4613c-6f4b-4166-929c-b7711cb73c7d"],536870916]],["^15",[757,"^J",["^1?"],536870916]],["^15",[757,"^4",["^ ","^1?","64b4613c-6f4b-4166-929c-b7711cb73c7d"],536870916]],["^15",[757,"^;","~u64b4613c-6f4b-4166-929c-b7711cb73c7d",536870916]],["^15",[758,"^Q","3. \"The god of prophecy\"",536870916]],["^15",[758,"^O","^17",536870916]],["^15",[758,"^F",804,536870916]],["^15",[758,"^X",651,536870916]],["^15",[758,"^V",681,536870916]],["^15",[758,"^U",651,536870916]],["^15",[758,"^;","~u679c5d79-2114-4ee7-9780-26c39ba15a6f",536870916]],["^15",[759,"^Q","История его взросления подобна происхождению [Пандоры](Πανδώρα), только наоборот. Они дважды скидывали его с Олимпа, заковывали в ограничивающие рост цепи и сделали своим чернорабочим.",536870916]],["^15",[759,"^O","^17",536870916]],["^15",[759,"^F",690,536870916]],["^15",[759,"^X",651,536870916]],["^15",[759,"^V",690,536870916]],["^15",[759,"^U",651,536870916]],["^15",[759,"^U",672,536870916]],["^15",[759,"^;","~u679c5d79-62a0-4609-a538-1b9bd1bafec8",536870916]],["^15",[760,"^Q","Ἀθηνᾶ\n.tags::\n.being:: god\n.mythology:: Greece\n.transcription:: /a.tʰɛː.nâː/\n.translation:: Афина\n.flags:: Olympian\nid:: 66ba0f9b-9bf9-4e3e-80ea-4bd53040a923",536870916]],["^15",[760,"^O","^17",536870916]],["^15",[760,"^F",836,536870916]],["^15",[760,"^X",651,536870916]],["^15",[760,"^V",723,536870916]],["^15",[760,"^U",651,536870916]],["^15",[760,"^U",670,536870916]],["^15",[760,"^U",671,536870916]],["^15",[760,"^U",674,536870916]],["^15",[760,"^U",676,536870916]],["^15",[760,"^U",678,536870916]],["^15",[760,"^U",679,536870916]],["^15",[760,"^?",["^ ","^1Q","","^1R","god","^1S","Greece","^1T","/a.tʰɛː.nâː/","^1U","Афина","^1V","Olympian","^1?","66ba0f9b-9bf9-4e3e-80ea-4bd53040a923"],536870916]],["^15",[760,"^J",["^1Q","^1R","^1S","^1T","^1U","^1V","^1?"],536870916]],["^15",[760,"^4",["^ ","^1Q","","^1R","god","^1S","Greece","^1T","/a.tʰɛː.nâː/","^1U","Афина","^1V","Olympian","^1?","66ba0f9b-9bf9-4e3e-80ea-4bd53040a923"],536870916]],["^15",[760,"^H",670,536870916]],["^15",[760,"^H",671,536870916]],["^15",[760,"^H",674,536870916]],["^15",[760,"^H",676,536870916]],["^15",[760,"^H",678,536870916]],["^15",[760,"^H",679,536870916]],["^15",[760,"^;","~u66ba0f9b-9bf9-4e3e-80ea-4bd53040a923",536870916]],["^15",[761,"^Q","Пятка Талоса\nid:: 66d3325b-a10c-4876-a064-70e45a456087",536870916]],["^15",[761,"^O","^17",536870916]],["^15",[761,"^F",823,536870916]],["^15",[761,"^X",651,536870916]],["^15",[761,"^V",694,536870916]],["^15",[761,"^U",651,536870916]],["^15",[761,"^U",672,536870916]],["^15",[761,"^?",["^ ","^1?","66d3325b-a10c-4876-a064-70e45a456087"],536870916]],["^15",[761,"^J",["^1?"],536870916]],["^15",[761,"^4",["^ ","^1?","66d3325b-a10c-4876-a064-70e45a456087"],536870916]],["^15",[761,"^;","~u66d3325b-a10c-4876-a064-70e45a456087",536870916]],["^15",[762,"^Q","После того как Гера из ревности мужа Зевса к Лето запретила земной тверди предоставить ей место для родов, та скиталась, пока плавучий остров Дилос не приютил её. Не привязанный к матушке Гее, он не был под запретом. Как только Лето опустилась на его поверхность, он остановился на месте, дал кров её двойняшкам Аполлону и Артемиде и возложил на себя ношу религиозных, административных и геометрических обязанностей. И долго затем грустил по океанам и грезил о неизведанных морях.",536870916]],["^15",[762,"^O","^17",536870916]],["^15",[762,"^F",785,536870916]],["^15",[762,"^X",651,536870916]],["^15",[762,"^V",785,536870916]],["^15",[762,"^U",651,536870916]],["^15",[762,"^;","~u679c5d79-4e80-4b4d-aa2e-50be03839398",536870916]],["^15",[763,"^Q","5. \"The god who protects the flocks and cattle",536870916]],["^15",[763,"^O","^17",536870916]],["^15",[763,"^F",792,536870916]],["^15",[763,"^X",651,536870916]],["^15",[763,"^V",681,536870916]],["^15",[763,"^U",651,536870916]],["^15",[763,"^;","~u679c5d79-ef52-40f6-9636-417ad6b1f7a8",536870916]],["^15",[764,"^Q","Разжалование бога по функциям и регионам",536870916]],["^15",[764,"^O","^17",536870916]],["^15",[764,"^F",841,536870916]],["^15",[764,"^X",651,536870916]],["^15",[764,"^V",841,536870916]],["^15",[764,"^U",651,536870916]],["^15",[764,"^U",672,536870916]],["^15",[764,"^;","~u679c5d79-5218-4996-b0fe-af305b65e965",536870916]],["^15",[765,"^Q","Пифийские в честь [Аполлона](((3755fb37-1121-4a9c-a22d-2fee9141dc8e)))",536870916]],["^15",[765,"^O","^17",536870916]],["^15",[765,"^F",788,536870916]],["^15",[765,"^X",651,536870916]],["^15",[765,"^V",777,536870916]],["^15",[765,"^U",651,536870916]],["^15",[765,"^H",831,536870916]],["^15",[765,"^;","~u679c5d79-5ea3-48f1-8e1e-bdc670eac27a",536870916]],["^15",[766,"^Q","Трезубец [Посейдона](((64af1cf7-5636-4536-917f-cb44f27037a8)))",536870916]],["^15",[766,"^O","^17",536870916]],["^15",[766,"^F",743,536870916]],["^15",[766,"^X",651,536870916]],["^15",[766,"^V",704,536870916]],["^15",[766,"^U",651,536870916]],["^15",[766,"^H",822,536870916]],["^15",[766,"^;","~u679c5d79-1768-4dab-ad6a-1612033cf001",536870916]],["^15",[767,"^Q","Переверни сюжет Пигмалиона, где каждый из богов учит её своей фирменной мерзости, чтобы она, собственно, и стала тем ящиком, и с другой стороны и чтобы навсегда подорвать доверие к женщине у мужчин и патриархия царила не только на Олимпе, но и внизу.",536870916]],["^15",[767,"^O","^17",536870916]],["^15",[767,"^F",770,536870916]],["^15",[767,"^X",651,536870916]],["^15",[767,"^V",770,536870916]],["^15",[767,"^U",651,536870916]],["^15",[767,"^U",670,536870916]],["^15",[767,"^U",671,536870916]],["^15",[767,"^U",672,536870916]],["^15",[767,"^U",674,536870916]],["^15",[767,"^U",676,536870916]],["^15",[767,"^U",678,536870916]],["^15",[767,"^U",679,536870916]],["^15",[767,"^;","~u679c5d79-c94f-4dd5-ac5f-109184d906c3",536870916]],["^15",[768,"^Q","ᾍδης\nid:: 64c03a7d-7892-4801-8d84-6c73af7c13ed\n.tags::\n.being:: god\n.mythology:: Greece\n.transcription:: /háːi̯.dɛːs/\n.translation:: Аид\n.flags:: chthonic",536870916]],["^15",[768,"^O","^17",536870916]],["^15",[768,"^F",723,536870916]],["^15",[768,"^X",651,536870916]],["^15",[768,"^V",824,536870916]],["^15",[768,"^U",651,536870916]],["^15",[768,"^U",670,536870916]],["^15",[768,"^U",671,536870916]],["^15",[768,"^U",674,536870916]],["^15",[768,"^U",676,536870916]],["^15",[768,"^U",678,536870916]],["^15",[768,"^U",679,536870916]],["^15",[768,"^?",["^ ","^1?","64c03a7d-7892-4801-8d84-6c73af7c13ed","^1Q","","^1R","god","^1S","Greece","^1T","/háːi̯.dɛːs/","^1U","Аид","^1V","chthonic"],536870916]],["^15",[768,"^J",["^1?","^1Q","^1R","^1S","^1T","^1U","^1V"],536870916]],["^15",[768,"^4",["^ ","^1?","64c03a7d-7892-4801-8d84-6c73af7c13ed","^1Q","","^1R","god","^1S","Greece","^1T","/háːi̯.dɛːs/","^1U","Аид","^1V","chthonic"],536870916]],["^15",[768,"^H",670,536870916]],["^15",[768,"^H",671,536870916]],["^15",[768,"^H",674,536870916]],["^15",[768,"^H",676,536870916]],["^15",[768,"^H",678,536870916]],["^15",[768,"^H",679,536870916]],["^15",[768,"^;","~u64c03a7d-7892-4801-8d84-6c73af7c13ed",536870916]],["^15",[769,"^Q","((648f0280-37e6-4988-b4e8-a9e4ded94c61))",536870916]],["^15",[769,"^O","^17",536870916]],["^15",[769,"^F",793,536870916