28-15a8d244bcaf",536870916]],["^15",[890,"^Q","My commentary",536870916]],["^15",[890,"^O","^17",536870916]],["^15",[890,"^F",887,536870916]],["^15",[890,"^X",653,536870916]],["^15",[890,"^V",882,536870916]],["^15",[890,"^U",653,536870916]],["^15",[890,"^;","~u679c5d79-935f-4f59-a613-c71d73ed425f",536870916]],["^15",[891,"^Q","If the lines are parallel, they don't intersect.",536870916]],["^15",[891,"^O","^17",536870916]],["^15",[891,"^F",853,536870916]],["^15",[891,"^X",653,536870916]],["^15",[891,"^V",853,536870916]],["^15",[891,"^U",653,536870916]],["^15",[891,"^;","~u679c5d79-ef36-4024-8a4c-1220e9b2c5a4",536870916]],["^15",[892,"^Q","One or more of the premises are false",536870916]],["^15",[892,"^O","^17",536870916]],["^15",[892,"^F",873,536870916]],["^15",[892,"^X",653,536870916]],["^15",[892,"^V",860,536870916]],["^15",[892,"^U",653,536870916]],["^15",[892,"^;","~u679c5d79-02dc-44bc-9937-063c0da92456",536870916]],["^15",[893,"^3","icon:: 🚶\n\n- #posture\n\t- It's a sensory issue first\n\t\t- 1 Sensory input -> 2 Brain sensory processing -> 3 Muscular output -> 1 Sensory input\n\t- Exercises\n\t\t- Some YouTube links are unlisted\n\t\t- Optimal Exercise Selection\n\t\t\t- https://www.youtube.com/watch?v=8rvGR1hVIFw&list=PLFq2zv7d_8BDM_v72NSdA1Dg2IRjZuZrb\n\t\t\t- Frequency\n\t\t\t  collapsed:: true\n\t\t\t\t- Basic exercises\n\t\t\t\t\t- 2 sets of 5 breath cycles each morning and 1-2 sets, 5 reps each night\n\t\t\t\t- Weight based\n\t\t\t\t\t- min 2-3 times a week for 3-4 sets of 10-15 reps\n\t\t- Progression\n\t\t  https://www.conorharris.com/blog/how-to-progress-corrective-exercise-from-the-ground-to-upright\n\t\t  https://www.youtube.com/watch?v=TZh4gflQC8o&t=2s\n\t\t\t- Referenced position\n\t\t\t\t- 90/90 hip lift\n\t\t\t\t\t- Basic\n\t\t\t\t\t\t- Execution\n\t\t\t\t\t\t\t- https://www.youtube.com/watch?v=GYTsaqHgtRY&t=2s&pp=ygUfUFJJIDkwLzkwIEhpcCBMaWZ0IGNvbm9yIGhhcnJpcw%3D%3D\n\t\t\t\t\t\t\t- Breathing\n\t\t\t\t\t\t\t\t- https://youtu.be/rjcVYy7szAI?si=kn3Pa2YwdR5TgEyu\n\t\t\t\t\t\t\t\t- Inhale through your nose, 5-10 sec exhale through mouth, pause for 5 seconds\n\t\t\t\t\t\t\t\t- When you inhale, you should get a little bit taller. When you exhale, you should get a little bit shorter.\n\t\t\t\t\t\t\t\t- Full exhalation is essential\n\t\t\t\t\t\t\t\t\t- https://www.youtube.com/watch?v=LlxtPicx6H8\n\t\t\t\t\t\t\t- 4-6/10 harmstring contraction\n\t\t\t- Referenced position + muscle integration\n\t\t\t\t- 90/90 hip lift with hip shift\n\t\t\t\t\t- https://www.youtube.com/watch?v=YoSf3OFpPp4\n\t\t\t\t- Sitting exercise\n\t\t\t\t\t- https://youtu.be/uYtLHHT1AhU?t=382\n\t\t\t\t- Ab exercises\n\t\t\t\t\t- https://www.youtube.com/watch?v=Uy4u23pzm3E&list=PLFq2zv7d_8BDM_v72NSdA1Dg2IRjZuZrb&index=13\n\t\t\t- Removing references + integration\n\t\t\t\t- Band exercises\n\t\t\t\t\t- https://youtu.be/xq0hXN5mAxY\n\t\t\t\t\t- https://www.youtube.com/watch?v=DGR_xH0wHrY&t=471s\n\t\t\t\t- Gait Mechanics\n\t\t\t\t\t- https://www.youtube.com/watch?v=cnNZ8YSaq74&list=PLFq2zv7d_8BDM_v72NSdA1Dg2IRjZuZrb&index=15\n\t\t\t- Loaded integration\n\t\t\t\t- https://youtu.be/Tsa-NaWpPxY?si=C5ZDspIxBz-yHhGz\n\t\t\t\t- Loaded integration in [starting] upright position\n\t\t\t\t\t- Squat\n\t\t\t\t\t\t- Deep Squat\n\t\t\t\t\t\t\t- https://www.youtube.com/watch?v=SdaqV9mJ_cw&pp=ygUSY29ub3IgaGFycmlzIHNxdWF0\n\t\t\t\t\t\t- Right Hip Shift in a Squat\n\t\t\t\t\t\t\t- https://youtu.be/I4hKmqYTpjY?si=LyvyXMn4oFJaBaOQ\n\t- Posture malformations or deformations\n\t\t- https://www.youtube.com/watch?v=ag3DG2UvnI8\n\t\t- Lateral pelvic tilt\n\t\t\t- The Left AIC (anterior interior chain) Pattern\n\t\t\t\t- https://www.youtube.com/watch?v=zk2ZRqvlRbo\n\t\t\t\t- Exercises\n\t\t\t- The Right BC (right brachial) Pattern\n\t\t\t\t- https://www.youtube.com/watch?v=471aoJqG5eg\n\t\t\t\t- https://www.conorharris.com/blog/how-to-fix-uneven-shoulders\n\t\t\t- PEC (posterior exterior chain) Pattern\n\t\t\t\t- https://www.youtube.com/watch?v=1qOG1v6Yjr8\n\t\t\t- The Rig