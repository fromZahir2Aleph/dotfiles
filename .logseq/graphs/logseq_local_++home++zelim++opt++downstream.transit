 295.375,\n                                   :x2 420.328125,\n                                   :y2 320.375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 432.796875,\n                                   :y1 295.375,\n                                   :x2 460.625,\n                                   :y2 320.375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 473.078125,\n                                   :y1 295.375,\n                                   :x2 534.265625,\n                                   :y2 320.375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 546.71875,\n                                   :y1 295.375,\n                                   :x2 593.484375,\n                                   :y2 320.375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 605.953125,\n                                   :y1 295.375,\n                                   :x2 628.96875,\n                                   :y2 320.375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 641.4375,\n                                   :y1 295.375,\n                                   :x2 667.5,\n                                   :y2 320.375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 679.96875,\n                                   :y1 295.375,\n                                   :x2 744.84375,\n                                   :y2 320.375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 757.296875,\n                                   :y1 295.375,\n                                   :x2 777.640625,\n                                   :y2 320.375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 790.109375,\n                                   :y1 295.375,\n                                   :x2 806.8050537109375,\n                                   :y2 320.375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 325.984375,\n                                   :x2 258.65130615234375,\n                                   :y2 350.984375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 150.234375,\n                                   :y1 356.484375,\n                                   :x2 807.1673583984375,\n                                   :y2 381.484375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 387.09375,\n                                   :x2 807.1761474609375,\n                                   :y2 412.09375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 417.703125,\n                                   :x2 807.6964721679688,\n                                   :y2 442.703125,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 448.1875,\n                                   :x2 196.90625,\n                                   :y2 473.1875,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 207.796875,\n                                   :y1 448.1875,\n                                   :x2 242.09375,\n                                   :y2 473.1875,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 252.984375,\n                                   :y1 448.1875,\n                                   :x2 311.296875,\n                                   :y2 473.1875,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 322.1875,\n                                   :y1 448.1875,\n                                   :x2 441.859375,\n                                   :y2 473.1875,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 452.75,\n                                   :y1 448.1875,\n                                   :x2 510.328125,\n                                   :y2 473.1875,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 521.3125,\n                                   :y1 448.1875,\n                                   :x2 631.75,\n                                   :y2 473.1875,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 642.640625,\n                                   :y1 448.1875,\n                                   :x2 714.171875,\n                                   :y2 473.1875,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 725.0625,\n                                   :y1 448.1875,\n                                   :x2 807.615478515625,\n                                   :y2 473.1875,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 478.796875,\n                                   :x2 806.7159423828125,\n                                   :y2 503.796875,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 509.421875,\n                                   :x2 807.6177978515625,\n                                   :y2 534.421875,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 540.03125,\n                                   :x2 446.746337890625,\n                                   :y2 565.03125,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}),\n                          :page 307},\n               :content {:text \"To be sure, we don’t want to suggest that an event has just one abstract structure. Speaking, a posteriori, of “the” abstract structure of an event gives the impression that there was and is only one correct way to perceive it and to have a memory of it get triggered, which is not the case; any of various distinct conceptual skeletons might get attached to a given situation, depending on the frame of mind one is in when it is encountered. The wide variety of potential encodings of Danny at the Grand Canyon means that many extremely diﬀerent situations, possibly encountered much later in life, could induce that old memory to bubble up from dormancy. Such situations would thereby become members of the category Danny at the Grand Canyon, or, to propose a more generic name for it, trivial side show more fascinating than the main event.\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"67054c79-5eb6-4c16-a300-c0d0974018d7\",\n               :page 313,\n               :position {:bounding {:x1 0,\n                                     :y1 815.171875,\n                                     :x2 924,\n                                     :y2 2401.5,\n                                     :width 924.0000000000001,\n                                     :height 1195.7647058823532},\n                          :rects ({:x1 150.234375,\n                                   :y1 815.171875,\n                                   :x2 806.7131958007812,\n                                   :y2 840.171875,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 845.65625,\n                                   :x2 807.0613403320312,\n                                   :y2 870.65625,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 876.265625,\n                                   :x2 806.9259643554688,\n                                   :y2 901.265625,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 906.875,\n                                   :x2 807.0366821289062,\n                                   :y2 931.875,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 937.375,\n                                   :x2 807.2847900390625,\n                                   :y2 962.375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 967.984375,\n                                   :x2 807.150634765625,\n                                   :y2 992.984375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 998.59375,\n                                   :x2 806.8179321289062,\n                                   :y2 1023.59375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 1029.09375,\n                                   :x2 806.9932250976562,\n                                   :y2 1054.09375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 1059.703125,\n                                   :x2 806.8179321289062,\n                                   :y2 1084.703125,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 0,\n                                   :y1 1205.75,\n                                   :x2 924,\n                                   :y2 2401.5,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}),\n                          :page 313},\n               :content {:text \"As is hopefully clear from our analysis, the way an event is unconsciously interpreted (the choice of cues that will enable remindings to take place far in the future) should not be confused with the much larger set of perceived facts about the situation. What matters is the perspective taken on the perceived facts: which dimensions are used in encoding the event, and the amount of abstraction along each dimension — how the event is distilled, in short. Thus if, in the Grand Canyon episode, one saw only ants and leaves and a toddler looking at them, then one\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"67054cc3-4254-4b44-bc93-6d5a006ebe92\",\n               :page 314,\n               :position {:bounding {:x1 116.234375,\n                                     :y1 111.953125,\n                                     :x2 807.7525634765625,\n                                     :y2 992.984375,\n                                     :width 924.0000000000001,\n                                     :height 1195.7647058823532},\n                          :rects ({:x1 116.234375,\n                                   :y1 111.953125,\n                                   :x2 807.2492065429688,\n                                   :y2 136.953125,\n               