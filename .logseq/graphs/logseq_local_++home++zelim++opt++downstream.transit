,["^15",[62,"^X",54,536870916]],["^15",[62,"^V",67,536870916]],["^15",[62,"^U",54,536870916]],["^15",[62,"^U",55,536870916]],["^15",[62,"^;","~u679c5d78-65e1-410e-a093-b16241a86130",536870916]],["^15",[63,"^Q","### Запах",536870916]],["^15",[63,"^O","^17",536870916]],["^15",[63,"^F",67,536870916]],["^15",[63,"^X",54,536870916]],["^15",[63,"^V",66,536870916]],["^15",[63,"^U",54,536870916]],["^15",[63,"^U",55,536870916]],["^15",[63,"^?",["^ ","^1<",3],536870916]],["^15",[63,"^J",[],536870916]],["^15",[63,"^;","~u679c5d78-bd71-4f84-ba7b-d9da1343e2ad",536870916]],["^15",[64,"^Q","джафорум, дзаги, олк. все под впном открывается только",536870916]],["^15",[64,"^O","^17",536870916]],["^15",[64,"^F",57,536870916]],["^15",[64,"^X",54,536870916]],["^15",[64,"^V",67,536870916]],["^15",[64,"^U",54,536870916]],["^15",[64,"^U",55,536870916]],["^15",[64,"^;","~u679c5d78-9bd3-4a9c-8b2e-a2e91e22ad3c",536870916]],["^15",[65,"^Q","палатка 14 стоила. ну твоя из-за размер помельче дешевле будет. борды светильники 40. ну ты за 8 найдешь. хотя я все ж рекомендую просто лампочки. это еще дешевле и ничем не хуже. лампы около 2500, фильтр 2500, канальник 2500. где то так)",536870916]],["^15",[65,"^O","^17",536870916]],["^15",[65,"^F",56,536870916]],["^15",[65,"^X",54,536870916]],["^15",[65,"^V",56,536870916]],["^15",[65,"^U",54,536870916]],["^15",[65,"^U",55,536870916]],["^15",[65,"^;","~u679c5d78-3e8d-4e30-aa78-86d7b868169e",536870916]],["^15",[66,"^Q","#mj если даже плохо получаться будет. фотопериодные сажай. индика доминантные. в принципе сорт можешь сам выбрать. мне очень нравится как барни фарм мимоза растет. она какая то такая дружелюбная к неумелым действиям.",536870916]],["^15",[66,"^O","^17",536870916]],["^15",[66,"^F",54,536870916]],["^15",[66,"^X",54,536870916]],["^15",[66,"^V",54,536870916]],["^15",[66,"^U",54,536870916]],["^15",[66,"^U",55,536870916]],["^15",[66,"^H",55,536870916]],["^15",[66,"^;","~u679c5d78-1517-4b80-b35c-c728d3f26400",536870916]],["^15",[67,"^Q","### Ресурсы\nid:: 679982eb-2412-4fb5-b5cd-b3c361fae2b4",536870916]],["^15",[67,"^O","^17",536870916]],["^15",[67,"^F",66,536870916]],["^15",[67,"^X",54,536870916]],["^15",[67,"^V",66,536870916]],["^15",[67,"^U",54,536870916]],["^15",[67,"^U",55,536870916]],["^15",[67,"^?",["^ ","~:id","679982eb-2412-4fb5-b5cd-b3c361fae2b4","^1<",3],536870916]],["^15",[67,"^J",["^1?"],536870916]],["^15",[67,"^4",["^ ","^1?","679982eb-2412-4fb5-b5cd-b3c361fae2b4"],536870916]],["^15",[67,"^;","~u679982eb-2412-4fb5-b5cd-b3c361fae2b4",536870916]],["^15",[68,"^3","- [[personality psychology/independence]] [[personality psychology/accentuation]] [[personality psychology/narcissism]] Если ты полагаешься на хорошее мнение о себе, ты попадаешь в парадокс нарциссизма и растворения себя как личности в других. Акцентуация, а не впечатление, должна быль стимулом общения. Нужно балансировать между самодостаточностью в общении и проекцией своей личности. Выражай себя, не стараять из кожи вон лезть, чтобы впечатлить других.",536888565]],["^15",[68,"^16",1738300792126,536870916]],["^15",[68,"^18","~m1744420730837",536888566]],["^15",[68,"^Z","journals/2025_01_28.md",536870916]],["^15",[69,"^K",1738300792126,536870916]],["^15",[69,"^[",68,536870916]],["^15",[69,"^N",20250128,536870916]],["^15",[69,"^@",true,536870916]],["^15",[69,"^Y","jan 28th, 2025",536870916]],["^15",[69,"^11","Jan 28th, 2025",536870916]],["^15",[69,"^B",1738300792126,536870916]],["^15",[69,"^;","~u67ff7314-6739-4c5c-a41b-0b9f85b04327",536888565]],["^15",[70,"^K",1738300792125,536870916]],["^15",[70,"^@",false,536870916]],["^15",[70,"^Y","personality psychology/accentuation",536870916]],["^15",[70,"^A",22,536870916]],["^15",[70,"^11","personality psychology/accentuation",536870916]],["^15",[70,"^B",1738300792125,536870916]],["^15",[70,"^;","~u67ff7314-6d6f-4dc9-8c7b-78fb39189162",536888565]],["^15",[71,"^K",1738300792587,536870916]],["^15",[71,"^@",false,536870916]],["^15",[71,"^Y","personality psychology/self-sufficiency",536870916]],["^15",[71,"^A",22,536870916]],["^15",[71,"^11","personality psychology/self-sufficiency",536870916]],["^15",[71,"^B",1738300792587,536870916]],["^15",[71,"^;","~u679c5d78-7383-4989-83a6-d610587b7816",536870916]],["^15",[72,"^Q","[[personality psychology/independence]] [[personality psychology/accentuation]] [[personality psychology/narcissism]] Если ты полагаешься на хорошее мнение о себе, ты попадаешь в парадокс нарциссизма и растворения себя как личности в других. Акцентуация, а не впечатление, должна быль стимулом общения. Нужно балансировать между самодостаточностью в общении и проекцией своей личности. Выражай себя, не стараять из кожи вон лезть, чтобы впечатлить других.",536888565]],["^15",[72,"^O","^17",536870916]],["^15",[72,"^F",69,536870916]],["^15",[72,"^X",69,536870916]],["^15",[72,"^V",69,536870916]],["^15",[72,"^U",22,536870916]],["^15",[72,"^U",23,536870916]],["^15",[72,"^U",69,536870916]],["^15",[72,"^U",70,536870916]],["^15",[72,"^U",71,536870916]],["^15",[72,"^U",2480,536888565]],["^15",[72,"^H",22,536888565]],["^15",[72,"^H",23,536888565]],["^15",[72,"^H",70,536888565]],["^15",[72,"^H",2480,536888565]],["^15",[72,"^;","~u679c5d78-1482-47f7-8cc8-27aaa7f1e911",536870916]],["^15",[73,"^3","tags:: [[Grozny Quiz]]\nplayed:: no\n\n- ## На эрудицию\n\t- ### Спорт\n\t\t- Коринф, Дельфы, Немея, .... Закончите список.\n\t\t\t- Олимпия. Прим. Коринф - Истмийские игры, Дельфы - Пифийские, Немея - Немейские, Олимпия - Олимпийские. Четыре Панэллинских игры.\n\t\t- #### Демографика спорта\n\t\t  collapsed:: true\n\t\t\t- Население этого уже несуществующего государства является среднестатически самым высоким в мире. Легионеров оттуда можно часто увидеть в НБА.\n\t\t\t\t- Югославия\n\t\t\t- Эти две страны Южной Азии являются самыми титулованными в своём регионе в крикете.\n\t\t\t\t- Индия и Пакистан\n\t\t\t- Эти два японских слова обозначают \"путь\" и \"искусство\". Их часто можно встретить в назваяниях видов спорта и традициях.\n\t\t\t\t- До и джитсу/дзюцу\n\t\t\t- Мы изменили грамматическую форму следующих трёх прилагательных: Пифийский, Немейский, Истмийский. Назовите четвёртое прилагательное в правильной форме.\n\t\t\t\t- Олимпийские. Речь идёт о Панэллинских играх.\n\t\t\t- В 2010 году Кристоф Леметр пробежал 100 метров быстрее 10 секунд. Он является первым таким атлетом, сделавшим это.\n\t\t\t\t- Белым\n\t\t- #### Дерби\n\t\t  collapsed:: true\n\t\t\t- Римское дерби\n\t\t\t\t- Рома и Лацио\n\t\t\t- Ле Классико\n\t\t\t\t- ПСЖ и Олимпик Марсель (также просто Марсель)\n\t\t\t- Мерсисайдское дерби\n\t\t\t\t- Ливерпуль и Эвертон\n\t\t\t- Дерби Старой Фирмы\n\t\t\t\t- Селтик и Рейнджерс\n\t\t\t- Рурское дерби\n\t\t\t\t- Боруссия (Дортмунд) и Шальке 04\n\t\t\t- Межконтинентальное дерби\n\t\t\t\t- Галатасарай и Фенербахче\n\t- ### География\n\t\t- В виде картинок. Страны, которые хотели бы существовать. Прим.: используй изображение флага в вопросе о цыганах, и географических контуров в остальных.\n\t\t  collapsed:: true\n\t\t\t- Каталония\n\t\t\t- Курдистан\n\t\t\t- Азавад\n\t\t\t- Страна Басков\n\t\t\t- Флаг Цыганской диаспоры\n\t\t- Прим.: изображение косовского флага. Шесть серебряных звёзд на флаге Республики Косово, проживающих на территории страны.\n\t\t  collapsed:: true\n\t\t\t- Албанцы\n\t\t\t- Бошняки/боснийцы\n\t\t\t- Горанцы\n\t\t\t- Сербы\n\t\t\t- Турки\n\t\t\t- Цыгане\n\t\t- Торговые пути в виде географических карт.\n\t\t  collapsed:: true\n\t\t\t- Шёлковый путь\n\t\t\t- Из варяг в греки\n\t\t\t- Triangular trade\n\t\t\t\t- Рабы\n\t\t\t\t- Сахар\n\t\t\t\t- Ром\n\t\t\t- Дорога специй\n\t\t\t- Морские республики\n\t\t- Название Пакистана - акроним этих регионов.\n\t\t  collapsed:: true\n\t\t\t- Пенджаб\n\t\t\t- Афгания\n\t\t\t- Кашмир\n\t\t\t- Синд\n\t\t\t- Белуджистан\n\t\t- В виде картинок. Флаги каких стран Северной Европы изображены?\n\t\t  collapsed:: true\n\t\t\t- Швеция\n\t\t\t- Норвегия\n\t\t\t- Исландия\n\t\t\t- Финляндия\n\t\t\t- Дания\n\t\t- Три паннационалистических движения. Если бы они были претворены в жизнь, они объединили бы как минимум пять неостровных государства Евразии.\n\t\t  collapsed:: true\n\t\t\t- Панарабизм\n\t\t\t- Пантюркизм\n\t\t\t- Панславизм\n\t\t- Названия стран\n\t\t  collapsed:: true\n\t\t\t- Ледяная страна\n\t\t\t\t- Исландия\n\t\t\t- Львиные горы\n\t\t\t\t- Сьерра-Леоне\n\t\t\t- Город льва\n\t\t\t\t- Сингапур\n\t\t\t- Серебристая\n\t\t\t\t- Аргентина\n\t\t\t- Берег Слоновой Кости\n\t\t\t\t- Кот-д’Ивуар\n\t\t\t- Название этой страны говорит о координате её расположения\n\t\t\t\t- Экватор\n\t- ### История\n\t  collapsed:: true\n\t\t- #### Новый свет\n\t\t\t- Когда Нью-Йорк был основан, он назывался так.\n\t\t\t\t- Нью-Амстердам\n\t\t\t- Этот штат США граничит со своей большей тёзкой.\n\t\t\t\t- Нью-Мексико. Тёзка - государство Мексика.\n\t\t\t- Вопросы в картинках.\n\t\t\t\t- Новая Испания\n\t\t\t\t- Новая Франция\n\t\t\t\t- Новая Англия\n\t- ### Плавающий раунд\n\t\t- #### Языки\n\t\t\t- Объявление раунда\n\t\t\t\t- Что обозначает каждый из цветов на этой карте Римской империи?\n\t\t\t\t\t- Зоны под влиянием латыни и греческого языка\n\t\t\t- В испанском языке есть слово \"ojalá\" (читается как охалá) и переводится как \"надеюсь\". Созвучное и знакомое нам слово имеет похожую этимологию и другое, хоть и немного схожее,  значение.\n\t\t\t\t- Иншааллахl. Наследие арабского присутствия в Испании.\n\t\t\t- Если не учитывать пары с буквой l, только с этих восьми пар согласных **букв** чеченского алфавита могут начинаться исконно чеченские слова. Прим.: подумай ещё; может, упустил кое-что.\n\t\t\t  collapsed:: true\n\t\t\t\t- Ст\n\t\t\t\t- Цхь\n\t\t\t\t- Схь\n\t\t\t\t- Пхь\n\t\t\t\t- Пх\n\t\t\t\t- Тх\n\t\t\t\t- Ткъ\n\t\t\t\t- Цкь\n\t\t- #### Цветная тема\n\t\t  collapsed:: true\n\t\t\t- Надпись 73000 кв. м. на красном фоне\n\t\t\t\t- Красная площадь\n\t\t\t- По географическим контурам нужно угадать реку\n\t\t\t\t- Хуанхэ. Прим.: Жёлтая река. Перед оглашением можно сменить синий цвет реки на жёлтый\n\t\t\t- На картинке зелёным шрифтом написано 5280 футов\n\t\t\t\t- Зелёная миля\n\t\t\t- Карта Лазурного Берега\n\t\t\t- Назовите два цвета, которые вы увидите после выхода игроков\n\t\t\t\t- Синий и гранатовый\n\t\t- #### Отцы наук и жанров\n\t\t  collapsed:: true\n\t\t\t- Отец истории\n\t\t\t\t- Геродот\n\t\t\t- Отец геометрии\n\t\t\t\t- Евклид\n\t\t\t- Отец алгебры\n\t\t\t\t- Мухаммад Аль-Хорезми. От его имени произошло слово \"алгоритм\".\n\t\t\t- Отец трагедии\n\t\t\t\t- Эсхил\n\t\t\t- Отец детектива\n\t\t\t\t- Эдгар Аллан По\n\t\t- #### Слова, неточно передающие смысл\n\t\t  collapsed:: true\n\t\t\t- Каспийское море\n\t\t\t\t- Озеро\n\t\t\t- Банановое дерево\n\t\t\t\t- Трава\n\t\t\t- Арабские цифры\n\t\t\t\t- Индийские\n\t\t\t- Кит-убийца\n\t\t\t\t- Дельфин\n\t\t\t- Столетняя война\n\t\t\t\t- Стошетнадцатилетняя\n- ## На логику\n\t- 1. В аналогии с фильмом Михалкова эти два народа выделяются среди остальных, один в славянском мире, а другой на Северном Кавказе.\n\t\t- Фильм - \"Свой среди чужих, чужой среди своих\". Народы - бошняки/боснийцы и осетины. Одни - единственные свои мусульмане среди славян, другие - единственные христиане среди нас, коренных народов Северного Кавказа.\n\t- 2. Особей разного пола этого домашнего животного называют неодинаково. В названии их мужских особей мы можем услышать эту разницу.\n\t\t- Петух. Происходит от слова петь\n\t- 3. Поэт Борхес с возрастом стал терять зрение. Когда он полностью ослеп, он стал использовать это.\n\t\t- Рифму. Так ему было легче воспроизводить свои стихи по памяти. До этого он писал стихи в свободном стиле.\n\t- 4. Первые тринадцать из них мир смог увидеть в 1777 г., а последнюю - в 1960 г.\n\t\t- Звёзд на флаге США\n\t- 5. В немецких настольных играх её используют очень редко.\n\t\t- Войну\n\t- 6. И в итальянском, и в английском названии этого фильма он стоит на первом месте; в русском переводе - тоже. У героя нет имени, поэтому вам нужно назвать имя актёра.\n\t\t- Клинт Иствуд. Фильм - Хороший, плохой, злой, англ. The Good, the Bad and the Ugly, итал. Il buono, il brutto, il cattivo.\n\t- 7. Это стенд времён ковида. Что рекламирует он?\n\t\t- Брекеты\n\t- 8. Когда премьера-министра Новой Зеландии спросили о том, что он думает по поводу миграции новозеландцев в Австралию, он пошутил, что это \"повышает ... ... обеих стран\". Первое слово - математическое прилагателное, второе - английская аббревиатура.\n\t\t- Средний IQ\n\t- 9.  Настоящее прошлого – это x; настоящее настоящего – это непосредственное y; настоящее будущего – это z.\n\t\t- x - память, y - созерцание, z - ожидание.",536889830]],["^15",[73,"^16",1738300792159,536870916]],["^15",[73,"^18","~m1745089509062",536889829]],["^15",[73,"^Z","journals/2025_01_27.md",536870916]],["^15",[74,"^K",1738300792158,536870916]],["^15",[74,"^[",73,536870916]],["^15",[74,"^N",20250127,536870916]],["^15",[74,"^@",true,536870916]],["^15",[74,"^Y","jan 27th, 2025",536870916]],["^15",[74,"^11","Jan 27th, 2025",536870916]],["^15",[74,"^?",["^ ","^19",["^1:",["Grozny Quiz"]],"^1;","no"],536870916]],["^15",[74,"^4",["^ ","^19","[[Grozny Quiz]]","^1;","no"],536870916]],["^15",[74,"^P",75,536882978]],["^15",[74,"^B",1745089508236,536889828]],["^15",[74,"^;","~u67c4424c-a4dd-4519-810d-6de777966f5f",536882978]],["^15",[75,"^K",1738300792157,536870916]],["^15",[75,"^@",false,536870916]],["^15",[75,"^Y","grozny quiz",536870916]],["^15",[75,"^11","Grozny Quiz",536870916]],["^15",[75,"^B",1738300792157,536870916]],["^15",[75,"^;","~u67c4424c-7189-4d11-90ef-bea4dfc42f88",536882978]],["^15",[76,"^Q","Цкь",536870916]],["^15",[76,"^O","^17",536870916]],["^15",[76,"^F",108,536870916]],["^15",[76,"^X",74,536870916]],["^15",[76,"^V",2168,536881756]],["^15",[76,"^U",74,536884685]],["^15",[76,"^;","~u679c5d78-86ba-4060-a602-f2bd351f3fee",536870916]],["^15",[77,"^Q","Цыгане",536870916]],["^15",[77,"^O","^17",536870916]],["^15",[77,"^F",109,536870916]],["^15",[77,"^X",74,536870916]],["^15",[77,"^V",101,536870916]],["^15",[77,"^U",74,536874707]],["^15",[77,"^;","~u679c5d78-0c6a-4c50-8922-f27b9833c84e