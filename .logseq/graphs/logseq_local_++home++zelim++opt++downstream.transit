",[641,"^F",634,536870916]],["^15",[641,"^X",617,536870916]],["^15",[641,"^V",617,536870916]],["^15",[641,"^U",617,536870916]],["^15",[641,"^;","~u679c5d78-5ee8-45a3-befe-af7c8806022c",536870916]],["^15",[642,"^Q","Смертники в вингсьютах, катапультирующие себя через проливы",536870916]],["^15",[642,"^O","^17",536870916]],["^15",[642,"^F",637,536870916]],["^15",[642,"^X",617,536870916]],["^15",[642,"^V",637,536870916]],["^15",[642,"^U",617,536870916]],["^15",[642,"^;","~u679c5d78-38db-45f0-bf35-ca49a98544a6",536870916]],["^15",[643,"^Q","Местные думают, что нашествие - это тоже часть цикла. Чтобы искоренить это поверье, серпантин и храм разрушаются.",536870916]],["^15",[643,"^O","^17",536870916]],["^15",[643,"^F",644,536870916]],["^15",[643,"^X",617,536870916]],["^15",[643,"^V",644,536870916]],["^15",[643,"^U",617,536870916]],["^15",[643,"^;","~u679c5d78-4204-4294-90c6-282ec12ecf13",536870916]],["^15",[644,"^Q","Гора-пирамида с серпантином вокруг в виде спирали. У них культ цикла. Напр., перед коронацией нового правителя, они поджигают на самой вершине старого.",536870916]],["^15",[644,"^O","^17",536870916]],["^15",[644,"^F",626,536870916]],["^15",[644,"^X",617,536870916]],["^15",[644,"^V",623,536870916]],["^15",[644,"^U",617,536870916]],["^15",[644,"^;","~u679c5d78-da4c-4c87-9316-c8cba326855e",536870916]],["^15",[645,"^Q","Народы моря",536870916]],["^15",[645,"^O","^17",536870916]],["^15",[645,"^F",635,536870916]],["^15",[645,"^X",617,536870916]],["^15",[645,"^V",627,536870916]],["^15",[645,"^U",617,536870916]],["^15",[645,"^;","~u679c5d78-dcea-479d-bd00-af98d9572811",536870916]],["^15",[646,"^Q","Наездники козлов и пилоты орлов",536870916]],["^15",[646,"^O","^17",536870916]],["^15",[646,"^F",645,536870916]],["^15",[646,"^X",617,536870916]],["^15",[646,"^V",627,536870916]],["^15",[646,"^U",617,536870916]],["^15",[646,"^;","~u679c5d78-ce39-4339-884b-6ac4b272484c",536870916]],["^15",[647,"^Q","стихия",536870916]],["^15",[647,"^O","^17",536870916]],["^15",[647,"^F",638