9845]],["^15",[2514,"^Q","У голландцев качественнее товар, у алгонкинов и гуронов - меха. Ирокезы - почти соседи голландцев. Алгонкины же граничат с французами. Если бы ирокезы не получали оружие получше и не совершали набеги на союзников французов, алгонкины и гуроны смогли бы беспрепятсвенно торговать с голландцами, что исключало бы и французов с товарами меньшего качества, и уже более слабых ирокезов.",536890172]],["^15",[2514,"^O","^17",536889903]],["^15",[2514,"^F",2513,536889903]],["^15",[2514,"^X",617,536889903]],["^15",[2514,"^V",2513,536889907]],["^15",[2514,"^U",617,536889943]],["^15",[2514,"^U",621,536889943]],["^15",[2514,"^;","~u680501df-87a3-4d3b-a570-d03de3bf9b38",536889903]],["^15",[2515,"^Q","Alan Taylor (2002). Canada and The five nations in Canada and Iroquoia 1500-1660. In *American Colonies: The Settling of North America, Vol. 1*.",536890314]],["^15",[2515,"^O","^17",536890172]],["^15",[2515,"^F",2514,536890172]],["^15",[2515,"^X",617,536890172]],["^15",[2515,"^V",2514,536890172]],["^15",[2515,"^U",617,536890172]],["^15",[2515,"^U",621,536890172]],["^15",[2515,"^?",["^ "],536890314]],["^15",[2515,"^;","~u68050adf-b0c3-4c7b-af95-b448fedcb094",536890172]],["^15",[2517,"^Q","Лесные бродяги - Coureur des bois",536890348]],["^15",[2517,"^O","^17",536890320]],["^15",[2517,"^F",2513,536890320]],["^15",[2517,"^X",617,536890320]],["^15",[2517,"^V",632,536890320]],["^15",[2517,"^U",617,536890321]],["^15",[2517,"^U",621,536890321]],["^15",[2517,"^?",["^ "],536890348]],["^15",[2517,"^;","~u68050cfc-1e03-461f-9f64-603c1ad14ac4",536890324]]]]]]