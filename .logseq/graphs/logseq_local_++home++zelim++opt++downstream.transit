96,"^U",379,536870916]],["^15",[396,"^U",380,536870916]],["^15",[396,"^U",381,536870916]],["^15",[396,"^;","~u679c5d78-abe9-4d4c-b46a-27ea4847d947",536870916]],["^15",[397,"^Q","более 26 000 книг и комиксов на Чердаке.",536870916]],["^15",[397,"^O","^17",536870916]],["^15",[397,"^F",396,536870916]],["^15",[397,"^X",379,536870916]],["^15",[397,"^V",393,536870916]],["^15",[397,"^U",379,536870916]],["^15",[397,"^U",380,536870916]],["^15",[397,"^U",381,536870916]],["^15",[397,"^;","~u679c5d78-c89a-44b7-aada-84707c216a38",536870916]],["^15",[398,"^Q","более 50 покупок в Стиме.",536870916]],["^15",[398,"^O","^17",536870916]],["^15",[398,"^F",389,536870916]],["^15",[398,"^X",379,536870916]],["^15",[398,"^V",393,536870916]],["^15",[398,"^U",379,536870916]],["^15",[398,"^U",380,536870916]],["^15",[398,"^U",381,536870916]],["^15",[398,"^;","~u679c5d78-83bf-4399-ba4f-4cbe32de7ad2",536870916]],["^15",[399,"^Q","в каталогах",536870916]],["^15",[399,"^O","^17",536870916]],["^15",[399,"^F",398,536870916]],["^15",[399,"^X",379,536870916]],["^15",[399,"^V",393,536870916]],["^15",[399,"^U",379,536870916]],["^15",[399,"^U",380,536870916]],["^15",[399,"^U",381,536870916]],["^15",[399,"^;","~u679c5d78-0b37-43d7-babd-059d78c82990",536870916]],["^15",[400,"^Q","Для сравнения в Улиссе 268 170 слов, в Каренине - 353 250.",536870916]],["^15",[400,"^O","^17",536870916]],["^15",[400,"^F",396,536870916]],["^15",[400,"^X",379,536870916]],["^15",[400,"^V",396,536870916]],["^15",[400,"^U",379,536870916]],["^15",[400,"^U",380,536870916]],["^15",[400,"^U",381,536870916]],["^15",[400,"^;","~u679c5d78-c8cb-48d3-8948-e878f242266b",536870916]],["^15",[401,"^Q","почти 25 000 файлов в Ранце.",536870916]],["^15",[401,"^O","^17",536870916]],["^15",[401,"^F",397,536870916]],["^15",[401,"^X",379,536870916]],["^15",[401,"^V",393,536870916]],["^15",[401,"^U",379,536870916]],["^15",[401,"^U",380,536870916]],["^15",[401,"^U",381,536870916]],["^15",[401,"^;","~u679c5d78-85a3-4969-87e1-e34ff9053bb9",536870916]],["^15",[402,"^3","- #[[liar paradox]] Задачи о рыцарях и плутах решаются сверкой их ответов. Однако моё сознание - и рыцарь, и плут в одном пространстве, в голове, но не в одном и том же времени. Поэтому я не могу знать, адекватен ли я в определённый момент. В обоих состояниях мозг даст  утвердительный ответ. Каждый раз я на распутье, где, не доходя до развилки, повесили вывеску Welcome. И это уже не задача, а парадокс. Назову-ка я его парадокс лжеца-правдеца.\n\t- #conditioning Как мне контролировать себя, меняться, если я не могу доверять собственному сознанию? Обусловленное поведение - одно из возможных решений.",536870916]],["^15",[402,"^16",1738300792620,536870916]],["^15",[402,"^Z","journals/2023_10_16.md",536870916]],["^15",[403,"^K",1738300792619,536870916]],["^15",[403,"^[",402,536870916]],["^15",[403,"^N",20231016,536870916]],["^15",[403,"^@",true,536870916]],["^15",[403,"^Y","oct 16th, 2023",536870916]],["^15",[403,"^11","Oct 16th, 2023",536870916]],["^15",[403,"^B",1738300792619,536870916]],["^15",[403,"^;","~u679c5d78-2d87-4215-8dc9-c2220879cb8e",536870916]],["^15",[404,"^K",1738300792619,536870916]],["^15",[404,"^@",false,536870916]],["^15",[404,"^Y","liar paradox",536870916]],["^15",[404,"^11","liar paradox",536870916]],["^15",[404,"^B",1738300792619,536870916]],["^15",[404,"^;","~u679c5d78-4479-4b6f-8586-7bdab52f0f9e",536870916]],["^15",[405,"^K",1738300792637,536870916]],["^15",[405,"^@",false,536870916]],["^15",[405,"^Y","conditioning",536870916]],["^15",[405,"^11","conditioning",536870916]],["^15",[405,"^B",1738300792637,536870916]],["^15",[405,"^;","~u679c5d78-e0af-49eb-8492-e3abb2982de7",536870916]],["^15",[406,"^Q","#[[liar paradox]] Задачи о рыцарях и плутах решаются сверкой их ответов. Однако моё сознание - и рыцарь, и плут в одном пространстве, в голове, но не в одном и том же времени. Поэтому я не могу знать, адекватен ли я в определённый момент. В обоих состояниях мозг даст  утвердительный ответ. Каждый раз я на распутье, где, не доходя до развилки, повесили вывеску Welcome. И это уже не задача, а парадокс. Назову-ка я его парадокс лжеца-правдеца.",536870916]],["^15",[406,"^O","^17",536870916]],["^15",[406,"^F",403,536870916]],["^15",[406,"^X",403,536870916]],["^15",[406,"^V",403,536870916]],["^15",[406,"^U",403,536870916]],["^15",[406,"^U",404,536870916]],["^15",[406,"^H",404,536870916]],["^15",[406,"^;","~u679c5d78-7d59-4ad7-9de4-139fd5029068",536870916]],["^15",[407,"^Q","#conditioning Как мне контролировать себя, меняться, если я не могу доверять собственному сознанию? Обусловленное поведение - одно из возможных решений.",536870916]],["^15",[407,"^O","^17",536870916]],["^15",[407,"^F",406,536870916]],["^15",[407,"^X",403,536870916]],["^15",[407,"^V",406,536870916]],["^15",[407,"^U",403,536870916]],["^15",[407,"^U",404,536870916]],["^15",[407,"^U",405,536870916]],["^15",[407,"^H",405,536870916]],["^15",[407,"^;","~u679c5d78-c0ea-4756-8348-cb760ee0f283",536870916]],["^15",[408,"^3","- #[[personality psychology/anxiety]]\n\t- Твоя основная тревога состоит из тревоги исполнения, которая у тебя зиждется на [предвосхищении]([[personality psychology/anxiety/anticipatory anxiety]]) ответственности, неоправдания ожиданий и неудачи. Но последнее не имеет веса, так как ты гораздо больше боишься ответственности и чужого осуждения. Дорога к себе избавит от зависимости от мнения других, а вот для первого нужно обрести покой.\n\t  id:: 655011be-f3fa-4370-bac4-416fc924d79e\n\t\t- Производные\n\t\t\t- #kenophobia\n\t\t\t\t- В пустоте тебе ещё страшнее, а эхо одиночества ещё громче. Научись для начала справляться с тишиной, затем с пустотой, потом с тем, что впереди, и наконец с тем, что в конце.\n\t\t\t- #[[personality psychology/anxiety/fulfilment-anxiety]]\n\t\t\t\t- Термин, обобщающий open loops и performance anxiety.\n\t\t- Сопутствующие\n\t\t\t- #procrastination\n\t\t- Решения\n\t\t\t- лекарства\n\t\t\t- #[[action/anticipatory commitment]]\n\t\t\t- #conditioning\n\t\t\t- #orthogonality\n\t\t\t- #authenticity\n\t\t\t- #metacogintion\n\t\t\t- #grounding\n\t\t\t- #catharsis\n\t\t\t- #CBT\n-",536870916]],["^15",[408,"^16",1738300792638,536870916]],["^15",[408,"^Z","journals/2023_10_14.md",536870916]],["^15",[409,"^K",1738300792637,536870916]],["^15",[409,"^@",false,536870916]],["^15",[409,"^Y","personality psychology/anxiety/fulfilment-anxiety",536870916]],["^15",[409,"^A",164,536870916]],["^15",[409,"^11","personality psychology/anxiety/fulfilment-anxiety",536870916]],["^15",[409,"^B",1738300792637,536870916]],["^15",[409,"^;","~u679c5d78-cc63-41ee-b113-cb81981f597a",536870916]],["^15",[410,"^K",1738300792636,536870916]],["^15",[410,"^[",408,536870916]],["^15",[410,"^N",20231014,536870916]],["^15",[410,"^@",true,536870916]],["^15",[410,"^Y","oct 14th, 2023",536870916]],["^15",[410,"^11","Oct 14th, 2023",536870916]],["^15",[410,"^B",1738300792636,536870916]],["^15",[410,"^;","~u679c5d78-a373-4b14-8d22-c411f04f3409",536870916]],["^15",[411,"^K",1738300794241,536870916]],["^15",[411,"^[",1477,536870916]],["^15",[411,"^@",false,536870916]],["^15",[411,"^Y","authenticity",536870916]],["^15",[411,"^11","authenticity",536870916]],["^15",[411,"^?",["^ ","~:filters","{}"],536870916]],["^15",[411,"^4",["^ ","^1D","{}"],536870916]],["^15",[411,"^B",1738300794241,536870916]],["^15",[411,"^;","~u67e16ff7-e478-4aaa-95c2-11e650488296",536884783]],["^15",[412,"^K",1738300792638,536870916]],["^15",[412,"^@",false,536870916]],["^15",[412,"^Y","cbt",536870916]],["^15",[412,"^11","CBT",536870916]],["^15",[412,"^B",1738300792638,536870916]],["^15",[412,"^;","~u679c5d78-35e5-4cd0-b327-e1db5d017636",536870916]],["^15",[413,"^K",1738300793557,536870916]],["^15",[413,"^@",false,536870916]],["^15",[413,"^Y","metacogintion",536870916]],["^15",[413,"^11","metacogintion",536870916]],["^15",[413,"^B",1738300793557,536870916]],["^15",[413,"^;","~u679c5d79-d8f1-412e-9736-9746571104ab",536870916]],["^15",[414,"^K",1738300792812,536870916]],["^15",[414,"^O","^17",536883943]],["^15",[414,"^@",false,536870916]