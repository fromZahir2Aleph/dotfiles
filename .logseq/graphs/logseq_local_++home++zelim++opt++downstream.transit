 у меня являются реакцией на других людей. Научись быть стартером в цепи обратной связи, а не шестерёнкой.",536870916]],["^15",[281,"^O","^17",536870916]],["^15",[281,"^F",280,536870916]],["^15",[281,"^X",279,536870916]],["^15",[281,"^V",280,536870916]],["^15",[281,"^U",22,536870916]],["^15",[281,"^U",71,536870916]],["^15",[281,"^U",279,536870916]],["^15",[281,"^U",2480,536888550]],["^15",[281,"^;","~u679c5d78-8e47-4bc0-86bc-75784ca5f5a1",536870916]],["^15",[282,"^3","- #[[personality psychology/independence]] #self-control Чувство достоинства требует самоконтроля без метакогнитивности. Легче держать осанку, дышать ровно и проецировать себя, чем постоянно корректировать свои мысли и действия. К тому же последнее мешает плыть по течению жизни или ловить ценные её моменты.\n\t- #[[[[personality psychology/experience seeking]]]] Воспитывай в себе хорошие качества которые повысят самоуважение, и тогда надобность в самоконроле понизится, а хороших моментов в жизни прибавится.",536888547]],["^15",[282,"^16",1738300792491,536870916]],["^15",[282,"^18","~m1744420487840",536888548]],["^15",[282,"^Z","journals/2024_01_15.md",536870916]],["^15",[283,"^K",1738300792491,536870916]],["^15",[283,"^[",282,536870916]],["^15",[283,"^N",20240115,536870916]],["^15",[283,"^@",true,536870916]],["^15",[283,"^Y","jan 15th, 2024",536870916]],["^15",[283,"^11","Jan 15th, 2024",536870916]],["^15",[283,"^B",1738300792491,536870916]],["^15",[283,"^;","~u67ff7314-a011-4fbd-bba9-57bb6c0ab360",536888547]],["^15",[284,"^K",1738300792491,536870916]],["^15",[284,"^@",false,536870916]],["^15",[284,"^Y","[[personality psychology/experience seeking",536870916]],["^15",[284,"^A",286,536870916]],["^15",[284,"^11","[[personality psychology/experience seeking",536870916]],["^15",[284,"^B",1738300792491,536870916]],["^15",[284,"^;","~u67ff7314-517e-4a7d-aaf6-aee31c0384a0",536888547]],["^15",[285,"^K",1738300792491,536870916]],["^15",[285,"^@",false,536870916]],["^15",[285,"^Y","[[personality psychology/exper