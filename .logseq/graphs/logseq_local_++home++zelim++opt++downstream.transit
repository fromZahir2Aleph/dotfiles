ело или двор.",536870916]],["^15",[261,"^16",1738300792445,536870916]],["^15",[261,"^Z","journals/2024_04_12.md",536870916]],["^15",[262,"^K",1738300792445,536870916]],["^15",[262,"^[",261,536870916]],["^15",[262,"^N",20240412,536870916]],["^15",[262,"^@",true,536870916]],["^15",[262,"^Y","apr 12th, 2024",536870916]],["^15",[262,"^11","Apr 12th, 2024",536870916]],["^15",[262,"^?",["^ ","^19",["^1:",["diary"]],"^1@","reflection","^1A","sad"],536870916]],["^15",[262,"^4",["^ ","^19","diary","^1@","reflection","^1A","sad"],536870916]],["^15",[262,"^P",155,536870916]],["^15",[262,"^B",1738300792445,536870916]],["^15",[262,"^;","~u679c5d78-5d79-4cd0-b863-c70272c80b33",536870916]],["^15",[263,"^Q","tags:: diary\ntype:: reflection\nmood:: sad\n\n",536870916]],["^15",[263,"^O","^17",536870916]],["^15",[263,"^1=",["^1:",[]],536870916]],["^15",[263,"^F",262,536870916]],["^15",[263,"^X",262,536870916]],["^15",[263,"^V",262,536870916]],["^15",[263,"^U",155,536870916]],["^15",[263,"^U",156,536870916]],["^15",[263,"^U",157,536870916]],["^15",[263,"^U",262,536870916]],["^15",[263,"^:",true,536870916]],["^15",[263,"^?",["^ ","^19",["^1:",["diary"]],"^1@","reflection","^1A","sad"],536870916]],["^15",[263,"^J",["^19","^1@","^1A"],536870916]],["^15",[263,"^4",["^ ","^19","diary","^1@","reflection","^1A","sad"],536870916]],["^15",[263,"^H",155,536870916]],["^15",[263,"^H",156,536870916]],["^15",[263,"^H",157,536870916]],["^15",[263,"^;","~u679c5d78-0ffb-42c1-bade-ede76af0e2b1",536870916]],["^15",[264,"^Q","За всю свою жизнь я никогда не тосковал по кому-то. Ни по семье, ни по одной живой душе, не говоря уже о такой для меня абстрактной категории как Родина, будь то страна, город, село или двор.",536870916]],["^15",[264,"^O","^17",536870916]],["^15",[264,"^F",263,536870916]],["^15",[264,"^X",262,536870916]],["^15",[264,"^V",263,536870916]],["^15",[264,"^U",155,536870916]],["^15",[264,"^U",156,536870916]],["^15",[264,"^U",157,536870916]],["^15",[264,"^U",262,536870916]],["^15",[264,"^;",