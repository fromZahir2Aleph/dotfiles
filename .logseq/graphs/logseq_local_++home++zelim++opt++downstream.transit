,[303,"^U",172,536870916]],["^15",[303,"^U",275,536870916]],["^15",[303,"^U",296,536870916]],["^15",[303,"^U",297,536870916]],["^15",[303,"^;","~u679c5d78-20dc-4bce-82b5-606ca01f7359",536870916]],["^15",[304,"^3","- #[[action/anticipatory commitment]]\n\t- #[[free will]] Будь готов к хорошему исходу событий, например, просто-напросто к хорошему завтрашнему дню. Когда наступит то, чего ты боялся, ты ничего не сможешь с этим поделать. Что ещё хуже, ты потратишь время на опасения впустую и не сможешь насладиться днём обычным. Поэтому просто жди его, пока есть хоть какая-то на это вероятность.\n\t- #determinism [[personality psychology/anxiety/anticipatory anxiety]] Не бойся плохого исхода. Страх в преддверии его наступления помешает тебе справиться с проблемой, если есть таковая возможность. Если её нет, то пусть день ненастья будет твоим периодом неудовлетворения или же началом горестного времени.\n\t\t- Некоторые события содержат в себе и свободную волю, и детерминизм. Самый яркий пример - рождение ребёнка. Ты можешь при наличии определённых условий выбрать факт самого рождения. Но ты мало можешь повлиять на то, как оно пройдёт, будет ли ребёнок здоров, будут ли его детство, зрелость и старость в меру счастливыми. Прими это.\n\t- [[action/anticipatory commitment/planfulness]] [[action/anticipatory commitment/purposefulness]] [[action/anticipatory commitment/self-discipline]]\n\t\t- Будь также готов к запланированной или незапланированной ответственности.",536870916]],["^15",[304,"^16",1738300792530,536870916]],["^15",[304,"^Z","journals/2023_12_06.md",536870916]],["^15",[305,"^K",1738300792824,536870916]],["^15",[305,"^@",false,536870916]],["^15",[305,"^Y","action/anticipatory commitment/planfulness",536870916]],["^15",[305,"^A",313,536870916]],["^15",[305,"^11","action/anticipatory commitment/planfulness",536870916]],["^15",[305,"^B",1738300792824,536870916]],["^15",[305,"^;","~u679c5d78-fc41-404b-8b5b-52d4a969ab71",536870916]],["^15",[306,"^K",1738300793657,536870916]],["^15",[306,"^@",false,536870916]],["^15",[306,"^Y","action/anticipatory commitment/self-discipline",536870916]],["^15",[306,"^A",313,536870916]],["^15",[306,"^11","action/anticipatory commitment/self-discipline",536870916]],["^15",[306,"^B",1738300793657,536870916]],["^15",[306,"^;","~u679c5d79-b1dd-4e2d-9ae2-cb30c0b82b03",536870916]],["^15",[307,"^K",1738300792669,536870916]],["^15",[307,"^@",false,536870916]],["^15",[307,"^Y","personality psychology/anxiety/anticipatory anxiety",536870916]],["^15",[307,"^A",164,536870916]],["^15",[307,"^11","personality psychology/anxiety/anticipatory anxiety",536870916]],["^15",[307,"^B",1738300792669,536870916]],["^15",[307,"^;","~u67ff7314-123f-40dd-8da3-a0c324861af9",536888544]],["^15",[308,"^K",1738300792530,536870916]],["^15",[308,"^@",false,536870916]],["^15",[308,"^Y","free will",536870916]],["^15",[308,"^11","free will",536870916]],["^15",[308,"^B",1738300792530,536870916]],["^15",[308,"^;","~u679c5d78-3a45-47d3-9bed-cb67284593a7",536870916]],["^15",[309,"^K",1738300792530,536870916]],["^15",[309,"^@",false,536870916]],["^15",[309,"^Y","determinism",536870916]],["^15",[309,"^11","determinism",536870916]],["^15",[309,"^B",1738300792530,536870916]],["^15",[309,"^;","~u679c5d78-4e55-4b21-a4c2-b37045a2dc5a",536870916]],["^15",[310,"^K",1738300792529,536870916]],["^15",[310,"^[",304,536870916]],["^15",[310,"^N",20231206,536870916]],["^15",[310,"^@",true,536870916]],["^15",[310,"^Y","dec 6th, 2023",536870916]],["^15",[310,"^11","Dec 6th, 2023",536870916]],["^15",[310,"^B",1738300792529,536870916]],["^15",[310,"^;","~u679c5d78-4e8e-4bb3-982b-223b7e090a7d",536870916]],["^15",[311,"^K",1738300794242,536870916]],["^15",[311,"^@",false,536870916]],["^15",[311,"^Y","action/anticipatory commitment/purposefulness",536870916]],["^15",[311,"^A",313,536870916]],["^15",[311,"^11","action/anticipatory commitment/purposefulness",536870916]],["^15",[311,"^B",1738300794242,536870916]],["^15",[311,"^;","~u679c5d7a-392e-4b10-b2b3-3d62d47b2