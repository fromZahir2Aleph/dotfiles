75,\n                                   :x2 645.671875,\n                                   :y2 467.9375,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 663.3125,\n                                   :y1 444.9375,\n                                   :x2 748.6839599609375,\n                                   :y2 467.9375,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 107.796875,\n                                   :y1 445.9375,\n                                   :x2 218.3740997314453,\n                                   :y2 468.9375,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 107.796875,\n                                   :y1 473.328125,\n                                   :x2 254.80160522460938,\n                                   :y2 496.328125,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}),\n                          :page 46},\n               :content {:text \"analogy-making is the machinery behind the pulsating heartbeat of thought: categorization.\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"64fba21e-5f7b-454a-b38a-bfda542f638b\",\n               :page 50,\n               :position {:bounding {:x1 0,\n                                     :y1 0,\n                                     :x2 891.7716064453125,\n                                     :y2 658.015625,\n                                     :width 1019.9999999999999,\n                                     :height 1319.9999999999998},\n                          :rects ({:x1 0,\n                                   :y1 0,\n                      