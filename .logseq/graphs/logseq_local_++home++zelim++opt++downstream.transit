0916]],["^15",[1467,"^X",1450,536870916]],["^15",[1467,"^V",1452,536870916]],["^15",[1467,"^U",1450,536889835]],["^15",[1467,"^;","~u679c5d79-de49-4450-87e7-40db94259ddd",536870916]],["^15",[1468,"^Q","задать тему или тон для последующего, например, абзаца",536870916]],["^15",[1468,"^O","^17",536870916]],["^15",[1468,"^F",1466,536870916]],["^15",[1468,"^X",1450,536870916]],["^15",[1468,"^V",1469,536870916]],["^15",[1468,"^U",1450,536889835]],["^15",[1468,"^;","~u679c5d79-1c9c-4cbe-a0e7-5ba1ac3c7acd",536870916]],["^15",[1469,"^Q","В плане стиля короткое предложение, одно или более, может...",536870916]],["^15",[1469,"^O","^17",536870916]],["^15",[1469,"^F",1457,536870916]],["^15",[1469,"^X",1450,536870916]],["^15",[1469,"^V",1452,536870916]],["^15",[1469,"^U",1450,536889835]],["^15",[1469,"^;","~u679c5d79-c09f-4aa5-ad82-79a860cfa99f",536870916]],["^15",[1470,"^Q","Стилистические приёмы всегда могут быть перевёрнуты, чтобы обмануть ожидания читателя.",536870916]],["^15",[1470,"^O","^17",536870916]],["^15",[1470,"^F",1472,536870916]],["^15",[1470,"^X",1450,536870916]],["^15",[1470,"^V",1450,536870916]],["^15",[1470,"^U",1450,536870916]],["^15",[1470,"^;","~u679c5d79-3b08-4bd9-949a-c1723c745ee7",536870916]],["^15",[1471,"^Q","менять тему или тон посередине, действуя как ось вращения",536870916]],["^15",[1471,"^O","^17",536870916]],["^15",[1471,"^F",1468,536870916]],["^15",[1471,"^X",1450,536870916]],["^15",[1471,"^V",1469,536870916]],["^15",[1471,"^U",1450,536889835]],["^15",[1471,"^;","~u679c5d79-a5a9-4f44-b17c-c87bd4921ad3",536870916]],["^15",[1472,"^Q","Предложение, а не слово, словосочетание или параграф, - атом прозы.",536870916]],["^15",[1472,"^O","^17",536870916]],["^15",[1472,"^F",1450,536870916]],["^15",[1472,"^X",1450,536870916]],["^15",[1472,"^V",1450,536870916]],["^15",[1472,"^U",1450,536870916]],["^15",[1472,"^;","~u679c5d79-80aa-498c-9dfc-c8ddccd6b38a",536870916]],["^15",[1473,"^Q","Существительное",536870916]],["^15",[1473,"^O","^17",536870916]],["^15",[1