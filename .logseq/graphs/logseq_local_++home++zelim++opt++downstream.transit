,"~u679c5d79-4337-4f60-abef-db1728f926be",536870916]],["^15",[730,"^Q","6. \"The god who delights in the foundation of towns and the establishment of civil constitutions\"",536870916]],["^15",[730,"^O","^17",536870916]],["^15",[730,"^F",763,536870916]],["^15",[730,"^X",651,536870916]],["^15",[730,"^V",681,536870916]],["^15",[730,"^U",651,536870916]],["^15",[730,"^;","~u679c5d79-a8d0-4499-8887-d4b617b9b461",536870916]],["^15",[731,"^Q","Chaoskampf\nid:: 64a5dc49-9f1c-472c-98f9-103a51fed1c6",536870916]],["^15",[731,"^O","^17",536870916]],["^15",[731,"^F",794,536870916]],["^15",[731,"^X",651,536870916]],["^15",[731,"^V",794,536870916]],["^15",[731,"^U",651,536870916]],["^15",[731,"^U",673,536870916]],["^15",[731,"^?",["^ ","^1?","64a5dc49-9f1c-472c-98f9-103a51fed1c6"],536870916]],["^15",[731,"^J",["^1?"],536870916]],["^15",[731,"^4",["^ ","^1?","64a5dc49-9f1c-472c-98f9-103a51fed1c6"],536870916]],["^15",[731,"^;","~u64a5dc49-9f1c-472c-98f9-103a51fed1c6",536870916]],["^15",[732,"^Q","Истмийские в честь [Посейдона](((64af1cf7-5636-4536-917f-cb44f27037a8)))",536870916]],["^15",[732,"^O","^17",536870916]],["^15",[732,"^F",718,536870916]],["^15",[732,"^X",651,536870916]],["^15",[732,"^V",777,536870916]],["^15",[732,"^U",651,536870916]],["^15",[732,"^H",822,536870916]],["^15",[732,"^;","~u679c5d79-77f7-4d99-a9a0-ae504b8aec9c",536870916]],["^15",[733,"^Q","Очень не хватает Хроноса. У орфиков и Алкмана он у самых истоков, а в одной орфической теогонии он даже самый первый.",536870916]],["^15",[733,"^O","^17",536870916]],["^15",[733,"^F",712,536870916]],["^15",[733,"^X",651,536870916]],["^15",[733,"^V",689,536870916]],["^15",[733,"^U",651,536870916]],["^15",[733,"^;","~u679c5d79-792f-44f7-bdac-6610d6ec860d",536870916]],["^15",[734,"^Q","Αἰθήρ\n.tags::\n.being:: god\n.mythology:: Greece\n.transcription:: /ai̯.tʰɛ̌ːr/\n.translation:: Эфир\n.flags:: primordial, personification",536870916]],["^15",[734,"^O","^17",536870916]],["^15",[734,"^F",708,536870916]],["^15",[734,"^X",651,5368