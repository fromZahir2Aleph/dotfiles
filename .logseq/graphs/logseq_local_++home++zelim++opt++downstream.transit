[327,"^U",323,536870916]],["^15",[327,"^;","~u679c5d78-605a-454b-8af6-0dbb87e3b2d9",536870916]],["^15",[328,"^Q","Спроси чат-бота.",536870916]],["^15",[328,"^O","^17",536870916]],["^15",[328,"^F",325,536870916]],["^15",[328,"^X",321,536870916]],["^15",[328,"^V",324,536870916]],["^15",[328,"^U",128,536870916]],["^15",[328,"^U",297,536870916]],["^15",[328,"^U",321,536870916]],["^15",[328,"^U",322,536870916]],["^15",[328,"^U",323,536870916]],["^15",[328,"^;","~u679c5d78-560f-4ed4-a748-3ee9dcf72d5b",536870916]],["^15",[329,"^3","- [[personality psychology/anxiety]] #willpower [[personality psychology/self-deception]]\n\t- Я признавал в себе тревожность и слабоволие. Нехотя добавлял иногда слово страх. Но если страх и слабоволие проявляются в одних ситуациях, в одно и то же время, то они живут в сердце человека малодушного и трусливого. Потому что трус - не тот, кто боится, а тот кто боится - и бежит. Не обманывай себя удобными словами, лишь отчасти правдивыми и скрывающими суть проблем. Если ты положишь их на весы напротив своей воли, то весы перекосит так, что они упадут. И тогда под тегом тревога обнаружится страх. Покопайся ещё немного - там и трусость найдёшь.",536870916]],["^15",[329,"^16",1738300792552,536870916]],["^15",[329,"^Z","journals/2023_11_18.md",536870916]],["^15",[330,"^K",1738300792552,536870916]],["^15",[330,"^[",329,536870916]],["^15",[330,"^N",20231118,536870916]],["^15",[330,"^@",true,536870916]],["^15",[330,"^Y","nov 18th, 2023",536870916]],["^15",[330,"^11","Nov 18th, 2023",536870916]],["^15",[330,"^B",1738300792552,536870916]],["^15",[330,"^;","~u679c5d78-3428-42f8-82d9-71b90e7a960f",536870916]],["^15",[331,"^K",1738300792552,536870916]],["^15",[331,"^@",false,536870916]],["^15",[331,"^Y","willpower",536870916]],["^15",[331,"^11","willpower",536870916]],["^15",[331,"^B",1738300792552,536870916]],["^15",[331,"^;","~u679c5d78-9ea7-4ddf-997c-10165bb32ccd",536870916]],["^15",[332,"^Q","[[personality psychology/anxiety]] #willpower [[personality psychology/self-deception]]",536870916]],["^15",[332,"^O","^17",536870916]],["^15",[332,"^F",330,536870916]],["^15",[332,"^X",330,536870916]],["^15",[332,"^V",330,536870916]],["^15",[332,"^U",22,536870916]],["^15",[332,"^U",164,536870916]],["^15",[332,"^U",217,536870916]],["^15",[332,"^U",330,536870916]],["^15",[332,"^U",331,536870916]],["^15",[332,"^H",22,536870916]],["^15",[332,"^H",164,536870916]],["^15",[332,"^H",217,536870916]],["^15",[332,"^H",331,536870916]],["^15",[332,"^;","~u679c5d78-3499-4e67-a809-2a2d82598ea7",536870916]],["^15",[333,"^Q","Я признавал в себе тревожность и слабоволие. Нехотя добавлял иногда слово страх. Но если страх и слабоволие проявляются в одних ситуациях, в одно и то же время, то они живут в сердце человека малодушного и трусливого. Потому что трус - не тот, кто боится, а тот кто боится - и бежит. Не обманывай себя удобными словами, лишь отчасти правдивыми и скрывающими суть проблем. Если ты положишь их на весы напротив своей воли, то весы перекосит так, что они упадут. И тогда под тегом тревога обнаружится страх. Покопайся ещё немного - там и трусость найдёшь.",536870916]],["^15",[333,"^O","^17",536870916]],["^15",[333,"^F",332,536870916]],["^15",[333,"^X",330,536870916]],["^15",[333,"^V",332,536870916]],["^15",[333,"^U",22,536870916]],["^15",[333,"^U",164,536870916]],["^15",[333,"^U",217,536870916]],["^15",[333,"^U",330,536870916]],["^15",[333,"^U",331,536870916]],["^15",[333,"^;","~u679c5d78-0f7f-40ba-b236-9684a59ded22",536870916]],["^15",[334,"^3","- #narratology\n\t- [[tropes/character]]\n\t\t- Гремас выделяет в персонаже актанта и его проявление, актора. Первый может быть существом, не наделённым разумом, или вообще объектом. В жанровой литературе протагонист больше актант судьбы или воли, чем актор со своим характером и причудами.\n\t\t\t- Нет смысла применять дихотомию к нежанровым работам. В них, если писатель прорисовывает персонажа, то делает это не ради сюжета. Ярким исключением является Кормак МакКарти.",536870916]],["^15",[334,"^16",1738300792563,536870916]],["^15",[334,"^Z","journals/2023_11_14.md",536870916]],["^15",[335,"^K",1738300792562,536870916]],["^15",[335,"^[",334,536870916]],["^15",[335,"^N",20231114,536870916]],["^15",[335,"^@",true,536870916]],["^15",[335,"^Y","nov 14th, 2023",536870916]],["^15",[335,"^11","Nov 14th, 2023",536870916]],["^15",[335,"^B",1738300792562,536870916]],["^15",[335,"^;","~u679c5d78-4a7b-4b29-8451-0e973afb6116",536870916]],["^15",[336,"^K",1738300792562,536870916]],["^15",[336,"^@",false,536870916]],["^15",[336,"^Y","narratology",536870916]],["^15",[336,"^11","narratology",536870916]],["^15",[336,"^B",1738300792562,536870916]],["^15",[336,"^;","~u679c5d78-f23e-4aba-a267-2ab64516bfe4",536870916]],["^15",[337,"^K",1738300792563,536870916]],["^15",[337,"^@",false,536870916]],["^15",[337,"^Y","tropes/character",536870916]],["^15",[337,"^A",338,536870916]],["^15",[337,"^11","tropes/character",536870916]],["^15",[337,"^B",1738300792563,536870916]],["^15",[337,"^;","~u679c5d78-a635-4fa8-a6ee-7a771a60aeb6",536870916]],["^15",[338,"^K",1738300792563,536870916]],["^15",[338,"^@",false,536870916]],["^15",[338,"^Y","tropes",536870916]],["^15",[338,"^11","tropes",536870916]],["^15",[338,"^B",1738300792563,536870916]],["^15",[338,"^;","~u679c5d78-b9a8-4e8d-a3a3-e3ed76f9570c",536870916]],["^15",[339,"^Q","#narratology",536870916]],["^15",[339,"^O","^17",536870916]],["^15",[339,"^F",335,536870916]],["^15",[339,"^X",335,536870916]],["^15",[339,"^V",335,536870916]],["^15",[339,"^U",335,536870916]],["^15",[339,"^U",336,536870916]],["^15",[339,"^H",336,536870916]],["^15",[339,"^;","~u679c5d78-9e6f-4cf0-9bd2-4ba9e294c733",536870916]],["^15",[340,"^Q","[[tropes/character]]",536870916]],["^15",[340,"^O","^17",536870916]],["^15",[340,"^F",339,536870916]],["^15",[340,"^X",335,536870916]],["^15",[340,"^V",339,536870916]],["^15",[340,"^U",335,536870916]],["^15",[340,"^U",336,536870916]],["^15",[340,"^U",337,536870916]],["^15",[340,"^U",338,536870916]],["^15",[340,"^H",337,536870916]],["^15",[340,"^H",338,536870916]],["^15",[340,"^;","~u679c5d78-4b48-4858-b918-7223601f19f1",536870916]],["^15",[341,"^Q","Гремас выделяет в персонаже актанта и его проявление, актора. Первый может быть существом, не наделённым разумом, или вообще объектом. В жанровой литературе протагонист больше актант судьбы или воли, чем актор со своим характером и причудами.",536870916]],["^15",[341,"^O","^17",536870916]],["^15",[341,"^F",340,536870916]],["^15",[341,"^X",335,536870916]],["^15",[341,"^V",340,536870916]],["^15",[341,"^U",335,536870916]],["^15",[341,"^U",336,536870916]],["^15",[341,"^U",337,536870916]],["^15",[341,"^U",338,536870916]],["^15",[341,"^;","~u679c5d78-8268-4f2e-a7df-ea446f2840a3",536870916]],["^15",[342,"^Q","Нет смысла применять дихотомию к нежанровым работам. В них, если писатель прорисовывает персонажа, то делает это не ради сюжета. Ярким исключением является Кормак МакКарти.",536870916]],["^15",[342,"^O","^17",536870916]],["^15",[342,"^F",341,536870916]],["^15",[342,"^X",335,536870916]],["^15",[342,"^V",341,536870916]],["^15",[342,"^U",335,536870916]],["^15",[342,"^U",336,536870916]],["^15",[342,"^U",337,536870916]],["^15",[342,"^U",338,536870916]],["^15",[342,"^;","~u679c5d78-45c3-429c-b7f8-c401c4c7d27d",536870916]],["^15",[343,"^3","- #[[action/anticipatory commitment]] #insomnia\n\t- Сначала начни с матраса, потом со своей комнаты, потом с маминой. Если будешь продолжать делать по-своему и негодовать о том, что ты не у дел в республике, так как и останешься на матрасе.\n\t- #orthogonality #bootstrap\n\t\t- На данном этапе жизни мне не стоит распыляться на те вещи, которые я могу реализовать только в здоровом состоянии, потому что я не самозапускаюсь. Только обретя покой я смогу это сделать. Пока нужно делать ставку на ортогональность времени и окружающей среды как границ, стимулирующих нужное мышления и поведение с привязкой областей внимания ко времени и месту.\n\t\t\t- Время\n\t\t\t\t- [[personality psychology/anxiety/anticipatory anxiety]] [[action/next action]]\n\t\t\t\t\t- #reflection\n\t\t\t\t\t\t- Перестань беспокоиться и начни планировать. Но не смотри вперёд дальше сегодняшнего дня, если это не конец недели или месяца. Не смотри вообще никуда, когда закрываешь глаза, то есть в постели.\n\t\t\t\t\t- Думай о следующем шаге только после реализации текущекого.\n\t\t\t\t\t\t- Не делай никаких пост-бустстреповских планов.\n\t\t\t\t- Никаких фантазий и раздумий до девяти вечера. После - переключись в режим таковости с помощью медитации, поделок или рисования. Если день не заладился или набрал слишком высокий для тебя темп двигайся к ночи тихим ходом. Обед и выходные режим \"не работа\".\n\t\t\t- Место\n\t\t\t\t- Дом\n\t\t\t\t\t- Условием должно быть в первую очередь положение тела, а уже затем кровать.\n\t\t\t\t\t  Лёжа на кровати:\n\t\t\t\t\t\t- Только сон. Скажи нет словам и мыслям.\n\t\t\t\t\t- Зал\n\t\t\t\t\t\t- Говори размеренно\n\t\t\t\t\t- Компьютер\n\t\t\t\t\t\t- Firefox\n\t\t\t\t\t\t\t- Работа\n\t\t\t\t\t\t- Chrome\n\t\t\t\t\t\t\t- Интересы, переписка и остальное.\n\t\t\t\t- Снаружи\n\t\t\t\t\t- Беседа\n\t\t\t\t\t\t- Включи режим [таковости]([[thusness]]), будь [самодостаточнее]([[personality psychology/independence]]) и контролируй свою вербальную [кенофобию]([[kenophobia]]).\n\t\t\t\t\t- Вне беседы (не обязательно наедине)\n\t\t\t\t\t\t- По ситуации",536888544]],["^15",[343,"^16",1738300792587,536870916]],["^15",[343,"^18","~m1744420487841",536888545]],["^15",[343,"^Z","journals/2023_10_29.md",536870916]],["^15",[344,"^K",1738300792586,536870916]],["^15",[344,"^@",false,536870916]],["^15",[344,"^Y","insomnia",536870916]],["^15",[344,"^11","insomnia",536870916]],["^15",[344,"^B",1738300792586,536870916]],["^15",[344,"^;","~u67ff7314-4aad-4ea1-80b3-b225ccb001a5",536888544]],["^15",[345,"^K",1738300792586,536870916]],["^15",[345,"^@",false,536870916]],["^15",[345,"^Y","bootstrap",536870916]],["^15",[345,"^11","bootstrap",536870916]],["^15",[345,"^B",1738300792586,536870916]],["^15",[345,"^;","~u67ff7314-662d-4bed-b03a-875af007af3b",536888544]],["^15",[346,"^K",1738300792586,536870916]],["^15",[346,"^[",343,536870916]],["^15",[346,"^N",20231029,536870916]],["^15",[346,"^@",true,536870916]],["^15",[346,"^Y","oct 29th, 2023",536870916]],["^15",[346,"^11","Oct 29th, 2023",536870916]],["^15",[346,"^B",1738300792586,536870916]],["^15",[346,"^;","~u67ff7314-c7b6-48e9-b70a-7b9e7f3730a5",536888544]],["^15",[347,"^K",1738300792637,536870916]],["^15",[347,"^O","^17",536871822]],["^15",[347,"^@",false,536870916]],["^15",[347,"^Y","kenophobia",536870916]],["^15",[347,"^11","kenophobia",536870916]],["^15",[347,"^B",1738300792637,536870916]],["^15",[347,"^;","~u67ff7314-2a8d-4ada-8133-2f9a55b2dd1a",536888556]],["^15",[348,"^K",1738300792586,536870916]],["^15",[348,"^@",false,536870916]],["^15",[348,"^Y","action/next action",536870916]],["^15",[348,"^A",312,536870916]],["^15",[348,"^11","action/next action",536870916]],["^15",[348,"^B",1738300792586,536870916]],["^15",[348,"^;","~u67ff7314-4aef-4df0-bd12-10a3e41aab52",536888544]],["^15",[349,"^K",1738300792587,536870916]],["^15",[349,"^@",false,536870916]],["^15",[349,"^Y","reflection",536870916]],["^15",[349,"^11","reflection",536870916]],["^15",[349,"^B",1738300792587,536870916]],["^15",[349,"^;","~u67ff7314-3584-4bfd-b19e-87464da33946",536888544]],["^15",[350,"^K",1738300792587,536870916]],["^15",[350,"^@",false,536870916]],["^15",[350,"^Y","thusness",536870916]],["^15",[350,"^11","thusness",536870916]],["^15",[350,"^B",1738300792587,536870916]],["^15",[350,"^;","~u67ff7314-db68-488f-83ca-5c67d223fc9b",536888544]],["^15",[351,"^Q","Думай о следующем шаге только после реализации текущекого.",536870916]],["^15",[351,"^O","^17",536870916]],["^15",[351,"^F",376,536870916]],["^15",[351,"^X",346,536870916]],["^15",[351,"^V",374,536870916]],["^15",[351,"^U",22,536870916]],["^15",[351,"^U",164,536870916]],["^15",[351,"^U",171,536870916]],["^15",[351,"^U",307,536870916]],["^15",[351,"^U",312,536870916]],["^15",[351,"^U",3