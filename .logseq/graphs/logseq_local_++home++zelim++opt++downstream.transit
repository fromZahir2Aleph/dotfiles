^15",[2047,"^Q","Панславизм",536877471]],["^15",[2047,"^O","^17",536877438]],["^15",[2047,"^F",2046,536877438]],["^15",[2047,"^X",74,536877438]],["^15",[2047,"^V",2044,536877438]],["^15",[2047,"^U",74,536877503]],["^15",[2047,"^;","~u67b520f0-52ed-4a34-b136-62908843b83f",536877438]],["^15",[2048,"^12",2,536877543]],["^15",[2049,"^Q","",536877565]],["^15",[2049,"^O","^17",536877565]],["^15",[2049,"^@",false,536877565]],["^15",[2049,"^F",655,536877565]],["^15",[2049,"^X",655,536877565]],["^15",[2049,"^V",655,536877565]],["^15",[2049,"^U",655,536877566]],["^15",[2049,"^?",["^ "],536877565]],["^15",[2049,"^;","~u67b5334d-d111-41c9-ab0f-9f17186e5079",536877565]],["^15",[2050,"^12",2,536877569]],["^15",[2051,"^3","- #mj #mlfb Charge one battery at a time. Leaving my batteries in the charger was the reason they all died after 2 months. Take them out once they're charged, don't leave them in overnight. Do not use hot batteries!!!",536877582]],["^15",[2051,"^18","~m1739933712073",536877581]],["^15",[2051,"^Z","journals/2025_02_18.md",536877573]],["^15",[2052,"^K",1739933670166,536877576]],["^15",[2052,"^@",false,536877576]],["^15",[2052,"^Y","mlfb",536877576]],["^15",[2052,"^11","mlfb",536877576]],["^15",[2052,"^B",1739933670166,536877576]],["^15",[2052,"^;","~u67b547e6-1caf-4b07-ac68-e18e99745477",536877576]],["^15",[2053,"^12",2,536877584]],["^15",[2054,"^Q","[[The Unfolding of Language]]",536877613]],["^15",[2054,"^O","^17",536877591]],["^15",[2054,"^F",2239,536882040]],["^15",[2054,"^X",650,536877591]],["^15",[2054,"^V",658,536882040]],["^15",[2054,"^U",650,536882044]],["^15",[2054,"^U",2055,536882044]],["^15",[2054,"^?",["^ "],536877595]],["^15",[2054,"^H",2055,536877595]],["^15",[2054,"^;","~u67b54ae4-ab66-48de-bb0c-1d60d5dfa002",536877591]],["^15",[2055,"^K",1739934458910,536877595]],["^15",[2055,"^[",2057,536877604]],["^15",[2055,"^O","^17",536877599]],["^15",[2055,"^@",false,536877595]],["^15",[2055,"^Y","the unfolding of language",536877611]],["^15",[2055,"^11","The Unfolding of Language",536877611]],["^15",[2055,"^B",1740196410906,536881730]],["^15",[2055,"^;","~u67b54afa-10b5-47d9-9983-d0659c5ebad0",536877595]],["^15",[2056,"^Q","![📄 The Unfolding of Language - Guy Deutscher.pdf](../assets/The Unfolding of Language - Guy Deutscher.pdf)",536877632]],["^15",[2056,"^O","^17",536877600]],["^15",[2056,"^@",false,536877600]],["^15",[2056,"^F",2055,536877600]],["^15",[2056,"^X",2055,536877600]],["^15",[2056,"^V",2055,536877600]],["^15",[2056,"^U",2055,536877601]],["^15",[2056,"^?",["^ "],536877632]],["^15",[2056,"^;","~u67b54aff-865d-44ad-a43f-f4453cc3a35b",536877600]],["^15",[2057,"^3","- ![📄 The Unfolding of Language - Guy Deutscher.pdf](../assets/The Unfolding of Language - Guy Deutscher.pdf)\n- ## Введение\n\t- Лингвистика следует принципу актуализма: язык меняется сегодня так же, как и в прошлом.\n\t- Две оговорки\n\t\t- Дословесная история языка не является предметом книги, так как лингвистика не может сегодня с какой либо уверенностью описать её\n\t\t- Гипотеза врождённости языковой способности остаётся гипотезой. Аргументы в пользу или против неё не влияют на содежание книги. Она описыает культурную эволюцию языка, а не биологическую.\n\t\t\t- Другими словами, наличие или отсутсвие гена языка не влияет на описанные факты.",536881732]],["^15",[2057,"^18","~m1740196411313",536881731]],["^15",[2057,"^Z","pages/The Unfolding of Language.md",536877612]],["^15",[2058,"^Q","## Введение",536881122]],["^15",[2058,"^O","^17",536877607]],["^15",[2058,"^@",false,536877607]],["^15",[2058,"^F",2056,536877607]],["^15",[2058,"^X",2055,536877607]],["^15",[2058,"^V",2055,536877607]],["^15",[2058,"^U",2055,536877608]],["^15",[2058,"^?",["^ ","^1<",2],536881122]],["^15",[2058,"^J",["^14",[]],536881122]],["^15",[2058,"^;","~u67b54b30-79e5-460a-a1b6-b541c19ecfa3",536877607]],["^15",[2059,"^K",1739934703992,536877619]],["^15",[2059,"^[",2061,536877621]],["^15",[2059,"^O","^17",536877619]],["^15",[2059,"^@",false,536877619]],["^15",[2059,"^Y","hl