6]],["^15",[721,"^U",674,536870916]],["^15",[721,"^U",676,536870916]],["^15",[721,"^U",678,536870916]],["^15",[721,"^U",679,536870916]],["^15",[721,"^?",["^ ","^1Q","","^1R","god","^1S","Greece","^1T","/uː.ra.nós/","^1U","Уран","^1V","primordial, personification"],536870916]],["^15",[721,"^J",["^1Q","^1R","^1S","^1T","^1U","^1V"],536870916]],["^15",[721,"^4",["^ ","^1Q","","^1R","god","^1S","Greece","^1T","/uː.ra.nós/","^1U","Уран","^1V","primordial, personification"],536870916]],["^15",[721,"^H",670,536870916]],["^15",[721,"^H",671,536870916]],["^15",[721,"^H",674,536870916]],["^15",[721,"^H",676,536870916]],["^15",[721,"^H",678,536870916]],["^15",[721,"^H",679,536870916]],["^15",[721,"^;","~u679c5d79-b307-4138-8d91-807c7c056cac",536870916]],["^15",[722,"^Q","[Пана](((66bd24c6-efdc-4fc5-bc54-c443a0a6f666))) отправили следить за пастухами и природой в Аркадию. Он был талантливее всех олимпийцев и умел всё. Оттуда и имя. Но они дали ему козлиную внешность и посадили туда, где никому нет дела до его талантов.",536870916]],["^15",[722,"^O","^17",536870916]],["^15",[722,"^F",764,536870916]],["^15",[722,"^X",651,536870916]],["^15",[722,"^V",764,536870916]],["^15",[722,"^U",651,536870916]],["^15",[722,"^U",672,536870916]],["^15",[722,"^H",775,536870916]],["^15",[722,"^;","~u679c5d79-6f93-458c-b583-6f170b5678b8",536870916]],["^15",[723,"^Q","Олимпийцы",536870916]],["^15",[723,"^O","^17",536870916]],["^15",[723,"^F",796,536870916]],["^15",[723,"^X",651,536870916]],["^15",[723,"^V",824,536870916]],["^15",[723,"^U",651,536870916]],["^15",[723,"^;","~u679c5d79-cd04-40e1-9b30-c0a8d408e606",536870916]],["^15",[724,"^Q","Вторая версия слетела согласно Гесиоду. Зевс установил слишком высокий параметр агрессии, и все наминимаксли боевые навыки и поубивали друг друга.",536870916]],["^15",[724,"^O","^17",536870916]],["^15",[724,"^F",754,536870916]],["^15",[724,"^X",651,536870916]],["^15",[724,"^V",754,536870916]],["^15",[724,"^U",651,536870916]],["^15",[724,"^;","~u679c5d79-1172-41d4