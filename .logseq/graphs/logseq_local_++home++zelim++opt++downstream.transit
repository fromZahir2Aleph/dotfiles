  --sidebarItemMinWidth: 250px;\n            --sidebarItemMaxWidth: 950px;\n        }\n\n        .cp__right-sidebar-inner.flex.flex-col.h-full {\n            overflow: visible;\n        }\n\n        .sidebar-item-list {\n            width: fit-content;\n            height: 96vh !important;\n            overflow: unset;\n            display: flex;\n            flex-direction: column;\n            flex-wrap: wrap;\n            align-content: flex-start;\n            padding: 0 0 0 6px;\n        }\n\n        .cp__right-sidebar .sidebar-item {\n            display: inline-block;\n            align-self: flex-start;\n            overflow-y: auto;\n            min-height: 75px;\n            height: calc(100% - 10px) !important;\n            min-width: var(--sidebarItemMinWidth);\n            max-width: var(--sidebarItemMaxWidth);\n            width: 100%;\n            margin: 0px;\n            background-color: var(--ls-primary-background-color);\n            box-shadow: 1px 1px 5px rgba(0, 0, 0, 0.4);\n            border: 1px solid black;\n            border-radius: 10px;\n            resize: both;\n            padding: 1.5rem 0.5rem;\n        }\n\n        .cp__right-sidebar-inner .resizer {\n            position: absolute;\n            top: 0;\n            bottom: 0;\n            left: 0;\n            width: 6px;\n            user-select: none;\n            cursor: col-resize !important;\n            z-index: 10;\n        }\n\n        .cp__right-sidebar .resizer:hover {\n            background-color: var(--ph-highlight-strong);\n        }\n\n        .cp__right-sidebar-scrollable {\n            overflow-y: hidden;\n            overflow-x: auto;\n            height: 100%;\n        }\n\n        /* sliding panes */\n        .sidebar-item.folded {\n            display: inline-block;\n            overflow: hidden;\n            margin: 0px 0 !important;\n            padding: 5px;\n            resize: none;\n            width: 40px !important;\n            min-width: 40px;\n            writing-mode: vertical-LR;\n        }\n\n        .sidebar-item.folded .rotating-arrow.collapsed svg {\n            transform: rotate(180deg) translate(3px, -1.2rem);\n            transition: none;\n        }\n\n        .sidebar-item.folded .ml-1.font-medium {\n            margin-top: 2rem;\n            transition: none;\n        }\n\n        .cp__right-sidebar .sidebar-item.folded .close {\n            transform: scale(.8) translate(-8px);\n            transition: transform .1s;\n        }\n\n/* ======================================== end of BETTER-SIDEBAR =====*/\n/* ==== hide special props ==========================*/\n        div[data-refs-self=\"bg-pic\"] {\n            display: none !important;\n        }\n",536870915]],["^15",[18,"~:file/created-at",1738300792953,536870916]],["^15",[18,"^Z","logseq/custom.css",536870915]],["^15",[19,"^3","- [[personality psychology/narcissism/covert narcissism]] Чувствительность к критике, хрупкое эго, жалость к себе и грандиозные фантазии указывают, что ты нарцисс, просто твой нарциссизм скрытый.",536870916]],["^15",[19,"^16",1738300792071,536870916]],["^15",[19,"^Z","journals/2025_01_31.md",536870916]],["^15",[20,"^K",1738300792071,536870916]],["^15",[20,"^[",19,536870916]],["^15",[20,"^N",20250131,536870916]],["^15",[20,"^@",true,536870916]],["^15",[20,"^Y","jan 31st, 2025",536870916]],["^15",[20,"^11","Jan 31st, 2025",536870916]],["^15",[20,"^B",1738300792071,536870916]],["^15",[20,"^;","~u679c5d78-e43b-4093-814a-20f45066ec4c",536870916]],["^15",[21,"^K",1738300792071,536870916]],["^15",[21,"^@",false,536870916]],["^15",[21,"^Y","personality psychology/narcissism/covert narcissism",536870916]],["^15",[21,"^A",23,536870916]],["^15",[21,"^11","personality psychology/narcissism/covert narcissism",536870916]],["^15",[21,"^B",1738300792071,536870916]],["^15",[21,"^;","~u679c5d78-7e1c-4b48-9d55-e28236040b27",536870916]],["^15",[22,"^K",1738300794242,536870916]],["^15",[22,"^O","~:markdown",536870916]],["^15",[22,"^@",false,536870916]],["^15",[22,"^Y","personality psychology",536870916]],["^15",[22,"^11","personality psychology",536870916]],["^15",[22,"^B",1738300794242,536870916]],["^15",[22,"^;","~u67ff7314-aebd-42e1-86ec-fd0df804666b",536888565]],["^15",[23,"^K",1738300792125,536870916]],["^15",[23,"^@",false,536870916]],["^15",[23,"^Y","personality psychology/narcissism",536870916]],["^15",[23,"^A",22,536870916]],["^15",[23,"^11","personality psychology/narcissism",536870916]],["^15",[23,"^B",1738300792125,536870916]],["^15",[23,"^;","~u67ff7314-3366-490f-99f6-1d8d9dc6770d",536888565]],["^15",[24,"^Q","[[personality psychology/narcissism/covert narcissism]] Чувствительность к критике, хрупкое эго, жалость к себе и грандиозные фантазии указывают, что ты нарцисс, просто твой нарциссизм скрытый.",536870916]],["^15",[24,"^O","^17",536870916]],["^15",[24,"^F",20,536870916]],["^15",[24,"^X",20,536870916]],["^15",[24,"^V",20,536870916]],["^15",[24,"^U",20,536870916]],["^15",[24,"^U",21,536870916]],["^15",[24,"^U",22,536870916]],["^15",[24,"^U",23,536870916]],["^15",[24,"^H",21,536870916]],["^15",[24,"^H",22,536870916]],["^15",[24,"^H",23,536870916]],["^15",[24,"^;","~u679c5d78-af69-478c-9964-72cfb44f261b",536870916]],["^15",[25,"^3","tags:: [[Своя игра]]\nplayed:: no\n\n- #### 1 Географические акронимы\n  collapsed:: true\n\t- 10. Назовите акроним самой южной страны Африки.\n\t\t- ЮАР\n\t- 20. Как расшифровывается название государства КНДР?\n\t\t- Корейская Народно-Демократическая Республика\n\t- 30. Третья буква в объединении БРИКС обозначает это государство.\n\t\t- Индия\n\t- 40. Страны-члены ОПЕК ведут экспорт этого сырья.\n\t\t- Нефть\n\t- 50. Ассоциацией государств какого региона является АСЕАН?\n\t\t- Юго-Восточная Азия\n- #### 2 Родня\n  collapsed:: true\n\t- 10. Эта чеченская единица организации происходит от арабского слова *таифа*.\n\t\t- Тайп\n\t- 20. Этот сериал, запущенный в 1999 году, повествует о мафиозном клане в Нью-Джерси.\n\t\t- Клан Сопрано\n\t- 30. Такое слово используется в качестве применения слова *кузен* к женщине.\n\t\t- Кузина\n\t- 40. И Пётр II, и Пётр III приходились Петру Великому ими.\n\t\t- Внуками\n\t- 50. Прозоровы Ольга, Маша и Ирина являются главными действующими лицами этой книги Чехова.\n\t\t- Три сестры\n-",536874118]],["^15",[25,"^16",1738300792099,536870916]],["^15",[25,"~:file/last-modified-at","~m1738559784021",536874117]],["^15",[25,"^Z","journals/2025_01_30.md",536870916]],["^15",[26,"^K",1738300792098,536870916]],["^15",[26,"^[",25,536870916]],["^15",[26,"^N",20250130,536870916]],["^15",[26,"^@",true,536870916]],["^15",[26,"^Y","jan 30th, 2025",536870916]],["^15",[26,"^11","Jan 30th, 2025",536870916]],["^15",[26,"^?",["^ ","~:tags",["~#set",["Своя игра"]],"~:played","no"],536870916]],["^15",[26,"^4",["^ ","^19","[[Своя игра]]","^1;","no"],536870916]],["^15",[26,"^P",27,536870916]],["^15",[26,"^B",1738300792098,536870916]],["^15",[26,"^;","~u679c5d78-4c1d-4d33-b9dd-b04c149fc5e8",536870916]],["^15",[27,"^K",1738300792098,536870916]],["^15",[27,"^@",false,536870916]],["^15",[27,"^Y","своя игра",536870916]],["^15",[27,"^11","Своя игра",536870916]],["^15",[27,"^B",1738300792098,536870916]],["^15",[27,"^;","~u679c5d78-3a50-4e8a-9faf-f74f16e5db68",536870916]],["^15",[28,"^K",1738300792157,536870916]],["^15",[28,"^@",false,536870916]],["^15",[28,"^Y","played",536870916]],["^15",[28,"^11","played",536870916]],["^15",[28,"^B",1738300792157,536870916]],["^15",[28,"^;","~u67c4424c-2a6c-46ce-9c05-605a6fc95e3e",536882978]],["^15",[29,"^Q","Тайп",536870916]],["^15",[29,"^O","^17",536870916]],["^15",[29,"^F",37,536870916]],["^15",[29,"^X",26,536870916]],["^15",[29,"^V",37,536870916]],["^15",[29,"^U",26,536870916]],["^15",[29,"^;","~u679c5d78-ef70-4ebc-89be-bcfe0a050b6b",536870916]],["^15",[30,"^Q","Внуками",536870916]],["^15",[30,"^O","^17",536870916]],["^15",[30,"^F",34,536870916]],["^15",[30,"^X",26,536870916]],["^15",[30,"^V",34,536870916]],["^15",[30,"^U",26,536870916]],["^15",[30,"^;","~u679c5d78-75e8-47f6-bd5