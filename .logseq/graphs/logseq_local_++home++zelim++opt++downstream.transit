,313,536870916]],["^15",[318,"^H",305,536870916]],["^15",[318,"^H",306,536870916]],["^15",[318,"^H",311,536870916]],["^15",[318,"^H",312,536870916]],["^15",[318,"^H",313,536870916]],["^15",[318,"^;","~u679c5d78-741d-4c5c-86a9-c7aec97b3a37",536870916]],["^15",[319,"^Q","Будь также готов к запланированной или незапланированной ответственности.",536870916]],["^15",[319,"^O","^17",536870916]],["^15",[319,"^F",318,536870916]],["^15",[319,"^X",310,536870916]],["^15",[319,"^V",318,536870916]],["^15",[319,"^U",305,536870916]],["^15",[319,"^U",306,536870916]],["^15",[319,"^U",310,536870916]],["^15",[319,"^U",311,536870916]],["^15",[319,"^U",312,536870916]],["^15",[319,"^U",313,536870916]],["^15",[319,"^;","~u679c5d78-534c-43b9-879d-3cb8af127a2b",536870916]],["^15",[320,"^3","- #randomisation #gamification [[focus areas/daily]]\n\t- Составь список упражнений или задач и случайным образом выбери одно из них или составь цепочку.\n\t\t- Выбери таким же образом параметр, напр., речь...\n\t\t\t- ... и его значение, напр. патетичность.\n\t- Спроси чат-бота.",536870916]],["^15",[320,"^16",1738300792540,536870916]],["^15",[320,"^Z","journals/2023_11_20.md",536870916]],["^15",[321,"^K",1738300792539,536870916]],["^15",[321,"^[",320,536870916]],["^15",[321,"^N",20231120,536870916]],["^15",[321,"^@",true,536870916]],["^15",[321,"^Y","nov 20th, 2023",536870916]],["^15",[321,"^11","Nov 20th, 2023",536870916]],["^15",[321,"^B",1738300792539,536870916]],["^15",[321,"^;","~u679c5d78-7c01-49d5-a320-0c056143c8ed",536870916]],["^15",[322,"^K",1738300792539,536870916]],["^15",[322,"^@",false,536870916]],["^15",[322,"^Y","focus areas/daily",536870916]],["^15",[322,"^A",128,536870916]],["^15",[322,"^11","focus areas/daily",536870916]],["^15",[322,"^B",1738300792539,536870916]],["^15",[322,"^;","~u679c5d78-1439-48fa-a66e-2d5fc0f3bca9",536870916]],["^15",[323,"^K",1738300792539,536870916]],["^15",[323,"^@",false,536870916]],["^15",[323,"^Y","randomisation",536870916]],["^15",[323,"^11","randomisatio