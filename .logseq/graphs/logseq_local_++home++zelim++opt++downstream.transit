"]],"^1B","backlog","^1@","writing","^1C","novel"],536870916]],["^15",[1581,"^4",["^ ","^19","workshop","^1B","backlog","^1@","writing","^1C","novel"],536870916]],["^15",[1581,"^P",618,536870916]],["^15",[1581,"^B",1738300794269,536870916]],["^15",[1581,"^;","~u679c5d7a-6e41-4e43-bcb8-e7ca9d251244",536870916]],["^15",[1582,"^Q","tags:: workshop\nstatus:: backlog\ntype:: writing\nform:: novel\n\n",536870916]],["^15",[1582,"^O","^17",536870916]],["^15",[1582,"^1=",["^1:",[]],536870916]],["^15",[1582,"^F",1581,536870916]],["^15",[1582,"^X",1581,536870916]],["^15",[1582,"^V",1581,536870916]],["^15",[1582,"^U",156,536870916]],["^15",[1582,"^U",618,536870916]],["^15",[1582,"^U",619,536870916]],["^15",[1582,"^U",620,536870916]],["^15",[1582,"^U",1581,536870916]],["^15",[1582,"^:",true,536870916]],["^15",[1582,"^?",["^ ","^19",["^1:",["workshop"]],"^1B","backlog","^1@","writing","^1C","novel"],536870916]],["^15",[1582,"^J",["^19","^1B","^1@","^1C"],536870916]],["^15",[1582,"^4",["^ ","^19","workshop","^1B","backlog","^1@","writing","^1C","novel"],536870916]],["^15",[1582,"^H",156,536870916]],["^15",[1582,"^H",618,536870916]],["^15",[1582,"^H",619,536870916]],["^15",[1582,"^H",620,536870916]],["^15",[1582,"^;","~u679c5d7a-a975-4e02-a20e-a692f119f43e",536870916]],["^15",[1583,"^Q","",536870916]],["^15",[1583,"^O","^17",536870916]],["^15",[1583,"^F",1582,536870916]],["^15",[1583,"^X",1581,536870916]],["^15",[1583,"^V",1581,536870916]],["^15",[1583,"^U",1581,536870916]],["^15",[1583,"^;","~u679c5d7a-5ccb-4773-b682-de0fa6fddbca",536870916]],["^15",[1584,"^3","tags:: workshop\nstatus:: backlog\ntype:: writing\nform:: novel\n\n- Выхожу в хорошем костюме, который я носил на работу. Одел его без повода. След Англии, страны, в которой я жил, но которая не стала частью меня.\n- Камни Руслана Каламбурча\n- Эпилог\n\t- Начинающий стукач-мент пишет отчёт обо мне.",536888784]],["^15",[1584,"^16",1738300794281,536870916]],["^15",[1584,"^18","~m1744795685775",536888783]],["^15",[1584,"^Z","