,[192,"^U",169,536870916]],["^15",[192,"^U",170,536870916]],["^15",[192,"^U",171,536870916]],["^15",[192,"^U",172,536870916]],["^15",[192,"^;","~u679c5d78-7475-4177-a604-4ae64e413a38",536870916]],["^15",[193,"^Q","Место и время",536870916]],["^15",[193,"^O","^17",536870916]],["^15",[193,"^F",185,536870916]],["^15",[193,"^X",169,536870916]],["^15",[193,"^V",185,536870916]],["^15",[193,"^U",22,536870916]],["^15",[193,"^U",164,536870916]],["^15",[193,"^U",165,536870916]],["^15",[193,"^U",166,536870916]],["^15",[193,"^U",167,536870916]],["^15",[193,"^U",168,536870916]],["^15",[193,"^U",169,536870916]],["^15",[193,"^U",170,536870916]],["^15",[193,"^U",171,536870916]],["^15",[193,"^U",172,536870916]],["^15",[193,"^;","~u679c5d78-fb40-4853-a0d2-2ea8c2af11cb",536870916]],["^15",[194,"^3","- #[[percentile problem]]\n\t- Касательно меня\n\t\t- Для чеченца у меня ультралиберальные взгляды, но для Запада они скорее умеренно левые. Даже их феминизм я ставлю под вопрос. Но родись я там, я бы определённо был бы SJW и woke.\n\t- Касательно других\n\t\t- С консервативными людьми здесь не о чем поговорить, а психотип либеральных кавказцев меня раздражает. Если раньше мой отъезд из Чечни был эскапизмом, то сейчас я понимаю, что, к сожалению, только так я могу избежать одиночества. Я на совесть выполнил домашнюю работу по социализации после возвращения из Феникса, но настоящих друзей я не завёл, хоть и стало легче жить.\n\t\t- Касательно избранницы\n\t\t\t- Она не может быть сексуально раскрепощённой и вместе с тем порядочной чеченкой.",536870916]],["^15",[194,"^16",1738300792256,536870916]],["^15",[194,"^Z","journals/2024_12_20.md",536870916]],["^15",[195,"^K",1738300792256,536870916]],["^15",[195,"^[",194,536870916]],["^15",[195,"^N",20241220,536870916]],["^15",[195,"^@",true,536870916]],["^15",[195,"^Y","dec 20th, 2024",536870916]],["^15",[195,"^11","Dec 20th, 2024",536870916]],["^15",[195,"^B",1738300792256,536870916]],["^15",[195,"^;","~u679c5d78-5579-4710-808d-3bebb8786fd4",536870916]],["^15",[196,"^K",1738300792256,536870916]],["^15",[196,"^@",false,536870916]],["^15",[196,"^Y","percentile problem",536870916]],["^15",[196,"^11","percentile problem",536870916]],["^15",[196,"^B",1738300792256,536870916]],["^15",[196,"^;","~u679c5d78-68c0-43d2-8a56-3d97d2738117",536870916]],["^15",[197,"^Q","#[[percentile problem]]",536870916]],["^15",[197,"^O","^17",536870916]],["^15",[197,"^F",195,536870916]],["^15",[197,"^X",195,536870916]],["^15",[197,"^V",195,536870916]],["^15",[197,"^U",195,536870916]],["^15",[197,"^U",196,536870916]],["^15",[197,"^H",196,536870916]],["^15",[197,"^;","~u679c5d78-d1ac-4867-8757-e6bb920d3d5d",536870916]],["^15",[198,"^Q","Касательно меня",536870916]],["^15",[198,"^O","^17",536870916]],["^15",[198,"^F",197,536870916]],["^15",[198,"^X",195,536870916]],["^15",[198,"^V",197,536870916]],["^15",[198,"^U",195,536870916]],["^15",[198,"^U",196,536870916]],["^15",[198,"^;","~u679c5d78-b8b8-4d6b-9655-7fc97e23cd2f",536870916]],["^15",[199,"^Q","Для чеченца у меня ультралиберальные взгляды, но для Запада они скорее умеренно левые. Даже их феминизм я ставлю под вопрос. Но родись я там, я бы определённо был бы SJW и woke.",536870916]],["^15",[199,"^O","^17",536870916]],["^15",[199,"^F",198,536870916]],["^15",[199,"^X",195,536870916]],["^15",[199,"^V",198,536870916]],["^15",[199,"^U",195,536870916]],["^15",[199,"^U",196,536870916]],["^15",[199,"^;","~u679c5d78-4e18-4f16-b29e-4a616bef6ecd",536870916]],["^15",[200,"^Q","Касательно других",536870916]],["^15",[200,"^O","^17",536870916]],["^15",[200,"^F",198,536870916]],["^15",[200,"^X",195,536870916]],["^15",[200,"^V",197,536870916]],["^15",[200,"^U",195,536870916]],["^15",[200,"^U",196,536870916]],["^15",[200,"^;","~u679c5d78-8417-46e6-acad-e5d38addcdd5",536870916]],["^15",[201,"^Q","С консервативными людьми здесь не о чем поговорить, а психотип либеральных кавказцев меня раздражает. Если раньше мой отъезд из Чечни был эскапизмом, то сейчас я понимаю, что, к сожалению, только так я могу избежать одиночества. Я на совесть выполнил домашнюю работу по социализации после возвращения из Феникса, но настоящих друзей я не завёл, хоть и стало легче жить.",536870916]],["^15",[201,"^O","^17",536870916]],["^15",[201,"^F",200,536870916]],["^15",[201,"^X",195,536870916]],["^15",[201,"^V",200,536870916]],["^15",[201,"^U",195,536870916]],["^15",[201,"^U",196,536870916]],["^15",[201,"^;","~u679c5d78-1d56-4ff6-bc3f-ae9059409024",536870916]],["^15",[202,"^Q","Касательно избранницы",536870916]],["^15",[202,"^O","^17",536870916]],["^15",[202,"^F",201,536870916]],["^15",[202,"^X",195,536870916]],["^15",[202,"^V",200,536870916]],["^15",[202,"^U",195,536870916]],["^15",[202,"^U",196,536870916]],["^15",[202,"^;","~u679c5d78-c19f-4b31-b7d3-55580e77b602",536870916]],["^15",[203,"^Q","Она не может быть сексуально раскрепощённой и вместе с тем порядочной чеченкой.",536870916]],["^15",[203,"^O","^17",536870916]],["^15",[203,"^F",202,536870916]],["^15",[203,"^X",195,536870916]],["^15",[203,"^V",202,536870916]],["^15",[203,"^U",195,536870916]],["^15",[203,"^U",196,536870916]],["^15",[203,"^;","~u679c5d78-de04-447a-91ae-801ff50e0249",536870916]],["^15",[204,"^3","tags:: diary\ntype:: reflection\nmood:: sad\n\n- #balance Я не смог жонглировать. Работа, семья, в частности Оа, и построение личных отношений - всё разбилось вдребезги.",536870916]],["^15",[204,"^16",1738300792270,536870916]],["^15",[204,"^Z","journals/2024_12_12.md",536870916]],["^15",[205,"^K",1738300792270,536870916]],["^15",[205,"^[",204,536870916]],["^15",[205,"^N",20241212,536870916]],["^15",[205,"^@",true,536870916]],["^15",[205,"^Y","dec 12th, 2024",536870916]],["^15",[205,"^11","Dec 12th, 2024",536870916]],["^15",[205,"^?",["^ ","^19",["^1:",["diary"]],"^1@","reflection","^1A","sad"],536870916]],["^15",[205,"^4",["^ ","^19","diary","^1@","reflection","^1A","sad"],536870916]],["^15",[205,"^P",155,536870916]],["^15",[205,"^B",1738300792270,536870916]],["^15",[205,"^;","~u679c5d78-1d50-4d72-a7e0-0e561714b4ab",536870916]],["^15",[206,"^K",1738300792270,536870916]],["^15",[206,"^@",false,536870916]],["^15",[206,"^Y","balance",536870916]],["^15",[206,"^11","balance",536870916]],["^15",[206,"^B",1738300792270,536870916]],["^15",[206,"^;","~u679c5d78-7f87-4c56-9347-d1fa13a949ca",536870916]],["^15",[207,"^Q","tags:: diary\ntype:: reflection\nmood:: sad\n\n",536870916]],["^15",[207,"^O","^17",536870916]],["^15",[207,"^1=",["^1:",[]],536870916]],["^15",[207,"^F",205,536870916]],["^15",[207,"^X",205,536870916]],["^15",[207,"^V",205,536870916]],["^15",[207,"^U",155,536870916]],["^15",[207,"^U",156,536870916]],["^15",[207,"^U",157,536870916]],["^15",[207,"^U",205,536870916]],["^15",[207,"^:",true,536870916]],["^15",[207,"^?",["^ ","^19",["^1:",["diary"]],"^1@","reflection","^1A","sad"],536870916]],["^15",[207,"^J",["^19","^1@","^1A"],536870916]],["^15",[207,"^4",["^ ","^19","diary","^1@","reflection","^1A","sad"],536870916]],["^15",[207,"^H",155,536870916]],["^15",[207,"^H",156,536870916]],["^15",[207,"^H",157,536870916]],["^15",[207,"^;","~u679c5d78-78fd-44ca-a7bb-f6203df77611",536870916]],["^15",[208,"^Q","#balance Я не смог жонглировать. Работа, семья, в частности Оа, и построение личных отношений - всё разбилось вдребезги.",536870916]],["^15",[208,"^O","^17",536870916]],["^15",[208,"^F",207,536870916]],["^15",[208,"^X",205,536870916]],["^15",[208,"^V",205,536870916]],["^15",[208,"^U",205,536870916]],["^15",[208,"^U",206,536870916]],["^15",[208,"^H",206,536870916]],["^15",[208,"^;","~u679c5d78-f61a-4696-9b2a-c8d9c270af42",536870916]],["^15",[209,"^3","- #Адам #religion Адам действительно был бы преступником, не будь он религиозным. В его мире Бог есть - и не всё дозволено. Порог, который он готов переступить, находится зачастую за пределами законопослушности, и даже за гранью дозволяемого исламом. Но без религии Адам и эту грань не брал бы в расчёт.\n\t- |Бог есть|Бога нет|\n\t  |Стероиды|Наркотики|\n\t  |Обнал|Кража|\n\t  |Коллекторство|Рэкет|",536870916]],["^15",[209,"^16",1738300792281,536870916]],["^15",[209,"^Z","journals/2024_12_11.md",536870916]],["^15",[210,"^K",1738300792280,536870916]],["^15",[210,"^[",209,536870916]],["^15",[210,"^N",20241211,536870916]],["^15",[210,"^@",true,536870916]],["^15",[210,"^Y","dec 11th, 2024",536870916]],["^15",[210,"^11","Dec 11th, 2024",536870916]],["^15",[210,"^B",1738300792280,536870916]],["^15",[210,"^;","~u679c5d78-af42-46c8-bb17-f5ccc4132e24",536870916]],["^15",[211,"^K",1738300792280,536870916]],["^15",[211,"^@",false,536870916]],["^15",[211,"^Y","religion",536870916]],["^15",[211,"^11","religion",536870916]],["^15",[211,"^B",1738300792280,536870916]],["^15",[211,"^;","~u679c5d78-f4ed-4a25-a9e2-b6bab6a94f18",536870916]],["^15",[212,"^K",1738300792280,536870916]],["^15",[212,"^@",false,536870916]],["^15",[212,"^Y","адам",536870916]],["^15",[212,"^11","Адам",536870916]],["^15",[212,"^B",1738300792280,536870916]],["^15",[212,"^;","~u679c5d78-7cb3-46af-a1f8-1de00793fe97",536870916]],["^15",[213,"^Q","#Адам #religion Адам действительно был бы преступником, не будь он религиозным. В его мире Бог есть - и не всё дозволено. Порог, который он готов переступить, находится зачастую за пределами законопослушности, и даже за гранью дозволяемого исламом. Но без религии Адам и эту грань не брал бы в расчёт.",536870916]],["^15",[213,"^O","^17",536870916]],["^15",[213,"^F",210,536870916]],["^15",[213,"^X",210,536870916]],["^15",[213,"^V",210,536870916]],["^15",[213,"^U",210,536870916]],["^15",[213,"^U",211,536870916]],["^15",[213,"^U",212,536870916]],["^15",[213,"^H",211,536870916]],["^15",[213,"^H",212,536870916]],["^15",[213,"^;","~u679c5d78-1ff4-45eb-ad98-c740c0168160",536870916]],["^15",[214,"^Q","|Бог есть|Бога нет|\n|Стероиды|Наркотики|\n|Обнал|Кража|\n|Коллекторство|Рэкет|",536870916]],["^15",[214,"^O","^17",536870916]],["^15",[214,"^F",213,536870916]],["^15",[214,"^X",210,536870916]],["^15",[214,"^V",213,536870916]],["^15",[214,"^U",210,536870916]],["^15",[214,"^U",211,536870916]],["^15",[214,"^U",212,536870916]],["^15",[214,"^;","~u679c5d78-98c2-4941-ab41-38411cff1bd9",536870916]],["^15",[215,"^3","- [[personality psychology/self-deception]] [[personality psychology/independence]] Будь я достаточно самодостаточным, я был бы избирателен в общении в Англии. В частности, не плёлся бы хвостом за земляками. Также нужно было держать расстояние с гэрэушником в больнице Сеченова и моряком в бехтеревке.\n\t- [[social circle]]\n\t\t- ЧГУ\n\t\t\t- Тот же круг без элемента религии\n\t\t- Эксетер\n\t\t\t- Окки, Джо, Оля\n\t\t\t- Игорь и его круг\n\t\t\t- Иса\n\t\t- Лестер\n\t\t\t- Нужно было пойти в гости к тому русскому, когда пригласили\n\t\t- Ньюкасл\n\t\t\t- Ибраxим\n\t\t- Грозный после Ростова\n\t\t\t- Эту ошибку я допустил с Амиром и Рамзаном из Феникса. Но она простительна, потому что это был мой первый опыт социализации после нейролептиков.",536888553]],["^15",[215,"^16",1738300792298,536870916]],["^15",[215,"^18","~m1744420487758",536888554]],["^15",[215,"^Z","journals/2024_12_09.md",536870916]],["^15",[216,"^K",1738300792297,536870916]],["^15",[216,"^[",215,536870916]],["^15",[216,"^N",20241209,536870916]],["^15",[216,"^@",true,536870916]],["^15",[216,"^Y","dec 9th, 2024",536870916]],["^15",[216,"^11","Dec 9th, 2024",536870916]],["^15",[216,"^B",1738300792297,536870916]],["^15",[216,"^;","~u67ff7314-936f-4dd5-af1f-b5433c6f6e74",536888553]],["^15",[217,"^K",1738300794242,536870916]],["^15",[217,"^@",false,536870916]],["^15",[217,"^Y","personality psychology/self-deception",536870916]],["^15",[217,"^A",22,536870916]],["^15",[217,"^11","personality psychology/self-deception",536870916]],["^15",[217,"^B",1738300794242,536870916]],["^15",[217,"^;","~u67ff7314-79e7-474a-a173-d2d029cc174d",536888553]],["^15",[218,"^K",1738300792297,536870916]],["^15",[218,"^@",false,536870916]],["^15",[218,"^Y","social circle",536870916]],["^15",[218,"^11","social circle",536870916]],["^15",[218,"^B",1738300792297,536870916]],["^15",[218,"^;","~u67ff7314-c091-4eaa-ad72-de4e5adb5c18",536888553]]