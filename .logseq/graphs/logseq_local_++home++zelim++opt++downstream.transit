O\" [2024-05-01 Wed 01:50]\n* State \"DONE\" from \"TODO\" [2024-06-01 Sat 17:50]\n* State \"DONE\" from \"TODO\" [2024-07-31 Wed 21:41]\n* State \"DONE\" from \"TODO\" [2024-08-30 Fri 00:23]\n* State \"DONE\" from \"TODO\" [2024-10-03 Thu 23:47]\n* State \"DONE\" from \"TODO\" [2024-10-30 Wed 21:59]\n* State \"DONE\" from \"TODO\" [2024-11-30 Sat 00:27]\n* State \"DONE\" from \"TODO\" [2024-12-31 Tue 18:09]\n* State \"DONE\" from \"TODO\" [2025-01-30 Thu 07:25]\n* State \"DONE\" from \"TODO\" [2025-03-02 Sun 14:34]\n* State \"DONE\" from \"TODO\" [2025-03-28 Fri 17:36]\n:END:",536887248]],["^15",[585,"^O","^17",536870916]],["^15",[585,"^F",584,536870916]],["^15",[585,"^10","TODO",536887248]],["^15",[585,"^X",584,536870916]],["^15",[585,"^V",584,536870916]],["^15",[585,"^U",4,536870916]],["^15",[585,"^U",584,536870916]],["^15",[585,"^?",["^ "],536887248]],["^15",[585,"^H",4,536887248]],["^15",[585,"^C",true,536887248]],["^15",[585,"^I",20250428,536887248]],["^15",[585,"^;","~u679c5d78-71fc-4d5a-9375-639fadfc1dca",536870916]],["^15",[586,"^3","- #PIM\n\t- ### Переплетённые иерархии\n\t\t- Trees do grow,\n\t\t  id:: 64b9bd7a-b308-4305-b197-a107adc889df\n\t\t  Web does stick:\n\t\t  Logseq's slow,\n\t\t  But does the trick.\n\t\t\t- Без контекста сеть концепций - это решето.\n\t\t\t  collapsed:: true\n\t\t\t\t- Иерархия - далеко не самая важный элемент контекста, но единственный, который можно себе навязать.\n\t\t\t\t\t- При работе с источниками её легко воспроизвести - спускайся сверху вниз: оглавление, главы, работа с блоками и ссылками на них.\n\t\t\t\t\t- А вот на уровне единичных заметок, иерархическое дерево должно вырасти само с самого низа с помощью тэгов и ссылок на уже созданные таким путём страницы и блоки.",536870916]],["^15",[586,"^16",1738300792854,536870916]],["^15",[586,"^Z","journals/2023_06_19.md",536870916]],["^15",[587,"^K",1738300792853,536870916]],["^15",[587,"^[",586,536870916]],["^15",[587,"^N",20230619,536870916]],["^15",[587,"^@",true,536870916]],["^15",[587,"^Y","jun 19th, 2023",536870916]],["^15",[587,"^11","Jun 19th, 2023",536870916]],["^15",[587,"^B",1738300792853,536870916]],["^15",[587,"^;","~u679c5d78-4c18-47e3-989e-c3c1f36f74bc",536870916]],["^15",[588,"^Q","#PIM",536870916]],["^15",[588,"^O","^17",536870916]],["^15",[588,"^F",587,536870916]],["^15",[588,"^X",587,536870916]],["^15",[588,"^V",587,536870916]],["^15",[588,"^U",521,536870916]],["^15",[588,"^U",587,536870916]],["^15",[588,"^H",521,536870916]],["^15",[588,"^;","~u679c5d78-14bf-48cb-86cc-f850b4e4a25e",536870916]],["^15",[589,"^Q","### Переплетённые иерархии",536870916]],["^15",[589,"^O","^17",536870916]],["^15",[589,"^F",588,536870916]],["^15",[589,"^X",587,536870916]],["^15",[589,"^V",588,536870916]],["^15",[589,"^U",521,536870916]],["^15",[589,"^U",587,536870916]],["^15",[589,"^?",["^ ","^1<",3],536870916]],["^15",[589,"^J",[],536870916]],["^15",[589,"^;","~u679c5d78-085d-4e88-8baf-9396103c6925",536870916]],["^15",[590,"^M",true,536870916]],["^15",[590,"^Q","Без контекста сеть концепций - это решето.\ncollapsed:: true",536870916]],["^15",[590,"^O","^17",536870916]],["^15",[590,"^F",552,536870916]],["^15",[590,"^X",587,536870916]],["^15",[590,"^V",552,536870916]],["^15",[590,"^U",521,536870916]],["^15",[590,"^U",587,536870916]],["^15",[590,"^?",["^ "],536870916]],["^15",[590,"^J",[],536870916]],["^15",[590,"^4",["^ "],536870916]],["^15",[590,"^;","~u679c5d78-ee3a-49c7-bfd6-fe544d51519d",536870916]],["^15",[591,"^Q","Иерархия - далеко не самая важный элемент контекста, но единственный, который можно себе навязать.",536870916]],["^15",[591,"^O","^17",536870916]],["^15",[591,"^F",590,536870916]],["^15",[591,"^X",587,536870916]],["^15",[591,"^V",590,536870916]],["^15",[591,"^U",521,536870916]],["^15",[591,"^U",587,536870916]],["^15",[591,"^;","~u679c5d78-ff97-44b8-8e4a-7f14d913d529",536870916]],["^15",[592,"^Q","При работе с источниками её легко воспроизвести - спускайся сверху вниз: оглавление, главы, работа с блоками и ссылками на них.",536870916]],["^15",[592,"^O","^17",536870916]],["^15",[592,"^F",591,536870916]],["^15",[592,"^X",587,536870916]],["^15",[592,"^V",591,536870916]],["^15",[592,"^U",521,536870916]],["^15",[592,"^U",587,536870916]],["^15",[592,"^;","~u679c5d78-8967-48f1-bc3a-1eb280bc6eaa",536870916]],["^15",[593,"^Q","А вот на уровне единичных заметок, иерархическое дерево должно вырасти само с самого низа с помощью тэгов и ссылок на уже созданные таким путём страницы и блоки.",536870916]],["^15",[593,"^O","^17",536870916]],["^15",[593,"^F",592,536870916]],["^15",[593,"^X",587,536870916]],["^15",[593,"^V",591,536870916]],["^15",[593,"^U",521,536870916]],["^15",[593,"^U",587,536870916]],["^15",[593,"^;","~u679c5d78-9152-4039-aaa9-d4408f033d24",536870916]],["^15",[594,"^3","- [[Ударение в древнегреческом языке]]\n  id:: 648f1fab-91e8-4290-a5b5-b4da2733f087\n\t- В древнегреческом языке словесное ударение было музыкальным, то есть характеризовалось изменением тона подударного гласного. Краткий (одноморный) ударный гласный мог иметь только восходящий тон, обозначающийся знаком острого ударения ´, двухморный (долгий) гласный или дифтонг мог иметь как острое ударение (с поднимающимся на второй море тоном), так и облегчённое ˜ или ῀ с преломленным тоном, восходящим на первой море и нисходящим на второй.",536870916]],["^15",[594,"^16",1738300792865,536870916]],["^15",[594,"^Z","journals/2023_06_05.md",536870916]],["^15",[595,"^K",1738300792864,536870916]],["^15",[595,"^[",594,536870916]],["^15",[595,"^N",20230605,536870916]],["^15",[595,"^@",true,536870916]],["^15",[595,"^Y","jun 5th, 2023",536870916]],["^15",[595,"^11","Jun 5th, 2023",536870916]],["^15",[595,"^B",1738300792864,536870916]],["^15",[595,"^;","~u679c5d78-8ff5-45d5-a3d9-69bbfc3c8482",536870916]],["^15",[596,"^K",1738300792864,536870916]],["^15",[596,"^@",false,536870916]],["^15",[596,"^Y","ударение в древнегреческом языке",536870916]],["^15",[596,"^11","Ударение в древнегреческом языке",536870916]],["^15",[596,"^B",1738300792864,536870916]],["^15",[596,"^;","~u679c5d78-3674-4689-8df8-b78c31297523",536870916]],["^15",[597,"^Q","[[Ударение в древнегреческом языке]]\nid:: 648f1fab-91e8-4290-a5b5-b4da2733f087",536870916]],["^15",[597,"^O","^17",536870916]],["^15",[597,"^F",595,536870916]],["^15",[597,"^X",595,536870916]],["^15",[597,"^V",595,536870916]],["^15",[597,"^U",595,536870916]],["^15",[597,"^U",596,536870916]],["^15",[597,"^?",["^ ","^1?","648f1fab-91e8-4290-a5b5-b4da2733f087"],536870916]],["^15",[597,"^J",["^1?"],536870916]],["^15",[597,"^4",["^ ","^1?","648f1fab-91e8-4290-a5b5-b4da2733f087"],536870916]],["^15",[597,"^H",596,536870916]],["^15",[597,"^;","~u648f1fab-91e8-4290-a5b5-b4da2733f087",536870916]],["^15",[598,"^Q","В древнегреческом языке словесное ударение было музыкальным, то есть характеризовалось изменением тона подударного гласного. Краткий (одноморный) ударный гласный мог иметь только восходящий тон, обозначающийся знаком острого ударения ´, двухморный (долгий) гласный или дифтонг мог иметь как острое ударение (с поднимающимся на второй море тоном), так и облегчённое ˜ или ῀ с преломленным тоном, восходящим на первой море и нисходящим на второй.",536870916]],["^15",[598,"^O","^17",536870916]],["^15",[598,"^F",597,536870916]],["^15",[598,"^X",595,536870916]],["^15",[598,"^V",597,536870916]],["^15",[598,"^U",595,536870916]],["^15",[598,"^U",596,536870916]],["^15",[598,"^;","~u679c5d78-fb41-4c6b-a60a-d19221962318",536870916]],["^15",[599,"^3","tags:: diary\ntype:: reflection\nmood:: sad\n\n\t- #Седа \"Ты чаще дома, чем я.\"",536870916]],["^15",[599,"^16",1738300792877,536870916]],["^15",[599,"^Z","journals/2023_05_20.md",536870916]],["^15",[600,"^K",1738300792877,536870916]],["^15",[600,"^[",599,536870916]],["^15",[600,"^N",20230520,536870916]],["^15",[600,"^@",true,536870916]],["^15",[600,"^Y","may 20th, 2023",536870916]],["^15",[600,"^11","May 20th, 2023",536870916]],["^15",[600,"^?",["^ ","^19",["^1:",["diary"]],"^1@","reflection","^1A","sad"],536870916]],["^15",[600,"^4",[