{:bounding {:x1 0,\n                                     :y1 46,\n                                     :x2 891.643310546875,\n                                     :y2 286.828125,\n                                     :width 1019.9999999999999,\n                                     :height 1319.9999999999998},\n                          :rects ({:x1 0,\n                                   :y1 46,\n                                   :x2 0,\n                                   :y2 66,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 248.29547119140625,\n                                   :y1 225.03125,\n                                   :x2 891.643310546875,\n                                   :y2 253.03125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 258.828125,\n                                   :x2 263.55206298828125,\n                                   :y2 286.828125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}),\n                          :page 51},\n               :content {:text \"we think only thanks to analogies that link our present to our past.\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"6502222f-95ec-44bf-938e-5876f0837a79\",\n               :page 67,\n               :position {:bounding {:x1 451.765625,\n                                     :y1 948.390625,\n                                     :x2 771.8077392578125,\n                                     :y2 981.390625,\n                                     :width 1224,\n                                     :height 1584},\n                          :rects ({:x1 451.765625,\n                                   :y1 948.390625,\n                                   :x2 771.8077392578125,\n                                   :y2 981.390625,\n                                   :width 1224,\n                                   :height 1584}),\n                          :page 67},\n               :content {:text \"Synopsis of This Book\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"6509d51a-bad3-4712-9219-b9222eae3373\",\n               :page 61,\n               :position {:bounding {:x1 0,\n                                     :y1 0,\n                                     :x2 1020,\n                                     :y2 2650,\n                                     :width 1019.9999999999999,\n                                     :height 1319.9999999999998},\n                          :rects ({:x1 0,\n                                   :y1 0,\n                                   :x2 0,\n                                   :y2 0,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 446,\n                                   :x2 0,\n                                   :y2 466,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 462,\n                                   :x2 0,\n                                   :y2 482,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 478,\n                                   :x2 0,\n                                   :y2 498,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\