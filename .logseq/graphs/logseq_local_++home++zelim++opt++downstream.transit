ветильники 40. ну ты за 8 найдешь. хотя я все ж рекомендую просто лампочки. это еще дешевле и ничем не хуже. лампы около 2500, фильтр 2500, канальник 2500. где то так)\n\t\t- ведро 150р. тазик 200р. орех 1500. но они по одному непродаются поэтому 5k. мелочи всякие типа обдувных вертушек - с компа достаются бесплатно. либо с авито. блок питания к ним 12в тож до 500р можно надыбать.\n\t\t- на озоне все это можно найти. или на авито. тут зависит новое тебя устроит или бу.\n\t\t- сайт минифермер ру. они с алика торгуют. но боле менее приличное качество",536870916]],["^15",[53,"^16",1738300792115,536870916]],["^15",[53,"^Z","journals/2025_01_29.md",536870916]],["^15",[54,"^K",1738300792114,536870916]],["^15",[54,"^[",53,536870916]],["^15",[54,"^N",20250129,536870916]],["^15",[54,"^@",true,536870916]],["^15",[54,"^Y","jan 29th, 2025",536870916]],["^15",[54,"^11","Jan 29th, 2025",536870916]],["^15",[54,"^B",1738300792114,536870916]],["^15",[54,"^;","~u679c5d78-3c7e-4037-b245-ee36c8b35d9c",536870916]],["^15",[55,"^5",1980,536875422]],["^15",[55,"^K",1738300792114,536870916]],["^15",[55,"^[",1979,536875392]],["^15",[55,"^O","^17",536875388]],["^15",[55,"^@",false,536870916]],["^15",[55,"^Y","mj",536870916]],["^15",[55,"^11","mj",536870916]],["^15",[55,"^?",["^ ","~:alias",["^1:",["marijuana"]]],536875422]],["^15",[55,"^4",["^ ","^1>","marijuana"],536875422]],["^15",[55,"^B",1739208052314,536875422]],["^15",[55,"^;","~u679c5d78-81c3-4aaf-a988-b7775084d2b1",536870916]],["^15",[56,"^Q","### Стоимость оборудования и сайты для покупки",536870916]],["^15",[56,"^O","^17",536870916]],["^15",[56,"^F",63,536870916]],["^15",[56,"^X",54,536870916]],["^15",[56,"^V",66,536870916]],["^15",[56,"^U",54,536870916]],["^15",[56,"^U",55,536870916]],["^15",[56,"^?",["^ ","^1<",3],536870916]],["^15",[56,"^J",[],536870916]],["^15",[56,"^;","~u679c5d78-585d-4096-ba08-c78ac1f83f6e",536870916]],["^15",[57,"^Q","https://t.me/growlibrary",536870916]],["^15",[57,"^O","^17",536870916]],["^15",[57,"^F",62,