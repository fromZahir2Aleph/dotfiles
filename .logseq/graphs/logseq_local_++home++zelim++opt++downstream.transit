,"^F",515,536870916]],["^15",[517,"^X",515,536870916]],["^15",[517,"^V",515,536870916]],["^15",[517,"^U",455,536870916]],["^15",[517,"^U",515,536870916]],["^15",[517,"^?",["^ ","~:query-sort-by",".flags","^1G",true,"~:query-sort-desc",true],536870916]],["^15",[517,"^J",["^1L","^1G","^1M"],536870916]],["^15",[517,"^4",["^ ","^1L",".flags","^1G","true","^1M","true"],536870916]],["^15",[517,"^H",455,536870916]],["^15",[517,"^;","~u679c5d78-e465-4554-bf3f-786fe4371aee",536870916]],["^15",[518,"^Q","#entropy #emergence Энтропия - это предлог для эмергентности.",536870916]],["^15",[518,"^O","^17",536870916]],["^15",[518,"^F",517,536870916]],["^15",[518,"^X",515,536870916]],["^15",[518,"^V",517,536870916]],["^15",[518,"^U",455,536870916]],["^15",[518,"^U",511,536870916]],["^15",[518,"^U",515,536870916]],["^15",[518,"^U",516,536870916]],["^15",[518,"^H",511,536870916]],["^15",[518,"^H",516,536870916]],["^15",[518,"^;","~u679c5d78-f788-4239-9b1e-394e14a06a2e",536870916]],["^15",[519,"^3","- #PIM\n\t- ### Data and PIM\n\t\t- Множества\n\t\t\t- Logseq\n\t\t\t\t- блоки, а страницы - это просто именованные блоки\n\t\t\t- Obsidian\n\t\t\t\t- страницы\n\t\t- Деревья\n\t\t\t- Logseq\n\t\t\t\t- блоки с ответвлениями в виде листьев или таких же деревьев\n\t\t\t- Obsidian\n\t\t\t\t- папки\n\t\t- Модели базы данных\n\t\t\t- Реляционная (таблицы, в частности каталоги)\n\t\t\t\t- Airtable\n\t\t\t- Документоориентированная (всё, что с метаданными и тегами)\n\t\t\t\t- тэги необходимы для запросов и поиска\n\t\t\t\t\t- использование их в качестве ссылок, как делает это Obsidan, создает сеть информации, по факту, только внутри приложения, а не твоего мозга\n\t\t\t\t- метаданные хоть и полезны, но TfT сообщество переоценивает их значимость\n\t\t\t- Орграфы\n\t\t\t\t- всего лишь фантик\n\t\t- Заключение\n\t\t\t- В Logseq...\n\t\t\t\t- Иерархия строится с помощью деревьев из блоков и деревьев из тэгов.\n\t\t\t\t\t- Сеть можно связать из тэгов и ссылок на блоки. Она полезна непосредственно при чтении, то есть когда мы передвигаемся от узла к узлу. Визуально графы смотрятся красиво, но эмергентности в них нет, и любая серендипность, считаю, искусственна, как, собственно, и сам этот термин.\n\t\t\t\t- Журнал и GTD интегрированы в Logseq, а конспектирование в Logseq лучше из-за блоков и ссылок на них.\n\t\t\t\t- Обдуманные тэги и метаданные облегчают запросы.\n\t\t\t- В Obsidian всё зиждется не на блоках, а на страницах, и работа начинается сверху, а именно с наименования страницы. В Logseq же и страница - блок.\n\t\t\t- {{embed ((64b9bd7a-b308-4305-b197-a107adc889df))}}",536870916]],["^15",[519,"^16",1738300792788,536870916]],["^15",[519,"^Z","journals/2023_07_23.md",536870916]],["^15",[520,"^K",1738300792787,536870916]],["^15",[520,"^[",519,536870916]],["^15",[520,"^N",20230723,536870916]],["^15",[520,"^@",true,536870916]],["^15",[520,"^Y","jul 23rd, 2023",536870916]],["^15",[520,"^11","Jul 23rd, 2023",536870916]],["^15",[520,"^B",1738300792787,536870916]],["^15",[520,"^;","~u679c5d78-25d3-4de2-88de-6e8c6bc08a3f",536870916]],["^15",[521,"^K",1738300792853,536870916]],["^15",[521,"^@",false,536870916]],["^15",[521,"^Y","pim",536870916]],["^15",[521,"^11","PIM",536870916]],["^15",[521,"^B",1738300792853,536870916]],["^15",[521,"^;","~u679c5d78-2d2d-4fee-91d4-e3939d97dbd4",536870916]],["^15",[522,"^K",1738300792788,536870916]],["^15",[522,"^@",false,536870916]],["^15",[522,"^Y","64b9bd7a-b308-4305-b197-a107adc889df",536870916]],["^15",[522,"^11","64b9bd7a-b308-4305-b197-a107adc889df",536870916]],["^15",[522,"^B",1738300792788,536870916]],["^15",[522,"^;","~u679c5d78-fc68-4add-b858-bf3c8df0887f",536870916]],["^15",[523,"^Q","блоки с ответвлениями в виде листьев или таких же деревьев",536870916]],["^15",[523,"^O","^17",536870916]],["^15",[523,"^F",536,536870916]],["^15",[523,"^X",520,536870916]],["^15",[523,"^V",536,536870916]],["^15",[523,"^U",520,536870916]],["^15",[523,"^U",521,536870916]],["^15",[523,"^;","~u679c5d78-e87e-45be-849e-accf50c3a113",536870916]],