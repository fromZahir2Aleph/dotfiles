5",[253,"^;","~u67bc1de3-9518-4eda-807e-88509d465720",536881753]],["^15",[254,"^K",1738300792381,536870916]],["^15",[254,"^O","^17",536872029]],["^15",[254,"^@",false,536870916]],["^15",[254,"^Y","personality psychology/self-awareness",536870916]],["^15",[254,"^A",22,536870916]],["^15",[254,"^11","personality psychology/self-awareness",536870916]],["^15",[254,"^B",1738300792381,536870916]],["^15",[254,"^;","~u67bc1de3-31fa-4003-9955-22d04ff2e74e",536881753]],["^15",[256,"^Q","#[[me|cfs]] #[[personality psychology/self-awareness]] Дискомфорт или боль уменьшают мою и так порой, особенно вечером, не в своей лучшей форме самоосознанность и соответственно при употреблении нейролептиков их эффективностъ.",536884733]],["^15",[256,"^O","^17",536870916]],["^15",[256,"^F",253,536870916]],["^15",[256,"^X",253,536870916]],["^15",[256,"^V",253,536870916]],["^15",[256,"^U",22,536870916]],["^15",[256,"^U",253,536870916]],["^15",[256,"^U",254,536870916]],["^15",[256,"^U",2144,536881753]],["^15",[256,"^H",22,536881753]],["^15",[256,"^H",254,536881753]],["^15",[256,"^H",2144,536881753]],["^15",[256,"^;","~u679c5d78-e15c-40e4-9019-378b6e2d73ab",536870916]],["^15",[257,"^3","tags:: diary\ntype:: acknowledgement\nmood:: sad\n\n- #Оа Tы был мне плохим отцом, но я тебя любил, люблю и буду любить. Я скучаю по тебе. Я прощаю тебя за твой эгоизм. Прости меня и ты за мой. И за другие слабости. Я прощаю себя за них ради мамы, ради Седы и себя, но уже, к сожалению, не ради тебя. \n  С любовью и последним и единственным поцелуем, твой, всё-таки  твой, Зема, хоть и не Зеламх.",536870916]],["^15",[257,"^16",1738300792434,536870916]],["^15",[257,"^Z","journals/2024_05_19.md",536870916]],["^15",[258,"^K",1738300792433,536870916]],["^15",[258,"^[",257,536870916]],["^15",[258,"^N",20240519,536870916]],["^15",[258,"^@",true,536870916]],["^15",[258,"^Y","may 19th, 2024",536870916]],["^15",[258,"^11","May 19th, 2024",536870916]],["^15",[258,"^?",["^ ","^19",["^1:",["diary"]],"^1@","acknowledgement","^1A"