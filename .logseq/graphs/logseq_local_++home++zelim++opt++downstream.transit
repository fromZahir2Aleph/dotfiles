0916]],["^15",[786,"^O","^17",536870916]],["^15",[786,"^F",684,536870916]],["^15",[786,"^X",651,536870916]],["^15",[786,"^V",684,536870916]],["^15",[786,"^U",651,536870916]],["^15",[786,"^U",670,536870916]],["^15",[786,"^U",671,536870916]],["^15",[786,"^U",674,536870916]],["^15",[786,"^U",676,536870916]],["^15",[786,"^U",678,536870916]],["^15",[786,"^U",679,536870916]],["^15",[786,"^H",794,536870916]],["^15",[786,"^;","~u679c5d79-a7d9-4f83-9088-51b4bc99d547",536870916]],["^15",[787,"^Q","((648f1fab-91e8-4290-a5b5-b4da2733f087))",536870916]],["^15",[787,"^O","^17",536870916]],["^15",[787,"^F",827,536870916]],["^15",[787,"^X",651,536870916]],["^15",[787,"^V",827,536870916]],["^15",[787,"^U",651,536870916]],["^15",[787,"^H",597,536870916]],["^15",[787,"^;","~u679c5d79-d383-4436-b06f-0f54fc2a81c6",536870916]],["^15",[788,"^Q","Олимпийские в честь [Зевса](((64af0846-e1c6-440c-9c8c-0da4d05fc25d)))",536870916]],["^15",[788,"^O","^17",536870916]],["^15",[788,"^F",777,536870916]],["^15",[788,"^X",651,536870916]],["^15",[788,"^V",777,536870916]],["^15",[788,"^U",651,536870916]],["^15",[788,"^H",836,536870916]],["^15",[788,"^;","~u679c5d79-6d4c-453c-93fa-68ae1a69e97a",536870916]],["^15",[789,"^Q","Братьям [Эпиметею](((655011bf-7aae-4201-abaa-518f4486a711))) (Апослею) и [Прометею](((655011bf-202c-4765-a16c-404b43766587))) (Предвидею) было поручено создание людей и животных. Эпиметей раздал всем по орудию к выживанию: корни, клыки и т.д., а про человека по глупости забыл. Прометей, пожалев людей, своровал у Афины и Гефеста инструменты и огонь, без которых они бесполезны. За это наказали и Прометея, приковав к горе на Кавказе, и человечество, подослав к нему [первую женщину](((654bc199-217e-45ee-963f-fed1e320e9c7))).",536870916]],["^15",[789,"^O","^17",536870916]],["^15",[789,"^F",826,536870916]],["^15",[789,"^X",651,536870916]],["^15",[789,"^V",826,536870916]],["^15",[789,"^U",651,536870916]],["^15",[789,"^H",728,536870916]],["^15",[789,"^H",737,536870916]],["^15",[789,"^H",771,536870916]],["^15",[789,"^;","~u679c5d79-22cc-4898-8eb5-47d83060aefb",536870916]],["^15",[790,"^Q","3. Так как последний багфикс не принёс Дилосскому союзу победу в войне, заподозрили, что проблема в живых, а не мёртвых, и спустя несколько лет провели генеральную очистку, выслав в Адрамитион всех дилосцев.",536870916]],["^15",[790,"^O","^17",536870916]],["^15",[790,"^F",715,536870916]],["^15",[790,"^X",651,536870916]],["^15",[790,"^V",744,536870916]],["^15",[790,"^U",651,536870916]],["^15",[790,"^;","~u679c5d79-6da3-4788-8b3d-cb6eff0f82d0",536870916]],["^15",[791,"^Q","Книга Стивена Фрая следует теогонии Гесиода, самой известной и, по-моему, самой изящной. В Орфейской традиции всё врассыпку, а у Алкмана - надуманно.",536870916]],["^15",[791,"^O","^17",536870916]],["^15",[791,"^F",688,536870916]],["^15",[791,"^X",651,536870916]],["^15",[791,"^V",688,536870916]],["^15",[791,"^U",651,536870916]],["^15",[791,"^;","~u679c5d79-e54c-437f-829d-35398326ad35",536870916]],["^15",[792,"^Q","4. \"The god of song and music\"",536870916]],["^15",[792,"^O","^17",536870916]],["^15",[792,"^F",758,536870916]],["^15",[792,"^X",651,536870916]],["^15",[792,"^V",681,536870916]],["^15",[792,"^U",651,536870916]],["^15",[792,"^;","~u679c5d79-c552-4712-82d0-a2af7c152f47",536870916]],["^15",[793,"^Q","...с природой",536870916]],["^15",[793,"^O","^17",536870916]],["^15",[793,"^F",686,536870916]],["^15",[793,"^X",651,536870916]],["^15",[793,"^V",837,536870916]],["^15",[793,"^U",651,536870916]],["^15",[793,"^;","~u679c5d79-a9f6-4302-be97-79f8f443c5de",536870916]],["^15",[794,"^Q","Мотив придания миру формы появляется в разных мифологиях.\nid:: 64b9bd7a-92b2-4e98-9aa3-fe085f42caea",536870916]],["^15",[794,"^O","^17",536870916]],["^15",[794,"^F",725,536870916]],["^15",[794,"^X",651,536870916]],["^15",[794,"^V",725,536870916]],["^15",[794,"^U",651,536870916]],["^15",[794,"^U",673,536870916]],["^15",[794,"^?",["^ ","^1?","64b9bd7a-92b2-4e98-9aa3-fe085f42caea"],536870916]],["^15",[794,"^J",["^1?"],536