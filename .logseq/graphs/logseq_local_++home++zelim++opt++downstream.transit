ng* must be wrong with it.",536870916]],["^15",[878,"^O","^17",536870916]],["^15",[878,"^F",868,536870916]],["^15",[878,"^X",653,536870916]],["^15",[878,"^V",868,536870916]],["^15",[878,"^U",653,536870916]],["^15",[878,"^;","~u679c5d79-4374-4e16-a3ed-cc5f2e3d7d60",536870916]],["^15",[879,"^Q","Follows from premises with probability, because the following is not conclusive",536870916]],["^15",[879,"^O","^17",536870916]],["^15",[879,"^F",889,536870916]],["^15",[879,"^X",653,536870916]],["^15",[879,"^V",889,536870916]],["^15",[879,"^U",653,536870916]],["^15",[879,"^;","~u679c5d79-1ec0-4e4e-99c2-b551e950f4b4",536870916]],["^15",[880,"^Q","",536870916]],["^15",[880,"^O","^17",536870916]],["^15",[880,"^F",865,536870916]],["^15",[880,"^X",653,536870916]],["^15",[880,"^V",849,536870916]],["^15",[880,"^U",653,536870916]],["^15",[880,"^;","~u679c5d79-bd5d-40f1-940b-fc40c3f1bc79",536870916]],["^15",[881,"^Q","XPL",536870916]],["^15",[881,"^O","^17",536870916]],["^15",[881,"^F",876,536870916]],["^15",[881,"^X",653,536870916]],["^15",[881,"^V",876,536870916]],["^15",[881,"^U",653,536870916]],["^15",[881,"^;","~u679c5d79-2207-4b28-aa6c-0916ca139c02",536870916]],["^15",[882,"^Q","Paragraph markers\nid:: 65677c5b-9d97-4bc0-b2b7-75c75bd7dca6",536870916]],["^15",[882,"^O","^17",536870916]],["^15",[882,"^F",849,536870916]],["^15",[882,"^X",653,536870916]],["^15",[882,"^V",653,536870916]],["^15",[882,"^U",653,536870916]],["^15",[882,"^?",["^ ","^1?","65677c5b-9d97-4bc0-b2b7-75c75bd7dca6"],536870916]],["^15",[882,"^J",["^1?"],536870916]],["^15",[882,"^4",["^ ","^1?","65677c5b-9d97-4bc0-b2b7-75c75bd7dca6"],536870916]],["^15",[882,"^;","~u65677c5b-9d97-4bc0-b2b7-75c75bd7dca6",536870916]],["^15",[883,"^Q","Validity is the topic-neutral property of argument's structure. Basically \"if the premise is true\", the conclusion of which can be:",536870916]],["^15",[883,"^O","^17",536870916]],["^15",[883,"^F",858,536870916]],["^15",[883,"^X",653,536870916]],["^15",[883,"^V",858,536870916]],["^15",