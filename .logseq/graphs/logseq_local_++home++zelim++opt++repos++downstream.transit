U",626,536870919]],["^15",[651,"^U",647,536870919]],["^15",[651,"^U",648,536870919]],["^15",[651,"^U",649,536870919]],["^15",[651,"^H",626,536870919]],["^15",[651,"^H",649,536870919]],["^15",[651,"^;","~u686ffd65-7ab5-46da-9209-035062f4273b",536870919]],["^15",[652,"^Q","Catch the Lead Reins",536870919]],["^15",[652,"^O","^1;",536870919]],["^15",[652,"^F",651,536870919]],["^15",[652,"^X",647,536870919]],["^15",[652,"^V",651,536870919]],["^15",[652,"^U",194,536870919]],["^15",[652,"^U",195,536870919]],["^15",[652,"^U",626,536870919]],["^15",[652,"^U",647,536870919]],["^15",[652,"^U",648,536870919]],["^15",[652,"^U",649,536870919]],["^15",[652,"^;","~u686ffd65-bcc8-4a67-b4ad-67db84857bcc",536870919]],["^15",[653,"^Q","#compulsion",536870919]],["^15",[653,"^O","^1;",536870919]],["^15",[653,"^F",651,536870919]],["^15",[653,"^X",647,536870919]],["^15",[653,"^V",650,536870919]],["^15",[653,"^U",194,536870919]],["^15",[653,"^U",195,536870919]],["^15",[653,"^U",625,536870919]],["^15",[653,"^U",647,536870919]],["^15",[653,"^U",648,536870919]],["^15",[653,"^H",625,536870919]],["^15",[653,"^;","~u686ffd65-9d6e-465d-843a-b1fa95081e23",536870919]],["^15",[654,"^Q","Whack-a-Whim",536870919]],["^15",[654,"^O","^1;",536870919]],["^15",[654,"^F",653,536870919]],["^15",[654,"^X",647,536870919]],["^15",[654,"^V",653,536870919]],["^15",[654,"^U",194,536870919]],["^15",[654,"^U",195,536870919]],["^15",[654,"^U",625,536870919]],["^15",[654,"^U",647,536870919]],["^15",[654,"^U",648,536870919]],["^15",[654,"^;","~u686ffd65-cde2-4765-9b10-c99fdf655197",536870919]],["^15",[655,"^3","- #[[action/anticipatory commitment]]\n\t- #[[free will]] Будь готов к хорошему исходу событий, например, просто-напросто к хорошему завтрашнему дню. Когда наступит то, чего ты боялся, ты ничего не сможешь с этим поделать. Что ещё хуже, ты потратишь время на опасения впустую и не сможешь насладиться днём обычным. Поэтому просто жди его, пока есть хоть какая-то на это вероятность.\n\t- #determinism [[personality psychology/anxiety/anticipatory anxiety]] Не бойся плохого исхода. Страх в преддверии его наступления помешает тебе справиться с проблемой, если есть таковая возможность. Если её нет, то пусть день ненастья будет твоим периодом неудовлетворения или же началом горестного времени.\n\t\t- Некоторые события содержат в себе и свободную волю, и детерминизм. Самый яркий пример - рождение ребёнка. Ты можешь при наличии определённых условий выбрать факт самого рождения. Но ты мало можешь повлиять на то, как оно пройдёт, будет ли ребёнок здоров, будут ли его детство, зрелость и старость в меру счастливыми. Прими это.\n\t- [[action/anticipatory commitment/planfulness]] [[action/anticipatory commitment/purposefulness]] [[action/anticipatory commitment/self-discipline]]\n\t\t- Будь также готов к запланированной или незапланированной ответственности.",536870919]],["^15",[655,"^16",1752169829168,536870919]],["^15",[655,"^Z","journals/2023_12_06.md",536870919]],["^15",[656,"^K",1752169829445,536870919]],["^15",[656,"^@",false,536870919]],["^15",[656,"^Y","action/anticipatory commitment/planfulness",536870919]],["^15",[656,"^A",664,536870919]],["^15",[656,"^11","action/anticipatory commitment/planfulness",536870919]],["^15",[656,"^B",1752169829445,536870919]],["^15",[656,"^;","~u686ffd65-6113-459e-81b7-d926a0c6ad2e",536870919]],["^15",[657,"^K",1752169829445,536870919]],["^15",[657,"^@",false,536870919]],["^15",[657,"^Y","action/anticipatory commitment/self-discipline",536870919]],["^15",[657,"^A",664,536870919]],["^15",[657,"^11","action/anticipatory commitment/self-discipline",536870919]],["^15",[657,"^B",1752169829445,536870919]],["^15",[657,"^;","~u686ffd67-f787-4856-9448-9297685e7169",536870920]],["^15",[658,"^K",1752169829308,536870919]],["^15",[658,"^O","^1;",536873115]],["^15",[658,"^@",false,536870919]],["^15",[658,"^Y","personality psychology/anxiety/anticipatory anxiety",536870919]],["^15",[658,"^A",152,536870919]],["^15",[658,"^11","personality psychology/anxiety/anticipa