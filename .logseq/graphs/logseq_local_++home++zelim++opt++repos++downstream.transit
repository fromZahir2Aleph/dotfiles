917]],["^15",[1609,"^U",1561,536870917]],["^15",[1609,"^U",1598,536870917]],["^15",[1609,"^;","~u69a845e5-1080-47c9-9506-0db7307104c1",536870917]],["^15",[1610,"^3","tags:: diary, [[roguelike vs metroidvania]] \ntype:: reflection\nmood:: neutral\n\n- #+BEGIN_QUOTE\n  Life is a tragedy when seen in closeup, but a comedy in long-shot.\n  #+END_QUOTE\n  Charlie Chaplin\n\t- Можно поставить вместо трагедии рогалик, а вместо комедии - метроидванию. Чем лучше игрок, тем больше второго.\n\t- В социальном взаимодействии обстоятельста генерируются процедурно.\n\t- Я получил наилучшую и наиредкую реликвию, когда поехал на учёбу в Англию. Нужен был лишь грайнд, чтобы не просрать её.",536870917]],["^15",[1610,"^16",1772635621799,536870917]],["^15",[1610,"^Z","journals/2025_01_05.md",536870917]],["^15",[1611,"^K",1772635621798,536870917]],["^15",[1611,"^[",1610,536870917]],["^15",[1611,"^N",20250105,536870917]],["^15",[1611,"^@",true,536870917]],["^15",[1611,"^Y","jan 5th, 2025",536870917]],["^15",[1611,"^11","Jan 5th, 2025",536870917]],["^15",[1611,"^?",["^ ","^19",["^1:",["roguelike vs metroidvania","diary"]],"^1;","reflection","^1<","neutral"],536870917]],["^15",[1611,"^4",["^ ","^19","diary, [[roguelike vs metroidvania]]","^1;","reflection","^1<","neutral"],536870917]],["^15",[1611,"^P",185,536870917]],["^15",[1611,"^P",1612,536870917]],["^15",[1611,"^B",1772635621798,536870917]],["^15",[1611,"^;","~u69a845e5-a579-4944-ac7b-b78a80b2e886",536870917]],["^15",[1612,"^K",1772635621820,536870917]],["^15",[1612,"^@",false,536870917]],["^15",[1612,"^Y","roguelike vs metroidvania",536870917]],["^15",[1612,"^11","roguelike vs metroidvania",536870917]],["^15",[1612,"^B",1772635621820,536870917]],["^15",[1612,"^;","~u69a845e5-886c-44f9-a7ef-36e8bb93e105",536870917]],["^15",[1613,"^Q","tags:: diary, [[roguelike vs metroidvania]] \ntype:: reflection\nmood:: neutral\n\n",536870917]],["^15",[1613,"^O","^17",536870917]],["^15",[1613,"^1=",["^1:",[]],536870917]],["^15",[1613,"^F",1611,536870917]],["^15",[1613,"^X",1611,536870917]],["^15",[1613,"^V",1611,536870917]],["^15",[1613,"^U",185,536870917]],["^15",[1613,"^U",186,536870917]],["^15",[1613,"^U",187,536870917]],["^15",[1613,"^U",1611,536870917]],["^15",[1613,"^U",1612,536870917]],["^15",[1613,"^:",true,536870917]],["^15",[1613,"^?",["^ ","^19",["^1:",["roguelike vs metroidvania","diary"]],"^1;","reflection","^1<","neutral"],536870917]],["^15",[1613,"^J",["^19","^1;","^1<"],536870917]],["^15",[1613,"^4",["^ ","^19","diary, [[roguelike vs metroidvania]]","^1;","reflection","^1<","neutral"],536870917]],["^15",[1613,"^H",185,536870917]],["^15",[1613,"^H",186,536870917]],["^15",[1613,"^H",187,536870917]],["^15",[1613,"^H",1612,536870917]],["^15",[1613,"^;","~u69a845e5-72e8-4acc-a8a1-f647f228bd23",536870917]],["^15",[1614,"^Q","#+BEGIN_QUOTE\nLife is a tragedy when seen in closeup, but a comedy in long-shot.\n#+END_QUOTE\nCharlie Chaplin",536870917]],["^15",[1614,"^O","^17",536870917]],["^15",[1614,"^F",1613,536870917]],["^15",[1614,"^X",1611,536870917]],["^15",[1614,"^V",1611,536870917]],["^15",[1614,"^U",1611,536870917]],["^15",[1614,"^;","~u69a845e5-7e3d-488d-91db-ded8042dfd06",536870917]],["^15",[1615,"^Q","Можно поставить вместо трагедии рогалик, а вместо комедии - метроидванию. Чем лучше игрок, тем больше второго.",536870917]],["^15",[1615,"^O","^17",536870917]],["^15",[1615,"^F",1614,536870917]],["^15",[1615,"^X",1611,536870917]],["^15",[1615,"^V",1614,536870917]],["^15",[1615,"^U",1611,536870917]],["^15",[1615,"^;","~u69a845e5-1f17-4f4e-b7b0-d841680da2b8",536870917]],["^15",[1616,"^Q","В социальном взаимодействии обстоятельста генерируются процедурно.",536870917]],["^15",[1616,"^O","^17",536870917]],["^15",[1616,"^F",1615,536870917]],["^15",[1616,"^X",1611,536870917]],["^15",[1616,"^V",1614,536870917]],["^15",[1616,"^U",1611,536870917]],["^15",[1616,"^;","~u69a845e5-b1ae-46a1-9fd7-35e05f84ab33",536870917]],["^15",[1617,"^Q","Я получил наилучшую и наиредкую реликвию, когда поехал на учёбу в Англию. Нужен был лишь грайнд, чтобы не просрать её.",536870917]],["^15",[1617,"^O","^17",536870917]],["^15",[1617,"^F",1616,536870917]],["^15",[1617,"^X",1611,536870917]],["^15",[1617,"^V",1614,536870917]],["^15",[1617,"^U",1611,536870917]],["^15",[1617,"^;","~u69a845e5-0114-48cd-8171-2d2241d06ecc",536870917]],["^15",[1618,"^3","- [[personality psychology/experience seeking]]\n\t- [[self-control/inhibition control]] [[personality psychology/anxiety]] Черта поиска новых впечатлений и в общем ощущений, как новых, так и старых, не ладит с сохранением самообладания, что, с одной стороны, помогает избежать глупостей, а с другой, мешает расслабиться.\n\t\t- #self-development Но тревога - это часть твоей личности. К тому же тебе нужно искать новые решения своих старых или новых проблем. Да, путь важнее точки назначения, но, \"что если точка назначения - это ты?\"\n\t\t- #flow В незнакомых водах трудно быть на волне, но в ударе ты можешь забраться на любую высоту, что намного веселее.\n\t\t- #self-development/techniques Выбрав вольную жизнь на Диком поле, ты рискуешь оказаться на пределе. Решения:\n\t\t\t- С учётом твоих склонностей опция поиска ощущений должна быть выключена.\n\t\t\t- #orthogonality\n\t\t\t\t- Место и время\n\t\t\t\t- Круг общения\n\t\t\t\t\t- В основном off\n\t\t\t\t- Масштаб\n\t\t\t\t\t- Здесь и сейчас\n\t\t\t\t\t\t- В основном off\n\t\t\t\t\t\t- Грайнд\n\t\t\t\t\t\t\t- off\n\t\t\t\t\t- Важные решения\n\t\t\t\t\t\t- on\n\t\t\t\t\t- Рост\n\t\t\t\t\t\t- on\n\t- [[roguelike vs metroidvania]]",536870917]],["^15",[1618,"^16",1772635621820,536870917]],["^15",[1618,"^Z","journals/2025_01_04.md",536870917]],["^15",[1619,"^K",1772635622013,536870917]],["^15",[1619,"^@",false,536870917]],["^15",[1619,"^Y","self-development/techniques",536870917]],["^15",[1619,"^A",215,536870917]],["^15",[1619,"^11","self-development/techniques",536870917]],["^15",[1619,"^B",1772635622013,536870917]],["^15",[1619,"^;","~u69a845e6-f5fe-4f5e-bd3d-78e48044c3f0",536870917]],["^15",[1620,"^K