 commitment/planfulness]]",536870917]],["^15",[1956,"^O","^17",536870917]],["^15",[1956,"^F",1946,536870917]],["^15",[1956,"^X",1946,536870917]],["^15",[1956,"^V",1946,536870917]],["^15",[1956,"^U",169,536870917]],["^15",[1956,"^U",172,536870917]],["^15",[1956,"^U",175,536870917]],["^15",[1956,"^U",1946,536870917]],["^15",[1956,"^U",1947,536870917]],["^15",[1956,"^H",169,536870917]],["^15",[1956,"^H",172,536870917]],["^15",[1956,"^H",175,536870917]],["^15",[1956,"^H",1947,536870917]],["^15",[1956,"^;","~u69a845e6-f930-405a-8924-94441fb18c7e",536870917]],["^15",[1957,"^Q","Успех слишком важен для тебя. Ты выгораешь, не успев включиться. Чтобы начать что-либо, тебе нужны:",536870917]],["^15",[1957,"^O","^17",536870917]],["^15",[1957,"^F",1956,536870917]],["^15",[1957,"^X",1946,536870917]],["^15",[1957,"^V",1956,536870917]],["^15",[1957,"^U",169,536870917]],["^15",[1957,"^U",172,536870917]],["^15",[1957,"^U",175,536870917]],["^15",[1957,"^U",1946,536870917]],["^15",[1957,"^U",1947,536870917]],["^15",[1957,"^;","~u69a845e6-6507-4cfc-885d-9c26738c0acc",536870917]],["^15",[1958,"^3","- #writing [Афантазия]([[aphantasia]]) оставила меня наедине со словом. Следуй за языком: [[NLP]], литература и т.д.\n\t- К сожалению, из-за неспособности к визуализации реализм отсеивается.\n- #[[locus of control]]\n\t- [Коленопреклонный манифест]([[serenity resolution]])\n\t\t- Я смиренно принимаю то, что не могу изменить, и неуклонно стараюсь изменить, что могу.  Чтобы видеть разницу между тем и другим, я буду непрестанно познавать себя и мир, и, чтобы той разницы стало меньше, а моих дел и слов на этом свете больше, я, пока в ясном сознании, обещаю работать над собой.",536870917]],["^15",[1958,"^16",1772635622309,536870917]],["^15",[1958,"^Z","journals/2023_08_07.md",536870917]],["^15",[1959,"^K",1772635622307,536870917]],["^15",[1959,"^[",1958,536870917]],["^15",[1959,"^N",20230807,536870917]],["^15",[1959,"^@",true,536870917]],["^15",[1959,"^Y","aug 7th, 2023",536870917]],["^15",[1959,"^11","Aug 7th, 2023",536870917]],["^15",[1959,"^B",1772635622307,536870917]],["^15",[1959,"^;","~u69a845e6-5597-4fc9-8aca-7cc7e1c232c8",536870917]],["^15",[1960,"^K",1772635622307,536870917]],["^15",[1960,"^@",false,536870917]],["^15",[1960,"^Y","nlp",536870917]],["^15",[1960,"^11","NLP",536870917]],["^15",[1960,"^B",1772635622307,536870917]],["^15",[1960,"^;","~u69a845e6-4acb-4add-bb82-cc74d48a1161",536870917]],["^15",[1961,"^K",1772635622308,536870917]],["^15",[1961,"^[",3213,536870918]],["^15",[1961,"^@",false,536870917]],["^15",[1961,"^Y","serenity resolution",536870917]],["^15",[1961,"^11","serenity resolution",536870917]],["^15",[1961,"^B",1772635622308,536870917]],["^15",[1961,"^;","~u69a845ea-dd15-4b8a-ace8-04fd70d32e39",536870918]],["^15",[1962,"^Q","#writing [Афантазия]([[aphantasia]]) оставила меня наедине со словом. Следуй за языком: [[NLP]], литература и т.д.",536870917]],["^15",[1962,"^O","^17",536870917]],["^15",[1962,"^F",1959,536870917]],["^15",[1962,"^X",1959,536870917]],["^15",[1962,"^V",1959,536870917]],["^15",[1962,"^U",197,536870917]],["^15",[1962,"^U",1313,536870917]],["^15",[1962,"^U",1959,536870917]],["^15",[1962,"^U",1960,536870917]],["^15",[1962,"^H",197,536870917]],["^15",[1962,"^H",1313,536870917]],["^15",[1962,"^H",1960,536870917]],["^15",[1962,"^;","~u69a845e6-89d2-4159-bb67-73363e351d06",536870917]],["^15",[1963,"^Q","К сожалению, из-за неспособности к визуализации реализм отсеивается.",536870917]],["^15",[1963,"^O","^17",536870917]],["^15",[1963,"^F",1962,536870917]],["^15",[1963,"^X",1959,536870917]],["^15",[1963,"^V",1962,536870917]],["^15",[1963,"^U",197,536870917]],["^15",[1963,"^U",1313,536870917]],["^15",[1963,"^U",1959,536870917]],["^15",[1963,"^U",1960,536870917]],["^15",[1963,"^;","~u69a845e6-3384-41b4-93c4-c6f9b4341d4c",536870917]],["^15",[1964,"^Q","#[[locus of control]]",536870917]],["^15",[1964,"^O","^17",536870917]],["^15",[1964,"^F",1962,536870917]],["^15",[1964,"^X",1959,536870917]],["^15",[1964,"^V",1959,536870917]],["^15",[1964,"^U",1948,536870917]],["^15",[1964,"^U",1959,536870917]],["^15",[1964,"^H",1948,536870917]],["^15",[1964,"^;","~u69a845e6-0cae-409b-9a6f-12b54106d073",536870917]],["^15",[1965,"^Q","[Коленопреклонный манифест]([[serenity resolution]])",536870917]],["^15",[1965,"^O","^17",536870917]],["^15",[1965,"^F",1964,536870917]],["^15",[1965,"^X",1959,536870917]],["^15",[1965,"^V",1964,536870917]],["^15",[1965,"^U",1948,536870917]],["^15",[1965,"^U",1959,536870917]],["^15",[1965,"^U",1961,536870917]],["^15",[1965,"^H",1961,536870917]],["^15",[1965,"^;","~u69a845e6-f219-4429-b023-28805ece5527",536870917]],["^15",[1966,"^Q","Я смиренно принимаю то, что не могу изменить, и неуклонно стараюсь изменить, что могу.  Чтобы видеть разницу между тем и другим, я буду непрестанно познавать себя и мир, и, чтобы той разницы стало меньше, а моих дел и слов на этом свете больше, я, пока в ясном сознании, обещаю работать над собой.",536870917]],["^15",[1966,"^O","^17",536870917]],["^15",[1966,"^F",1965,536870917]],["^15",[1966,"^X",1959,536870917]],["^15",[1966,"^V",1965,536870917]],["^15",[1966,"^U",1948,536870917]],["^15",[1966,"^U",1959,536870917]],["^15",[1966,"^U",1961,536870917]],["^15",[1966,"^;","~u69a845e6-ae08-4fb9-9ac6-2e01a50bfd81",536870917]],["^15",[1967,"^3","- #[[information entropy]] #[[Karenina principle]] Системы с одним выигрышным результатом и одним способом его достижения функционируют только при исполнении каждым компонентом своей задачи. Такие системы работают одинаково, а из строя выходят по-разному.\n\t- Поэтому большинство гениев прозы рисуют в тёмных тонах? Почему тогда художники могут с успехом писать и в светлых тоже? Не говоря уже о музыкантах.\n\t\t- Писатели имеют дело с семантикой, которая описывает мир и с помощью которой мы ищем смысл жизни. С другой стороны, музыка и живопись не привязаны к реальности семантически.\n\t\t- [[personality psychology/ambiguity tolerance]] Люди, которые всегда видели и видят в определенных тонах, неспособны размышлять гипотетически, что необходимо для рисования неприглядной стороны реальности. Хоть Толстой и Достоевский приходят к четко определенной правде, их дорога к ней у них была длинной и трудной.\n\t\t- Поэты излагают историю момента. Проза же имеет дело с процессом, будь то нарратив или сознание.\n\t\t- Многие примеры гениальной прозы, вызывающие положительные эмоции, - сатиры. Они не создают свою идею, а высмеивают чужую. Поэтому сатира производна.\n\t\t- Также есть те, для кого форма важнее содержания (Набоков), или писатели описывающие мир бесстрастно (Борхес).",536870917]],["^15",[1967,"^16",1772635622327,536870917]],["^15",[1967,"^Z","journals/2023_07_25.md",536870917]],["^15",[1968,"^K",1772635622325,536870917]],["^15",[1968,"^[",1967,536870917]],["^15",[1968,"^N",20230725,536870917]],["^15",[1968,"^@",true,536870917]],["^15",[1968,"^Y","jul 25th, 2023",536870917]],["^15",[1968,"^11","Jul 25th, 2023",536870917]],["^15",[1968,"^B",1772635622325,536870917]],["^15",[1968,"^;","~u69a845e6-1778-473a-ab24-00632bdd1627",536870917]],["^15",[1969,"^K",1772635622324,536870917]],["^15",[1969,"^@",false,536870917]],["^15",[1969,"^Y","karenina principle",536870917]],["^15",[1969,"^11","Karenina principle",536870917]],["^15",[1969,"^B",1772635622324,536870917]],["^15",[1969,"^;","~u69a845e6-cd92-4eb9-9c36-4aef126c9c12",536870917]],["^15",[1970,"^K",1772635622325,536870917]],["^15",[1970,"^@",false,536870917]],["^15",[1970,"^Y","information entropy",536870917]],["^15",[1970,"^11","information entropy",536870917]],["^15",[1970,"^B",1772635622325,536870917]],["^15",[1970,"^;","~u69a845e6-3ce1-4f50-8ec4-d53be7e2e829",536870917]],["^15",[1971,"^K",1772635622326,536870917]],["^15",[1971,"^@",false,536870917]],["^15",[1971,"^Y","personality psychology/ambiguity tolerance",536870917]],["^15",[1971,"^A",150,536870917]],["^15",[1971,"^11","personality psychology/ambiguity tolerance",536870917]],["^15",[1971,"^B",1772635622326,536870917]],["^15",[1971,"^;","~u69a845e6-52bf-47a6-b95a-7c21c1cb865f",536870917]],["^15",[1972,"^Q","#[[information entropy]] #[[Karenina principle]] Системы с одним выигрышным результатом и одним способом его достижения функционируют только при исполнении каждым компонентом своей задачи. Такие системы работают одинаково, а из строя выходят по-разному.",536870917]],["^15",[1972,"^O","^17",536870917]],["^15",[1972,"^F",1968,536870917]],["^15",[1972,"^X",1968,536870917]],["^15",[1972,"^V",1968,536870917]],["^15",[1972,"^U",1968,536870917]],["^15",[1972,"^U",1969,536870917]],["^15",[1972,"^U",1970,536870917]],["^15",[1972,"^H",1969,536870917]],["^15",[1972,"^H",1970,536870917]],["^15",[1972,"^;","~u69a845e6-29ee-4aca-a2bf-12bd55229303",536870917]],["^15",[1973,"^Q","Поэтому большинство гениев прозы рисуют в тёмных тонах? Почему тогда художники могут с успехом писать и в светлых тоже? Не говоря уже о музыкантах.",536870917]],["^15",[1973,"^O","^17",536870917]],["^15",[1973,"^F",1972,536870917]],["^15",[1973,"^X",1968,536870917]],["^15",[1973,"^V",1972,536870917]],["^15",[1973,"^U",1968,536870917]],["^15",[1973,"^U",1969,536870917]],["^15",[1973,"^U",1970,536870917]],["^15",[1973,"^;","~u69a845e6-3f25-46b3-b665-abeef532da6a",536870917]],["^15",[1974,"^Q","Писатели имеют дело с семантикой, которая описывает мир и с помощью которой мы ищем смысл жизни. С другой стороны, музыка и живопись не привязаны к реальности семантически.",536870917]],["^15",[1974,"^O","^17",536870917]],["^15",[1974,"^F",1973,536870917]],["^15",[1974,"^X",1968,536870917]],["^15",[1974,"^V",1973,536870917]],["^15",[1974,"^U",1968,536870917]],["^15",[1974,"^U",1969,536870917]],["^15",[1974,"^U",1970,536870917]],["^15",[1974,"^;","~u69a845e6-e27b-41df-ab72-7765a6daad26",536870917]],["^15",[1975,"^Q","[[personality psychology/ambiguity tolerance]] Люди, которые всегда видели и видят в определенных тонах, неспособны размышлять гипотетически, что необходимо для рисования неприглядной стороны реальности. Хоть Толстой и Достоевский приходят к четко определенной правде, их дорога к ней у них была длинной и трудной.",536870917]],["^15",[1975,"^O","^17",536870917]],["^15",[1975,"^F",1974,536870917]],["^15",[1975,"^X",1968,536870917]],["^15",[1975,"^V",1973,536870917]],["^15",[1975,"^U",150,536870917]],["^15",[1975,"^U",1968,536870917]],["^15",[1975,"^U",1969,536870917]],["^15",[1975,"^U",1970,536870917]],["^15",[1975,"^U",1971,536870917]],["^15",[1975,"^H",150,536870917]],["^15",[1975,"^H",1971,536870917]],["^15",[1975,"^;","~u69a845e6-c495-430a-a2cf-c27a1f29c865",536870917]],["^15",[1976,"^Q","Поэты излагают историю момента. Проза же имеет дело с процессом, будь то нарратив или сознание.",536870917]],["^15",[1976,"^O","^17",536870917]],["^15",[1976,"^F",1975,536870917]],["^15",[1976,"^X",1968,536870917]],["^15",[1976,"^V",1973,536870917]],["^15",[1976,"^U",1968,536870917]],["^15",[1976,"^U",1969,536870917]],["^15",[1976,"^U",1970,536870917]],["^15",[1976,"^;","~u69a845e6-1f07-46cf-b4ec-468dc2765468",536870917]],["^15",[1977,"^Q","Многие примеры гениальной прозы, вызывающие положительные эмоции, - сатиры. Они не создают свою идею, а высмеивают чужую. Поэтому сатира производна.",536870917]],["^15",[1977,"^O","^17",536870917]],["^15",[1977,"^F",1976,536870917]],["^15",[1977,"^X",1968,536870917]],["^15",[1977,"^V",1973,536870917]],["^15",[1977,"^U",1968,536870917]],["^15",[1977,"^U",1969,536870917]],["^15",[1977,"^U",1970,536870917]],["^15",[1977,"^;","~u69a845e6-a9b7-466c-b023-c2d49a899c12",536870917]],["^15",[1978,"^Q","Также есть те, для кого форма важнее содержания (Набоков), или писатели описывающие мир бесстрастно (Борхес).",536870917]],["^15",[1978,"^O","^17",536870917]],["^15",[1978,"^F",1977,536870917]],["^15",[1978,"^X",1968,536870917]],["^15",[1978,"^V",1973,536870917]],["^15",[1978,"^U",1968,536870917]],["^15",[1978,"^U",1969,536870917]],["^15",[1978,"^U",1970,536870917]],["^15",[1978,"^;","~u69a845e6-cd4c-4e2e-b457-f4f6f6e3d99b",536870917]],["^15",[1979,"^3","- #entropy #holism|atomism Энтропия - это потенциальная возможность для эмергентности.\n  query-sort-by:: .flags\n  query-table:: true\n  query-sort-desc:: true",536870917]],["^15",[1979,"^16",1772635622338,536870917]],["^15",[1979,"^Z","journals/2023_07_24.md",536870917]],["^15",[1980,"^K",1772635622337,536870917]],["^15",[1980,"^[",1979,536870917]],["^15",[1980,"^N",20230724,536870917]],["^15",[1980,"^@",true,536870917]],["^15",[1980,"^Y","jul 24th, 2023",536870917]],["^15",[1980,"^11","Jul 24th, 2023",536870917]],["^15",[1980,"^B",1772635622337,536870917]],["^15",[1980,"^;","~u69a845e6-44d3-4c4c-a99b-27f46fa8b41b",536870917]],["^15",[1981,"^K",1772635622337,536870917]],["^15",[1981,"^@",false,536870917]],["^15",[1981,"^Y","entropy",536870917]],["^15",[1981,"^11","entropy",536870917]],["^15",[1981,"^B",1772635622337,536870917]],["^15",[1981,"^;","~u69a845e6-a1ca-4b03-9ac1-cb8864efd0a0",536870917]],["^15",[1982,"^Q","#entropy #holism|atomism Энтропия - это потенциальная возможность для эмергентности.\nquery-sort-by:: .flags\nquery-table:: true\nquery-sort-desc:: true",536870917]],["^15",[1982,"^O","^17",536870917]],["^15",[1982,"^F",1980,536870917]],["^15",[1982,"^X",1980,536870917]],["^15",[1982,"^V",1980,536870917]],["^15",[1982,"^U",1106,536870917]],["^15",[1982,"^U",1980,536870917]],["^15",[1982,"^U",1981,536870917]],["^15",[1982,"^?",["^ ","~:query-sort-by",".flags","^1I",true,"~:query-sort-desc",true],536870917]],["^15",[1982,"^J",["^1M","^1I","^1N"],536870917]],["^15",[1982,"^4",["^ ","^1M",".flags","^1I","true","^1N","true"],536870917]],["^15",[1982,"^H",1106,536870917]],["^15",[1982,"^H",1981,536870917]],["^15",[1982,"^;","~u69a845e6-e15d-4aa3-a077-6f9410c7e4f8",536870917]],["^15",[1983,"^3","- #PIM\n\t- ### Data and PIM\n\t\t- Множества\n\t\t\t- Logseq\n\t\t\t\t- блоки, а страницы - это просто именованные блоки\n\t\t\t- Obsidian\n\t\t\t\t- страницы\n\t\t- Деревья\n\t\t\t- Logseq\n\t\t\t\t- блоки с ответвлениями в виде листьев или таких же деревьев\n\t\t\t- Obsidian\n\t\t\t\t- папки\n\t\t- Модели базы данных\n\t\t\t- Реляционная (таблицы, в частности каталоги)\n\t\t\t\t- Airtable\n\t\t\t- Документоориентированная (всё, что с метаданными и тегами)\n\t\t\t\t- тэги необходимы для запросов и поиска\n\t\t\t\t\t- использование их в качестве ссылок, как делает это Obsidan, создает сеть информации, по факту, только внутри приложения, а не твоего мозга\n\t\t\t\t- метаданные хоть и полезны, но TfT сообщество переоценивает их значимость\n\t\t\t- Орграфы\n\t\t\t\t- всего лишь фантик\n\t\t- Заключение\n\t\t\t- В Logseq...\n\t\t\t\t- Иерархия строится с помощью деревьев из блоков и деревьев из тэгов.\n\t\t\t\t\t- Сеть можно связать из тэгов и ссылок на блоки. Она полезна непосредственно при чтении, то есть когда мы передвигаемся от узла к узлу. Визуально графы смотрятся красиво, но эмергентности в них нет, и любая серендипность, считаю, искусственна, как, собственно, и сам этот термин.\n\t\t\t\t- Журнал и GTD интегрированы в Logseq, а конспектирование в Logseq лучше из-за блоков и ссылок на них.\n\t\t\t\t- Обдуманные тэги и метаданные облегчают запросы.\n\t\t\t- В Obsidian всё зиждется не на блоках, а на страницах, и работа начинается сверху, а именно с наименования страницы. В Logseq же и страница - блок.\n\t\t\t- {{embed ((64b9bd7a-b308-4305-b197-a107adc889df))}}",536870917]],["^15",[1983,"^16",1772635622360,536870917]],["^15",[1983,"^Z","journals/2023_07_23.md",536870917]],["^15",[1984,"^K",1772635622359,536870917]],["^15",[1984,"^[",1983,536870917]],["^15",[1984,"^N",20230723,536870917]],["^15",[1984,"^@",true,536870917]],["^15",[1984,"^Y","jul 23rd, 2023",536870917]],["^15",[1984,"^11","Jul 23rd, 2023",536870917]],["^15",[1984,"^B",1772635622359,536870917]],["^15",[1984,"^;","~u69a845e6-a504-4d14-80ce-1473f13c5c3d",536870917]],["^15",[1985,"^K",1772635622417,536870917]],["^15",[1985,"^@",false,536870917]],["^15",[1985,"^Y","pim",536870917]],["^15",[1985,"^11","PIM",536870917]],["^15",[1985,"^B",1772635622417,536870917]],["^15",[1985,"^;","~u69a845e6-bab4-4ede-8e0e-78cbcb9ba739",536870917]],["^15",[1986,"^K",1772635622360,536870917]],["^15",[1986,"^@",false,536870917]],["^15",[1986,"^Y","64b9bd7a-b308-4305-b197-a107adc889df",536870917]],["^15",[1986,"^11","64b9bd7a-b308-4305-b197-a107adc889df",536870917]],["^15",[1986,"^B",1772635622360,536870917]],["^15",[1986,"^;","~u69a845e6-5c17-4f18-a7f2-ad05ef1b982b",536870917]],["^15",[1987,"^Q","Журнал и GTD интегрированы в Logseq, а конспектирование в Logseq лучше из-за блоков и ссылок на них.",536870917]],["^15",[1987,"^O","^17",536870917]],["^15",[1987,"^F",1995,536870917]],["^15",[1987,"^X",1984,536870917]],["^15",[1987,"^V",2007,536870917]],["^15",[1987,"^U",1984,536870917]],["^15",[1987,"^U",1985,536870917]],["^15",[1987,"^;","~u69a845e6-93cc-491f-9375-5250e1a0dd50",536870917]],["^15",[1988,"^Q","Обдуманные тэги и метаданные облегчают запросы.",536870917]],["^15",[1988,"^O","^17",536870917]],["^15",[1988,"^F",1987,536870917]],["^15",[1988,"^X",1984,536870917]],["^15",[1988,"^V",2007,536870917]],["^15",[1988,"^U",1984,536870917]],["^15",[1988,"^U",1985,536870917]],["^15",[1988,"^;","~u69a845e6-7116-4acb-b439-5d795bec1378",536870917]],["^15",[1989,"^Q","блоки с ответвлениями в виде листьев или таких же деревьев",536870917]],["^15",[1989,"^O","^17",536870917]],["^15",[1989,"^F",2000,536870917]],["^15",[1989,"^X",1984,536870917]],["^15",[1989,"^V",2000,536870917]],["^15",[1989,"^U",1984,536870917]],["^15",[1989,"^U",1985,536870917]],["^15",[1989,"^;","~u69a845e6-ed09-40c1-adf6-d1e9515f1699",536870917]],["^15",[1990,"^Q","В Obsidian всё зиждется не на блоках, а на страницах, и работа начинается сверху, а именно с наименования страницы. В Logseq же и страница - блок.",536870917]],["^15",[1990,"^O","^17",536870917]],["^15",[1990,"^F",2007,536870917]],["^15",[1990,"^X",1984,536870917]],["^15",[1990,"^V",1991,536870917]],["^15",[1990,"^U",1984,536870917]],["^15",[1990,"^U",1985,536870917]],["^15",[1990,"^;","~u69a845e6-05b9-46a1-ad08-0add1ac3e208",536870917]],["^15",[1991,"^Q","Заключение",536870917]],["^15",[199