93,"^F",1368,536870915]],["^15",[1393,"^X",1354,536870915]],["^15",[1393,"^V",1368,536870915]],["^15",[1393,"^U",1299,536870915]],["^15",[1393,"^U",1354,536870915]],["^15",[1393,"^;","~u69a845e4-550a-4f98-9267-72cfc407fa7f",536870915]],["^15",[1394,"^3","/* logseq table resizer v20220331 ======================= */\n/* add rules to custom.css =============================== */\n        .table th {\n            position: relative;\n        }\n        .query-table-resizer {\n            position: relative;\n            top: -20px;\n            float: right;\n            margin-bottom: -18px;\n            cursor: col-resize;\n            user-select: none;\n            border-right: 1px solid var(--ls-border-color);\n            width: 10px; /* hitbox width */\n            height: 20px; \n        }\n\n        .query-table-resizer:active,\n        .query-table-resizing {\n            border-right: 2px solid rgb(255, 0, 0);\n        }\n\n        .custom-query table.table-auto {\n            width: -webkit-fill-available;\n            table-layout: fixed;\n        }\n        .custom-query .table-auto>thead>tr>th {\n            border-bottom: 1px solid var(--ls-border-color);\n        }\n        .custom-query .table-auto>thead>tr>th {\n            background-color: rgba(0, 0, 0, 0.1);\n            padding: 3px 6px;\n        }\n        .custom-query .table-auto>tbody>tr>td.whitespace-nowrap {\n            overflow-wrap: break-word;\n            min-width: 20px;\n            white-space: normal;\n            font-weight: 300;\n            font-size: 13px;\n        }\n        .custom-query .table-auto>tbody>tr>.whitespace-nowrap img {\n            max-height: 120px;\n            margin: 0;\n        }\n/* ==================================== end of table resizer */\n\n/* ==========  BETTER-SIDEBAR - right sidebarshrinking panes w/ horizontal scroll v20221217==================*/\n\n        :root {\n            --sidebarItemMinWidth: 250px;\n            --sidebarItemMaxWidth: 950