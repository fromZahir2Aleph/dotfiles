",[724,"^X",695,536870919]],["^15",[724,"^V",715,536870919]],["^15",[724,"^U",153,536870919]],["^15",[724,"^U",156,536870919]],["^15",[724,"^U",663,536870919]],["^15",[724,"^U",664,536870919]],["^15",[724,"^U",694,536870919]],["^15",[724,"^U",695,536870919]],["^15",[724,"^;","~u686ffd65-7cdd-4960-a25e-b3c8d09edcd0",536870919]],["^15",[725,"^Q","Вне беседы (не обязательно наедине)",536870919]],["^15",[725,"^O","^1;",536870919]],["^15",[725,"^F",717,536870919]],["^15",[725,"^X",695,536870919]],["^15",[725,"^V",703,536870919]],["^15",[725,"^U",153,536870919]],["^15",[725,"^U",156,536870919]],["^15",[725,"^U",663,536870919]],["^15",[725,"^U",664,536870919]],["^15",[725,"^U",694,536870919]],["^15",[725,"^U",695,536870919]],["^15",[725,"^;","~u686ffd65-2377-4b86-b3dc-bbc2eb4fdc3e",536870919]],["^15",[726,"^3","- #[[collector's fallacy]] #[[procrastination/sophisticated procrastination]]\n\t- Я собрал...\n\t\t- почти 220 000 слов в заметках.\n\t\t\t- Для сравнения в Улиссе 268 170 слов, в Каренине - 353 250.\n\t\t- более 26 000 книг и комиксов на Чердаке.\n\t\t\t- Прочитал около двухсот.\n\t\t- почти 25 000 файлов в Ранце.\n\t\t\t- Ничего не прочитано.\n\t\t- 450 фильмов в Movies.\n\t\t\t- 200 из них в To watch.\n\t\t- более 50 покупок в Стиме.\n\t\t\t- Играл по сути в девять игр.\n\t\t- в каталогах\n\t\t\t- около 770 фильмов. С учётом того, что эти, подлежащие к просмотру, у меня отдельно от моей коллекции и вовсе незалогенных, то это единственный пункт, где я получил хоть какую-то пользу.\n\t\t\t- около 450 видеоигр.\n\t\t\t\t- Поиграл примерно в пятнадцать.\n\t\t\t- 370 настольных.\n\t\t\t\t- Поиграл более двух раз в четыре.\n\t\t\t- кучу сериалов, музыки, лекций и прочего.\n\t- Я их постоянно организовывал, переименовывал и классифицировал.",536870919]],["^15",[726,"^16",1752169829244,536870919]],["^15",[726,"^Z","journals/2023_10_17.md",536870919]],["^15",[727,"^K",1752169829243,536870919]],["^15",[727,"^[",726,536870919]],["^15",[727,"^N",20231017,536870919]],["^15",