,[1161,"^X",1159,536870915]],["^15",[1161,"^V",1159,536870915]],["^15",[1161,"^U",149,536873151]],["^15",[1161,"^U",150,536873151]],["^15",[1161,"^U",1156,536873151]],["^15",[1161,"^U",1159,536873151]],["^15",[1161,"^?",["^ "],536873150]],["^15",[1161,"^H",149,536873150]],["^15",[1161,"^H",150,536873150]],["^15",[1161,"^H",1156,536873150]],["^15",[1161,"^;","~u69a845e4-0b49-4075-8c30-720b42896f4f",536870915]],["^15",[1162,"^Q","Примеры",536870915]],["^15",[1162,"^O","^17",536870915]],["^15",[1162,"^F",1161,536870915]],["^15",[1162,"^X",1159,536870915]],["^15",[1162,"^V",1161,536870915]],["^15",[1162,"^U",149,536873151]],["^15",[1162,"^U",150,536873151]],["^15",[1162,"^U",1156,536873151]],["^15",[1162,"^U",1159,536873151]],["^15",[1162,"^;","~u69a845e4-a991-493b-b64c-27f204aef52a",536870915]],["^15",[1163,"^Q","Я стал статусом выше, когда занял места в олимпиадах в одиннадцатом (?) классе.",536870915]],["^15",[1163,"^O","^17",536870915]],["^15",[1163,"^F",1162,536870915]],["^15",[1163,"^X",1159,536870915]],["^15",[1163,"^V",1162,536870915]],["^15",[1163,"^U",149,536873151]],["^15",[1163,"^U",150,536873151]],["^15",[1163,"^U",1156,536873151]],["^15",[1163,"^U",1159,536873151]],["^15",[1163,"^;","~u69a845e4-09f1-460b-902d-34c2a04e6d65",536870915]],["^15",[1164,"^3","- #Gloomhaven\n\t- Синергии\n\t\t- https://boardgamegeek.com/thread/2456458/poll-best-2-player-character-combo\n\t\t- Looks like Demo has synergies only with Hatchet\n\t\t- Voidwarden is support only with some synergy with Guard.\n\t\t- Попробуй Hatchet, Demo и Voidwarden на высокой сложности. Потом RG, V, D на самой высокой сложности. Чередуй с RG, H, D и RG, H, V и, возможно, опять H, D, V.\n\t- Игровая механика\n\t\t- Abilities on a monster card, like SHIELD or RETALIATE, only take effect on the monster's turn, so any attacks made BEFORE the monster's turn aren't affected by them.\n\t\t- (Double Throw \\* (Power Pitch + The Favorite token + Poison)) \\* critical Attack Modifier. DT doubles the next attack, which is PP + TF + Poi. All of that is doubled by the Attack Modifier. If the boss happens to have any armor, you'd subtract that at the end.\n\t\t- Рана применяется в начале хода, а лечение в течение.",536870915]],["^15",[1164,"^16",1772635620125,536870915]],["^15",[1164,"^Z","journals/2025_06_21.md",536870915]],["^15",[1165,"^K",1772635620124,536870915]],["^15",[1165,"^[",1164,536870915]],["^15",[1165,"^N",20250621,536870915]],["^15",[1165,"^@",true,536870915]],["^15",[1165,"^Y","jun 21st, 2025",536870915]],["^15",[1165,"^11","Jun 21st, 2025",536870915]],["^15",[1165,"^B",1772635620124,536870915]],["^15",[1165,"^;","~u69a845e4-0c15-4ba0-a98d-41f5ef39efee",536870915]],["^15",[1166,"^K",1772635620124,536870915]],["^15",[1166,"^@",false,536870915]],["^15",[1166,"^Y","gloomhaven",536870915]],["^15",[1166,"^11","Gloomhaven",536870915]],["^15",[1166,"^B",1772635620124,536870915]],["^15",[1166,"^;","~u69a845e4-e067-4701-8641-5fc9b3abade8",536870915]],["^15",[1167,"^Q","Voidwarden is support only with some synergy with Guard.",536870915]],["^15",[1167,"^O","^17",536870915]],["^15",[1167,"^F",1176,536870915]],["^15",[1167,"^X",1165,536870915]],["^15",[1167,"^V",1171,536870915]],["^15",[1167,"^U",1165,536870915]],["^15",[1167,"^U",1166,536870915]],["^15",[1167,"^;","~u69a845e4-2655-4778-91de-b32b3e3024fb",536870915]],["^15",[1168,"^Q","Abilities on a monster card, like SHIELD or RETALIATE, only take effect on the monster's turn, so any attacks made BEFORE the monster's turn aren't affected by them.",536870915]],["^15",[1168,"^O","^17",536870915]],["^15",[1168,"^F",1169,536870915]],["^15",[1168,"^X",1165,536870915]],["^15",[1168,"^V",1169,536870915]],["^15",[1168,"^U",1165,536870915]],["^15",[1168,"^U",1166,536870915]],["^15",[1168,"^;","~u69a845e4-7029-4fb8-8fd3-af6aa17da401",536870915]],["^15",[1169,"^Q","Игровая механика",536870915]],["^15",[1169,"^O","^17",536870915]],["^15",[1169,"^F",1171,536870915]],["^15",[1169,"^X",1165,536870915]],["^15",[1169,"^V",1174,53687091