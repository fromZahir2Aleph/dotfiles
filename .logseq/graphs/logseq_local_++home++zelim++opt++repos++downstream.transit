,"NOW",536870914]],["^15",[5,"^;","~u2e09a03d-63c0-4df7-955c-fc574027b22f",536885369]],["^15",[6,"^@",false,536870914]],["^15",[6,"^Y","later",536870914]],["^15",[6,"^11","LATER",536870914]],["^15",[6,"^;","~u8184cd6f-838e-4192-ba5b-b12c133ae3f7",536885369]],["^15",[7,"^@",false,536870914]],["^15",[7,"^Y","done",536870914]],["^15",[7,"^11","DONE",536870914]],["^15",[7,"^;","~u19fd0218-8dc7-420d-a7b4-a79f10cb809b",536885369]],["^15",[8,"^@",false,536870914]],["^15",[8,"^Y","doing",536870914]],["^15",[8,"^11","DOING",536870914]],["^15",[8,"^;","~u38cf766f-5c8a-4a1d-995f-65c1dc15eba9",536885369]],["^15",[9,"^@",false,536870914]],["^15",[9,"^Y","in-progress",536870914]],["^15",[9,"^11","IN-PROGRESS",536870914]],["^15",[9,"^;","~ue484e876-5252-40f7-b8e9-3be0ba954bdf",536885369]],["^15",[10,"^@",false,536870914]],["^15",[10,"^Y","c",536870914]],["^15",[10,"^11","C",536870914]],["^15",[10,"^;","~u38c16969-f4d2-4302-a3d3-160402804d67",536885369]],["^15",[11,"^@",false,536870914]],["^15",[11,"^Y","b",536870914]],["^15",[11,"^11","B",536870914]],["^15",[11,"^;","~uaf586a5a-bdbf-4425-a6e1-dbeeded442f2",536885369]],["^15",[12,"^[",958,536870919]],["^15",[12,"^@",false,536870914]],["^15",[12,"^Y","contents",536870914]],["^15",[12,"^11","Contents",536870914]],["^15",[12,"^;","~u982c5b75-72d5-4281-9ec7-98023ab95c40",536885369]],["^15",[13,"^@",false,536870914]],["^15",[13,"^Y","waiting",536870914]],["^15",[13,"^11","WAITING",536870914]],["^15",[13,"^;","~u04568cb8-6b70-4b6a-8a87-6c9be897a4f8",536885369]],["^15",[14,"^@",false,536870914]],["^15",[14,"^Y","favorites",536870914]],["^15",[14,"^11","Favorites",536870914]],["^15",[14,"^;","~u13d86416-ae8c-4964-b701-38a28ecde4b6",536885369]],["^15",[15,"^@",false,536870914]],["^15",[15,"^Y","a",536870914]],["^15",[15,"^11","A",536870914]],["^15",[15,"^;","~u38bcef97-211a-431d-8056-1e87e0e560de",536885369]],["^15",[16,"^@",false,536870914]],["^15",[16,"^Y","cancelled",536870914]],["^15",[16,"^11","CANCELLED",536870914]],["^15",[16,"^;","~u954238b3-db91-435d-b886-40e58b959f49",536885369]],["^15",[17,"^@",false,536870914]],["^15",[17,"^Y","wait",536870914]],["^15",[17,"^11","WAIT",536870914]],["^15",[17,"^;","~uf98d84a2-813d-490c-80a9-8d894229d8db",536885369]],["^15",[20,"^3","/* logseq table resizer v20220331 ======================= */\n/* add rules to custom.css =============================== */\n        .table th {\n            position: relative;\n        }\n        .query-table-resizer {\n            position: relative;\n            top: -20px;\n            float: right;\n            margin-bottom: -18px;\n            cursor: col-resize;\n            user-select: none;\n            border-right: 1px solid var(--ls-border-color);\n            width: 10px; /* hitbox width */\n            height: 20px; \n        }\n\n        .query-table-resizer:active,\n        .query-table-resizing {\n            border-right: 2px solid rgb(255, 0, 0);\n        }\n\n        .custom-query table.table-auto {\n            width: -webkit-fill-available;\n            table-layout: fixed;\n        }\n        .custom-query .table-auto>thead>tr>th {\n            border-bottom: 1px solid var(--ls-border-color);\n        }\n        .custom-query .table-auto>thead>tr>th {\n            background-color: rgba(0, 0, 0, 0.1);\n            padding: 3px 6px;\n        }\n        .custom-query .table-auto>tbody>tr>td.whitespace-nowrap {\n            overflow-wrap: break-word;\n            min-width: 20px;\n            white-space: normal;\n            font-weight: 300;\n            font-size: 13px;\n        }\n        .custom-query .table-auto>tbody>tr>.whitespace-nowrap img {\n            max-height: 120px;\n            margin: 0;\n        }\n/* ==================================== end of table resizer */\n\n/* ==========  BETTER-SIDEBAR - right sidebarshrinking panes w/ horizontal scroll v20221217==================*/\n\n        :root {\n            --sidebarItemMinWidth: 250px;\n            --sidebarItemMaxWidth: 950px;\n        }\n\n        .cp__right-sidebar-inner.flex.flex-col.h-full {\n            overflow: visible;\n        }\n\n        .sidebar-item-list {\n            width: fit-content;\n            height: 96vh !important;\n            overflow: unset;\n            display: flex;\n            flex-direction: column;\n            flex-wrap: wrap;\n            align-content: flex-start;\n            padding: 0 0 0 6px;\n        }\n\n        .cp__right-sidebar .sidebar-item {\n            display: inline-block;\n            align-self: flex-start;\n            overflow-y: auto;\n            min-height: 75px;\n            height: calc(100% - 10px) !important;\n            min-width: var(--sidebarItemMinWidth);\n            max-width: var(--sidebarItemMaxWidth);\n            width: 100%;\n            margin: 0px;\n            background-color: var(--ls-primary-background-color);\n            box-shadow: 1px 1px 5px rgba(0, 0, 0, 0.4);\n            border: 1px solid black;\n            border-radius: 10px;\n            resize: both;\n            padding: 1.5rem 0.5rem;\n        }\n\n        .cp__right-sidebar-inner .resizer {\n            position: absolute;\n            top: 0;\n            bottom: 0;\n            left: 0;\n            width: 6px;\n            user-select: none;\n            cursor: col-resize !important;\n            z-index: 10;\n        }\n\n        .cp__right-sidebar .resizer:hover {\n            background-color: var(--ph-highlight-strong);\n        }\n\n        .cp__right-sidebar-scrollable {\n            overflow-y: hidden;\n            overflow-x: auto;\n            height: 100%;\n        }\n\n        /* sliding panes */\n        .sidebar-item.folded {\n            display: inline-block;\n            overflow: hidden;\n            margin: 0px 0 !important;\n            padding: 5px;\n            resize: none;\n            width: 40px !important;\n            min-width: 40px;\n            writing-mode: vertical-LR;\n        }\n\n        .sidebar-item.folded .rotating-arrow.collapsed svg {\n            transform: rotate(180deg) translate(3px, -1.2rem);\n            transition: none;\n        }\n\n        .sidebar-item.folded .ml-1.font-medium {\n            margin-top: 2rem;\n            transition: none;\n        }\n\n        .cp__right-sidebar .sidebar-item.folded .close {\n            transform: scale(.8) translate(-8px);\n            transition: transform .1s;\n        }\n\n/* ======================================== end of BETTER-SIDEBAR =====*/\n/* ==== hide special props ==========================*/\n        div[data-refs-self=\"bg-pic\"] {\n            display: none !important;\n        }\n",536870918]],["^15",[20,"~:file/created-at",1752169829532,536870919]],["^15",[20,"^Z","logseq/custom.css",536870918]],["^15",[21,"^3","tags:: Grozny Quiz\nplayed:: yes\n\n- Вопрос: Конкистадорам, владеющим этим, приходилось гораздо легче. Также тем, кто был под начальством Франсиско Писарро, это удвоило долю золота.\n  Ответ: лошади. Прим.: только зажиточные испанцы того времени могли купить и содержать лошадь.\n- Вопрос: Что на самом деле изображено в этой шуточной картинке?\n  Ответ: Китай, “Римская империя нашего времени”.\n- Вопрос: Согласно одной шутке они в чеченском языке в отличие от большинства языков, напр. английского и русского, носят сандали или ходят босиком.\n  Ответ: цифры.\n  Прим.: в большинстве языков система исчисления, потому что считают по пальцам. В чеченском, француском и других языках двадцатеричная предположительно потому, что к ним добавляются пальцы ног.\n- Вопрос: Вот названия этого фильма на арабском, корейском: تانت, 테넷, टेनेट.\n  Ответ: Довод. Название фильма Tenet и его переводы на все языки мира - палиндромы.\n- Вопрос: На английском их называют рыцарь и епископ, а на немецком - прыгун и бегун. Какими животными их соответственно называют на русском?\n  Ответ: конь и слон.\n  Прим.: шахматные фигуры.",536884012]],["^15",[21,"^16",1752169828357,536870919]],["^15",[21,"~:file/last-modified-at","~m1757368818521",536884011]],["^15",[21,"^Z","journals/2025_07_08.md",536870919]],["^15",[22,"^K",1752169828355,536870919]],["^15",[22,"^[",21,536870919]],["^15",[22,"^N",20250708,536870919]],["^15",[22,"^@",true,536870919]],["^15",[22,"^Y","jul 8th, 2025",536870919]],["^15",[22,"^11","Jul 8th, 2025",536870919]],["^15",[22,"^?",["^ ","~:tags",["~#set",["Grozny Quiz"]],"~:played","yes"],536884010]],["^15",[22,"^4",["^ ","^18","Grozny Quiz","^1:","yes"],536884010]],["^15",[22,"^P",23,536884010]],["^15",[22,"^B",1757368817395,536884010]],["^15",[22,"^;","~u686ffd64-e307-4a55-8f85-b5bb37c77ff0",536870919]],["^15",[23,"^K",1752169828815,536870919]],["^15",[23,"^O","~:markdown",536880070]],["^15",[23,"^@",false,536870919]],["^15",[23,"^Y","grozny quiz",536870919]],["^15",[23,"^11","Grozny Quiz",536870919]],["^15",[23,"^B",1752169828815,536870919]],["^15",[23,"^;","~u686ffd64-bfaf-46f4-93f9-ad64385b0654",536870919]],["^15",[24,"^K",1752169828815,536870919]],["^15",[24,"^@",false,536870919]],["^15",[24,"^Y","played",536870919]],["^15",[24,"^11","played",536870919]],["^15",[24,"^B",1752169828815,536870919]],["^15",[24,"^;","~u686ffd64-651e-4b32-bbd4-b0eadc9dd8c5",536870919]],["^15",[25,"^Q","tags:: Grozny Quiz\nplayed:: yes",536884010]],["^15",[25,"^O","^1;",536870919]],["^15",[25,"~:block/invalid-properties",["^19",[]],536884010]],["^15",[25,"^F",22,536870919]],["^15",[25,"^X",22,536870919]],["^15",[25,"^V",22,536870919]],["^15",[25,"^U",22,536870919]],["^15",[25,"^U",23,536870919]],["^15",[25,"^U",24,536870919]],["^15",[25,"^:",true,536884010]],["^15",[25,"^?",["^ ","^18",["^19",["Grozny Quiz"]],"^1:","yes"],536884010]],["^15",[25,"^J",["^14",["^18","^1:"]],536884010]],["^15",[25,"^4",["^ ","^18","Grozny Quiz","^1:","yes"],536884010]],["^15",[25,"^H",23,536884010]],["^15",[25,"^H",24,536884010]],["^15",[25,"^;","~u686ffd64-18df-4e2e-8516-f319bc273d5a",536870919]],["^15",[26,"^Q","Вопрос: Конкистадорам, владеющим этим, приходилось гораздо легче. Также тем, кто был под начальством Франсиско Писарро, это удвоило долю золота.\nОтвет: лошади. Прим.: только зажиточные испанцы того времени могли купить и содержать лошадь.",536878157]],["^15",[26,"^O","^1;",536870919]],["^15",[26,"^F",25,536870919]],["^15",[26,"^X",22,536870919]],["^15",[26,"^V",22,536870919]],["^15",[26,"^U",22,536870919]],["^15",[26,"^?",["^ "],536878157]],["^15",[26,"^;","~u686ffd64-409e-4a8d-81a2-e6f1ec195975",536870919]],["^15",[27,"^Q","Вопрос: Что на самом деле изображено в этой шуточной картинке?\nОтвет: Китай, “Римская империя нашего времени”.",536878160]],["^15",[27,"^O","^1;",536870919]],["^15",[27,"^F",26,536870919]],["^15",[27,"^X",22,536870919]],["^15",[27,"^V",22,536870919]],["^15",[27,"^U",22,536870919]],["^15",[27,"^?",["^ "],536878160]],["^15",[27,"^;","~u686ffd64-ec91-4c0f-ba3f-8c0a572eb387",536870919]],["^15",[28,"^Q","Вопрос: Согласно одной шутке они в чеченском языке в отличие от большинства языков, напр. английского и русского, носят сандали или ходят босиком.\nОтвет: цифры.\nПрим.: в большинстве языков система исчисления, потому что считают по пальцам. В чеченском, француском и других языках двадцатеричная предположительно потому, что к ним добавляются пальцы ног.",536878429]],["^15",[28,"^O","^1;",536870919]],["^15",[28,"^F",27,536870919]],["^15",[28,"^X",22,536870919]],["^15",[28,"^V",22,536870919]],["^15",[28,"^U",22,536870919]],["^15",[28,"^?",["^ "],536878429]],["^15",[28,"^;","~u686ffd64-6e1f-486e-bf85-13a59d4fe524",536870919]],["^15",[29,"^Q","Вопрос: Вот названия этого фильма на арабском, корейском: تانت, 테넷, टेनेट.\nОтвет: Довод. Название фильма Tenet и его переводы на все языки мира - палиндромы.",536878249]],["^15",[29,"^O","^1;",536870919]],["^15",[29,"^F",28,536878176]],["^15",[29,"^X",22,536870919]],["^15",[29,"^V",22,536870919]],["^15",[29,"^U",22,536870919]],["^15",[29,"^?",["^ "],536878249]],["^15",[29,"^;","~u686ffd64-a7ab-4a67-995a-36e4b4de0b29",536870919]],["^15",[30,"^3","- [[personality psychology/experience seeking/breadth and depth]] [[interests/board games]] Так как ты уже не можешь соревноваться в интеллектуальных настолках, лучше расширяй, а не углубляй знакомство с этим хобби. В частности, абстрактные игры имеют больше нюансов, но они не тебе не под силу. С другой стороны каждая новая игра будет стоит гораздо больше времени, чем раньше, даже поверхностное знакомство с ними. Выбирай игры, которые социальны, но не имеют сильный аспект конкуренции.",536881916]],["^15",[30,"^16",1752169828373,536870919]],["^15",[30,"^17","~m1756384829647",536881915]],["^15",[30,"^Z","journals/2025_07_07.md",536870919]],["^15",[31,"^K",1752169828372,536870919]],["^15",[31,"^[",30,536870919]],["^15",[31,"^N",20250707,536870919]],["^15",[31,"^@",true,536870919]],["^15",[31,"^Y","jul 7th, 2025",536870919]],["^15",[31,"^11","Jul 7th, 2025",536870919]],["^15",[31,"^B",1756384829106,536881913]],["^15",[31,"^;","~u686ffd64-b9ea-405f-83ba-f906ab8e4ed7",536870919]],["^15",[33,"^K",1752169828926,536870919]],["^15",[33,"^@",false,536870919]],["^15",[33,"^Y","personality psychology/experience seeking/novelty seeking",536870919]],["^15",[33,"^A",35,536870919]],["^15",[33,"^11","personality psychology/experience seeking/novelty seeking",536870919]],["^15",[33,"^B",1752169828926,536870919]],["^15",[33,"^;","~u686ffd64-cab7-4e88-9512-06664901ca91",536870919]],["^15",[34,"^K",1752169829308,536870919]],["^15",[34,"^O","^1;",536870920]],["^15",[34,"^@",false,536870919]],["^15",[34,"^Y","personality psychology",536870919]],["^15",[34,"^11","personality psychology",536870919]],["^15",[34,"^B",1752169829308,536870919]],["^15",[34,"^;","~u686ffd68-c2a3-4e3a-af4d-e46b390ceb02",536870920]],["^15",[35,"^K",1752169829127,536870919]],["^15",[35,"^[",2320,536870920]],["^15",[35,"^@",false,536870919]],["^15",[35,"^Y","personality psychology/experience seeking",536870919]],["^15",[35,"^A",34,536870919]],["^15",[35,"^11","personality psychology/experience seeking",536870919]],["^15",[35,"^B",1752169829127,536870919]],["^15",[35,"^;","~u686ffd68-6c9d-4c96-84f5-f64f77159a41",536870920]],["^15",[36,"^Q","[[personality psychology/experience seeking/breadth and depth]] [[interests/board games]] Так как ты уже не можешь соревноваться в интеллектуальных настолках, лучше расширяй, а не углубляй знакомство с этим хобби. В частности, абстрактные игры имеют больше нюансов, но они не тебе не под силу. С другой стороны каждая новая игра будет стоит гораздо больше времени, чем раньше, даже поверхностное знакомство с ними. Выбирай игры, которые социальны, но не имеют сильный аспект конкуренции.",536881913]],["^15",[36,"^O","^1;",536870919]],["^15",[36,"^F",31,536870919]],["^15",[36,"^X",31,536870919]],["^15",[36,"^V",31,536870919]],["^15",[36,"^U",31,536881914]],["^15",[36,"^U",34,536881914]],["^15",[36,"^U",35,536881914]],["^15",[36,"^U",520,536881914]],["^15",[36,"^U",2730,536881914]],["^15",[36,"^U",3302,536881914]],["^15",[36,"^?",["^ "],536881913]],["^15",[36,"^H",34,536881913]],["^15",[36,"^H",35,536881913]],["^15",[36,"^H",520,536881913]],["^15",[36,"^H",2730,536881913]],["^15",[36,"^H",3302,536881913]],["^15",[36,"^;","~u686ffd64-dba2-41e6-89f9-40e46cee8cb2",536870919]],["^15",[37,"^3","- #isolation Наблюдать труднее, то есть смирится, что тебя нет, чем признать то, не станет. А ещё труднее встать из-за стола и уйти, не из жизни, а к себе, оставаясь один на один с собой",536870919]],["^15",[37,"^16",1752169828386,536870919]],["^15",[37,"^Z","journals/2025_07_05.md",536870919]],["^15",[38,"^K",1752169828386,536870919]],["^15",[38,"^[",37,536870919]],["^15",[38,"^N",20250705,536870919]],["^15",[38,"^@",true,536870919]],["^15",[38,"^Y","jul 5th, 2025",536870919]],["^15",[38,"^11","Jul 5th, 2025",536870919]],["^15",[38,"^B",1752169828386,536870919]],["^15",[38,"^;","~u686ffd64-6d6a-4d58-ba13-817e246f0202",536870919]],["^15",[39,"^K",1752169828460,536870919]],["^15",[39,"^@",false,536870919]],["^15",[39,"^Y","isolation",536870919]],["^15",[39,"^11","isolation",536870919]],["^15",[39,"^B",1752169828460,536870919]],[