                                :y2 1045.5625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1051.359375,\n                                   :x2 192.6875,\n                                   :y2 1079.359375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 204.609375,\n                                   :y1 1051.359375,\n                                   :x2 321.203125,\n                                   :y2 1079.359375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 333.125,\n                                   :y1 1051.359375,\n                                   :x2 364.25,\n                                   :y2 1079.359375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 376.171875,\n                                   :y1 1051.359375,\n                                   :x2 444.125,\n                                   :y2 1079.359375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 456.03125,\n                                   :y1 1051.359375,\n                                   :x2 552.4375,\n                                   :y2 1079.359375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 564.359375,\n                                   :y1 1051.359375,\n                                   :x2 666.78125,\n                                   :y2 1079.359375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 678.703125,\n                                   :y1 1051.359375,\n                                   :x2 704.109375,\n                                   :y2 1079.359375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 716.03125,\n                                   :y1 1051.359375,\n                                   :x2 770.515625,\n                                   :y2 1079.359375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 782.328125,\n                                   :y1 1051.359375,\n                                   :x2 840.6875,\n                                   :y2 1079.359375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 852.609375,\n                                   :y1 1051.359375,\n                                   :x2 891.0916748046875,\n                                   :y2 1079.359375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1085.015625,\n                                   :x2 891.913330078125,\n                                   :y2 1113.015625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1118.796875,\n                                   :x2 216.5625,\n                                   :y2 1146.796875,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 228.78125,\n                                   :y1 1118.796875,\n                                   :x2 286.21875,\n                                   :y2 1146.796875,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 298.4375,\n                                   :y1 1118.796875,\n                                   :x2 392.296875,\n                                   :y2 1146.796875,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 404.53125,\n                                   :y1 1118.796875,\n                                   :x2 457.8944091796875,\n                                   :y2 1146.796875,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}),\n                          :page 316},\n               :content {:text \"Such unlabeled and personal categories have much in common with lexicalized categories — those labeled by words, expressions, proverbs, fables, and so on — to which we devoted our ﬁrst two chapters. They are diﬀerent, however, in the way they are constructed. One distinction is that they are built on events experienced in private, as opposed to events picked up from exposure to one’s culture. Another is that they are idiosyncratic, in the sense that they might wind up never being shared with anyone else.\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"670c2eb9-435a-496d-93cf-fab257324fcf\",\n               :page 324,\n               :position {:bounding {:x1 128.3125,\n                                     :y1 292.484375,\n                                     :x2 891.548828125,\n                                     :y2 894.28125,\n                                     :width 1019.9999999999999,\n                                     :height 1319.9999999999998},\n                          :rects ({:x1 487.978515625,\n                                   :y1 292.484375,\n                                   :x2 890.338623046875,\n                                   :y2 320.484375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 326.28125,\n                                   :x2 891.322509765625,\n                                   :y2 354.28125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 360.0625,\n                                   :x2 891.1527099609375,\n                                   :y2 388.0625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 393.734375,\n                                   :x2 891.017822265625,\n                                   :y2 421.734375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 427.515625,\n                                   :x2 890.999755859375,\n                                   :y2 455.515625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n      