g:: god\n.mythology:: Greece\n.transcription:: /a.tʰɛː.nâː/\n.translation:: Афина\n.flags:: Olympian\nid:: 66ba0f9b-9bf9-4e3e-80ea-4bd53040a923",536870919]],["^15",[1115,"^O","^1;",536870919]],["^15",[1115,"^F",1200,536870919]],["^15",[1115,"^X",1003,536870919]],["^15",[1115,"^V",1159,536870919]],["^15",[1115,"^U",1003,536870919]],["^15",[1115,"^U",1032,536870919]],["^15",[1115,"^U",1033,536870919]],["^15",[1115,"^U",1036,536870919]],["^15",[1115,"^U",1038,536870919]],["^15",[1115,"^U",1040,536870919]],["^15",[1115,"^U",1041,536870919]],["^15",[1115,"^?",["^ ","^1S","","^1T","god","^1U","Greece","^1V","/a.tʰɛː.nâː/","^1W","Афина","^1X","Olympian","^1D","66ba0f9b-9bf9-4e3e-80ea-4bd53040a923"],536870919]],["^15",[1115,"^J",["^1S","^1T","^1U","^1V","^1W","^1X","^1D"],536870919]],["^15",[1115,"^4",["^ ","^1S","","^1T","god","^1U","Greece","^1V","/a.tʰɛː.nâː/","^1W","Афина","^1X","Olympian","^1D","66ba0f9b-9bf9-4e3e-80ea-4bd53040a923"],536870919]],["^15",[1115,"^H",1032,536870919]],["^15",[1115,"^H",1033,536870919]],["^15",[1115,"^H",1036,536870919]],["^15",[1115,"^H",1038,536870919]],["^15",[1115,"^H",1040,536870919]],["^15",[1115,"^H",1041,536870919]],["^15",[1115,"^;","~u66ba0f9b-9bf9-4e3e-80ea-4bd53040a923",536870919]],["^15",[1116,"^Q","Пятка Талоса\nid:: 66d3325b-a10c-4876-a064-70e45a456087",536870919]],["^15",[1116,"^O","^1;",536870919]],["^15",[1116,"^F",1149,536870919]],["^15",[1116,"^X",1003,536870919]],["^15",[1116,"^V",1075,536870919]],["^15",[1116,"^U",1003,536870919]],["^15",[1116,"^U",1034,536870919]],["^15",[1116,"^?",["^ ","^1D","66d3325b-a10c-4876-a064-70e45a456087"],536870919]],["^15",[1116,"^J",["^1D"],536870919]],["^15",[1116,"^4",["^ ","^1D","66d3325b-a10c-4876-a064-70e45a456087"],536870919]],["^15",[1116,"^;","~u66d3325b-a10c-4876-a064-70e45a456087",536870919]],["^15",[1117,"^Q","Месть Гейи и оросившие её капли полового члена Урана, брошенного Кроносом в море, произвели высокомерных, пошедших на Олимп, гигантов, мстительных Эриний и знойную [Афродиту](((64f25048-c96a-40fa-8c9e-293ba050bfe7))).",536870919]],["^15",[1117,"^O","^1;",536870919]],["^15",[1117,"^F",1189,536870919]],["^15",[1117,"^X",1003,536870919]],["^15",[1117,"^V",1189,536870919]],["^15",[1117,"^U",1003,536870919]],["^15",[1117,"^U",1035,536870919]],["^15",[1117,"^H",1140,536870919]],["^15",[1117,"^;","~u686ffd65-5ab0-4a9c-9304-f1c9c9515c10",536870919]],["^15",[1118,"^Q","Зевс тоже занялся генной инженерией. Мотивы - зависть к скилам отца и тщеславие. От людей без храмов и жертвоприношений нет прока богам, хоть храмы те и не посещают, а угощения не поедают. Они спускались, чтобы поваляться с нимфами или нашими девками и парнями, или погоняться за ними. Первый запуск был с большим багом, лишней хромосомой. Организм рос, но не самозапускался.",536870919]],["^15",[1118,"^O","^1;",536870919]],["^15",[1118,"^F",1103,536870919]],["^15",[1118,"^X",1003,536870919]],["^15",[1118,"^V",1103,536870919]],["^15",[1118,"^U",1003,536870919]],["^15",[1118,"^;","~u686ffd65-35af-46c7-bcf5-1968c0e0fc43",536870919]],["^15",[1119,"^Q","У Кроноса получилось с первого раза. Беззаботная жизнь, безболезненная смерть. И в отличие от сына он не требовал, чтобы к нему ходили на поклон.",536870919]],["^15",[1119,"^O","^1;",536870919]],["^15",[1119,"^F",1051,536870919]],["^15",[1119,"^X",1003,536870919]],["^15",[1119,"^V",1051,536870919]],["^15",[1119,"^U",1003,536870919]],["^15",[1119,"^;","~u686ffd65-fe15-4d20-9c54-1ead573a7de6",536870919]],["^15",[1120,"^Q","Желая отомстить Зевсу за заключение в Тартар своих Титанов [Гея](((64e64a87-5607-4ebc-ad26-47231557940f))) натравила других детей, сначала гигантов Гигантомахии, а потом Тифона.",536870919]],["^15",[1120,"^O","^1;",536870919]],["^15",[1120,"^F",1171,536870919]],["^15",[1120,"^X",1003,536870919]],["^15",[1120,"^V",1131,536870919]],["^15",[1120,"^U",1003,536870919]],["^15",[1120,"^H",1164,536870919]],["^15",[1120,"^;","~u686ffd65-7994-404d-8053-599ad521a2a5",536870919]],["^15",[1121,"^Q","Талос",536870919]],["^15",[1121,"^O","^1;",536870919]],["^15",[1121,"^F",1067,536870919]],["^15",[1121,"^X",1003,536870919]],["^15",[1121,"^V",1067,536870919]],["^15",[1121,"^U",1003,536870919]],["^15",[1121,"^;","~u686ffd65-9261-4bfc-b86c-03db68079822",536870919]],["^15",[1122,"^Q","[Пана](((66bd24c6-efdc-4fc5-bc54-c443a0a6f666))) отправили следить за пастухами и природой в Аркадию. Он был талантливее всех олимпийцев и умел всё. Оттуда и имя. Но они дали ему козлиную внешность и посадили туда, где никому нет дела до его талантов.",536870919]],["^15",[1122,"^O","^1;",536870919]],["^15",[1122,"^F",1088,536870919]],["^15",[1122,"^X",1003,536870919]],["^15",[1122,"^V",1088,536870919]],["^15",[1122,"^U",1003,536870919]],["^15",[1122,"^U",1034,536870919]],["^15",[1122,"^H",1136,536870919]],["^15",[1122,"^;","~u686ffd65-4977-48b1-9637-ca64c080a4b8",536870919]],["^15",[1123,"^Q","Изначальные божества",536870919]],["^15",[1123,"^O","^1;",536870919]],["^15",[1123,"^F",1190,536870919]],["^15",[1123,"^X",1003,536870919]],["^15",[1123,"^V",1190,536870919]],["^15",[1123,"^U",1003,536870919]],["^15",[1123,"^;","~u686ffd65-00b8-4a5d-be42-08e2d1080aeb",536870919]],["^15",[1124,"^Q","[[Alternate mythology]]",536870919]],["^15",[1124,"^O","^1;",536870919]],["^15",[1124,"^F",1090,536870919]],["^15",[1124,"^X",1003,536870919]],["^15",[1124,"^V",1130,536870919]],["^15",[1124,"^U",1003,536870919]],["^15",[1124,"^U",1034,536870919]],["^15",[1124,"^H",1034,536870919]],["^15",[1124,"^;","~u686ffd65-cf7c-49db-a0de-cb5799bc8709",536870919]],["^15",[1125,"^Q","Ῥέα\n.tags:: \n.being:: god\n.mythology:: Greece\n.transcription:: /r̥é.aː/\n.translation:: Рея\n.flags:: titan",536870919]],["^15",[1125,"^O","^1;",536870919]],["^15",[1125,"^F",1174,536870919]],["^15",[1125,"^X",1003,536870919]],["^15",[1125,"^V",1161,536870919]],["^15",[1125,"^U",1003,536870919]],["^15",[1125,"^U",1032,536870919]],["^15",[1125,"^U",1033,536870919]],["^15",[1125,"^U",1036,536870919]],["^15",[1125,"^U",1038,536870919]],["^15",[1125,"^U",1040,536870919