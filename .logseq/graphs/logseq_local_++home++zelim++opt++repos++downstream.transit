",[670,"^U",662,536870919]],["^15",[670,"^U",663,536870919]],["^15",[670,"^U",664,536870919]],["^15",[670,"^;","~u686ffd65-6714-4a31-ab76-253b5c8e2050",536870919]],["^15",[671,"^3","- #randomisation #gamification [[focus areas/daily]]\n\t- Составь список упражнений или задач и случайным образом выбери одно из них или составь цепочку.\n\t\t- Выбери таким же образом параметр, напр., речь...\n\t\t\t- ... и его значение, напр. патетичность.\n\t- Спроси чат-бота.",536870919]],["^15",[671,"^16",1752169829182,536870919]],["^15",[671,"^Z","journals/2023_11_20.md",536870919]],["^15",[672,"^K",1752169829181,536870919]],["^15",[672,"^[",671,536870919]],["^15",[672,"^N",20231120,536870919]],["^15",[672,"^@",true,536870919]],["^15",[672,"^Y","nov 20th, 2023",536870919]],["^15",[672,"^11","Nov 20th, 2023",536870919]],["^15",[672,"^B",1752169829181,536870919]],["^15",[672,"^;","~u686ffd65-c78b-4e0e-b96d-750f555103fd",536870919]],["^15",[673,"^K",1752169829180,536870919]],["^15",[673,"^@",false,536870919]],["^15",[673,"^Y","focus areas/daily",536870919]],["^15",[673,"^A",436,536870919]],["^15",[673,"^11","focus areas/daily",536870919]],["^15",[673,"^B",1752169829180,536870919]],["^15",[673,"^;","~u686ffd65-eb38-4aa0-bcc0-f56ea8dedf44",536870919]],["^15",[674,"^K",1752169829181,536870919]],["^15",[674,"^@",false,536870919]],["^15",[674,"^Y","randomisation",536870919]],["^15",[674,"^11","randomisation",536870919]],["^15",[674,"^B",1752169829181,536870919]],["^15",[674,"^;","~u686ffd65-1c76-4fd1-a1fc-4f229eb27204",536870919]],["^15",[675,"^Q","#randomisation #gamification [[focus areas/daily]]",536870919]],["^15",[675,"^O","^1;",536870919]],["^15",[675,"^F",672,536870919]],["^15",[675,"^X",672,536870919]],["^15",[675,"^V",672,536870919]],["^15",[675,"^U",436,536870919]],["^15",[675,"^U",648,536870919]],["^15",[675,"^U",672,536870919]],["^15",[675,"^U",673,536870919]],["^15",[675,"^U",674,536870919]],["^15",[675,"^H",436,536870919]],["^15",[675,"^H",648,536870919]],["^15",[675,"^H",673