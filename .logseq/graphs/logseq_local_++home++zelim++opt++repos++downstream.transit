,"^U",33,536870953]],["^15",[544,"^U",34,536870953]],["^15",[544,"^U",35,536870953]],["^15",[544,"^U",520,536870953]],["^15",[544,"^U",534,536870953]],["^15",[544,"^;","~u686ffd64-801b-43f1-b9be-0c5135f9ec7a",536870919]],["^15",[545,"^Q","|Текущий|Потенциальный|Расширенный|\n|Романтические фильмы|В любви как на войне|Аниме|",536870919]],["^15",[545,"^O","^1;",536870919]],["^15",[545,"^F",539,536870919]],["^15",[545,"^X",534,536870919]],["^15",[545,"^V",539,536870919]],["^15",[545,"^U",33,536870953]],["^15",[545,"^U",34,536870953]],["^15",[545,"^U",35,536870953]],["^15",[545,"^U",520,536870953]],["^15",[545,"^U",534,536870953]],["^15",[545,"^;","~u686ffd64-bd50-49cf-9799-f0f3515daf2e",536870919]],["^15",[546,"^Q","Гейтвей",536870919]],["^15",[546,"^O","^1;",536870919]],["^15",[546,"^F",543,536870919]],["^15",[546,"^X",534,536870919]],["^15",[546,"^V",541,536870919]],["^15",[546,"^U",33,536870953]],["^15",[546,"^U",34,536870953]],["^15",[546,"^U",35,536870953]],["^15",[546,"^U",520,536870953]],["^15",[546,"^U",534,536870953]],["^15",[546,"^;","~u686ffd64-cc87-4eb0-8522-7040289e9c0e",536870919]],["^15",[547,"^M",true,536870919]],["^15",[547,"^Q","Регби\ncollapsed:: true",536870919]],["^15",[547,"^O","^1;",536870919]],["^15",[547,"^F",541,536870919]],["^15",[547,"^X",534,536870919]],["^15",[547,"^V",541,536870919]],["^15",[547,"^U",33,536870953]],["^15",[547,"^U",34,536870953]],["^15",[547,"^U",35,536870953]],["^15",[547,"^U",520,536870953]],["^15",[547,"^U",534,536870953]],["^15",[547,"^?",["^ "],536870919]],["^15",[547,"^J",[],536870919]],["^15",[547,"^4",["^ "],536870919]],["^15",[547,"^;","~u686ffd64-0e6f-44e3-ac0d-2daf18536d72",536870919]],["^15",[548,"^3","- #[[percentile problem]]\n\t- Касательно меня\n\t\t- Для чеченца у меня ультралиберальные взгляды, но для Запада они скорее умеренно левые. Даже их феминизм я ставлю под вопрос. Но родись я там, я бы определённо был бы SJW и woke.\n\t- Касательно других\n\t\t- С консервативными людьми здесь не о чем поговорить, а психотип либеральных кавказцев меня раздражает. Если раньше мой отъезд из Чечни был эскапизмом, то сейчас я понимаю, что, к сожалению, только так я могу избежать одиночества. Я на совесть выполнил домашнюю работу по социализации после возвращения из Феникса, но настоящих друзей я не завёл, хоть и стало легче жить.\n\t\t- Касательно избранницы\n\t\t\t- Она не может быть сексуально раскрепощённой и вместе с тем порядочной чеченкой.",536870919]],["^15",[548,"^16",1752169828976,536870919]],["^15",[548,"^Z","journals/2024_12_20.md",536870919]],["^15",[549,"^K",1752169828975,536870919]],["^15",[549,"^[",548,536870919]],["^15",[549,"^N",20241220,536870919]],["^15",[549,"^@",true,536870919]],["^15",[549,"^Y","dec 20th, 2024",536870919]],["^15",[549,"^11","Dec 20th, 2024",536870919]],["^15",[549,"^B",1752169828975,536870919]],["^15",[549,"^;","~u686ffd64-af44-4999-b74c-de1ad3c582d1",536870919]],["^15",[550,"^K",1752169828975,536870919]],["^15",[550,"^@",false,536870919]],["^15",[550,"^Y","percentile problem",536870919]],["^15",[550,"^11","percentile problem",536870919]],["^15",[550,"^B",1752169828975,536870919]],["^15",[550,"^;","~u686ffd64-04ca-4cd0-b42e-f02e7a02901d",536870919]],["^15",[551,"^Q","#[[percentile problem]]",536870919]],["^15",[551,"^O","^1;",536870919]],["^15",[551,"^F",549,536870919]],["^15",[551,"^X",549,536870919]],["^15",[551,"^V",549,536870919]],["^15",[551,"^U",549,536870919]],["^15",[551,"^U",550,536870919]],["^15",[551,"^H",550,536870919]],["^15",[551,"^;","~u686ffd64-48ee-47af-9e02-74625ffd42b4",536870919]],["^15",[552,"^Q","Касательно меня",536870919]],["^15",[552,"^O","^1;",536870919]],["^15",[552,"^F",551,536870919]],["^15",[552,"^X",549,536870919]],["^15",[552,"^V",551,536870919]],["^15",[552,"^U",549,536870919]],["^15",[552,"^U",550,536870919]],["^15",[552,"^;","~u686ffd64-c7f6-4ce7-97d7-56f977efebc1",536870919]],["^15",[553,"^Q","Для чеченца у меня ультралиберальные взгляды, но для Запада они скорее умеренно левые. Даже их феминизм я ставлю под вопрос. Но родись я там, я бы определённо был бы SJW и woke.",536870919]],["^15",[553,"^O","^1;",536870919]],["^15",[553,"^F",552,536870919]],["^15",[553,"^X",549,536870919]],["^15",[553,"^V",552,536870919]],["^15",[553,"^U",549,536870919]],["^15",[553,"^U",550,536870919]],["^15",[553,"^;","~u686ffd64-c9a9-4f3c-86dd-141b0701fc4e",536870919]],["^15",[554,"^Q","Касательно других",536870919]],["^15",[554,"^O","^1;",536870919]],["^15",[554,"^F",552,536870919]],["^15",[554,"^X",549,536870919]],["^15",[554,"^V",551,536870919]],["^15",[554,"^U",549,536870919]],["^15",[554,"^U",550,536870919]],["^15",[554,"^;","~u686ffd64-e757-4ba4-8d7e-1e28ad05298f",536870919]],["^15",[555,"^Q","С консервативными людьми здесь не о чем поговорить, а психотип либеральных кавказцев меня раздражает. Если раньше мой отъезд из Чечни был эскапизмом, то сейчас я понимаю, что, к сожалению, только так я могу избежать одиночества. Я на совесть выполнил домашнюю работу по социализации после возвращения из Феникса, но настоящих друзей я не завёл, хоть и стало легче жить.",536870919]],["^15",[555,"^O","^1;",536870919]],["^15",[555,"^F",554,536870919]],["^15",[555,"^X",549,536870919]],["^15",[555,"^V",554,536870919]],["^15",[555,"^U",549,536870919]],["^15",[555,"^U",550,536870919]],["^15",[555,"^;","~u686ffd64-221e-4e77-92b5-1d0444847f5c",536870919]],["^15",[556,"^Q","Касательно избранницы",536870919]],["^15",[556,"^O","^1;",536870919]],["^15",[556,"^F",555,536870919]],["^15",[556,"^X",549,536870919]],["^15",[556,"^V",554,536870919]],["^15",[556,"^U",549,536870919]],["^15",[556,"^U",550,536870919]],["^15",[556,"^;","~u686ffd64-d66e-42fd-bbb1-04e6acfc18d3",536870919]],["^15",[557,"^Q","Она не может быть сексуально раскрепощённой и вместе с тем порядочной чеченкой.",536870919]],["^15",[557,"^O","^1;",536870919]],["^15",[557,"^F",556,536870919]],["^15",[557,"^X",549,536870919]],["^15",[557,"^V",556,536870919]],["^15",[557,"^U",549,536870919]],["^15",[557,"^U",550,536870919]],["^15",[557,"^;","~u686ffd64-6af0-41d4-981a-62639db35d37",536870919]],["^15",[558,"^3","tags:: diary\ntype:: reflection\nmood:: sad\n\n- #balance Я не смог жонглировать. Работа, семья, в частности Оа, и построение личных отношений - всё разбилось вдребезги.",536870919]],["^15",[558,"^16",1752169828986,536870919]],["^15",[558,"^Z","journals/2024_12_12.md",536870919]],["^15",[559,"^K",1752169828985,536870919]],["^15",[559,"^[",558,536870919]],["^15",[559,"^N",20241212,536870919]],["^15",[559,"^@",true,536870919]],["^15",[559,"^Y","dec 12th, 2024",536870919]],["^15",[559,"^11","Dec 12th, 2024",536870919]],["^15",[559,"^?",["^ ","^18",["^19",["diary"]],"^1=","reflection","^1>","sad"],536870919]],["^15",[559,"^4",["^ ","^18","diary","^1=","reflection","^1>","sad"],536870919]],["^15",[559,"^P",69,536870919]],["^15",[559,"^B",1752169828985,536870919]],["^15",[559,"^;","~u686ffd64-d2e4-475c-a6e9-f5651376f9ca",536870919]],["^15",[560,"^K",1752169828986,536870919]],["^15",[560,"^@",false,536870919]],["^15",[560,"^Y","balance",536870919]],["^15",[560,"^11","balance",536870919]],["^15",[560,"^B",1752169828986,536870919]],["^15",[560,"^;","~u686ffd64-0ea6-4a98-8273-8ca70abd6799",536870919]],["^15",[561,"^Q","tags:: diary\ntype:: reflection\nmood:: sad\n\n",536870919]],["^15",[561,"^O","^1;",536870919]],["^15",[561,"^1<",["^19",[]],536870919]],["^15",[561,"^F",559,536870919]],["^15",[561,"^X",559,536870919]],["^15",[561,"^V",559,536870919]],["^15",[561,"^U",69,536870919]],["^15",[561,"^U",70,536870919]],["^15",[561,"^U",71,536870919]],["^15",[561,"^U",559,536870919]],["^15",[561,"^:",true,536870919]],["^15",[561,"^?",["^ ","^18",["^19",["diary"]],"^1=","reflection","^1>","sad"],536870919]],["^15",[561,"^J",["^18","^1=","^1>"],536870919]],["^15",[561,"^4",["^ ","^18","diary","^1=","reflection","^1>","sad"],536870919]],["^15",[561,"^H",69,536870919]],["^15",[561,"^H",70,536870919]],["^15",[561,"^H",71,536870919]],["^15",[561,"^;","~u686ffd64-cf11-47b9-bf75-fb80d9f2c8bd",536870919]],["^15",[562,"^Q","#balance Я не смог жонглировать. Работа, семья, в частности Оа, и построение личных отношений - всё разбилось вдребезги.",536870919]],["^15",[562,"^O","^1;",536870919]],["^15",[562,"^F",561,536870919]],["^15",[562,"^X",559,536870919]],["^15",[562,"^V",559,536870919]],["^15",[562,"^U",559,536870919]],["^15",[562,"^U",560,536870919]],["^15",[562,"^H",560,536870919]],["^15",[562,"^;","~u686ffd64-0745-4419-9276-d84789fec95a",536870919]],["^15",[563,"^3","- #Адам #religion Адам действительно был бы преступником, не будь он религиозным. В его мире Бог есть - и не всё дозволено. Порог, который он готов переступить, находится зачастую за пределами законопослушности, и даже за гранью дозволяемого исламом. Но без религии Адам и эту грань не брал бы в расчёт.\n\t- |Бог есть|Бога нет|\n\t  |Стероиды|Наркотики|\n\t  |Обнал|Кража|\n\t  |Коллекторство|Рэкет|",536870919]],["^15",[563,"^16",1752169828998,536870919]],["^15",[563,"^Z","journals/2024_12_11.md",536870919]],["^15",[564,"^K",1752169828998,536870919]],["^15",[564,"^[",563,536870919]],["^15",[564,"^N",20241211,536870919]],["^15",[564,"^@",true,536870919]],["^15",[564,"^Y","dec 11th, 2024",536870919]],["^15",[564,"^11","Dec 11th, 2024",536870919]],["^15",[564,"^B",1752169828998,536870919]],["^15",[564,"^;","~u686ffd64-7b25-4ce0-8554-1dc25c49947a",536870919]],["^15",[565,"^K",1752169828996,536870919]],["^15",[565,"^@",false,536870919]],["^15",[565,"^Y","religion",536870919]],["^15",[565,"^11","religion",536870919]],["^15",[565,"^B",1752169828996,536870919]],["^15",[565,"^;","~u686ffd64-93bd-45a2-988c-46356f7a7bd2",536870919]],["^15",[566,"^K",1752169828997,536870919]],["^15",[566,"^@",false,536870919]],["^15",[566,"^Y","адам",536870919]],["^15",[566,"^11","Адам",536870919]],["^15",[566,"^B",1752169828997,536870919]],["^15",[566,"^;","~u686ffd64-9c04-47e2-865e-ab1a39ee5b6b",536870919]],["^15",[567,"^Q","#Адам #religion Адам действительно был бы преступником, не будь он религиозным. В его мире Бог есть - и не всё дозволено. Порог, который он готов переступить, находится зачастую за пределами законопослушности, и даже за гранью дозволяемого исламом. Но без религии Адам и эту грань не брал бы в расчёт.",536870919]],["^15",[567,"^O","^1;",536870919]],["^15",[567,"^F",564,536870919]],["^15",[567,"^X",564,536870919]],["^15",[567,"^V",564,536870919]],["^15",[567,"^U",564,536870919]],["^15",[567,"^U",565,536870919]],["^15",[567,"^U",566,536870919]],["^15",[567,"^H",565,536870919]],["^15",[567,"^H",566,536870919]],["^15",[567,"^;","~u686ffd64-6a43-4977-bd10-f082948ba647",536870919]],["^15",[568,"^Q","|Бог есть|Бога нет|\n|Стероиды|Наркотики|\n|Обнал|Кража|\n|Коллекторство|Рэкет|",536870919]],["^15",[568,"^O","^1;",536870919]],["^15",[568,"^F",567,536870919]],["^15",[568,"^X",564,536870919]],["^15",[568,"^V",567,536870919]],["^15",[568,"^U",564,536870919]],["^15",[568,"^U",565,536870919]],["^15",[568,"^U",566,536870919]],["^15",[568,"^;","~u686ffd64-f1c4-4394-818d-d4dd6691bf37",536870919]],["^15",[569,"^3","- [[personality psychology/self-deception]] [[personality psychology/independence]] Будь я достаточно самодостаточным, я был бы избирателен в общении в Англии. В частности, не плёлся бы хвостом за земляками. Также нужно было держать расстояние с гэрэушником в больнице Сеченова и моряком в бехтеревке.\n\t- [[social circle]]\n\t\t- ЧГУ\n\t\t\t- Тот же круг без элемента религии\n\t\t- Эксетер\n\t\t\t- Окки, Джо, Оля\n\t\t\t- Игорь и его круг\n\t\t\t- Иса\n\t\t- Лестер\n\t\t\t- Нужно было пойти в гости к тому русскому, когда пригласили\n\t\t- Ньюкасл\n\t\t\t- Ибраxим\n\t\t- Грозный после Ростова\n\t\t\t- Эту ошибку я допустил с Амиром и Рамзаном из Феникса. Но она простительна, потому что это был мой первый опыт социализации после нейролептиков.",536870919]],["^15",[569,"^16",1752169829012,536870919]],["^15",[569,"^Z","journals/2024_12_09.md",536870919]],["^15",[570,"^K",1752169829010,536870919]],["^15",[570,"^[",569,536870919]],["^15",[570,"^N",20241209,536870919]],["^15",[570,"^@",true,536870919]],["^15",[570,"^Y","dec 9th, 2024",536870919]],["^15",[570,"^11","Dec 9th, 2024",536870919]],["^15",[570,"^B",1752169829010,536870919]],["^15",[570,"^;","~u686ffd65-b0d5-48a3-9952-8bfc9751cdd5",536870919]],["^15",[571,"^K",1752169829011,536870919]],["^15",[571,"^@",false,536870919]],["^15",[571,"^Y","social circle",536870919]],["^15",[571,"^11","social circle",536870919]],["^15",[571,"^B",1752169829011,536870919]],["^15",[571,"^;","~u686ffd65-7856-40be-9478-18a70d8595f9",536870919]],["^15",[572,"^Q","Эту ошибку я допустил с Амиром и Рамзаном из Феникса. Но она простительна, потому что это был мой первый опыт социализации после нейролептиков.",536870919]],["^15",[572,"^O","^1;",536870919]],["^15",[572,"^F",577,536870919]],["^15",[572,"^X",570,536870919]],["^15",[572,"^V",577,536870919]],["^15",[572,"^U",34,536870919]],["^15",[572,"^U",90,536870919]],["^15",[572,"^U",145,536870919]],["^15",[572,"^U",570,536870919]],["^15",[572,"^U",571,536870919]],["^15",[572,"^;","~u686ffd65-fe9b-47ad-83e5-28ed7239a850",536870919]],["^15",[573,"^Q","[[social circle]]",536870919]],["^15",[573,"^O","^1;",536870919]],["^15",[573,"^F",579,536870919]],["^15",[573,"^X",570,536870919]],["^15",[573,"^V",579,536870919]],["^15",[573,"^U",34,536870919]],["^15",[573,"^U",90,536870919]],["^15",[573,"^U",145,536870919]],["^15",[573,"^U",570,536870919]],["^15",[573,"^U",571,536870919]],["^15",[573,"^H",571,536870919]],["^15",[573,"^;","~u686ffd65-85b2-4fd5-a887-bc52b3429cd3",536870919]],["^15",[574,"^Q","Тот же круг без элемента религии",536870919]],["^15",[574,"^O","^1;",536870919]],["^15",[574,"^F",585,536870919]],["^15",[574,"^X",570,536870919]],["^15",[574,"^V",585,536870919]],["^15",[574,"^U",34,536870919]],["^15",[574,"^U",90,536870919]],["^15",[574,"^U",145,536870919]],["^15",[574,"^U",570,536870919]],["^15",[574,"^U",571,536870919]],["^15",[574,"^;","~u686ffd65-eed4-41e9-9ac6-b225950a2002",536870919]],["^15",[575,"^Q","Ибраxим",536870919]],["^15",[575,"^O","^1;",536870919]],["^15",[575,"^F",578,5368