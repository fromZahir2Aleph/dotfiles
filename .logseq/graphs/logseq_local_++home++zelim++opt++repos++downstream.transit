 264.765625,\n                                   :x2 807.5899658203125,\n                                   :y2 289.765625,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 116.234375,\n                                   :y1 295.375,\n                                   :x2 237.65625,\n                                   :y2 320.375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 250.125,\n                                   :y1 295.375,\n                                   :x2 284.046875,\n                                   :y2 320.375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 296.5,\n                                   :y1 295.375,\n                                   :x2 337.8125,\n                                   :y2 320.375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 350.28125,\n                                   :y1 295.375,\n                                   :x2 420.328125,\n                                   :y2 320.375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 432.796875,\n                                   :y1 295.375,\n                                   :x2 460.625,\n                                   :y2 320.375,\n                                   :width 924.0000000000001,\n                                   :height 1195.7647058823532}\n                                  {:x1 473.078125,\n                                   :y1 295.375,\n                       