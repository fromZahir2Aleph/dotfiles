",[3490,"^;","~u686ffd67-6555-4a87-82e9-07d1400b0979",536884735]],["^15",[3491,"^Q","Можно использовать пассивный залог, но осторожно",536884735]],["^15",[3491,"^O","^1;",536884735]],["^15",[3491,"^F",3490,536884735]],["^15",[3491,"^X",3406,536884735]],["^15",[3491,"^V",3488,536884735]],["^15",[3491,"^;","~u686ffd67-4bb2-4952-9309-92be83386163",536884735]],["^15",[3492,"^Q","Тематическое предложение появляется в начале параграфа и раскрывается далее",536884735]],["^15",[3492,"^O","^1;",536884735]],["^15",[3492,"^F",3488,536884735]],["^15",[3492,"^X",3406,536884735]],["^15",[3492,"^V",3486,536884735]],["^15",[3492,"^;","~u686ffd67-f8da-45df-a432-952a32ddc2a8",536884735]],["^15",[3493,"^Q","Местоимения указывают на известную информацию или в случае притяжательных согласовываются с ней",536884735]],["^15",[3493,"^O","^1;",536884735]],["^15",[3493,"^F",3492,536884735]],["^15",[3493,"^X",3406,536884735]],["^15",[3493,"^V",3486,536884735]],["^15",[3493,"^;","~u686ffd67-dd7b-49fe-84ee-77b7428c6db2",536884735]],["^15",[3494,"^M",true,536884735]],["^15",[3494,"^Q","Ритм\ncollapsed:: true",536884735]],["^15",[3494,"^O","^1;",536884735]],["^15",[3494,"^F",3480,536884735]],["^15",[3494,"^X",3406,536884735]],["^15",[3494,"^V",3435,536884735]],["^15",[3494,"^?",["^ "],536884735]],["^15",[3494,"^J",["^14",[]],536884735]],["^15",[3494,"^4",["^ "],536884735]],["^15",[3494,"^;","~u686ffd67-5495-457b-ae8a-5b24d169be0d",536884735]],["^15",[3495,"^Q","Из-за свободного порядка слов русский язык не имеет ограничений как английский.",536884735]],["^15",[3495,"^O","^1;",536884735]],["^15",[3495,"^F",3494,536884735]],["^15",[3495,"^X",3406,536884735]],["^15",[3495,"^V",3494,536884735]],["^15",[3495,"^;","~u686ffd67-4f3d-463b-92d1-8083c563e084",536884735]],["^15",[3496,"^Q","Ударение в предложении падает на новую информацию, которая согласно когезии находится в конце предложения, а именно в качестве последнего или предпоследнего слова.",536884735]],["^15",[3496,"^O","^1;",536884735]],["^15",[