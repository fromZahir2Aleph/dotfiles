84,"^U",186,536870917]],["^15",[1684,"^U",187,536870917]],["^15",[1684,"^U",1682,536870917]],["^15",[1684,"^:",true,536870917]],["^15",[1684,"^?",["^ ","^19",["^1:",["diary"]],"^1;","reflection","^1<","sad"],536870917]],["^15",[1684,"^J",["^19","^1;","^1<"],536870917]],["^15",[1684,"^4",["^ ","^19","diary","^1;","reflection","^1<","sad"],536870917]],["^15",[1684,"^H",185,536870917]],["^15",[1684,"^H",186,536870917]],["^15",[1684,"^H",187,536870917]],["^15",[1684,"^;","~u69a845e5-6c43-47b7-9f28-2ca46634557b",536870917]],["^15",[1685,"^Q","#balance Я не смог жонглировать. Работа, семья, в частности Оа, и построение личных отношений - всё разбилось вдребезги.",536870917]],["^15",[1685,"^O","^17",536870917]],["^15",[1685,"^F",1684,536870917]],["^15",[1685,"^X",1682,536870917]],["^15",[1685,"^V",1682,536870917]],["^15",[1685,"^U",1682,536870917]],["^15",[1685,"^U",1683,536870917]],["^15",[1685,"^H",1683,536870917]],["^15",[1685,"^;","~u69a845e5-04fd-4043-b13e-8291465c3dd7",536870917]],["^15",[1686,"^3","- #Адам #religion Адам действительно был бы преступником, не будь он религиозным. В его мире Бог есть - и не всё дозволено. Порог, который он готов переступить, находится зачастую за пределами законопослушности, и даже за гранью дозволяемого исламом. Но без религии Адам и эту грань не брал бы в расчёт.\n\t- |Бог есть|Бога нет|\n\t  |Стероиды|Наркотики|\n\t  |Обнал|Кража|\n\t  |Коллекторство|Рэкет|",536870917]],["^15",[1686,"^16",1772635621899,536870917]],["^15",[1686,"^Z","journals/2024_12_11.md",536870917]],["^15",[1687,"^K",1772635621898,536870917]],["^15",[1687,"^[",1686,536870917]],["^15",[1687,"^N",20241211,536870917]],["^15",[1687,"^@",true,536870917]],["^15",[1687,"^Y","dec 11th, 2024",536870917]],["^15",[1687,"^11","Dec 11th, 2024",536870917]],["^15",[1687,"^B",1772635621898,536870917]],["^15",[1687,"^;","~u69a845e5-54b2-49ab-a4cb-93d7daba92b0",536870917]],["^15",[1688,"^K",1772635621897,536870917]],["^15",[1688,"^@",false,536870917]],["^15",[1688,"^Y","religion",536870917]],["^15",[1688,"^11","religion",536870917]],["^15",[1688,"^B",1772635621897,536870917]],["^15",[1688,"^;","~u69a845e5-f5ff-4027-8c5c-ce454d99cd78",536870917]],["^15",[1689,"^K",1772635621898,536870917]],["^15",[1689,"^@",false,536870917]],["^15",[1689,"^Y","адам",536870917]],["^15",[1689,"^11","Адам",536870917]],["^15",[1689,"^B",1772635621898,536870917]],["^15",[1689,"^;","~u69a845e5-64db-470e-ad4f-d70f9407c555",536870917]],["^15",[1690,"^Q","#Адам #religion Адам действительно был бы преступником, не будь он религиозным. В его мире Бог есть - и не всё дозволено. Порог, который он готов переступить, находится зачастую за пределами законопослушности, и даже за гранью дозволяемого исламом. Но без религии Адам и эту грань не брал бы в расчёт.",536870917]],["^15",[1690,"^O","^17",536870917]],["^15",[1690,"^F",1687,536870917]],["^15",[1690,"^X",1687,536870917]],["^15",[1690,"^V",1687,536870917]],["^15",[1690,"^U",1687,536870917]],["^15",[1690,"^U",1688,536870917]],["^15",[1690,"^U",1689,536870917]],["^15",[1690,"^H",1688,536870917]],["^15",[1690,"^H",1689,536870917]],["^15",[1690,"^;","~u69a845e5-b6b9-434b-8c91-1a9630ee1b1d",536870917]],["^15",[1691,"^Q","|Бог есть|Бога нет|\n|Стероиды|Наркотики|\n|Обнал|Кража|\n|Коллекторство|Рэкет|",536870917]],["^15",[1691,"^O","^17",536870917]],["^15",[1691,"^F",1690,536870917]],["^15",[1691,"^X",1687,536870917]],["^15",[1691,"^V",1690,536870917]],["^15",[1691,"^U",1687,536870917]],["^15",[1691,"^U",1688,536870917]],["^15",[1691,"^U",1689,536870917]],["^15",[1691,"^;","~u69a845e5-6cec-46ca-bb83-7c357bdcf184",536870917]],["^15",[1692,"^3","- [[personality psychology/self-deception]] [[personality psychology/independence]] Будь я достаточно самодостаточным, я был бы избирателен в общении в Англии. В частности, не плёлся бы хвостом за земляками. Также нужно было держать расстояние с гэрэушником в больнице Сеченова и моряком в бехтеревке.\n\t- [[social circle]]\n\t\t- ЧГУ\n\t\t\t- Тот же круг без элемента религии\n\t\t- Эксетер\n\t\t\t- Окки, Джо, Оля\n\t\t\t- Игорь и его круг\n\t\t\t- Иса\n\t\t- Лестер\n\t\t\t- Нужно было пойти в гости к тому русскому, когда пригласили\n\t\t- Ньюкасл\n\t\t\t- Ибраxим\n\t\t- Грозный после Ростова\n\t\t\t- Эту ошибку я допустил с Амиром и Рамзаном из Феникса. Но она простительна, потому что это был мой первый опыт социализации после нейролептиков.",536870917]],["^15",[1692,"^16",1772635621915,536870917]],["^15",[1692,"^Z","journals/2024_12_09.md",536870917]],["^15",[1693,"^K",1772635621913,536870917]],["^15",[1693,"^[",1692,536870917]],["^15",[1693,"^N",20241209,536870917]],["^15",[1693,"^@",true,536870917]],["^15",[1693,"^Y","dec 9th, 2024",536870917]],["^15",[1693,"^11","Dec 9th, 2024",536870917]],["^15",[1693,"^B",1772635621913,536870917]],["^15",[1693,"^;","~u69a845e5-2205-4643-b73f-178d116bd5e2",536870917]],["^15",[1694,"^K",1772635621914,536870917]],["^15",[1694,"^@",false,536870917]],["^15",[1694,"^Y","social circle",536870917]],["^15",[1694,"^11","social circle",536870917]],["^15",[1694,"^B",1772635621914,536870917]],["^15",[1694,"^;","~u69a845e5-15a0-45f8-8b10-dc105f4c6bc1",536870917]],["^15",[1695,"^Q","Грозный после Ростова",536870917]],["^15",[1695,"^O","^17",536870917]],["^15",[1695,"^F",1703,536870917]],["^15",[1695,"^X",1693,536870917]],["^15",[1695,"^V",1697,536870917]],["^15",[1695,"^U",150,536870917]],["^15",[1695,"^U",219,536870917]],["^15",[1695,"^U",1196,536870917]],["^15",[1695,"^U",1693,536870917]],["^15",[1695,"^U",1694,536870917]],["^15",[1695,"^;","~u69a845e5-8cbb-481f-a409-fcefc840a36c",536870917]],["^15",[1696,"^Q","ЧГУ",536870917]],["^15",[1696,"^O","^17",536870917]],["^15",[1696,"^F",1697,536870917]],["^15",[1696,"^X",1693,536870917]],["^15",[1696,"^V",1697,536870917]],["^15",[1696,"^U",150,536870917]],["^15",[1696,"^U",219,536870917]],["^15",[1696,"^U",1196,536870917]],["^15",[1696,"^U",1693,536870917]],["^15",[1696,"^U",1694,536870917]],["^15",[1696,"^;","~u69a845e5-c60c-4036-a3cb-193c8628ef7e",536870917]],["^15",[1697,"^Q",