king]] [[personality psychology/experience seeking/breadth and depth]] Поиск нового с одной стороны расширяет опыт, так как новое открывает пути к новому. С другой стороны ширина обратно пропорциональна глубине.",536870915]],["^15",[1042,"^O","^17",536870915]],["^15",[1042,"^F",1037,536870915]],["^15",[1042,"^X",1037,536870915]],["^15",[1042,"^V",1037,536870915]],["^15",[1042,"^U",150,536870915]],["^15",[1042,"^U",1037,536870915]],["^15",[1042,"^U",1038,536870915]],["^15",[1042,"^U",1039,536870915]],["^15",[1042,"^U",1040,536870915]],["^15",[1042,"^H",150,536870915]],["^15",[1042,"^H",1038,536870915]],["^15",[1042,"^H",1039,536870915]],["^15",[1042,"^H",1040,536870915]],["^15",[1042,"^;","~u69a845e3-c68a-419e-b9f9-a9f12a001c0a",536870915]],["^15",[1043,"^Q","[[personality psychology/experience seeking/aesthetic appreciation]]  Также ты привыкаешь к чувству поиска свежих ощущений, и получить удовольствие от старых уже трудно.",536870915]],["^15",[1043,"^O","^17",536870915]],["^15",[1043,"^F",1042,536870915]],["^15",[1043,"^X",1037,536870915]],["^15",[1043,"^V",1042,536870915]],["^15",[1043,"^U",150,536870915]],["^15",[1043,"^U",1037,536870915]],["^15",[1043,"^U",1038,536870915]],["^15",[1043,"^U",1039,536870915]],["^15",[1043,"^U",1040,536870915]],["^15",[1043,"^U",1041,536870915]],["^15",[1043,"^H",150,536870915]],["^15",[1043,"^H",1040,536870915]],["^15",[1043,"^H",1041,536870915]],["^15",[1043,"^;","~u69a845e3-6f46-4b5b-9c60-d8931eae0f83",536870915]],["^15",[1044,"^3","- [[personality psychology/experience seeking/aesthetic appreciation]] Ищи импрессионистское \"га\" реальности вместо абстрактного \"ва \" эскапизма. Например, хобби бёрдинга или астрономии.\n  id:: 68adbb96-1fb8-4efb-8c11-689f736f2e9f\n\t- ظاهر‎ が すごい",536870915]],["^15",[1044,"^16",1772635619922,536870915]],["^15",[1044,"^Z","journals/2025_08_26.md",536870915]],["^15",[1045,"^K",1772635619922,536870915]],["^15",[1045,"^[",1044,536870915]],["^15",[1045,"^N",20250826,536870915]],["^15",[1045,"^@",true,536870915]],["^15",[1045,"^Y","aug 26th, 2025",536870915]],["^15",[1045,"^11","Aug 26th, 2025",536870915]],["^15",[1045,"^B",1772635619922,536870915]],["^15",[1045,"^;","~u69a845e3-d08d-4955-8340-976f7a163578",536870915]],["^15",[1046,"^Q","[[personality psychology/experience seeking/aesthetic appreciation]] Ищи импрессионистское \"га\" реальности вместо абстрактного \"ва \" эскапизма. Например, хобби бёрдинга или астрономии.\nid:: 68adbb96-1fb8-4efb-8c11-689f736f2e9f",536870915]],["^15",[1046,"^O","^17",536870915]],["^15",[1046,"^F",1045,536870915]],["^15",[1046,"^X",1045,536870915]],["^15",[1046,"^V",1045,536870915]],["^15",[1046,"^U",150,536870915]],["^15",[1046,"^U",1040,536870915]],["^15",[1046,"^U",1041,536870915]],["^15",[1046,"^U",1045,536870915]],["^15",[1046,"^?",["^ ","^1>","68adbb96-1fb8-4efb-8c11-689f736f2e9f"],536870915]],["^15",[1046,"^J",["^1>"],536870915]],["^15",[1046,"^4",["^ ","^1>","68adbb96-1fb8-4efb-8c11-689f736f2e9f"],536870915]],["^15",[1046,"^H",150,536870915]],["^15",[1046,"^H",1040,536870915]],["^15",[1046,"^H",1041,536870915]],["^15",[1046,"^;","~u68adbb96-1fb8-4efb-8c11-689f736f2e9f",536870915]],["^15",[1047,"^Q","ظاهر‎ が すごい",536870915]],["^15",[1047,"^O","^17",536870915]],["^15",[1047,"^F",1046,536870915]],["^15",[1047,"^X",1045,536870915]],["^15",[1047,"^V",1046,536870915]],["^15",[1047,"^U",150,536870915]],["^15",[1047,"^U",1040,536870915]],["^15",[1047,"^U",1041,536870915]],["^15",[1047,"^U",1045,536870915]],["^15",[1047,"^;","~u69a845e3-a02b-473a-a02a-1aadd634b475",536870915]],["^15",[1048,"^3","- #writing/acting Используй приемы актерского искусства для большей спонтанности и живого слога.",536870915]],["^15",[1048,"^16",1772635619936,536870915]],["^15",[1048,"^Z","journals/2025_08_24.md",536870915]],["^15",[1049,"^K",1772635619935,536870915]],["^15",[1049,"^[",1048,536870915]],["^15",[1049,"^N",20250824,536870915]],["^15",[1049,"^@",true,536870915]],["^15",[1049,"^Y","aug 24th, 2025",536870915]],["^15",[1049,"^11","Aug 24th, 2025",536870915]],["^15",[1049,"^B",1772635619935,536870915]],["^15",[1049,"^;","~u69a845e3-45bf-4bba-b6df-d96d0369565a",536870915]],["^15",[1050,"^Q","#writing/acting Используй приемы актерского искусства для большей спонтанности и живого слога.",536870915]],["^15",[1050,"^O","^17",536870915]],["^15",[1050,"^F",1049,536870915]],["^15",[1050,"^X",1049,536870915]],["^15",[1050,"^V",1049,536870915]],["^15",[1050,"^U",197,536870915]],["^15",[1050,"^U",464,536870915]],["^15",[1050,"^U",1049,536870915]],["^15",[1050,"^H",197,536870915]],["^15",[1050,"^H",464,536870915]],["^15",[1050,"^;","~u69a845e3-6e95-4301-83d7-a6e0a04f293c",536870915]],["^15",[1051,"^3","tags:: [[quiz]]\nplayed:: no\n\n- Что описывают четыре следующих слова на чеченском языке: ӀаьржбӀаьрг, жӀар, цӀентӀадам, биъса?\n\t- Масти игральных карт: соответственно пики, крести, черви, бубны.\n- На разных языках она называется из-за внешнего вида башней или замком, а из-за манеры движения кораблем, пушкой или колесницей. Как она называется на русском?\n\t- Ладья. Прим.: шахматная фигура.\n- Среди недостатков этой традиции - лишняя арифметика и дискриминация по внешнему виду.\n\t- Чаевые\n- В Юникоде этот религиозный символ существует с 1993 года, но массовую популярность в мире он приобрёл благодаря Твиттеру, где был оценён по достоинству его главный атрибут — экономия места. Какую знакомую вам фразу обозначает этот символ?\n\t- صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ салла Аллах ‘алайхи ва-саллама\n- Арабское имя может включать следующие компоненты: насаб, нисба, исм, кунья, лакъаб\n\t- Что соответствует им в имени халифа Абy Хафса Умар ибн аль-Хаттаб Аль-Фарукъ Аль-Къурайши?\n\t\t- Абу Хафса - кунья\n\t\t- Умар - исм\n\t\t- ибн аль-Хаттаб - насаб\n\t\t- Аль-Фарукъ - лакъаб\n\t\t- Аль-Къурайши - нисба\n- Что общего между Салах ад-Дином, Калигулой, Пеле и Че Геварой?\n\t- Личности Юсуф ибн Айюб, Гай Цезарь Германик, Эдсон ду Насименту и Эрнесто Гевара известны больше по своим прозвищам, чем именам.\n- Как пророки, упомянутые в Библии как Илия, Авраам, Иона, Иоанн и Давид, именуются в Коране?\n\t- Соответственно Ильяс, Ибрахим, Юнус, Яхья и Дауд.\n- В России популярна психологическая командная игра «Мафия», в которой участники делятся на мирных жителей и мафию. В западной версии игры ночью на улицы выходит другое вымышленное существо. Оно может выйти ночью только раз в 29 или 30 дней. Назовите его.\n\t- Оборотень. Так и называется игра Мафия на Западе. Прим.: полнолуние случается только раз в лунный месяц.\n- В китайском языке невозможно подсчитать количество слов без специального програмного обеспечения из-за отсутствия этого символа.\n\t- Пробел\n- Мукъаттӏаа - это 14 букв арабского алфавита, с сочетаний которых начинаются 29 сур Корана. Назовите 10 из них.\n\t- أ, هـ, ح, ط, ي, ك, ل, م, ن, س, ع, ص, ق, ر\n\t- Результаты\n\t\t- 10 - 2\n\t\t- 8 - 1,5\n\t\t- 6 - 1\n\t\t- 4 - 0,5\n- Начало использования нефтяных продуктов в качестве горючего спасло это животное от вымирания.\n\t- Киты. Прим. пропала надобность в китовом жире как в горючем.\n- Человечество распространило индоевропейские языки от Испании до Индии на ней. От Мадагаскара до острова Пасхи - на другом.\n\t- Лошадь и лодка\n- Так как между каждой попыткой в этом спорте проходит много времени, в нем использует следующую разновидность определенного предмета. LAMIBEE Golf Stainless Steel 10 Beads Score Counter Bracelet, Golf Stroke Count Bracelet\n\t- Гольф\n- Если вы добавите линии к этому изображению, у вас должен получиться символ. По определенным причинам мы не проситм вас его нарисовать.\n  collapsed:: true\n\t- ![20251128_1533_Fasces with Dual Axes_remix_01kb574tsyehdbjy00cy84axny (1).jpg](../assets/20251128_1533_Fasces_with_Dual_Axes_remix_01kb574tsyehdbjy00cy84axny_(1)_1764340278138_0.jpg)\n\t- У вас должна была получиться свастика, символ немецкого фашизма. Слово \"фашизм\" происходит от слова \"фасции\", которые изображены на рисунке.\n- Эту руну вы видите регулярно. Нарисуйте ее. Для этого вопроса мы делаем исключение: вы можете пользоваться телефоном.\n\t- Bluetooth символ",536877866]],["^15",[1051,"^16",1772635619969,536870915]],["^15",[1051,"^18","~m1774811139461",536877865]],["^15",[1051,"^Z","journals/2025_08_20.md",536870915]],["^15",[1052,"^K",1772635619968,536870915]],["^15",[1052,"^[",1051,536870915]],["^15",[1052,"^N",20250820,536870915]],["^15",[1052,"^@",true,536870915]],["^15",[1052,"^Y","aug 20th, 2025",536870915]],["^15",[1052,"^11","Aug 20th, 2025",536870915]],["^15",[1052,"^?",["^ ","^19",["^1:",["quiz"]],"^1?","no"],536870915]],["^15",[1052,"^4",["^ ","^19","[[quiz]]","^1?","no"],536870915]],["^15",[1052,"^P",344,536870915]],["^15",[1052,"^B",1774811138696,536877864]],["^15",[1052,"^;","~u69a845e3-5634-45cf-ad6e-3db600b3029e",536870915]],["^15",[1053,"^Q","6 - 1",536870915]],["^15",[1053,"^O","^17",536870915]],["^15",[1053,"^F",1068,536870915]],["^15",[1053,"^X",1052,536870915]],["^15",[1053,"^V",1081,536870915]],["^15",[1053,"^U",1052,536870915]],["^15",[1053,"^;","~u69a845e3-5185-41d7-bbbc-89696b0a0fb5",536870915]],["^15",[1054,"^Q","Личности Юсуф ибн Айюб, Гай Цезарь Германик, Эдсон ду Насименту и Эрнесто Гевара известны больше по своим прозвищам, чем именам.",536870915]],["^15",[1054,"^O","^17",536870915]],["^15",[1054,"^F",1074,536870915]],["^15",[1054,"^X",1052,536870915]],["^15",[1054,"^V",1074,536870915]],["^15",[1054,"^U",1052,536870915]],["^15",[1054,"^;","~u69a845e3-2e33-4f63-863e-66d822ed3c6c",536870915]],["^15",[1055,"^Q","Аль-Къурайши - нисба",536870915]],["^15",[1055,"^O","^17",536870915]],["^15",[1055,"^F",1069,536870915]],["^15",[1055,"^X",1052,536870915]],["^15",[1055,"^V",1059,536870915]],["^15",[1055,"^U",1052,536870915]],["^15",[1055,"^;","~u69a845e3-b222-4d20-b6fb-943ce0082ed5",536870915]],["^15",[1056,"^Q","tags:: [[quiz]]\nplayed:: no\n\n",536870915]],["^15",[1056,"^O","^17",536870915]],["^15",[1056,"^1=",["^1:",[]],536870915]],["^15",[1056,"^F",1052,536870915]],["^15",[1056,"^X",1052,536870915]],["^15",[1056,"^V",1052,536870915]],["^