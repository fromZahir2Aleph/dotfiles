                        {:x1 499.453125,\n                                   :y1 444.9375,\n                                   :x2 602.3125,\n                                   :y2 467.9375,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 619.953125,\n                                   :y1 444.9375,\n                                   :x2 645.671875,\n                                   :y2 467.9375,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 663.3125,\n                                   :y1 444.9375,\n                                   :x2 748.6839599609375,\n                                   :y2 467.9375,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 107.796875,\n                                   :y1 445.9375,\n                                   :x2 218.3740997314453,\n                                   :y2 468.9375,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 107.796875,\n                                   :y1 473.328125,\n                                   :x2 254.80160522460938,\n                                   :y2 496.328125,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}),\n                          :page 46},\n               :content {:text \"analogy-making is the machinery behind the pulsating heartbeat of thought: categorization.\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"64fba21e-5f7b-454a-b38a-bfda542f638b\",\n               :page 50,\n               :position {:bounding {:x1 0,\n                                     :y1 0,\n                                     :x2 891.7716064453125,\n                                     :y2 658.015625,\n                                     :width 1019.9999999999999,\n                                     :height 1319.9999999999998},\n                          :rects ({:x1 0,\n                                   :y1 0,\n                                   :x2 0,\n                                   :y2 0,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 158,\n                                   :x2 0,\n                                   :y2 178,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 174,\n                                   :x2 0,\n                                   :y2 194,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 190,\n                                   :x2 0,\n                                   :y2 210,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 206,\n                                   :x2 0,\n                                   :y2 226,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 393.1009521484375,\n                                   :y1 461.3125,\n                                   :x2 891.0501098632812,\n                                   :y2 489.3125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 495.046875,\n                                   :x2 891.4285888671875,\n                                   :y2 523.046875,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 528.765625,\n                                   :x2 890.9505615234375,\n                                   :y2 556.765625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 562.5625,\n                                   :x2 891.619873046875,\n                                   :y2 590.5625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 596.34375,\n                                   :x2 891.7716064453125,\n                                   :y2 624.34375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 630.015625,\n                                   :x2 357.52783203125,\n                                   :y2 658.015625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}),\n                          :page 50},\n               :content {:text \"cognition takes place thanks to a constantﬂow of categorizations, and that at the base of it all is found, in contrast to classiﬁcation (which aims to put all things into ﬁxed and rigid mental boxes), the phenomenon of categorization through analogy-making, which endows human thinking with its remarkable ﬂuidity.\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"64fba2dd-ed27-4cfd-8d45-5a163fb0ab9b\",\n               :page 51,\n               :position {:bounding {:x1 0,\n                                     :y1 46,\n                                     :x2 891.643310546875,\n                                     :y2 286.828125,\n                                     :width 1019.9999999999999,\n                                     :height 1319.9999999999998},\n                          :rects ({:x1 0,\n                                   :y1 46,\n                                   :x2 0,\n                                   :y2 66,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 248.29547119140625,\n                                   :y1 225.03125,\n                                   :x2 891.643310546875,\n                                   :y2 253.03125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 258.828125,\n                                   :x2 263.55206298828125,\n                                   :y2 286.828125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}),\n                          :page 51},\n               :content {:text \"we think only thanks to analogies that link our present to our past.\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"6502222f-95ec-44bf-938e-5876f0837a79\",\n               :page 67,\n               :position {:bounding {:x1 451.765625,\n                                     :y1 948.390625,\n                                     :x2 771.8077392578125,\n                                     :y2 981.390625,\n                                     :width 1224,\n                                     :height 1584},\n                          :rects ({:x1 451.765625,\n                                   :y1 948.390625,\n                                   :x2 771.8077392578125,\n                                   :y2 981.390625,\n                                   :width 1224,\n                                   :height 1584}),\n                          :page 67},\n               :content {:text \"Synopsis of This Book\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"6509d51a-bad3-4712-9219-b9222eae3373\",\n               :page 61,\n               :position {:bounding {:x1 0,\n                                     :y1 0,\n                                     :x2 1020,\n                                     :y2 2650,\n                                     :width 1019.9999999999999,\n                                     :height 1319.9999999999998},\n                          :rects ({:x1 0,\n                                   :y1 0,\n                                   :x2 0,\n                                   :y2 0,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 446,\n                                   :x2 0,\n                                   :y2 466,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 462,\n                                   :x2 0,\n                                   :y2 482,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 478,\n                                   :x2 0,\n                                   :y2 498,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 496,\n                                   :x2 1020,\n                                   :y2 496,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 701.140625,\n                                   :y1 1068.78125,\n                                   :x2 722.0625,\n                                   :y2 1096.78125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 738.984375,\n                                   :y1 1068.78125,\n                                   :x2 890.8310546875,\n                                   :y2 1096.78125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1102.5625,\n                                   :x2 891.26806640625,\n                                   :y2 1130.5625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1136.234375,\n                                   :x2 890.503173828125,\n                                   :y2 1164.234375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1170.015625,\n                                   :x2 732.9063720703125,\n                                   :y2 1198.015625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 1320,\n                                   :x2 1020,\n                                   :y2 1320,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 1330,\n                                   :x2 1020,\n                                   :y2 2650,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}),\n                          :page 61},\n               :content {:text \"a conversation constrains the ideas in it, the ideas constrain the sentences, the sentences constrain the phrases, the phrases constrain the words, and ﬁnally, the words constrain their letters.\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"6509d6f3-2119-4f1a-bd4d-52ff04b431c8\",\n               :page 62,\n               :position {:bounding {:x1 0,\n                                     :y1 478,\n                                     :x2 1020,\n                                     :y2 2650,\n                                     :width 1019.9999999999999,\n                                     :height 1319.9999999999998},\n                          :rects ({:x1 0,\n                                   :y1 478,\n                                   :x2 0,\n                                   :y2 498,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 496,\n                                   :x2 1020,\n                                   :y2 496,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 165.84375,\n                                   :y1 1136.234375,\n                                   :x2 891.396240234375,\n                                   :y2 1164.234375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 1151.03125,\n                                   :x2 1020,\n                                   :y2 1320,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 1328,\n                                   :x2 0,\n                                   :y2 1348,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 1330,\n                                   :x2 1020,\n                                   :y2 2650,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 1344,\n                                   :x2 0,\n                                   :y2 1364,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 1360,\n                                   :x2 0,\n                                   :y2 1380,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 1376,\n                                   :x2 0,\n                                   :y2 1396,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 1392,\n                                   :x2 0,\n                                   :y2 1412,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 1408,\n                                   :x2 0,\n                                   :y2 1428,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 1424,\n                                   :x2 0,\n                                   :y2 1444,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 1440,\n                                   :x2 0,\n                                   :y2 1460,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}),\n                          :page 62},\n               :content {:text \"And thus we see that at the top level of the conversation, we are dealing with the very high-level categories need for a bigger military budget and need for a smaller military budget, and the activation of either category in an advocate’s mind will trigger, with a bit of variability, yet also a considerable degree of predictability, the auxiliary ideas that will pop to mind, and these will promptly enlist appropriate stock phrases and well-worn grammatical patterns, which will in their turn call up the standarized words that comprise them — and these words, in the end, will call up, with essentially no maneuvering room, the letters or sounds that make them up.\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"6509d798-f405-4754-8c21-90365576f88b\",\n               :page 63,\n               :position {:bounding {:x1 0,\n                                     :y1 0,\n                                     :x2 891.0196533203125,\n                                     :y2 523.109375,\n                                     :width 1019.9999999999999,\n                                     :height 1319.9999999999998},\n                          :rects ({:x1 0,\n                                   :y1 0,\n                                   :x2 0,\n                                   :y2 0,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 158,\n                                   :x2 0,\n                                   :y2 178,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 735.0894775390625,\n                                   :y1 461.3125,\n                                   :x2 891.0196533203125,\n                                   :y2 489.3125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 495.109375,\n                                   :x2 690.5701904296875,\n                                   :y2 523.109375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}),\n                          :page 63},\n               :content {:text \"analogies, at all the diﬀerent levels, are in the driver’s seat\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"6509dad4-5ebc-479b-9d27-6a10d5e88ceb\",\n               :page 65,\n               :position {:bounding {:x1 0,\n                                     :y1 0,\n                                     :x2 891.991455078125,\n                                     :y2 843.046875,\n                                     :width 1019.9999999999999,\n                                     :height 1319.9999999999998},\n                          :rects ({:x1 0,\n                                   :y1 0,\n                                   :x2 0,\n                                   :y2 0,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 174,\n                                   :x2 0,\n                                   :y2 194,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 190,\n                                   :x2 0,\n                                   :y2 210,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 206,\n                                   :x2 0,\n                                   :y2 226,\n       