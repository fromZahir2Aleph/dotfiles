15",[1756,"^V",1746,536870917]],["^15",[1756,"^U",1746,536870917]],["^15",[1756,"^;","~u69a845e6-dbec-467c-8579-987b1b01f0d4",536870917]],["^15",[1757,"^Q","Mеры",536870917]],["^15",[1757,"^O","^17",536870917]],["^15",[1757,"^F",1756,536870917]],["^15",[1757,"^X",1746,536870917]],["^15",[1757,"^V",1746,536870917]],["^15",[1757,"^U",1746,536870917]],["^15",[1757,"^;","~u69a845e6-64b6-4095-afb3-c5b0b5026fa6",536870917]],["^15",[1758,"^Q","если не работает, то...",536870917]],["^15",[1758,"^O","^17",536870917]],["^15",[1758,"^F",1757,536870917]],["^15",[1758,"^X",1746,536870917]],["^15",[1758,"^V",1757,536870917]],["^15",[1758,"^U",1746,536870917]],["^15",[1758,"^;","~u69a845e6-47a7-42dd-8a89-210f32713643",536870917]],["^15",[1759,"^Q","tags:: OCD\n\n",536870917]],["^15",[1759,"^O","^17",536870917]],["^15",[1759,"^1=",["^1:",[]],536870917]],["^15",[1759,"^F",1746,536870917]],["^15",[1759,"^X",1746,536870917]],["^15",[1759,"^V",1746,536870917]],["^15",[1759,"^U",170,536870917]],["^15",[1759,"^U",1746,536870917]],["^15",[1759,"^:",true,536870917]],["^15",[1759,"^?",["^ ","^19",["^1:",["OCD"]]],536870917]],["^15",[1759,"^J",["^19"],536870917]],["^15",[1759,"^4",["^ ","^19","OCD"],536870917]],["^15",[1759,"^H",170,536870917]],["^15",[1759,"^;","~u69a845e6-30cb-435d-935e-06534cf59b5a",536870917]],["^15",[1760,"^3","- [[personality psychology/independence]]\n\t- Самые сильные как позитивные, так и негативные чувства у меня являются реакцией на других людей. Научись быть стартером в цепи обратной связи, а не шестерёнкой.",536870917]],["^15",[1760,"^16",1772635622041,536870917]],["^15",[1760,"^Z","journals/2024_01_16.md",536870917]],["^15",[1761,"^K",1772635622041,536870917]],["^15",[1761,"^[",1760,536870917]],["^15",[1761,"^N",20240116,536870917]],["^15",[1761,"^@",true,536870917]],["^15",[1761,"^Y","jan 16th, 2024",536870917]],["^15",[1761,"^11","Jan 16th, 2024",536870917]],["^15",[1761,"^B",1772635622041,536870917]],["^15",[1761,"^;","~u69a845e6-b728-4ced-a84e-115e44e39991",536870917]],["^15",[1762,"^Q","[[personality psychology/independence]]",536870917]],["^15",[1762,"^O","^17",536870917]],["^15",[1762,"^F",1761,536870917]],["^15",[1762,"^X",1761,536870917]],["^15",[1762,"^V",1761,536870917]],["^15",[1762,"^U",150,536870917]],["^15",[1762,"^U",219,536870917]],["^15",[1762,"^U",1761,536870917]],["^15",[1762,"^H",150,536870917]],["^15",[1762,"^H",219,536870917]],["^15",[1762,"^;","~u69a845e6-9106-4896-94b7-bcb924c2d22e",536870917]],["^15",[1763,"^Q","Самые сильные как позитивные, так и негативные чувства у меня являются реакцией на других людей. Научись быть стартером в цепи обратной связи, а не шестерёнкой.",536870917]],["^15",[1763,"^O","^17",536870917]],["^15",[1763,"^F",1762,536870917]],["^15",[1763,"^X",1761,536870917]],["^15",[1763,"^V",1762,536870917]],["^15",[1763,"^U",150,536870917]],["^15",[1763,"^U",219,536870917]],["^15",[1763,"^U",1761,536870917]],["^15",[1763,"^;","~u69a845e6-22b7-4646-a940-4b2e4551c96c",536870917]],["^15",[1764,"^3","- #[[personality psychology/self-worth]] #self-control Чувство достоинства требует самоконтроля без метакогнитивности. Легче держать осанку, дышать ровно и проецировать себя, чем постоянно корректировать свои мысли и действия. К тому же последнее мешает плыть по течению жизни или ловить ценные её моменты.\n\t- #[[[[personality psychology/experience seeking]]]] Воспитывай в себе хорошие качества которые повысят самоуважение, и тогда надобность в самоконроле понизится, а хороших моментов в жизни прибавится.",536870917]],["^15",[1764,"^16",1772635622057,536870917]],["^15",[1764,"^Z","journals/2024_01_15.md",536870917]],["^15",[1765,"^K",1772635622054,536870917]],["^15",[1765,"^[",1764,536870917]],["^15",[1765,"^N",20240115,536870917]],["^15",[1765,"^@",true,536870917]],["^15",[1765,"^Y","jan 15th, 2024",536870917]],["^15",[1765,"^11","Jan 15th, 2024",536870917]],["^15",[1765,"^B",1772635622054,536870917]],["^15",[1765,"^;","~u69a845e6-bde0-4a91-b1da-6ea6f5881191",536870917]],["^15",[1766,"^K",1772635622053,536870917]],["^15",[1766,"^@",false,536870917]],["^15",[1766,"^Y","personality psychology/self-worth",536870917]],["^15",[1766,"^A",150,536870917]],["^15",[1766,"^11","personality psychology/self-worth",536870917]],["^15",[1766,"^B",1772635622053,536870917]],["^15",[1766,"^;","~u69a845e6-b84b-418a-a03f-fb336bc843ac",536870917]],["^15",[1767,"^K",1772635622055,536870917]],["^15",[1767,"^@",false,536870917]],["^15",[1767,"^Y","[[personality psychology/experience seeking",536870917]],["^15",[1767,"^A",1769,536870917]],["^15",[1767,"^11","[[personality psychology/experience seeking",536870917]],["^15",[1767,"^B",1772635622055,536870917]],["^15",[1767,"^;","~u69a845e6-b64a-438e-92f7-bf912bf0bc9b",536870917]],["^15",[1768,"^K",1772635622056,536870917]],["^15",[1768,"^@",false,536870917]],["^15",[1768,"^Y","[[personality psychology/experience seeking]]",536870917]],["^15",[1768,"^11","[[personality psychology/experience seeking]]",536870917]],["^15",[1768,"^B",1772635622056,536870917]],["^15",[1768,"^;","~u69a845e6-564d-47d9-8f8f-d9cef92ede99",536870917]],["^15",[1769,"^K",1772635622056,536870917]],["^15",[1769,"^@",false,536870917]],["^15",[1769,"^Y","[[personality psychology",536870917]],["^15",[1769,"^11","[[personality psychology",536870917]],["^15",[1769,"^B",1772635622056,536870917]],["^15",[1769,"^;","~u69a845e6-7d71-4a19-9860-5238c9338d90",536870917]],["^15",[1770,"^Q","#[[personality psychology/self-worth]] #self-control Чувство достоинства требует самоконтроля без метакогнитивности. Легче держать осанку, дышать ровно и проецировать себя, чем постоянно корректировать свои мысли и действия. К тому же последнее мешает плыть по течению жизни или ловить ценные её моменты.",536870917]],["^15",[1770,"^O","^17",536870917]],["^15",[1770,"^F",1765,536870917]],["^15",[1770,"^X",1765,536870917]],["^15",[1770,"^V",1765,536870917]],["^15",[1770,"^U",150,536870917]],["^15",[1770,"^U",1293,536870917]],["^15",[1770,"^U",1765,536870917]],["^15",[1770,"^U",1766,536870917]],["^15",[1770,"^H",150,536870917]],["^15",[1770,"^H",1293,536870917]],["^15",[1770,"^H",1766,536870917]],["^15",[1770,"^;","~u69a845e6-c267-445a-bb3a-1d2fbe8760a1",536870917]],["^15",[1771,"^Q","#[[[[personality psychology/experience seeking]]]] Воспитывай в себе хорошие качества которые повысят самоуважение, и тогда надобность в самоконроле понизится, а хороших моментов в жизни прибавится.",536870917]],["^15",[1771,"^O","^17",536870917]],["^15",[1771,"^F",1770,536870917]],["^15",[1771,"^X",1765,536870917]],["^15",[1771,"^V",1770,536870917]],["^15",[1771,"^U",150,536870917]],["^15",[1771,"^U",1040,536870917]],["^15",[1771,"^U",1293,536870917]],["^15",[1771,"^U",1765,536870917]],["^15",[1771,"^U",1766,536870917]],["^15",[1771,"^U",1767,536870917]],["^15",[1771,"^U",1768,536870917]],["^15",[1771,"^U",1769,536870917]],["^15",[1771,"^H",150,536870917]],["^15",[1771,"^H",1040,536870917]],["^15",[1771,"^H",1767,536870917]],["^15",[1771,"^H",1768,536870917]],["^15",[1771,"^H",1769,536870917]],["^15",[1771,"^;","~u69a845e6-f8c2-40c6-ac85-75fe8bdeb695",536870917]],["^15",[1772,"^3","- [[self-reference/autological]]\n\t- В автологических произведениях форма описывает сущность, напр., в музыке, поэзии и изобразительных искусствах. Примеры из прозы: Волны Вирджинии Вульф. Если брать шире то слог Борхеса и Толстого тоже описывает философию этих авторов и содержание их работ.\n",536870917]],["^15",[1772,"^16",1772635622068,536870917]],["^15",[1772,"^Z","journals/2023_12_29.md",536870917]],["^15",[1773,"^K",1772635622067,536870917]],["^15",[1773,"^[",1772,536870917]],["^15",[1773,"^N",20231229,536870917]],["^15",[1773,"^@",true,536870917]],["^15",[1773,"^Y","dec 29th, 2023",536870917]],["^15",[1773,"^11","Dec 29th, 2023",536870917]],["^15",[1773,"^B",1772635622067,536870917]],["^15",[1773,"^;","~u69a845e6-7768-4bf1-82b8-6bd7b10a8ae4",536870917]],["^15",[1774,"^K",1772635622067,536870917]],["^15",[1774,"^@",false,536870917]],["^15",[1774,"^Y","self-reference/autological",536870917]],["^15",[1774,"^A",1775,536870917]],["^15",[1774,"^11","self-reference/autological",536870917]],["^15",[1774,"^B",1772635622067,536870917]],["^15",[1774,"^;","~u69a845e6-54b6-48fb-be34-922a5dffa77b",536870917]],["^15",[1775,"^K",1772635622067,536870917]],["^15",[1775,"^@",false,536870917]],["^15",[1775,"^Y","self-reference",536870917]],["^15",[1775,"^11","self-reference",536870917]],["^15",[1775,"^B",1772635622067,536870917]],["^15",[1775,"^;","~u69a845e6-5aa7-43e7-ba76-c62ff78d0698",536870917]],["^15",[1776,"^Q","[[self-reference/autological]]",536870917]],["^15",[1776,"^O","^17",536870917]],["^15",[1776,"^F",1773,536870917]],["^15",[1776,"^X",1773,536870917]],["^15",[1776,"^V",1773,536870917]],["^15",[1776,"^U",1773,536870917]],["^15",[1776,"^U",1774,536870917]],["^15",[1776,"^U",1775,536870917]],["^15",[1776,"^H",1774,536870917]],["^15",[1776,"^H",1775,536870917]],["^15",[1776,"^;","~u69a845e6-bb65-4713-b6d5-38fce6bf6e24",536870917]],["^15",[1777,"^Q","В автологических произведениях форма описывает сущность, напр., в музыке, поэзии и изобразительных искусствах. Примеры из прозы: Волны Вирджинии Вульф. Если брать шире то слог Борхеса и Толстого тоже описывает философию этих авторов и содержание их работ.",536870917]],["^15",[1777,"^O","^17",536870917]],["^15",[1777,"^F",1776,536870917]],["^15",[1777,"^X",1773,536870917]],["^15",[1777,"^V",1776,536870917]],["^15",[1777,"^U",1773,536870917]],["^15",[1777,"^U",1774,536870917]],["^15",[1777,"^U",1775,536870917]],["^15",[1777,"^;","~u69a845e6-943c-4b56-81ed-75381931c39e",536870917]],["^15",[1778,"^3","- #[[action/anticipatory commitment]]\n\t- #[[free will]] Будь готов к хорошему исходу событий, например, просто-напросто к хорошему завтрашнему дню. Когда наступит то, чего ты боялся, ты ничего не сможешь с этим поделать. Что ещё хуже, ты потратишь время на опасения впустую и не сможешь насладиться днём обычным. Поэтому просто жди его, пока есть хоть какая-то на это вероятность.\n\t- #determinism [[personality psychology/anxiety/anticipatory anxiety]] Не бойся плохого исхода. Страх в преддверии его наступления помешает тебе справиться с проблемой, если есть таковая возможность. Если её нет, то пусть день ненастья будет твоим периодом неудовлетворения или же началом горестного времени.\n\t\t- Некоторые события содержат в себе и свободную волю, и детерминизм. Самый яркий пример - рождение ребёнка. Ты можешь при наличии определённых условий выбрать факт самого рождения. Но ты мало можешь повлиять на то, как оно пройдёт, будет ли ребёнок здоров, будут ли его детство, зрелость и старость в меру счастливыми. Прими это.\n\t- [[action/anticipatory commitment/planfulness]] [[action/anticipatory commitment/purposefulness]] [[action/anticipatory commitment/self-discipline]]\n\t\t- Будь также готов к запланированной или незапланированной ответственности.",536870917]],["^15",[1778,"^16",1772635622086,536870917]],["^15",[1778,"^Z","journals/2023_12_06.md",536870917]],["^15",[1779,"^K",1772635622234,536870917]],["^15",[1779,"^@",false,536870917]],["^15",[1779,"^Y","personality psychology/anxiety/anticipatory anxiety",536870917]],["^15",[1779,"^A",148,536870917]],["^15",[1779,"^11","personality psychology/anxiety/anticipatory anxiety",536870917]],["^15",[1779,"^B",1772635622234,536870917]],["^15",[1779,"^;","~u69a845e6-2f1c-409c-bf06-9b3cc37c06dd",536870917]],["^15",[1780,"^K",1772635622084,536870917]],["^15",[1780,"^@",false,536870917]],["^15",[1780,"^Y","free will",536870917]],["^15",[1780,"^11","free will",536870917]],["^15",[1780,"^B",1772635622084,536870917]],["^15",[1780,"^;","~u69a845e6-8962-4a6a-8a32-e29630c227fc",536870917]],["^15",[1781,"^K",1772635622085,536870917]],["^15",[1781,"^@",false,536870917]],["^15",[1781,"^Y","determinism",536870917]],["^15",[1781,"^11","determinism",536870917]],["^15",[1781,"^B",1772635622085,536870917]],["^15",[1781,"^;","~u69a845e6-62ee-4657-945c-b01bc5bbf6fa",536870917]],["^15",[1782,"^K",1772635622083,536870917]],["^15",[1782,"^[",1778,536870917]],[