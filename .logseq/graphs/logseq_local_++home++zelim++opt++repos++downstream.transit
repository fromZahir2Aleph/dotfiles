убивали друг друга.",536870917]],["^15",[2174,"^O","^17",536870917]],["^15",[2174,"^F",2258,536870917]],["^15",[2174,"^X",2161,536870917]],["^15",[2174,"^V",2258,536870917]],["^15",[2174,"^U",2161,536870917]],["^15",[2174,"^;","~u69a845e6-1f0e-4320-b5cc-d9d9ba57edb9",536870917]],["^15",[2175,"^Q","Циклопы в Одиссее",536870917]],["^15",[2175,"^O","^17",536870917]],["^15",[2175,"^F",2226,536870917]],["^15",[2175,"^X",2161,536870917]],["^15",[2175,"^V",2255,536870917]],["^15",[2175,"^U",2161,536870917]],["^15",[2175,"^;","~u69a845e6-31b4-49d5-84e5-50323f19cf8f",536870917]],["^15",[2176,"^Q","Ἥφαιστος\n.tags::\n.being:: god\n.mythology:: Greece\n.transcription:: /hɛ̌ː.pʰai̯s.tos/\n.translation:: Гефест\n.flags:: Olympian\nid:: 66ba0f9a-fa8e-429f-aaef-bca6524c1fe8",536870917]],["^15",[2176,"^O","^17",536870917]],["^15",[2176,"^F",2314,536870917]],["^15",[2176,"^X",2161,536870917]],["^15",[2176,"^V",2300,536870917]],["^15",[2176,"^U",2157,536870917]],["^15",[2176,"^U",2158,536870917]],["^15",[2176,"^U",2161,536870917]],["^15",[2176,"^U",2162,536870917]],["^15",[2176,"^U",2164,536870917]],["^15",[2176,"^U",2166,536870917]],["^15",[2176,"^U",2167,536870917]],["^15",[2176,"^?",["^ ","^1R","","^1S","god","^1T","Greece","^1U","/hɛ̌ː.pʰai̯s.tos/","^1V","Гефест","^1W","Olympian","^1>","66ba0f9a-fa8e-429f-aaef-bca6524c1fe8"],536870917]],["^15",[2176,"^J",["^1R","^1S","^1T","^1U","^1V","^1W","^1>"],536870917]],["^15",[2176,"^4",["^ ","^1R","","^1S","god","^1T","Greece","^1U","/hɛ̌ː.pʰai̯s.tos/","^1V","Гефест","^1W","Olympian","^1>","66ba0f9a-fa8e-429f-aaef-bca6524c1fe8"],536870917]],["^15",[2176,"^H",2157,536870917]],["^15",[2176,"^H",2158,536870917]],["^15",[2176,"^H",2162,536870917]],["^15",[2176,"^H",2164,536870917]],["^15",[2176,"^H",2166,536870917]],["^15",[2176,"^H",2167,536870917]],["^15",[2176,"^;","~u66ba0f9a-fa8e-429f-aaef-bca6524c1fe8",536870917]],["^15",[2177,"^Q","Маловероятно, но интересно",536870917]],["^15",[2177,"^O","^17",536870917]],["^15",[2177,"^F",2212,536870917]],["^15",[2177,"^X",2161,536870917]],["^15",[2177,"^V",2212,536870917]],["^15",[2177,"^U",2161,536870917]],["^15",[2177,"^;","~u69a845e6-5f83-4ea2-a99b-26deeb997f6c",536870917]],["^15",[2178,"^Q","Титаны и Титаниды",536870917]],["^15",[2178,"^O","^17",536870917]],["^15",[2178,"^F",2263,536870917]],["^15",[2178,"^X",2161,536870917]],["^15",[2178,"^V",2315,536870917]],["^15",[2178,"^U",2161,536870917]],["^15",[2178,"^;","~u69a845e6-69da-4fbf-bced-5cf80c99c00e",536870917]],["^15",[2179,"^Q","Зевс тоже занялся генной инженерией. Мотивы - зависть к скилам отца и тщеславие. От людей без храмов и жертвоприношений нет прока богам, хоть храмы те и не посещают, а угощения не поедают. Они спускались, чтобы поваляться с нимфами или нашими девками и парнями, или погоняться за ними. Первый запуск был с большим багом, лишней хромосомой. Организм рос, но не самозапускался.",536870917]],["^15",[2179,"^O","^17",536870917]],["^15",[2179,"^F",2259,536870917]],["^15",[2179,"^X",2161,536870917]],["^15",[2179,"^V",2259,536870917]],["^15",[2179,"^U",2161,536870917]],["^15",[2179,"^;","~u69a845e6-f72a-47db-b199-bd15bc665798",536870917]],["^15",[2180,"^Q","Теомахия",536870917]],["^15",[2180,"^O","^17",536870917]],["^15",[2180,"^F",2183,536870917]],["^15",[2180,"^X",2161,536870917]],["^15",[2180,"^V",2183,536870917]],["^15",[2180,"^U",2161,536870917]],["^15",[2180,"^;","~u69a845e6-e378-440e-a51d-6d2485215837",536870917]],["^15",[2181,"^M",true,536870917]],["^15",[2181,"^Q","Калечение Гефеста\ncollapsed:: true",536870917]],["^15",[2181,"^O","^17",536870917]],["^15",[2181,"^F",2272,536870917]],["^15",[2181,"^X",2161,536870917]],["^15",[2181,"^V",2272,536870917]],["^15",[2181,"^U",2159,536870917]],["^15",[2181,"^U",2161,536870917]],["^15",[2181,"^?",["^ "],536870917]],["^15",[2181,"^J",[],536870917]],["^15",[2181,"^4",["^ "],536870917]],["^15",[2181,"^;","~u69a845e6-261a-4b51-acbd-9e798cc15909",536870917]],["^15",[2182,"^Q","[Гефест](((66ba0f9a-fa8e-429f-aaef-bca6524c1fe8))) был сыном титана, но ему говорили, что он безотцовщина.",536870917]],["^15",[2182,"^O","^17",536870917]],["^15",[2182,"^F",2181,536870917]],["^15",[2182,"^X",2161,536870917]],["^15",[2182,"^V",2181,536870917]],["^15",[2182,"^U",2159,536870917]],["^15",[2182,"^U",2161,536870917]],["^15",[2182,"^H",2176,536870917]],["^15",[2182,"^;","~u69a845e6-3b7b-4adf-9e52-7f5445355a21",536870917]],["^15",[2183,"^Q","...рас и поколений",536870917]],["^15",[2183,"^O","^17",536870917]],["^15",[2183,"^F",2328,536870917]],["^15",[2183,"^X",2161,536870917]],["^15",[2183,"^V",2328,536870917]],["^15",[2183,"^U",2161,536870917]],["^15",[2183,"^;","~u69a845e6-52ea-46b8-b2ce-b9ecd689088f",536870917]],["^15",[2184,"^Q","Троянский конь",536870917]],["^15",[2184,"^O","^17",536870917]],["^15",[2184,"^F",2238,536870917]],["^15",[2184,"^X",2161,536870917]],["^15",[2184,"^V",2221,536870917]],["^15",[2184,"^U",2161,536870917]],["^15",[2184,"^;","~u69a845e6-afeb-4735-94fa-175fb7b78b62",536870917]],["^15",[2185,"^Q","Немейские в честь [Зевса](((64af0846-e1c6-440c-9c8c-0da4d05fc25d)))",536870917]],["^15",[2185,"^O","^17",536870917]],["^15",[2185,"^F",2303,536870917]],["^15",[2185,"^X",2161,536870917]],["^15",[2185,"^V",2296,536870917]],["^15",[2185,"^U",2161,536870917]],["^15",[2185,"^H",2326,536870917]],["^15",[2185,"^;","~u69a845e6-25ea-4203-813f-0b4bbaf864c5",536870917]],["^15",[2186,"^Q","[[Alternate mythology]]",536870917]],["^15",[2186,"^O","^17",536870917]],["^15",[2186,"^F",2239,536870917]],["^15",[2186,"^X",2161,536870917]],["^15",[2186,"^V",2239,536870917]],["^15",[2186,"^U",2157,536870917]],["^15",[2186,"^U",2158,536870917]],["^15",[2186,"^U",2159,536870917]],["^15",[2186,"^U",2161,536870917]],["^15",[2186,"^U",2162,536870917]],["^15",[2186,"^U",2164,536870917]],["^15",[2186,"^U",2166,536870917]],["^15",[2186,"^U",2167,536870917]],["^15",[2186,"^H",2159,536870917]],["^15",[2186,"^;","~u69a845e6-ac41-488a-b26c-2d841e9d7452",536870917]],["^15",[2187,"^Q","Ζαγρεύς\n.tags:: \n.being:: god\n.mythology:: Greece\n.transcription:: /zdag.rěu̯s/\n.translation:: Загрей\n.flags::",536870917]],["^15",[2187,"^O","^17",536870917]],["^15",[2187,"^F",2232,536870917]],["^15",[2187,"^X",2161,536870917]],["^15",[2187,"^V",2315,536870917]],["^15",[2187,"^U",2157,536870917]],["^15",[2187,"^U",2158,536870917]],["^15",[2187,"^U",2161,536870917]],["^15",[2187,"^U",2162,536870917]],["^15",[2187,"^U",2164,536870917]],["^15",[2187,"^U",2166,536870917]],["^15",[2187,"^U",2167,536870917]],["^15",[2187,"^?",["^ ","^1R","","^1S","god","^1T","Greece","^1U","/zdag.rěu̯s/","^1V","Загрей","^1W",""],536870917]],["^15",[2187,"^J",["^1R","^1S","^1T","^1U","^1V","^1W"],536870917]],["^15",[2187,"^4",["^ ","^1R","","^1S","god","^1T","Greece","^1U","/zdag.rěu̯s/","^1V","Загрей","^1W",""],536870917]],["^15",[2187,"^H",2157,536870917]],["^15",[2187,"^H",2158,536870917]],["^15",[2187,"^H",2162,536870917]],["^15",[2187,"^H",2164,536870917]],["^15",[2187,"^H",2166,536870917]],["^15",[2187,"^H",2167,536870917]],["^15",[2187,"^;","~u69a845e6-c59c-48a9-8105-d181fd04c793",536870917]],["^15",[2188,"^M",true,536870917]],["^15",[2188,"^Q","Дилос - сакральный и геометрический центр Киклад, место рождения [Аполлона](((3755fb37-1121-4a9c-a22d-2fee9141dc8e))) и [Артемиды](((64f10e8f-7931-4b80-9e4f-3e3ce7882297))).\ncollapsed:: true",536870917]],["^15",[2188,"^O","^17",536870917]],["^15",[2188,"^F",2328,536870917]],["^15",[2188,"^X",2161,536870917]],["^15",[2188,"^V",2161,536870917]],["^15",[2188,"^U",2161,536870917]],["^15",[2188,"^?",["^ "],536870917]],["^15",[2188,"^J",[],536870917]],["^15",[2188,"^4",["^ "],536870917]],["^15",[2188,"^H",2319,536870917]],["^15",[2188,"^H",2321,536870917]],["^15",[2188,"^;","~u69a845e6-32a1-4c58-907f-70918149ede3",536870917]],["^15",[2189,"^Q","Среди греческих героев есть и варвары. Самые известные - фракиец Орфей и финикиец Кадм.",536870917]],["^15",[2189,"^O","^17",536870917]],["^15",[2189,"^F",2297,536870917]],["^15",[2189,"^X",2161,536870917]],["^15",[2189,"^V",2282,536870917]],["^15",[2189,"^U",2161,536870917]],["^15",[2189,"^;","~u69a845e6-1e1d-432f-a80d-9010205ab613",536870917]],["^15",[2190,"^Q","После окончания второй греко-персидской войны ещё и политический центр Дилосского союза. Полисы, входившие в него, собирались внутри храма острова как на нейтральной священной территории. Там же хранилась общая казна.",536870917]],["^15",[2190,"^O","^17",536870917]],["^15",[2190,"^F",2268,536870917]],["^15",[2190,"^X",2161,536870917]],["^15",[2190,"^V",2188,536870917]],["^15",[2190,"^U",2161,536870917]],["^15",[2190,"^;","~u69a845e6-9558-404c-8d50-326e5e426d6d",536870917]],["^15",[2191,"^Q","Αἰθήρ\n.tags::\n.being:: god\n.mythology:: Greece\n.transcription:: /ai̯.tʰɛ̌ːr/\n.translation:: Эфир\n.flags:: primordial, personification",536870917]],["^15",[2191,"^O","^17",536870917]],["^15",[2191,"^F",2246,536870917]],["^15",[2191,"^X",2161,536870917]],["^15",[2191,"^V",2244,536870917]],["^15",[2191,"^U",2157,536870917]],["^15",[2191,"^U",2158,536870917]],["^15",[2191,"^U",2161,536870917]],["^15",[2191,"^U",2162,536870917]],["^15",[2191,"^U",2164,536870917]],["^15",[2191,"^U",2166,536870917]],["^15",[2191,"^U",2167,536870917]],["^15",[2191,"^?",["^ ","^1R","","^1S","god","^1T","Greece","^1U","/ai̯.tʰɛ̌ːr/","^1V","Эфир","^1W","primordial, personification"],536870917]],["^15",[2191,"^J",["^1R","^1S","^1T","^1U","^1V","^1W"],536870917]],["^15",[2191,"^4",["^ ","^1R","","^1S","god","^1T","Greece","^1U","/ai̯.tʰɛ̌ːr/","^1V","Эфир","^1W","primordial, personification"],536870917]],["^15",[2191,"^H",2157,536870917]],["^15",[2191,"^H",2158,536870917]],["^15",[2191,"^H",2162,536870917]],["^15",[2191,"^H",2164,536870917]],["^15",[2191,"^H",2166,536870917]],["^15",[2191,"^H",2167,536870917]],["^15",[2191,"^;","~u69a845e6-b056-44c8-8081-8b143371e600",536870917]],["^15",[2192,"^Q","Отец монстров",536870917]],["^15",[2192,"^O","^17",536870917]],["^15",[2192,"^F",2291,536870917]],["^15",[2192,"^X",2161,536870917]],["^15",[2192,"^V",2291,536870917]],["^15",[2192,"^U",2157,536870917]],["^15",[2192,"^U",2158,536870917]],["^15",[2192,"^U",2161,536870917]],["^15",[2192,"^U",2162,536870917]],["^15",[2192,"^U",2164,536870917]],["^15",[2192,"^U",2166,536870917]],["^15",[2192,"^U",2167,536870917]],["^15",[2192,"^;","~u69a845e6-b74b-4b86-9830-11502778b08d",536870917]],["^15",[2193,"^Q","2. В начале Пелопоннесской войны по наставлению оракула , переместив все могилы с острова. Также издали указ о запрете смерти и рождения на острове. Если же в окно стучался Кондратий или в пузо малёкв окно стучался Кондратий или в пузо малёк, то умирающего или беременную надлежало перевезти на Ринию.",536870917]],["^15",[2193,"^O","^17",536870917]],["^15",[2193,"^F",2206,536870917]],["^15",[2193,"^X",2161,536870917]],["^15",[2193,"^V",2266,536870917]],["^15",[2193,"^U",2161,536870917]],["^15",[2193,"^;","~u69a845e6-a776-4afb-ba98-1748164a2c3c",536870917]],["^15",[2194,"^Q","[[Commentary]]",536870917]],["^15",[2194,"^O","^17",536870917]],["^15",[2194,"^F",2275,536870917]],["^15",[2194,"^X",2161,536870917]],["^15",[2194,"^V",2255,536870917]],["^15",[2194,"^U",2160,536870917]],["^15",[2194,"^U",2161,536870917]],["^15",[2194,"^H",2160,536870917]],["^15",[2194,"^;","~u69a845e6-0cee-4625-8f69-1400d6945882",536870917]],["^15",[2195,"^Q","Если представить Эроса как шопенгауэровскую Волю к жизни, то он хорошо вписывается в первое поколение, особенно в контексте [Chaoskampf](((64b9bd7a-92b2-4e98-9aa3-fe085f42caea))).",536870917]],["^15",[2195,"^O","^17",536870917]],["^15",[2195,"^F",2331,536870917]],["^15",[2195,"^X",2161,536870917]],["^15",[2195,"^V",2331,536870917]],["^15",[2195,"^U",2157,536870917]],["^15",[2195,"^U",2158,536870917]],["^15",[2195,"^U",2161,536870917]],["^15",[2195,"^U",2162,536870917]],["^15",[2195,"^U",2164,536870917]],["^15",[2195,"^U",2166,536870917]],["^15",[2195,"^U",2167,536870917]],["^15",[2195,"^H",2265,536870917]],["^15",[2195,"^;","~u69a845e6-b445-4bd7-b72e-016a07753f4e",536870917]],["^15",[2196,"^Q","Шлем [Аида](((64c03a7d-7892-4801-8d84-6c73