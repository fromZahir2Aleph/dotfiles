70915]],["^15",[1205,"^H",1195,536870915]],["^15",[1205,"^H",1196,536870915]],["^15",[1205,"^;","~u69a845e4-8275-4c41-9585-643e0ce98ec6",536870915]],["^15",[1206,"^Q","[[personality psychology/accentuation]]",536870915]],["^15",[1206,"^O","^17",536870915]],["^15",[1206,"^F",1191,536870915]],["^15",[1206,"^X",1191,536870915]],["^15",[1206,"^V",1191,536870915]],["^15",[1206,"^U",150,536870915]],["^15",[1206,"^U",1191,536870915]],["^15",[1206,"^U",1192,536870915]],["^15",[1206,"^H",150,536870915]],["^15",[1206,"^H",1192,536870915]],["^15",[1206,"^;","~u69a845e4-4e05-4d66-aa5f-e92fd65fb58c",536870915]],["^15",[1207,"^Q","На улице",536870915]],["^15",[1207,"^O","^17",536870915]],["^15",[1207,"^F",1199,536870915]],["^15",[1207,"^X",1191,536870915]],["^15",[1207,"^V",1199,536870915]],["^15",[1207,"^U",150,536870915]],["^15",[1207,"^U",1191,536870915]],["^15",[1207,"^U",1192,536870915]],["^15",[1207,"^U",1193,536870915]],["^15",[1207,"^;","~u69a845e4-0aef-40a3-8bf1-182a3b726da2",536870915]],["^15",[1208,"^Q","Замени мат неручными и неречевыми сигналами.",536870915]],["^15",[1208,"^O","^17",536870915]],["^15",[1208,"^F",1201,536870915]],["^15",[1208,"^X",1191,536870915]],["^15",[1208,"^V",1201,536870915]],["^15",[1208,"^U",150,536870915]],["^15",[1208,"^U",1191,536870915]],["^15",[1208,"^U",1192,536870915]],["^15",[1208,"^U",1193,536870915]],["^15",[1208,"^;","~u69a845e4-c67a-45e2-8720-da4fb23d1163",536870915]],["^15",[1209,"^3","- [[cognitive dialectic]]\n\t- Рассеивай и записывай мысли, наблюдения и умозаключения, потом собирай их в единое. Рассеивать станет сложнее с возрастом по мере того, как ты станешь более ригидным и менее любопытным.\n\t- Я всегда любил строить воздушные замки, но лет пять назад я полюбил разрушать их. Стремясь упорядочить новоприобретённые концепции, ты начинаешь как их адепт. Затем твоё критическое мышление вносит поправки.в разных странах мира",536870915]],["^15",[1209,"^16",1772635620204,536870915]],["^15",[1209,"^Z","journals/2025_05_08.md",536870915]],["^15",[1210,"^K",1772635620203,536870915]],["^15",[1210,"^[",1209,536870915]],["^15",[1210,"^N",20250508,536870915]],["^15",[1210,"^@",true,536870915]],["^15",[1210,"^Y","may 8th, 2025",536870915]],["^15",[1210,"^11","May 8th, 2025",536870915]],["^15",[1210,"^B",1772635620203,536870915]],["^15",[1210,"^;","~u69a845e4-0ac8-4ffe-831c-6d97880b1620",536870915]],["^15",[1211,"^K",1772635620263,536870915]],["^15",[1211,"^@",false,536870915]],["^15",[1211,"^Y","cognitive dialectic",536870915]],["^15",[1211,"^11","cognitive dialectic",536870915]],["^15",[1211,"^B",1772635620263,536870915]],["^15",[1211,"^;","~u69a845e4-fbd9-4913-9f6b-09491bad6da4",536870915]],["^15",[1212,"^Q","[[cognitive dialectic]]",536870915]],["^15",[1212,"^O","^17",536870915]],["^15",[1212,"^F",1210,536870915]],["^15",[1212,"^X",1210,536870915]],["^15",[1212,"^V",1210,536870915]],["^15",[1212,"^U",1210,536870915]],["^15",[1212,"^U",1211,536870915]],["^15",[1212,"^H",1211,536870915]],["^15",[1212,"^;","~u69a845e4-60e0-4781-b620-0a46d0cf7c64",536870915]],["^15",[1213,"^Q","Рассеивай и записывай мысли, наблюдения и умозаключения, потом собирай их в единое. Рассеивать станет сложнее с возрастом по мере того, как ты станешь более ригидным и менее любопытным.",536870915]],["^15",[1213,"^O","^17",536870915]],["^15",[1213,"^F",1212,536870915]],["^15",[1213,"^X",1210,536870915]],["^15",[1213,"^V",1212,536870915]],["^15",[1213,"^U",1210,536870915]],["^15",[1213,"^U",1211,536870915]],["^15",[1213,"^;","~u69a845e4-e550-4fbf-ad58-54d1a200e2e0",536870915]],["^15",[1214,"^Q","Я всегда любил строить воздушные замки, но лет пять назад я полюбил разрушать их. Стремясь упорядочить новоприобретённые концепции, ты начинаешь как их адепт. Затем твоё критическое мышление вносит поправки.в разных странах мира",536870915]],["^15",[1214,"^O","^17",536870915]],["^15",[1214,"^F",1213,536870915]],["^15",[1214,"^X",1210,536870915]],["^15",[1214,"^V",1212,536870915]],["^15",[1214,"^U",1210,536870915]],["^15",[1214,"^U",1211,536870915]],["^15",[1214,"^;","~u69a845e4-6937-4ff5-a110-ccff422ec910",536870915]],["^15",[1215,"^3","- [[letter to Nika]]\n\t- Отрывки\n\t\t- Моя первая учительница, доктор Давал и ты Ника - три человека вне моей семьи, которые сформировали мою личность соответственно образованием, психотерапией и советом.\n\t\t- Запоздалое, несвоевроменное, но искреннее спасибо. Хотел приберечь его и высказаться, когда моя жизнь наладится, чтобы ты записался меня в актив, в список пациентов, которым ты помогла.\n\t\t\t- Может, этого никогда не случится, потому что на данный момент СХУ/постковид неизлечиваем. Но благодаря тебе годы первые годы после Феникса и даже то, как я справляюсь сегодня с болезнью.\n\t\t- Личный портной\n\t\t\t- Задним числом\n\t\t\t\t- Аутентичность, акцентуация\n\t\t\t\t- Отверг превосходсто интеллекта\n\t\t\t\t- Малодушие, токсичность, истероидность\n\t\t\t\t- Культ карго\n\t\t- Я не прохожу мимо, просто присяду на скамейку.",536870915]],["^15",[1215,"^16",1772635620221,536870915]],["^15",[1215,"^Z","journals/2025_04_28.md",536870915]],["^15",[1216,"^K",1772635620220,536870915]],["^15",[1216,"^[",1215,536870915]],["^15",[1216,"^N",20250428,536870915]],["^15",[1216,"^@",true,536870915]],["^15",[1216,"^Y","apr 28th, 2025",536870915]],["^15",[1216,"^11","Apr 28th, 2025",536870915]],["^15",[1216,"^B",1772635620220,536870915]],["^15",[1216,"^;","~u69a845e4-f426-4673-b17e-bda659105c6b",536870915]],["^15",[1217,"^K",1772635620219,536870915]],["^15",[1217,"^@",false,536870915]],["^15",[1217,"^Y","letter to nika",536870915]],["^15",[1217,"^11","letter to Nika",536870915]],["^15",[1217,"^B",1772635620219,536870915]],["^15",[1217,"^;","~u69a845e4-5584-4c0d-b418-5e9435b7309e",536870915]],["^15",[1218,"^Q","[[letter to Nika]]",536870915]],["^15",[1218,"^O","^17",536870915]],["^15",[1218,"^F",1216,536870915]],["^15",[1218,"^X",1216,536870915]],["^15",[1218,"^V",1216,536870915]],["^15",[1218,"^U",1216,536870915]],["^15",[1218,"^U",1217,536870915]],["^15",[1218,"^H",1217,536870915]],["^15",[1218,"^;","~u69a845e4-a4a8-45d8-b13e-1c4fd9bd2b97",536870915]],["^15",[1219,"^Q","Запоздалое, несвоевроменное, но искреннее спасибо. Хотел приберечь его и высказаться, когда моя жизнь наладится, чтобы ты записался меня в актив, в список пациентов, которым ты помогла.",536870915]],["^15",[1219,"^O","^17",536870915]],["^15",[1219,"^F",1220,536870915]],["^15",[1219,"^X",1216,536870915]],["^15",[1219,"^V",1227,536870915]],["^15",[1219,"^U",1216,536870915]],["^15",[1219,"^U",1217,536870915]],["^15",[1219,"^;","~u69a845e4-2ebc-4a69-81b1-556bff81ff63",536870915]],["^15",[1220,"^Q","Моя первая учительница, доктор Давал и ты Ника - три человека вне моей семьи, которые сформировали мою личность соответственно образованием, психотерапией и советом.",536870915]],["^15",[1220,"^O","^17",536870915]],["^15",[1220,"^F",1227,536870915]],["^15",[1220,"^X",1216,536870915]],["^15",[1220,"^V",1227,536870915]],["^15",[1220,"^U",1216,536870915]],["^15",[1220,"^U",1217,536870915]],["^15",[1220,"^;","~u69a845e4-fb12-42a8-bef8-00a401c95d5f",536870915]],["^15",[1221,"^Q","Я не прохожу мимо, просто присяду на скамейку.",536870915]],["^15",[1221,"^O","^17",536870915]],["^15",[1221,"^F",1228,536870915]],["^15",[1221,"^X",1216,536870915]],["^15",[1221,"^V",1227,536870915]],["^15",[1221,"^U",1216,536870915]],["^15",[1221,"^U",1217,536870915]],["^15",[1221,"^;","~u69a845e4-77ad-49a1-8bc8-dd972ec61b06",536870915]],["^15",[1222,"^Q","Отверг превосходсто интеллекта",536870915]],["^15",[1222,"^O","^17",536870915]],["^15",[1222,"^F",1225,536870915]],["^15",[1222,"^X",1216,536870915]],["^15",[1222,"^V",1223,536870915]],["^15",[1222,"^U",1216,536870915]],["^15",[1222,"^U",1217,536870915]],["^15",[1222,"^;","~u69a845e4-1e1f-45e5-8655-a3c28441dc15",536870915]],["^15",[1223,"^Q","Задним числом",536870915]],["^15",[1223,"^O","^17",536870915]],["^15",[1223,"^F",1228,536870915]],["^15",[1223,"^X",1216,536870915]],["^15",[1223,"^V",1228,536870915]],["^15",[1223,"^U",1216,536870915]],["^15"