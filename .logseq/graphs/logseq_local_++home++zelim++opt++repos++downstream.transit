,[606,"^O","^1;",536870919]],["^15",[606,"^F",605,536870919]],["^15",[606,"^X",605,536870919]],["^15",[606,"^V",605,536870919]],["^15",[606,"^U",34,536870919]],["^15",[606,"^U",52,536870919]],["^15",[606,"^U",207,536870919]],["^15",[606,"^U",605,536870919]],["^15",[606,"^H",34,536870919]],["^15",[606,"^H",52,536870919]],["^15",[606,"^H",207,536870919]],["^15",[606,"^;","~u686ffd65-c978-42aa-a50e-f9e843c95beb",536870919]],["^15",[607,"^3","tags:: diary\ntype:: acknowledgement\nmood:: sad\n\n- #Оа Tы был мне плохим отцом, но я тебя любил, люблю и буду любить. Я скучаю по тебе. Я прощаю тебя за твой эгоизм. Прости меня и ты за мой. И за другие слабости. Я прощаю себя за них ради мамы, ради Седы и себя, но уже, к сожалению, не ради тебя. \n  С любовью и последним и единственным поцелуем, твой, всё-таки  твой, Зема, хоть и не Зеламх.",536870919]],["^15",[607,"^16",1752169829074,536870919]],["^15",[607,"^Z","journals/2024_05_19.md",536870919]],["^15",[608,"^K",1752169829073,536870919]],["^15",[608,"^[",607,536870919]],["^15",[608,"^N",20240519,536870919]],["^15",[608,"^@",true,536870919]],["^15",[608,"^Y","may 19th, 2024",536870919]],["^15",[608,"^11","May 19th, 2024",536870919]],["^15",[608,"^?",["^ ","^18",["^19",["diary"]],"^1=","acknowledgement","^1>","sad"],536870919]],["^15",[608,"^4",["^ ","^18","diary","^1=","acknowledgement","^1>","sad"],536870919]],["^15",[608,"^P",69,536870919]],["^15",[608,"^B",1752169829073,536870919]],["^15",[608,"^;","~u686ffd65-28dc-4e22-8ec3-457b3c5bc24a",536870919]],["^15",[609,"^Q","tags:: diary\ntype:: acknowledgement\nmood:: sad\n\n",536870919]],["^15",[609,"^O","^1;",536870919]],["^15",[609,"^1<",["^19",[]],536870919]],["^15",[609,"^F",608,536870919]],["^15",[609,"^X",608,536870919]],["^15",[609,"^V",608,536870919]],["^15",[609,"^U",69,536870919]],["^15",[609,"^U",70,536870919]],["^15",[609,"^U",71,536870919]],["^15",[609,"^U",608,536870919]],["^15",[609,"^:",true,536870919]],["^15",[609,"^?",["^ ","^18",["^19",["diary"]],"^1=","ackn