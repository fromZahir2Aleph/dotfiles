5",[3718,"^V",3713,536884735]],["^15",[3718,"^;","~u686ffd67-14d7-4e8d-b43b-3a5b9c44059d",536884735]],["^15",[3719,"^Q","Выбор слов - парадигматичный выбор, а их порядка - синтагматичный.",536884735]],["^15",[3719,"^O","^1;",536884735]],["^15",[3719,"^F",3718,536884735]],["^15",[3719,"^X",3406,536884735]],["^15",[3719,"^V",3718,536884735]],["^15",[3719,"^;","~u686ffd67-5add-4697-a3e0-c19bdfb7c86a",536884735]],["^15",[3720,"^Q","Парадигматичный",536884735]],["^15",[3720,"^O","^1;",536884735]],["^15",[3720,"^F",3719,536884735]],["^15",[3720,"^X",3406,536884735]],["^15",[3720,"^V",3719,536884735]],["^15",[3720,"^;","~u686ffd67-698d-431e-a2fb-f5296d5d90bf",536884735]],["^15",[3721,"^Q","Лестница абстракции",536884735]],["^15",[3721,"^O","^1;",536884735]],["^15",[3721,"^F",3720,536884735]],["^15",[3721,"^X",3406,536884735]],["^15",[3721,"^V",3720,536884735]],["^15",[3721,"^;","~u686ffd67-a7fc-4082-a253-859ab8433615",536884735]],["^15",[3722,"^Q","Синтагматичный",536884735]],["^15",[3722,"^O","^1;",536884735]],["^15",[3722,"^F",3720,536884735]],["^15",[3722,"^X",3406,536884735]],["^15",[3722,"^V",3719,536884735]],["^15",[3722,"^;","~u686ffd67-a876-4151-85ff-7e8f3a4dfe58",536884735]],["^15",[3723,"^Q","Форма есть содержимое.",536884735]],["^15",[3723,"^O","^1;",536884735]],["^15",[3723,"^F",3722,536884735]],["^15",[3723,"^X",3406,536884735]],["^15",[3723,"^V",3722,536884735]],["^15",[3723,"^;","~u686ffd67-e9ab-4863-b43a-7c358c6af6c4",536884735]],["^15",[3724,"^Q","2 Грамматика и реторика",536884735]],["^15",[3724,"^O","^1;",536884735]],["^15",[3724,"^F",3718,536884735]],["^15",[3724,"^X",3406,536884735]],["^15",[3724,"^V",3713,536884735]],["^15",[3724,"^;","~u686ffd67-a08d-49e2-ab08-135027ad130e",536884735]],["^15",[3725,"^Q","Эффективность определяется тем, насколько хорошо писатель согласует выражаемые пропозиции с обстоятельствами ситуации, своими целями, а также требованиями и ожиданиями читателя.",536884735]],["^15",[3725,"^O","^1;",536884735]],["^15",[3725,"^F",3724,536884735]],["^15",[3725,"^X",3406,536884735]],["^15",[3725,"^V",3724,536884735]],["^15",[3725,"^;","~u686ffd67-9f52-40cd-8f94-765ef5e6da44",536884735]],["^15",[3726,"^Q","Выразительность показывает, как успешно автор отражает эмоциональное измерение: себя, атмосферу, настроение и т.д.",536884735]],["^15",[3726,"^O","^1;",536884735]],["^15",[3726,"^F",3725,536884735]],["^15",[3726,"^X",3406,536884735]],["^15",[3726,"^V",3724,536884735]],["^15",[3726,"^;","~u686ffd67-f452-4f3a-a197-790a5b5bbb0e",536884735]],["^15",[3727,"^Q","Грамматика учит нас, как оперировать мёртвую птицу, а реторика - как воспринимать полёт живой. Реторика имеет дело с причинами, по которым мы пользуемся словами, чтобы достигнуть определённых целей, и степенью успешности их достижения. Согласно Ланему реторика - это \"наука структур человеческого внимания\".",536884735]],["^15",[3727,"^O","^1;",536884735]],["^15",[3727,"^F",3726,536884735]],["^15",[3727,"^X",3406,536884735]],["^15",[3727,"^V",3724,536884735]],["^15",[3727,"^;","~u686ffd67-f6aa-46d7-b634-5c33c7a11ec0",536884735]],["^15",[3728,"^Q","\"Меня интересует намного, намного больше реторика.\"",536884735]],["^15",[3728,"^O","^1;",536884735]],["^15",[3728,"^F",3727,536884735]],["^15",[3728,"^X",3406,536884735]],["^15",[3728,"^V",3727,536884735]],["^15",[3728,"^;","~u686ffd67-50ab-4eb7-a095-f767ed13a8c9",536884735]],["^15",[3729,"^Q","Одной лишь гремметики не достаточно для эффективного пись",536884735]],["^15",[3729,"^O","^1;",536884735]],["^15",[3729,"^F",3728,536884735]],["^15",[3729,"^X",3406,536884735]],["^15",[3729,"^V",3727,536884735]],["^15",[3729,"^;","~u686ffd67-ec69-44de-b1e5-6e4023cad0a1",536884735]],["^15",[3730,"^Q","Стиль - то, что писатель пишет и читатель читает. Автору не следует предполагать, что читатель замечает и читает то же, что и он сам.",536884735]],["^15",[3730,"^O","^1;",536884735]],["^15",[3730,"^F",3729,536884735]],["^15",[3730,"^X",3406,536884735]],["^15",[3730,"^V",3727,536884735]],["^15",[3730,"^;","~u686ffd67-9050-4b62-8574-cc52260c9551",536884735]],["^15",[3731,"^Q","3 Первоначальность высказываний",536884735]],["^15",[3731,"^O","^1;",536884735]],["^15",[3731,"^F",3724,536884735]],["^15",[3731,"^X",3406,536884735]],["^15",[3731,"^V",3713,536884735]],["^15",[3731,"^;","~u686ffd67-efdd-448c-8c96-92a9ae7b1401",536884735]],["^15",[3732,"^Q","Элементарной единицей предложения являются не слова или фраза, а высказывание.",536884735]],["^15",[3732,"^O","^1;",536884735]],["^15",[3732,"^F",3731,536884735]],["^15",[3732,"^X",3406,536884735]],["^15",[3732,"^V",3731,536884735]],["^15",[3732,"^;","~u686ffd67-6c42-4fac-bdd1-dada8e7e6623",536884735]],["^15",[3733,"^Q","Высказывание - это элементарное высказывание, которое не имеет составляющих высказываний.",536884735]],["^15",[3733,"^O","^1;",536884735]],["^15",[3733,"^F",3732,536884735]],["^15",[3733,"^X",3406,536884735]],["^15",[3733,"^V",3731,536884735]],["^15",[3733,"^;","~u686ffd67-eee8-4710-a193-36ede622a5a9",536884735]],["^15",[3734,"^Q","Предложение не всегда имеет лишь тот смысл, который можно извлечь из высказываний на поверхности. Его главным содержанием может быть то, на что они намекают.",536884735]],["^15",[3734,"^O","^1;",536884735]],["^15",[3734,"^F",3733,536884735]],["^15",[3734,"^X",3406,536884735]],["^15",[3734,"^V",3731,536884735]],["^15",[3734,"^;","~u686ffd67-f162-415d-bf1d-2ab140d642d3",536884735]],["^15",[3735,"^Q","Плотность пропозиций указывает на то, насколько они содержательны.",536884735]],["^15",[3735,"^O","^1;",536884735]],["^15",[3735,"^F",3734,536884735]],["^15",[3735,"^X",3406,536884735]],["^15",[3735,"^V",3734,536884735]],["^15",[3735,"^;","~u686ffd67-870d-4d19-831e-253e5e491138",536884735]],["^15",[3736,"^Q","4 Как строятся предложения",536884735]],["^15",[3736,"^O","^1;",536884735]],["^15",[3736,"^F",3731,536884735]],["^15",[3736,"^X",3406,536884735]],["^15",[3736,"^V",3713,536884735]],["^15",[3736,"^;","~u686ffd67-2cdb-4330-b912-64de3a021109",536884735]],["^15",[3737,"^Q","Простое предложение - ядро длинного.",536884735]],["^15",[3737,"^O","^1;",536884735]],["^15",[3737,"^F",3736,536884735]],["^15",[3737,"^X",3406,536884735]],["^15",[3737,"^V",3736,536884735]],["^15",[3737,"^;","~u686ffd67-397f-4314-b961-356f469d81fd",536884735]],["^15",[3738,"^Q","Предикативный стиль использует мало деталей.",536884735]],["^15",[3738,"^O","^1;",536884735]],["^15",[3738,"^F",3737,536884735]],["^15",[3738,"^X",3406,536884735]],["^15",[3738,"^V",3736,536884735]],["^15",[3738,"^;","~u686ffd67-41c2-4f9f-8364-6f130852bdd3",536884735]],["^15",[3739,"^Q","Он показывает, что герой видит, но не то, о чём он размышляет.",536884735]],["^15",[3739,"^O","^1;",536884735]],["^15",[3739,"^F",3738,536884735]],["^15",[3739,"^X",3406,536884735]],["^15",[3739,"^V",3738,536884735]],["^15",[3739,"^;","~u686ffd67-5ffe-44e6-a46b-55b95b38a981",536884735]],["^15",[3740,"^Q","Виды развёртывания предложения",536884735]],["^15",[3740,"^O","^1;",536884735]],["^15",[3740,"^F",3738,536884735]],["^15",[3740,"^X",3406,536884735]],["^15",[3740,"^V",3736,536884735]],["^15",[3740,"^;","~u686ffd67-a06a-42bd-90e8-0496fe9547ed",536884735]],["^15",[3741,"^Q","Сложное предложение",536884735]],["^15",[3741,"^O","^1;",536884735]],["^15",[3741,"^F",3740,536884735]],["^15",[3741,"^X",3406,536884735]],["^15",[3741,"^V",3740,536884735]],["^15",[3741,"^;","~u686ffd67-5801-4764-abdf-3085f3eba81e",536884735]],["^15",[3742,"^Q","1 Сочинение",536884735]],["^15",[3742,"^O","^1;",536884735]],["^15",[3742,"^F",3741,536884735]],["^15",[3742,"^X",3406,536884735]],["^15",[3742,"^V",3741,536884735]],["^15",[3742,"^;","~u686ffd67-cd31-4844-8dcc-46040cf5d887",536884735]],["^15",[3743,"^Q","2 Подчинение",536884735]],["^15",[3743,"^O","^1;",536884735]],["^15",[3743,"^F",3742,536884735]],["^15",[3743,"^X",3406,536884735]],["^15",[3743,"^V",3741,536884735]],["^15",[3743,"^;","~u686ffd67-c9d6-4483-acc1-9a0530a2a29e",536884735]],["^15",[3744,"^Q","3 Определение",536884735]],["^15",[3744,"^O","^1;",536884735]],["^15",[3744,"^F",3741,536884735]],["^15",[3744,"^X",3406,536884735]],["^15",[3744,"^V",3740,536884735]],["^15",[3744,"^;","~u686ffd67-2414-4eb9-b949-09a01a9defc6",536884735]],["^15",[3745,"^Q","Самый используемый в этой книге метод",536884735]],["^15",[3745,"^O","^1;",536884735]],["^15",[3745,"^F",3744,536884735]],["^15",[3745,"^X",3406,536884735]],["^15",[3745,"^V",3744,536884735]],["^15",[3745,"^;","~u686ffd67-21fd-44c9-adec-7db4ed8d404d",536884735]],["^15",[3746,"^Q","5 Собирательный синтаксис",536884735]],["^15",[3746,"^O","^1;",536884735]],["^15",[3746,"^F",3736,536884735]],["^15",[3746,"^X",3406,536884735]],["^15",[3746,"^V",3713,536884735]],["^15",[3746,"^;","~u686ffd67-9783-4cb6-9fed-500a1fb71721",536884735]],["^15",[3747,"^Q","Cumulative syntax",536884735]],["^15",[3747,"^O","^1;",536884735]],["^15",[3747,"^F",3746,536884735]],["^15",[3747,"^X",3406,536884735]],["^15",[3747,"^V",3746,536884735]],["^15",[3747,"^?",["^ "],536884735]],["^15",[3747,"^;","~u687aae7f-948d-4642-bc35-b0d79c91f305",536884735]],["^15",[3748,"^Q","#+BEGIN_QUOTE\nРитм хорошей современной прозы исходит примерно поровну из одновременного прослеживания сочинительных конструкций и уточнения и возврата к вершинам свободных определений.\n#+END_QUOTE\nФрэнсис Кристенсен",536884735]],["^15",[3748,"^O","^1;",536884735]],["^15",[3748,"^F",3747,536884735]],["^15",[3748,"^X",3406,536884735]],["^15",[3748,"^V",3746,536884735]],["^15",[3748,"^;","~u686ffd67-fd24-44ee-a945-bec344279fa8",536884735]],["^15",[3749,"^Q","Существительное, глагол и главное предложение содержит информацию, известную читателю. Если он этого не знает, то это не твой читатель.",536884735]],["^15",[3749,"^O","^1;",536884735]],["^15",[3749,"^F",3748,536884735]],["^15",[3749,"^X",3406,536884735]],["^15",[3749,"^V",3746,536884735]],["^15",[3749,"^;","~u686ffd67-35f8-4cb6-9eb3-5b10ced00b54",536884735]],["^15",[3750,"^Q","Читатель обнаруживает суть в определениях.",536884735]],["^15",[3750,"^O","^1;",536884735]],["^15",[3750,"^F",3749,536884735]],["^15",[3750