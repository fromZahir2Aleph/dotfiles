45e5-dee4-4852-98ed-b5986ecb2a4c",536870917]],["^15",[1722,"^3","- #[[me|cfs]] #[[personality psychology/self-awareness]] Дискомфорт или боль уменьшают мою и так порой, особенно вечером, не в своей лучшей форме самоосознанность и соответственно при употреблении нейролептиков их эффективностъ.",536870917]],["^15",[1722,"^16",1772635621963,536870917]],["^15",[1722,"^Z","journals/2024_08_20.md",536870917]],["^15",[1723,"^K",1772635621963,536870917]],["^15",[1723,"^[",1722,536870917]],["^15",[1723,"^N",20240820,536870917]],["^15",[1723,"^@",true,536870917]],["^15",[1723,"^Y","aug 20th, 2024",536870917]],["^15",[1723,"^11","Aug 20th, 2024",536870917]],["^15",[1723,"^B",1772635621963,536870917]],["^15",[1723,"^;","~u69a845e5-2f8b-4460-a07e-01d33798f7b2",536870917]],["^15",[1724,"^Q","#[[me|cfs]] #[[personality psychology/self-awareness]] Дискомфорт или боль уменьшают мою и так порой, особенно вечером, не в своей лучшей форме самоосознанность и соответственно при употреблении нейролептиков их эффективностъ.",536870917]],["^15",[1724,"^O","^17",536870917]],["^15",[1724,"^F",1723,536870917]],["^15",[1724,"^X",1723,536870917]],["^15",[1724,"^V",1723,536870917]],["^15",[1724,"^U",150,536870917]],["^15",[1724,"^U",255,536870917]],["^15",[1724,"^U",1156,536870917]],["^15",[1724,"^U",1723,536870917]],["^15",[1724,"^H",150,536870917]],["^15",[1724,"^H",255,536870917]],["^15",[1724,"^H",1156,536870917]],["^15",[1724,"^;","~u69a845e5-f85e-489f-9c8a-7d29fac063fc",536870917]],["^15",[1725,"^3","tags:: diary\ntype:: acknowledgement\nmood:: sad\n\n- #Оа Tы был мне плохим отцом, но я тебя любил, люблю и буду любить. Я скучаю по тебе. Я прощаю тебя за твой эгоизм. Прости меня и ты за мой. И за другие слабости. Я прощаю себя за них ради мамы, ради Седы и себя, но уже, к сожалению, не ради тебя. \n  С любовью и последним и единственным поцелуем, твой, всё-таки  твой, Зема, хоть и не Зеламх.",536877448]],["^15",[1725,"^16",1772635621977,536870917]],["^15",[1725,"^18","~m1774473986833",536877447]],["^15",[1725,"^Z","journals/2024_05_19.md",536870917]],["^15",[1726,"^K",1772635621977,536870917]],["^15",[1726,"^[",1725,536870917]],["^15",[1726,"^N",20240519,536870917]],["^15",[1726,"^@",true,536870917]],["^15",[1726,"^Y","may 19th, 2024",536870917]],["^15",[1726,"^11","May 19th, 2024",536870917]],["^15",[1726,"^?",["^ ","^19",["^1:",["diary"]],"^1;","acknowledgement","^1<","sad"],536870917]],["^15",[1726,"^4",["^ ","^19","diary","^1;","acknowledgement","^1<","sad"],536870917]],["^15",[1726,"^P",185,536870917]],["^15",[1726,"^B",1774473986263,536877446]],["^15",[1726,"^;","~u69a845e5-d1c2-4a7d-8d8c-cc0064cb3a7b",536870917]],["^15",[1727,"^Q","tags:: diary\ntype:: acknowledgement\nmood:: sad\n\n",536870917]],["^15",[1727,"^O","^17",536870917]],["^15",[1727,"^1=",["^1:",[]],536870917]],["^15",[1727,"^F",1726,536870917]],["^15",[1727,"^X",1726,536870917]],["^15",[1727,"^V",1726,536870917]],["^15",[1727,"^U",185,536870917]],["^15",[1727,"^U",186,536870917]],["^15",[1727,"^U",187,536870917]],["^15",[1727,"^U",1726,536870917]],["^15",[1727,"^:",true,536870917]],["^15",[1727,"^?",["^ ","^19",["^1:",["diary"]],"^1;","acknowledgement","^1<","sad"],536870917]],["^15",[1727,"^J",["^19","^1;","^1<"],536870917]],["^15",[1727,"^4",["^ ","^19","diary","^1;","acknowledgement","^1<","sad"],536870917]],["^15",[1727,"^H",185,536870917]],["^15",[1727,"^H",186,536870917]],["^15",[1727,"^H",187,536870917]],["^15",[1727,"^;","~u69a845e5-142d-46f4-8f81-cea60d649b3c",536870917]],["^15",[1728,"^Q","#Оа Tы был мне плохим отцом, но я тебя любил, люблю и буду любить. Я скучаю по тебе. Я прощаю тебя за твой эгоизм. Прости меня и ты за мой. И за другие слабости. Я прощаю себя за них ради мамы, ради Седы и себя, но уже, к сожалению, не ради тебя. \nС любовью и последним и единственным поцелуем, твой, всё-таки  твой, Зема, хоть и не Зеламх.",536877446]],["^15",[1728,"^O","^17",536870917]],["^15",[1728,"^F",1727,536870917]],["^15",[1728,"^X",1726,536870917]],["^15",[1728,"^V",1726,536870917]],["^15",[1728,"^U",1719,536870917]],["^15",[1728,"^U",1726,536870917]],["^15",[1728,"^?",["^ "],536877446]],["^15",[1728,"^H",1719,536877446]],["^15",[1728,"^;","~u69a845e5-3180-4bd5-b0fe-1a432fc30f3f",536870917]],["^15",[1729,"^3","tags:: diary\ntype:: reflection\nmood:: sad\n\n\t- За всю свою жизнь я никогда не тосковал по кому-то. Ни по семье, ни по одной живой душе, не говоря уже о такой для меня абстрактной категории как Родина, будь то страна, город, село или двор.",536870917]],["^15",[1729,"^16",1772635621991,536870917]],["^15",[1729,"^Z","journals/2024_04_12.md",536870917]],["^15",[1730,"^K",1772635621990,536870917]],["^15",[1730,"^[",1729,536870917]],["^15",[1730,"^N",20240412,536870917]],["^15",[1730,"^@",true,536870917]],["^15",[1730,"^Y","apr 12th, 2024",536870917]],["^15",[1730,"^11","Apr 12th, 2024",536870917]],["^15",[1730,"^?",["^ ","^19",["^1:",["diary"]],"^1;","reflection","^1<","sad"],536870917]],["^15",[1730,"^4",["^ ","^19","diary","^1;","reflection","^1<","sad"],536870917]],["^15",[1730,"^P",185,536870917]],["^15",[1730,"^B",1772635621990,536870917]],["^15",[1730,"^;","~u69a845e5-95fe-4dae-8c72-07ad403eb625",536870917]],["^15",[1731,"^Q","tags:: diary\ntype:: reflection\nmood:: sad\n\n",536870917]],["^15",[1731,"^O","^17",536870917]],["^15",[1731,"^1=",["^1:",[]],536870917]],["^15",[1731,"^F",1730,536870917]],["^15",[1731,"^X",1730,536870917]],["^15",[1731,"^V",1730,536870917]],["^15",[1731,"^U",185,536870917]],["^15",[1731,"^U",186,536870917]],["^15",[1731,"^U",187,536870917]],["^15",[1731,"^U",1730,536870917]],["^15",[1731,"^:",true,536870917]],["^15",[1731,"^?",["^ ","^19",["^1:",["diary"]],"^1;","reflection","^1<","sad"],536870917]],["^15",[1731,"^J",["^19","^1;","^1<"],536870917]],["^15",[1731,"^4",["^ ","^19","diary","^1;","reflection","^1<","sad"],536870917]],["^15",[1731,"^H",185,536870917]],["^15",[1731,"^H",186,536870917]],["^15",[1731,"^H",187,536870917]],["^15",[1731,"^;","~u69a845e5-57d6-476d-b85a-77777f475f79",536870917]],["^15