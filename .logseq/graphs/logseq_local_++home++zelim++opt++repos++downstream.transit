33]],["^15",[4025,"^[",4027,536875438]],["^15",[4025,"^O","^17",536875433]],["^15",[4025,"^N",20260325,536875433]],["^15",[4025,"^@",true,536875433]],["^15",[4025,"^Y","mar 25th, 2026",536875433]],["^15",[4025,"^11","Mar 25th, 2026",536875433]],["^15",[4025,"^?",["^ ","^19",["^1:",["diary"]],"^1;","reflection","^1<","neutral"],536875445]],["^15",[4025,"^4",["^ ","^19","diary","^1;","reflection","^1<","neutral"],536875445]],["^15",[4025,"^P",185,536875445]],["^15",[4025,"^B",1774474060681,536877462]],["^15",[4025,"^;","~u69c3efb1-8c85-4894-8c60-c520ba60f7ac",536875433]],["^15",[4026,"^Q","#[[mind wandering/maladaptive daydreaming]] Я не впитал в себя Саблю, потому что жил в фантазиях. Но в Чечне я малость обчеченился, так как окружающая среда там агрессивно навязывает свои правила. К тому же разные обязаловки по отношении к многочисленным родственникам даже меня иногда вытаскивали из конуры.",536879742]],["^15",[4026,"^O","^17",536875434]],["^15",[4026,"^N",20260325,536875434]],["^15",[4026,"^@",true,536875434]],["^15",[4026,"^F",4028,536875441]],["^15",[4026,"^X",4025,536875434]],["^15",[4026,"^V",4025,536875434]],["^15",[4026,"^U",201,536875437]],["^15",[4026,"^U",4025,536875437]],["^15",[4026,"^?",["^ "],536877462]],["^15",[4026,"^H",201,536877462]],["^15",[4026,"^;","~u69c3efb1-9b8a-48d4-af88-3868c92b1f9c",536875434]],["^15",[4027,"^3","tags:: diary\ntype:: reflection\nmood:: neutral\n\n- #[[mind wandering/maladaptive daydreaming]] Я не впитал в себя Саблю, потому что жил в фантазиях. Но в Чечне я малость обчеченился, так как окружающая среда там агрессивно навязывает свои правила. К тому же разные обязаловки по отношении к многочисленным родственникам даже меня иногда вытаскивали из конуры.",536879749]],["^15",[4027,"^18","~m1775842160466",536879748]],["^15",[4027,"^Z","journals/2026_03_25.md",536875438]],["^15",[4028,"^Q","tags:: diary\ntype:: reflection\nmood:: neutral",536875445]],["^15",[4028,"^O","^17",536875441]],["^15",[4028,"^1=",["^1:",[]],536875445]],["^15",[4028,"^@",true,536875441]],["^15",[4028,"^F",4025,536875441]],["^15",[4028,"^X",4025,536875441]],["^15",[4028,"^V",4025,536875441]],["^15",[4028,"^U",185,536875446]],["^15",[4028,"^U",186,536875446]],["^15",[4028,"^U",187,536875446]],["^15",[4028,"^U",4025,536875446]],["^15",[4028,"^:",true,536875445]],["^15",[4028,"^?",["^ ","^19",["^1:",["diary"]],"^1;","reflection","^1<","neutral"],536875445]],["^15",[4028,"^J",["^14",["^19","^1;","^1<"]],536875445]],["^15",[4028,"^4",["^ ","^19","diary","^1;","reflection","^1<","neutral"],536875445]],["^15",[4028,"^H",185,536875445]],["^15",[4028,"^H",186,536875445]],["^15",[4028,"^H",187,536875445]],["^15",[4028,"^;","~u69c3efc4-dfd7-4eca-a962-5f73681818a6",536875441]],["^15",[4029,"^U",472,536875901]],["^15",[4031,"^Q","Присоединить к последней главе?",536875978]],["^15",[4031,"^O","^17",536875941]],["^15",[4031,"^F",3739,536875941]],["^15",[4031,"^X",472,536875941]],["^15",[4031,"^V",3739,536875941]],["^15",[4031,"^U",472,536875942]],["^15",[4031,"^?",["^ "],536875978]],["^15",[4031,"^;","~u69c3f5a6-f9b4-4d48-9f2c-843a2502a43a",536875941]],["^15",[4033,"^Q","У тех, кому надлежить проверять книги на крамолу, не могут не просыпаться противоречия мыслях. Ведь одни достаточны умны, чтобы увидеть крамолу, потому что знают, как власть имущие попирают нравы, зачастую лучше среднего человека. Но в чувства этот диссонанс не переходит, потому что либо совесть заснула, либо никогда не просыпалась. Ты из первых. У обеих категорий гнет позволяет стать гражданином несколькими ступенями, чем они были бы при обычном состоянии дел, когда слово сбодно.",536876879]],["^15",[4033,"^O","^17",536876625]],["^15",[4033,"^F",3701,536876625]],["^15",[4033,"^X",472,536876625]],["^15",[4033,"^V",3681,536876625]],["^15",[4033,"^U",472,536876626]],["^15",[4033,"^?",["^ "],536876879]],["^15",[4033,"^;","~u69c3f638-3473-44b0-9bb9-3a44222f851d",536876629]],["^15",[4035,"^Q","Блокада звездчатого ганглия",536876912]],["^15",[4035,"^O","^17",536876908]],