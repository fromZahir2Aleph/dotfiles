",[3413,"^Z","pages/The Power of the Actor.md",536884261]],["^15",[3414,"^K",1757432471266,536884267]],["^15",[3414,"^@",false,536884267]],["^15",[3414,"^Y","acting",536884267]],["^15",[3414,"^11","acting",536884267]],["^15",[3414,"^B",1757432471266,536884267]],["^15",[3415,"^K",1757432502969,536884274]],["^15",[3415,"^@",false,536884274]],["^15",[3415,"^Y","ivana chubbuck",536884274]],["^15",[3415,"^11","Ivana Chubbuck",536884274]],["^15",[3415,"^B",1757432502969,536884274]],["^15",[3416,"^Q","This is objective-driven script-analysis approach.",536884347]],["^15",[3416,"^O","^1;",536884276]],["^15",[3416,"^@",false,536884276]],["^15",[3416,"^F",3412,536884276]],["^15",[3416,"^X",3411,536884276]],["^15",[3416,"^V",3411,536884276]],["^15",[3416,"^U",3411,536884277]],["^15",[3416,"^?",["^ "],536884347]],["^15",[3416,"^;","~u68c04ab7-d49a-4fff-92ef-7a370dd981dd",536884276]],["^15",[3417,"^Q","",536884348]],["^15",[3417,"^O","^1;",536884348]],["^15",[3417,"^@",false,536884348]],["^15",[3417,"^F",3416,536884348]],["^15",[3417,"^X",3411,536884348]],["^15",[3417,"^V",3411,536884348]],["^15",[3417,"^U",3411,536884349]],["^15",[3417,"^?",["^ "],536884348]],["^15",[3417,"^;","~u68c04aea-51cf-4b00-a8eb-f87ece98035f",536884348]],["^15",[3418,"^K",1757434268935,536884358]],["^15",[3418,"^[",3420,536884367]],["^15",[3418,"^O","^1;",536884358]],["^15",[3418,"^@",false,536884358]],["^15",[3418,"^Y","черновик палимпсеста",536884362]],["^15",[3418,"^11","Черновик палимпсеста",536884362]],["^15",[3418,"^B",1757434473836,536884402]],["^15",[3418,"^;","~u68c1c915-ffd6-4e88-a80a-3194df4f8b94",536885359]],["^15",[3419,"^Q","Я жена Прометея, бросившего вызов Зевсу, похитившему с Олимпа огонь, передавшему этот запретный дар человечеству, прикованному за это к горе далекого Кавказа к вечным терзаниям. Я мать его детей.\n\nЕдинственным памятником мне будет мое надгробие, на котором будет высечено Гесиона.",536885359]],["^15",[3419,"^O","^1;",536884359]],["^15",[3419,"^@",false,536884359]],["^15",[3419,"^F",3418,536884359]],["^15",[3419,"^X",3418,536884359]],["^15",[3419,"^V",3418,536884359]],["^15",[3419,"^U",3418,536884360]],["^15",[3419,"^;","~u68c0519c-8c88-4af4-be88-b8856c0295c7",536884359]],["^15",[3420,"^3","- Я жена Прометея, бросившего вызов Зевсу, похитившему с Олимпа огонь, передавшему этот запретный дар человечеству, прикованному за это к горе далекого Кавказа к вечным терзаниям. Я мать его детей.\n\nЕдинственным памятником мне будет мое надгробие, на котором будет высечено Гесиона.\n",536885359]],["^15",[3420,"^17","~m1757530387430",536885360]],["^15",[3420,"^Z","pages/Черновик палимпсеста.md",536884367]],["^15",[3421,"^Q","Большая Гора",536884441]],["^15",[3421,"^O","^1;",536884406]],["^15",[3421,"^F",2748,536884406]],["^15",[3421,"^X",962,536884406]],["^15",[3421,"^V",985,536884406]],["^15",[3421,"^U",962,536884407]],["^15",[3421,"^?",["^ "],536884441]],["^15",[3421,"^;","~u68c05281-d77f-433e-abd3-c2659f8c7e07",536884406]],["^15",[3422,"^Q","Единственный искуственный и безуловно самый красивый остров, величие которого основано на эксплуатации колонизированных островов, достопримечательности которых перевезены в столицу.",536884662]],["^15",[3422,"^O","^1;",536884430]],["^15",[3422,"^F",3421,536884430]],["^15",[3422,"^X",962,536884430]],["^15",[3422,"^V",3421,536884434]],["^15",[3422,"^U",962,536884442]],["^15",[3422,"^?",["^ "],536884662]],["^15",[3422,"^;","~u68c052dc-78f4-43aa-b8b9-ca5ead9912bc",536884430]],["^15",[3425,"^K",1757436463375,536884675]],["^15",[3425,"^[",3427,536884680]],["^15",[3425,"^O","^1;",536884675]],["^15",[3425,"^@",false,536884675]],["^15",[3425,"^Y","sanford meisner on acting",536884675]],["^15",[3425,"^11","Sanford Meisner on Acting",536884675]],["^15",[3425,"^?",["^ ","^18",["^19",["acting"]],"^1R",["^19",["Sanford Meisner"]]],536884694]],["^15",[3425,"^4",["^ ","^18","acting","^1R","[[Sanford Meisner]]"],536884694]],["^15",[3425,"^P",3414,536884694]],["^15",[3425,"^B",1757528093603,536885352]],["^15",[3425,"^;","~u68c05a2f-60b5-4b17-97bd-0e629c044528",536884675]],["^15",[3426,"^Q","tags:: acting\nauthor:: [[Sanford Meisner]]",536884694]],["^15",[3426,"^O","^1;",536884676]],["^15",[3426,"^1<",["^19",[]],536884694]],["^15",[3426,"^@",false,536884676]],["^15",[3426,"^F",3425,536884676]],["^15",[3426,"^X",3425,536884676]],["^15",[3426,"^V",3425,536884676]],["^15",[3426,"^U",1027,536884695]],["^15",[3426,"^U",3414,536884695]],["^15",[3426,"^U",3425,536884695]],["^15",[3426,"^U",3429,536884695]],["^15",[3426,"^:",true,536884694]],["^15",[3426,"^?",["^ ","^18",["^19",["acting"]],"^1R",["^19",["Sanford Meisner"]]],536884694]],["^15",[3426,"^J",["^14",["^18","^1R"]],536884694]],["^15",[3426,"^4",["^ ","^18","acting","^1R","[[Sanford Meisner]]"],536884694]],["^15",[3426,"^H",1027,536884694]],["^15",[3426,"^H",3414,536884694]],["^15",[3426,"^H",3429,536884694]],["^15",[3426,"^;","~u68c05a2f-6d63-491d-be92-b629c97caa98",536884676]],["^15",[3427,"^3","tags:: acting\nauthor:: [[Sanford Meisner]]\n\n- The approach is rooted in spontaneity and truthfulness.\n\t- #+BEGIN_QUOTE\n\t  I decided I wanted an exercise for actors where there is no intellectuality. I wanted to eliminate all that ‘head’ work, to take away all the mental manipulation and get to where the impulses come from. And I began with the premise that if I repeat what I hear you saying, my head is not working. I’m listening, and there is an absolute elimination of the brain.\n\t  #+END_QUOTE\n- #+BEGIN_QUOTE\n  The foundation of acting is the reality of doing.\n  #+END_QUOTE\n\t- Of doing it as myself, not as an actor. Thus you become the character.\n- Word repetition game\n\t- Process\n\t\t- Listening, observing, commenting\n\t\t- Mechanical repetition\n\t\t- Repetition from your point of view\n\t- Instincts dictate the changes, not just the repetition.\n\t\t- Do not think.\n\t\t- Do not compound.\n\t\t\t- Instead of Repetition and X either repeat or say X.\n\t- First principle\n\t\t- #+BEGIN_QUOTE\n\t\t  Don’t do anything unless something happens to make you do it.\n\t\t  #+END_QUOTE\n\t- Second principle\n\t\t- #+BEGIN_QUOTE\n\t\t  What you do doesn’t depend on you it depends on the other fellow.\n\t\t  #+END_QUOTE",536885354]],["^15",[3427,"^17","~m1757528094334",536885353]],["^15",[3427,"^Z","pages/Sanford Meisner on Acting.md",536884680]],["^15",[3429,"^K",1757436493203,536884694]],["^15",[3429,"^@",false,536884694]],["^15",[3429,"^Y","sanford meisner",536884694]],["^15",[3429,"^11","Sanford Meisner",536884694]],["^15",[3429,"^B",1757436493203,536884694]],["^15",[3430,"^Q","#+BEGIN_QUOTE\nThe foundation of acting is the reality of doing.\n#+END_QUOTE",536885199]],["^15",[3430,"^O","^1;",536884696]],["^15",[3430,"^@",false,536884696]],["^15",[3430,"^F",3975,536885345]],["^15",[3430,"^X",3425,536884696]],["^15",[3430,"^V",3425,536884696]],["^15",[3430,"^U",3425,536884697]],["^15",[3430,"^?",["^ "],536885199]],["^15",[3430,"^;","~u68c05a4d-3099-4c76-8366-8bb5b2a85b26",536884696]],["^15",[3431,"^12",2,536884723]],["^15",[3434,"^Q","Стилистические приёмы всегда могут быть перевёрнуты, чтобы обмануть ожидания читателя.",536884735]],["^15",[3434,"^O","^1;",536884735]],["^15",[3434,"^F",3407,536884735]],["^15",[3434,"^X",3406,536884735]],["^15",[3434,"^V",3406,536884735]],["^15",[3434,"^;","~u686ffd67-a120-4dea-a5b1-ef7f2f7eaadc",536884735]],["^15",[3435,"^Q","Реторическая грамматика. Kolln, M. J., & Gray, L. S. (n.d.). *Rhetorical Grammar: Grammatical Choices, Rhetorical Effects*.",536884735]],["^15",[3435,"^O","^1;",536884735]],["^15",[3435,"^F",3434,536884735]],["^15",[3435,"^X",3406,536884735]],["^15",[3435,"^V",3406,536884735]],["^15",[3435,"^;","~u686ffd67-c828-4829-be73-942a429c8c0e",536884735]],["^15",[3436,"^M",true,536884735]],["^15",[3436,"^Q","Короткие элементарные предложения: подлежащее, составное сказуемое (глагол и комплемент) и возможный сирконстант (адвербальное или номинативное приложение),\ncollapsed:: true",536884735]],["^15",[3436,"^O","^1;",536884735]],["^15",[3436,