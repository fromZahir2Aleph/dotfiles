ые искусные предложения",536884735]],["^15",[3886,"^O","^1;",536884735]],["^15",[3886,"^F",3881,536884735]],["^15",[3886,"^X",3406,536884735]],["^15",[3886,"^V",3879,536884735]],["^15",[3886,"^?",["^ "],536884735]],["^15",[3886,"^;","~u68750f5d-e72a-4f33-b724-af74290c9816",536884735]],["^15",[3887,"^Q","редки даже у максималистов",536884735]],["^15",[3887,"^O","^1;",536884735]],["^15",[3887,"^F",3886,536884735]],["^15",[3887,"^X",3406,536884735]],["^15",[3887,"^V",3886,536884735]],["^15",[3887,"^?",["^ "],536884735]],["^15",[3887,"^;","~u68751163-7363-4586-8a1d-2174efd4e518",536884735]],["^15",[3888,"^Q","зачастую отлагательны",536884735]],["^15",[3888,"^O","^1;",536884735]],["^15",[3888,"^F",3887,536884735]],["^15",[3888,"^X",3406,536884735]],["^15",[3888,"^V",3886,536884735]],["^15",[3888,"^?",["^ "],536884735]],["^15",[3888,"^;","~u68751173-2f25-4e34-ae80-80401a7ba21c",536884735]],["^15",[3889,"^Q","внимание читателя должно быть вознаграждено",536884735]],["^15",[3889,"^O","^1;",536884735]],["^15",[3889,"^F",3888,536884735]],["^15",[3889,"^X",3406,536884735]],["^15",[3889,"^V",3888,536884735]],["^15",[3889,"^?",["^ "],536884735]],["^15",[3889,"^;","~u687511bd-b4be-49ec-bcd7-2abc9210fa15",536884735]],["^15",[3890,"^Q","Анализ прозы. Lanham, R. A. (2003). *Analyzing prose*.",536884735]],["^15",[3890,"^O","^1;",536884735]],["^15",[3890,"^F",3713,536884735]],["^15",[3890,"^X",3406,536884735]],["^15",[3890,"^V",3406,536884735]],["^15",[3890,"^?",["^ "],536884735]],["^15",[3890,"^;","~u686ffd67-5bfc-4b81-98be-ccdad0f7569c",536884735]],["^15",[3891,"^Q","Глагольный слог вместо существительного слога",536884735]],["^15",[3891,"^O","^1;",536884735]],["^15",[3891,"^F",3890,536884735]],["^15",[3891,"^X",3406,536884735]],["^15",[3891,"^V",3890,536884735]],["^15",[3891,"^?",["^ "],536884735]],["^15",[3891,"^;","~u6878fc62-aea3-4350-ae87-aaf7431006a0",536884735]],["^15",[3892,"^Q","Существительный слог\nid:: 687a5d5c-4f73-42f8-aca5-5e9178e87659",536884735]],["^15",[3892,"^O","^1;",536884735]],["^15",[3892,"^F",3891,536884735]],["^15",[3892,"^X",3406,536884735]],["^15",[3892,"^V",3891,536884735]],["^15",[3892,"^?",["^ ","^1D","687a5d5c-4f73-42f8-aca5-5e9178e87659"],536884735]],["^15",[3892,"^J",["^14",["^1D"]],536884735]],["^15",[3892,"^4",["^ ","^1D","687a5d5c-4f73-42f8-aca5-5e9178e87659"],536884735]],["^15",[3892,"^;","~u687a5d5c-4f73-42f8-aca5-5e9178e87659",536884735]],["^15",[3893,"^Q","глагол-связка, тире или статичный глагол + предложная фраза + предложная фраза + ...",536884735]],["^15",[3893,"^O","^1;",536884735]],["^15",[3893,"^F",3892,536884735]],["^15",[3893,"^X",3406,536884735]],["^15",[3893,"^V",3892,536884735]],["^15",[3893,"^?",["^ "],536884735]],["^15",[3893,"^;","~u687a6121-45a8-4c13-8e48-91021d721940",536884735]],["^15",[3894,"^Q","глагол + качество",536884735]],["^15",[3894,"^O","^1;",536884735]],["^15",[3894,"^F",3893,536884735]],["^15",[3894,"^X",3406,536884735]],["^15",[3894,"^V",3892,536884735]],["^15",[3894,"^?",["^ "],536884735]],["^15",[3894,"^;","~u687a6124-08a4-4366-a910-a0bf138effc6",536884735]],["^15",[3895,"^Q","#+BEGIN_QUOTE\nWe often observe this contrast between the absence of nominal inﬂection and the richness of the verbal inﬂection. This is due to the nature of the noun and the verb. The noun indicates an idea of permanent nature: a thing, a person, or a quality; the verb indicates a process. . . . For the very reason that it indicates a permanent notion, the noun has a sole form or at most a principal form from which the others are derived. On the other hand, the verb, which indicates a process, has personal forms and the expression of nuances which vary with languages, but can be numerous. The fact that the forms of the noun and verb obey divergent tendencies thus results from the nature of things.\n#+END_QUOTE\nA. Meillet, The Comparative Method in Historical Linguistics, p. 114",536884735]],["^15",[3895,"^O","^1;",536884735]],["^15",[3895,"^F",3892,536884735]],["^15",[3895,"^X",3406,536884735]],["^15",[3895,"^V",3891,536884735]],["^15",[3895,"^?",["^ "],536884735]],["^15",[3895,"^;","~u68bded0c-d9bc-4dc2-a0c7-a6802f271eaa",536884735]],["^15",[3896,"^Q","Паратаксис и гипотаксис",536884735]],["^15",[3896,"^O","^1;",536884735]],["^15",[3896,"^F",3891,536884735]],["^15",[3896,"^X",3406,536884735]],["^15",[3896,"^V",3890,536884735]],["^15",[3896,"^?",["^ "],536884735]],["^15",[3896,"^;","~u687a6138-a946-456b-a548-5e566827a594",536884735]],["^15",[3897,"^Q","Это деление касается пропозиций, хоть и соотносится с синтаксисом.",536884735]],["^15",[3897,"^O","^1;",536884735]],["^15",[3897,"^F",3896,536884735]],["^15",[3897,"^X",3406,536884735]],["^15",[3897,"^V",3896,536884735]],["^15",[3897,"^?",["^ "],536884735]],["^15",[3897,"^;","~u687a9a98-ac00-4c41-8783-48821b6e5d6e",536884735]],["^15",[3898,"^Q","Часто сочетаются в одном предложении.",536884735]],["^15",[3898,"^O","^1;",536884735]],["^15",[3898,"^F",3897,536884735]],["^15",[3898,"^X",3406,536884735]],["^15",[3898,"^V",3896,536884735]],["^15",[3898,"^?",["^ "],536884735]],["^15",[3898,"^;","~u687a9c66-4b34-4407-a3e5-96281318a54a",536884735]],["^15",[3899,"^Q","В паратаксических предложениях синтаксические единицы равны.",536884735]],["^15",[3899,"^O","^1;",536884735]],["^15",[3899,"^F",3898,536884735]],["^15",[3899,"^X",3406,536884735]],["^15",[3899,"^V",3896,536884735]],["^15",[3899,"^?",["^ "],536884735]],["^15",[3899,"^;","~u687a9772-afd3-4e59-911a-2c0ac6c474b9",536884735]],["^15",[3900,"^Q","Гипотаксис отражает...",536884735]],["^15",[3900,"^O","^1;",536884735]],["^15",[3900,"^F",3899,536884735]],["^15",[3900,"^X",3406,536884735]],["^15",[3900,"^V",3896,536884735]],["^15",[3900,"^?",["^ "],536884735]],["^15",[3900,"^;","~u687a9815-1720-43e0-b691-8c79779c56f3",536884735]],["^15",[3901,"^Q","причинно-следственную связь",536884735]],["^15",[3901,"^O","^1;",536884735]],["^15",[3901,"^F",3900,536884735]],["^15",[3901,"^X",3406,536884735]],["^15",[3901,"^V",3900,536884735]],["^15",[3901,"^?",["^ "],536884735]],["^15",[3901,"^;","~u687a9823-7ef5-43ab-81b8-b50fb0da464b",536884735]],["^15",[3902,"^Q","хронологию",536884735]],["^15",[3902,"^O","^1;",536884735]],["^15",[3902,"^F",3901,536884735]],["^15",[3902,"^X",3406,536884735]],["^15",[3902,"^V",3900,536884735]],["^15",[3902,"^?",["^ "],536884735]],["^15",[3902,"^;","~u687a983b-879b-4749-b833-351516238fad",536884735]],["^15",[3903,"^Q","сравнение",536884735]],["^15",[3903,"^O","^1;",536884735]],["^15",[3903,"^F",3902,536884735]],["^15",[3903,"^X",3406,536884735]],["^15",[3903,"^V",3900,536884735]],["^15",[3903,"^?",["^ "],536884735]],["^15",[3903,"^;","~u687a982f-7263-4b22-b1c8-d69655bed95f",536884735]],["^15",[3904,"^Q","Подчинительные союзы показывают логику, сочинительные (их повторение или отсутствие) - слог.",536884735]],["^15",[3904,"^O","^1;",536884735]],["^15",[3904,"^F",3900,536884735]],["^15",[3904,"^X",3406,536884735]],["^15",[3904,"^V",3896,536884735]],["^15",[3904,"^?",["^ "],536884735]],["^15",[3904,"^;","~u687a9cbe-2f8d-4aed-80e8-e437e529be43",536884735]],["^15",[3905,"^Q","За несколькими паратаксическими предложениями часто стоит неумение свести их в одно гипотаксическое.",536884735]],["^15",[3905,"^O","^1;",536884735]],["^15",[3905,"^F",3904,536884735]],["^15",[3905,"^X",3406,536884735]],["^15",[3905,"^V",3896,536884735]],["^15",[3905,"^?",["^ "],536884735]],["^15",[3905,"^;","~u687a9c82-1ef3-444b-9235-8db2377195eb",536884735]],["^15",[3906,"^Q","Цельный и текущий слоги",536884735]],["^15",[3906,"^O","^1;",536884735]],["^15",[3906,"^F",3896,536884735]],["^15",[3906,"^X",3406,536884735]],["^15",[3906,"^V",3890,536884735]],["^15",[3906,"^?",["^ "],536884735]],["^15",[3906,"^;","~u687aadea-cf5a-45b5-bdc5-7a95e5fbb1dc",536884735]],["^15",[3907,"^Q","Periodic style and running style",536884735]],["^15",[3907,"^O","^1;",536884735]],["^15",[3907,"^F",3906,536884735]],["^15",[3907,"^X",3406,536884735]],["^15",[3907,"^V",3906,536884735]],["^15",[3907,"^?",["^ "],536884735]],["^15",[3907,"^;","~u687aae1f-d90e-44db-aa26-a51d67dd6ff3",536884735]],["^15",[3908,"^Q","#+BEGIN_QUOTE\nSyntax follows sense, either a pattern of association, or of subject, or as here, a chronological sequence. What follows builds upon what went before, modiﬁes it, restates it. A diachronic style, we might call it, one that acknowledges the passage of time. It often creates immediacy and action\n#+END_QUOTE",536884735]],["^15",[3908,"^O","^1;",536884735]],["^15",[3908,"^F",3907,536884735]],["^15",[3908,"^X",3406,536884735]],["^15",[3908,"^V",3907,536884735]],["^15",[3908,"^?",["^ "],536884735]],["^15",[3908,"^;","~u68bc6133-14c5-447d-8c5c-9447cde7a122",536884735]],["^15",[3909,"^Q","#+BEGIN_QUOTE\nThe periodic style works diﬀerently. It encloses time into a single, syntactically controllable unit, treats experience synchronically rather than diachronically. Here, arrangement controls, not time. In it, order triumphs; in the running style, order operates. The running style surprises the mind operating; in the periodic style, the mind has ﬁnished its work.\n#+END_QUOTE",536884735]],["^15",[3909,"^O","^1;",536884735]],["^15",[3909,"^F",3908,536884735]],["^15",[3909,"^X",3406,536884735]],["^15",[3909,"^V",3907,536884735]],["^15",[3909,"^?",["^ "],536884735]],["^15",[3909,"^;","~u68bdeb30-8984-4ffc-aaec-b9433abc6bf0",536884735]],["^15",[3910,"^Q","#+BEGIN_QUOTE\nThe periodic style, then, may represent pattern, and the running style, process.\n#+END_QUOTE",536884735]],["^15",[3910,"^O","^1;",536884735]],["^15",[3910,"^F",3909,536884735]],["^15",[3910,"^X",3406,536884735]],["^15",[3910,"^V",3907,536884735]],["^15",[3910,"^?",["^ "],536884735]],["^15",[3910,"^;","~u68bc6135-3db5-486b-8b9c-708c773072d3",536884735]],["^15",[3911,"^Q","Две крайности спектра",536884735]],["^15",[3911,"^O","^1;",536884735]],["^15",[3911,"^F",3907,536884735]],["^15",[3911,"^X",3406,536884735]],["^15",[3911,"^V",3906,536884735]],["^15",[3911,"^?",["^ "],536884735]],["^15",[3911,"^;","~u687bd92d-0693-473c-95db-04578a3810bd",536884735]],["^15",[3912,"^Q","Единицей зачастую является несколько предложений.",536884735]],["^15",[3912,"^O","^1;",536884735]],["^15",[3912,"^F",3911,536884735]],["^15",[3912,"^X",3406,536884735]],["^15",[3912,"^V",3906,536884735]],["^15",[3912,"^?",["^ "],536884735]],["^15",[3912,"^;","~u687bce0c-da57-4198-846c-d33144a8ca38",536884735]],["^15",[3913,"^Q","Цельный слог в отличие от текущего упорядочен.",536884735]],["^15",[3913,"^O","^1;",536884735]],["^15",[3913,"^F",3912,536884735]],["^15",[3913,"^X",3406,536884735]],["^15",[3913,"^V",3906,536884735]],["^15",[3913,"^?",["^ "],536884735]],["^15",[3913,"^;","~u687bcdbc-c183-49a6-b715-5b16aed6f135",536884735]],["^15",[3914,"^Q","Качества цельного слога:",536884735]],["^15",[3914,"^O","^1;",536884735]],["^15",[3914,"^F",3913,536884735]],["^15",[3914,"^X",3406,536884735]],["^15",[3914,"^V",3906,536884735]],["^15",[3914,"^?",["^ "],536884735]],["^15",[3914,"^;","~u687bce2d-25b5-43c0-8950-6d2cea0961ce",536884735]],["^15",[3915,"^Q","откладывание",536884735]],["^15",[3915,"^O","^1;",536884735]],["^15",[3915,"^F",3914,536884735]],["^15",[3915,"^X",3406,536884735]],["^15",[3915,"^V",3914,536884735]],["^15",[3915,"^?",["^ "],536884735]],["^15",[3915,"^;","~u687bce6c-c9d9-4e86-bc58-acbc119f8fdf",536884735]],["^15",[3916,"^Q","параллелизм",536884735]],["^15",[3916,"^O","^1;",536884735]],["^15",[3916,"^F",3915,536884735]],["^15",[3916,"^X",3406,536884735]],["^15",[3916,"^V",3914,536884735]],["^15",[3916,"^?",["^ "],536884735]],["^15",[3916,"^;","~u687bce80-8f06-4a89-86ad-a24d982ff0a0",536884735]],["^15",[3917,"^Q","баланс",536884735]],["^15",[3917,"^O","^1;",536884735]],["^15",[3917,"^F",3916,536884735]],["^15",[3917,"^X",3406,536884735]],["^15",[3917,"^V",3914,536884735]],["^15",[3917,"^?",["^ "],536884735]],["^15",[3917,"^;","~u687bce85-5365-4d70-bd4a-14840d8c869e",536884735]],["^15",[3918,"^Q","кульминация",536884735]],["^15",[3918,"^O","^1;",536884735]],["^15",[3918,"^F",3917,536884735]],["^15",[3918,"^X",3406,536884735]],["^15",[3918,"^V",3914,536884735]],["^15",[3918,"^?",["^ "],536884735]],["^15",[3918,"^;","~u687bce9a-0c80-4a30-87ec-c3cf4bb3949a",536884735]],["^15",[3919,"^Q","продуманность",536884735]],["^15",[3919,"^O","^1;",536884735]],["^15",[3919,"^F",3918,536884735]],["^15",[3919,"^X",3406,536884735]],["^15",[3919,"^V",3914,536884735]],["^15",[3919,"^?",["^ "],536884735]],["^15",[3919,"^;","~u687bcea0-e607-4010-b458-7a4707700322",536884735]],["^15",[3920,"^Q","Качества текущего слога:",536884735]],["^15",[3920,"^O","^1;",536884735]],["^15",[3920,"^F",3914,536884735]],["^15",[3920,"^X",3406,536884735]],["^15",[3920,"^V",3906,536884735]],["^15",[3920,"^?",["^ "],536884735]],["^15",[3920,"^;","~u687bcebf-727a-481c-a44b-c1905fa110d2",536884735]],["^15",[3921,"^Q","как будто пишется в реальном времени",536884735]],["^15",[3921,"^O","^1;",536884735]],["^15",[3921,"^F",3920,536884735]],["^15",[3921,"^X",3406,536884735]],["^15",[3921,"^V",3920,536884735]],["^15",[3921,"^?",["^ "],536884735]],["^15",[3921,"^;","~u687bcf05-ad1c-4281-a299-17f8371653c0",536884735]],["^15",[3922,"^Q","ощущение импровизации: остановки, мысли заново, ревизия сказанного",536884735]],["^15",[3922,"^O","^1;",536884735]],["^15",[3922,"^F",3921,536884735]],["^15",[3922,"^X",3406,536884735]],["^15",[3922,"^V",3921,536884735]],["^15",[3922,"^?",["^ "],536884735]],["^15",[3922,"^;","~u687bcfbe-98da-43e5-be52-3dcd5fa93bb1",536884735]],["^15",[3923,"^Q","отступления внутри предложений (которые можно заключить в скобки)",536884735]],["^15",[3923,"^O","^1;",536884735]],["^15",[3923,"^F",3921,536884735]],["^15",[3923,"^X",3406,536884735]],["^15",[3923,"^V",3920,536884735]],["^15",[3923,"^?",["^ "],536884735]],["^15",[3923,"^;","~u687bcf34-ddc0-42ce-9c58-34553eb70d49",536884735]],["^15",[3924,"^Q","Проза на слух",536884735]],["^15",[3924,"^O","^1;",536884735]],["^15",[3924,"^F",3906,536884735]],["^15",[3924,"^X",3406,536884735]],["^15",[3924,"^V",3890,536884735]],["^15",[3924,"^?",["^ "],536884735]],["^15",[3924,"^;","~u687a9848-f308-4e66-8823-0111c19a133e",536884735]],["^15",[3925,"^Q","Два значения:",536884735]],["^15",[3925,"^O","^1;",536884735]],["^15",[3925,"^F",3924,536884735]],["^15",[3925,"^X",3406,536884735]],["^15",[3925,"^V",3924,536884735]],["^15",[3925,"^?",["^ "],536884735]],["^15",[3925,"^;","~u688504c3-d027-45dc-9e3a-e9cff09b56e4",536884735]],["^15",[3926,"^Q","ритм и акцентирование слога\nlogseq.order-list-type:: number",536884735]],["^15",[3926,"^O","^1;",536884735]],["^15",[3926,"^F",3925,536884735]],["^15",[3926,"^X",3406,536884735]],["^15",[3926,"^V",3925,536884735]],["^15",[3926,"^?",["^ ","^1K","number"],536884735]],["^15",[3926,"^J",["^14",["^1K"]],536884735]],["^15",[3926,"^4",["^ ","^1K","number"],536884735]],["^15",[3926,"^;","~u688504da-9230-4724-8a79-4e1057fc7c92",536884735]],["^15",[3927,"^Q","голос персонажа или повествователя\nlogseq.order-list-type:: number",536884735]],["^15",[3927,"^O","^1;",536884735]],["^15",[3927,"^F",3926,536884735]],["^15",[3927,"^X",3406,536884735]],["^15",[3927,"^V",3925,536884735]],["^15",[3927,"^?",["^ ","^1K","number"],536884735]],["^15",[3927,"^J",["^14",["^1K"]],536884735]],["^15",[3927,"^4",["^ ","^1K","number"],536884735]],["^15",[3927,"^;","~u6885054d-e49b-42b2-94f8-5fabb3ff6899",536884735]],["^15",[3928,"^Q","#+BEGIN_QUOTE\nThe rhythm of a passage does not simply exist, as does its imagery: reading has to create it.\n#+END_QUOTE",536884735]],["^15",[3928,"^O","^1;",536884735]],["^15",[3928,"^F",3925,536884735]],["^15",[3928,"^X",3406,536884735]],["^15",[3928,"^V",3924,536884735]],["^15",[3928,"^?",["^ "],536884735]],["^15",[3928,"^;","~u68bdebc8-ffbb-4616-bbb2-ae1133b84eae",536884735]],["^15",[3929,"^Q","#+BEGIN_QUOTE\nStudents of meter often refer to the tension between natural word stress and the stress pattern that meter imposes. In prose rhythm an analogous tension waits there for the exploiting. The reader must supply meaning, color it to a degree that poetry seldom permits. Because of this larger freedom, prose is often more fun to read aloud than poetry.\n#+END_QUOTE",536884735]],["^15",[3929,"^O","^1;",536884735]],["^15",[3929,"^F",3928,536884735]],["^15",[3929,"^X",3406,536884735]],["^15",[3929,"^V",3924,536884735]],["^15",[3929,"^?",["^ "],536884735]],["^15",[3929,"^;","~u68bdebf0-8f3f-48fa-9e39-8113262200cb",536884735]],["^15",[3930,"^Q","Форма предложенияй как содержимое",536884735]],["^15",[3930,"^O","^1;",536884735]],["^15",[3930,"^F",3924,536884735]],["^15",[3930,"^X",3406,536884735]],["^15",[3930,"^V",3890,536884735]],["^15",[3930,"^?",["^ "],536884735]],["^15",[3930,"^;","~u6885090b-1eb0-46f7-9764-c0acd0969a05",536884735]],["^15",[3931,"^Q","... - это поиск знакомого паттерна известного смысла в новом \"удачном\" наборе слов.",536884735]],["^15",[3931,"^O","^1;",536884735]],["^15",[3931,"^F",3930,536884735]],["^15",[3931,"^X",3406,536884735]],["^15",[3931,"^V",3930,536884735]],["^15",[3931,"^?",["^ "],536884735]],["^15",[3931,"^;","~u6887a3b5-5e73-4363-b49c-3d33fba8d673",536884735]],["^15",[3932,"^Q","... - это имитация поэзии прозой.",536884735]],["^15",[3932,"^O","^1;",536884735]],["^15",[3932,"^F",3931,536884735]],["^15",[3932,"^X",3406,536884735]],["^15",[3932,"^V",3930,536884735]],["^15",[3932,"^?",["^ "],536884735]],["^15",[3932,"^;","~u6887a49b-9d75-447d-85ca-8f3421e8c570",536884735]],["^15",[3933,"^Q","Чтобы избежать поверхностности, нужно следовать от мысли к паттерну, а не наоборот. Выбирай паттерн, который поможет выразить мысль.",536884735]],["^15",[3933,"^O","^1;",536884735]],["^15",[3933,"^F",3932,536884735]],["^15",[3933,"^X",3406,536884735]],["^15",[3933,"^V",3930,536884735]],["^15",[3933,"^?",["^ "],536884735]],["^15",[3933,"^;","~u6887a5fd-82b3-4d48-8559-ec36c08fa808",536884735]],["^15",[3934,"^Q","ABAB... или ABBA... по форме или смыслу, иногда в разных паттернах",536884735]],["^15",[3934,"^O","^1;",536884735]],["^15",[3934,"^F",3933,536884735]],["^15",[3934,"^X",3406,536884735]],["^15",[3934,"^V",3930,536884735]],["^15",[3934,"^?",["^ "],536884735]],["^15",[3934,"^;","~u68879fb4-2f6d-42b3-87b1-7e492f4759f3",536884735]],["^15",[3935,"^Q","Элементы",536884735]],["^15",[3935,"^O","^1;",536884735]],["^15",[3935,"^F",3934,536884735]],["^15",[3935,"^X",3406,536884735]],["^15",[3935,"^V",3930,536884735]],["^15",[3935,"^?",["^ "],536884735]],["^15",[3935,"^;","~u6887a02f-85df-45a1-9866-0e875d0ca838",536884735]],["^15",[3936,"^Q","инверсия и повторение",536884735]],["^15",[3936,"^O","^1;",536884735]],["^15",[3936,"^F",3935,536884735]],["^15",[3936,"^X",3406,536884735]],["^15",[3936,"^V",3935,536884735]],["^15",[3936,"^?",["^ "],536884735]],["^15",[3936,"^;","~u6887a041-c624-484d-8870-221b650137de",536884735]],["^15",[3937,"^Q","кульминация или обратная кульминация, если A и B больше двух",536884735]],["^15",[3937,"^O","^1;",536884735]],["^15",[3937,"^F",3936,536884735]],["^15",[3937,"^X",3406,536884735]],["^15",[3937,"^V",3935,536884735]],["^15",[3937,"^?",["^ "],536884735]],["^15",[3937,"^;","~u6887a0da-1a7e-4ecd-8692-c715afbc259f",536884735]],["^15",[3938,"^Q","Высокий, средний и низкий стиль",536884735]],["^15",[3938,"^O","^1;",536884735]],["^15",[3938,"^F",3930,536884735]],["^15",[3938,"^X",3406,536884735]],["^15",[3938,"^V",3890,536884735]],["^15",[3938,"^?",["^ "],536884735]],["^15",[3938,"^;","~u6890c865-bd43-4947-8042-ab6a3e09061f",536884735]],["^15",[3939,"^Q","Средний может восприниматься как стиль...",536884735]],["^15",[3939,"^O","^1;",536884735]],["^15",[3939,"^F",3938,536884735]],["^15",[3939,"^X",3406,536884735]],["^15",[3939,"^V",3938,536884735]],["^15",[3939,"^?",["^ "],536884735]],["^15",[3939,"^;","~u6890c87f-970f-4560-bccb-111f904b78b1",536884735]],["^15",[3940,"^Q","между высоким и низким",536884735]],["^15",[3940,"^O","^1;",536884735]],["^15",[3940,"^F",3939,536884735]],["^15",[3940,"^X",3406,536884735]],["^15",[3940,"^V",3939,536884735]],["^15",[3940,"^?",["^ "],536884735]],["^15",[3940,"^;","~u6890c89f-faea-46b9-b5e5-546cfac3407a",536884735]],["^15",[3941,"^Q","нейтральный",536884735]],["^15",[3941,"^O","^1;",536884735]],["^15",[3941,"^F",3940,536884735]],["^15",[3941,"^X",3406,536884735]],["^15",[3941,"^V",3939,536884735]],["^15",[3941,"^?",["^ "],536884735]],["^15",[3941,"^;","~u6890c8c4-4535-43bf-9beb-389d10c46649",536884735]],["^15",[3942,"^Q","Прозрачый и туманный стиль",536884735]],["^15",[3942,"^O","^1;",536884735]],["^15",[3942,"^F",3938,536884735]],["^15",[3942,"^X",3406,536884735]],["^15",[3942,"^V",3890,536884735]],["^15",[3942,"^?",["^ "],536884735]],["^15",[3942,"^;","~u6890c8ca-3b8b-4852-932b-b968b0fbc641",536884735]],["^15",[3943,"^Q","Transparent style and opaque style",536884735]],["^15",[3943,"^O","^1;",536884735]],["^15",[3943,"^F",3942,536884735]],["^15",[3943,"^X",3406,536884735]],["^15",[3943,"^V",3942,536884735]],["^15",[3943,"^?",["^ "],536884735]],["^15",[3943,"^;","~u6890ca02-a73d-4a01-8fee-f3ca010c456d",536884735]],["^15",[3944,"^Q","Смотреть на/сквозь слова",536884735]],["^15",[3944,"^O","^1;",536884735]],["^15",[3944,"^F",3943,536884735]],["^15",[3944,"^X",3406,536884735]],["^15",[3944,"^V",3942,536884735]],["^15",[3944,"^?",["^ "],536884735]],["^15",[3944,"^;","~u6890ca1b-4019-4fd8-befe-54afb7c4a4c7",536884735]],["^15",[3945,"^Q","Looking at/through words",536884735]],["^15",[3945,"^O","^1;",536884735]],["^15",[3945,"^F",3944,536884735]],["^15",[3945,"^X",3406,536884735]],["^15",[3945,"^V",3944,536884735]],["^15",[3945,"^?",["^ "],536884735]],["^15",[3945,"^;","~u6890caa7-6aeb-4d81-a571-eebe150e8a15",536884735]],["^15",[3946,"^Q","Плоскости",536884735]],["^15",[3946,"^O","^1;",536884735]],["^15",[3946,"^F",3945,536884735]],["^15",[3946,"^X",3406,536884735]],["^15",[3946,"^V",3944,536884735]],["^15",[3946,"^?",["^ "],536884735]],["^15",[3946,"^;","~u6890cbde-2727-4794-a777-b88516ad1af7",536884735]],["^15",[3947,"^Q","Переключатель",536884735]],["^15",[3947,"^O","^1;",536884735]],["^15",[3947,"^F",3946,536884735]],["^15",[3947,"^X",3406,536884735]],["^15",[3947,"^V",3946,536884735]],["^15",[3947,"^?",["^ "],536884735]],["^15",[3947,"^;","~u6890cbf4-6c3d-42fe-8199-3a5e7740e8e5",536884735]],["^15",[3948,"^Q","Спектр",536884735]],["^15",[3948,"^O","^1;",536884735]],["^15",[3948,"^F",3947,536884735]],["^15",[3948,"^X",3406,536884735]],["^15",[3948,"^V",3946,536884735]],["^15",[3948,"^?",["^ "],536884735]],["^15",[3948,"^;","~u6890cbff-6161-469d-b9e9-1eb147ef8a9f",536884735]],["^15",[3949,"^Q","Большинство читателей не видят двух срезов одновременно. Они либо смотрят сквозь слова на их значение, либо переключаются между at/through.",536884735]],["^15",[3949,"^O","^1;",536884735]],["^15",[3949,"^F",3948,536884735]],["^15",[3949,"^X",3406,536884735]],["^15",[3949,"^V",3948,536884735]],["^15",[3949,"^?",["^ "],536884735]],["^15",[3949,"^;","~u6890e806-8993-450a-96e3-c9e38279338a",536884735]],["^15",[3950,"^Q","Аллитерация, рифма и другие похожие художественные элементы указывают на смутный стиль за исключением случаев, когда форма и есть содержание. Тогда произведение перемещается из плоскости переключатель в плоскость спектра.",536884735]],["^15",[3950,"^O","^1;",536884735]],["^15",[3950,"^F",3946,536884735]],["^15",[3950,"^X",3406,536884735]],["^15",[3950,"^V",3944,536884735]],["^15",[3950,"^?",["^ "],536884735]],["^15",[3950,"^;","~u6890cac3-b7c3-4307-933e-a36907eef5b8",536884735]],["^15",[3951,"^Q","Правильное чтение подразумевает быстрое переключение между at/through. Поэтому самосознание обязательно для хорошего читателя.",536884735]],["^15",[3951,"^O","^1;",536884735]],["^15",[3951,"^F",3950,536884735]],["^15",[3951,"^X",3406,536884735]],["^15",[3951,"^V",3944,536884735]],["^15",[3951,"^?",["^ "],536884735]],["^15",[3951,"^;","~u6890ec3f-a0bf-49f5-86da-79f3966b17fc",536884735]],["^15",[3952,"^Q","tags:: writing/syntax",536884744]],["^15",[3952,"^O","^1;",536884736]],["^15",[3952,"^1<",["^19",[]],536884744]],["^15",[3952,"^@",true,536884736]],["^15",[3952,"^F",3406,536884736]],["^15",[3952,"^X",3406,536884736]],["^15",[3952,"^V",3406,536884736]],["^15",[3952,"^U",846,536884745]],["^15",[3952,"^U",3406,536884745]],["^15",[3952,"^U",3955,536884745]],["^15",[3952,"^:",true,536884744]],["^15",[3952,"^?",["^ ","^18",["^19",["writing/syntax"]]],536884744]],["^15",[3952,"^J",["^14",["^18"]],536884744]],["^15",[3952,"^4",["^ ","^18","writing/syntax"],536884744]],["^15",[3952,"^H",846,536884744]],["^15",[3952,"^H",3955,536884744]],["^15",[3952,"^;","~u68c1b1ce-104f-4edf-807d-c3bcd9017c3d",536884736]],["^15",[3953,"^3","tags:: writing/syntax\n\n- #+BEGIN_QUOTE\n  Goethe, in his conversations with Eckermann, is reputed to have said that “if any man would write in a noble style let him ﬁrst possess a noble soul.” Wonderful, but not much help. It may be, though some wise men have denied it, that virtue can be taught, but it seems unlikely that it can be taught in Freshman Composition. Nor sincerity. Nor spontaneity. Nor true grit. What can be taught is words. And they must be taught in the full matrix of human utterance, written and spoken, accompanied by a theory of style equally broad. A student bright enough to be taught style needs a context for it beyond didactic precept, an intelligible and sound context. Style cannot be taught only by lists of self-contradicting proverbs, strings of dos and don’ts. Students so instructed are not being taught; they are being housebroken. I recommend, in what follows, a particular strategy for a particular time and place. Prose style cannot be taught, as it has been, in—and as—a vacuum. It will simply end up, as has been happening with increasing frequency (vacuums being hard to teach), not being taught at all. It cannot be taught as a duty, for you cannot teach as duty what society does not feel a duty. Style must be taught for and as what it is—a pleasure, a grace, a joy, a delight. Pleasure will not, it is true, teach the dumb to speak, the stupid to write, or the bad to practice goodness. But neither will anything else.\n  #+END_QUOTE\n  Lanham, R. A. (2018). *Style: An anti-textbook*.\n- Стилистические приёмы всегда могут быть перевёрнуты, чтобы обмануть ожидания читателя.\n- Реторическая грамматика. Kolln, M. J., & Gray, L. S. (n.d.). *Rhetorical Grammar: Grammatical Choices, Rhetorical Effects*.\n\t- Короткие элементарные предложения: подлежащее, составное сказуемое (глагол и комплемент) и возможный сирконстант (адвербальное или номинативное приложение),\n\t  collapsed:: true\n\t\t- где глагол - ...\n\t\t\t- Связующий\n\t\t\t\t- Копула\n\t\t\t- Непереходный\n\t\t\t- Переходный с прямым дополнением и возможным косвенным дополнением или сирконстантом дополнения\n\t\t- Первые три глагола обычно используются для описания или ёмкого обозначения, а последний - часто для действия или описания перемены.\n\t\t- Копула,\n\t\t\t- где лексическая часть составного сказуемого, в данном случае только комплемент, - ...\n\t\t\t\t- Вид метонимии\n\t\t\t\t\t- Напр., синекдоха\n\t\t\t\t- Метафора, где комплемент - ...\n\t\t\t\t\t- Существительное\n\t\t\t\t\t- Прилагательное\n\t\t\t\t\t- Наречие или наречная группа\n\t\t\t\t\t- Предложная группа\n\t\t- В случае копулы и связующего глагола лексическое ударение падает на комплемент.\n\t\t- В плане стиля короткое предложение, одно или более, может...\n\t\t\t- обращать на себя внимание\n\t\t\t- задать тему или тон для последующего, например, абзаца\n\t\t\t- менять тему или тон посередине, действуя как ось вращения\n\t\t\t- ставить точку в конце абзаца\n\t\t\t- быть частью ритма или драмы в контрасте с более длинными предложениями\n\t\t- Рядом с развёрнутым определением короткое простое предложение - ядро целого сложного.\n\t- Сложное предложение\n\t\t- Сочинение\n\t\t  collapsed:: true\n\t\t\t- В простом предложении\n\t\t\t\t- Однородных членов\n\t\t\t\t\t- Градация\n\t\t\t\t\t\t- По насыщенности\n\t\t\t\t\t\t- По длине\n\t\t- Подчинение\n\t\t  collapsed:: true\n\t\t\t- Придаточное предложение\n\t\t\t\t- относительные\n\t\t\t\t\t- существительного\n\t\t\t\t\t- главного предложения\n\t\t\t\t\t\t- Присоединяются с помощью союзных слов: *что, куда, откуда, где, когда, как, почему*. Дополняют и поясняют содержание основной части. Нередко обладают значением следствия.\n\t\t\t\t- изъяснительные\n\t\t\t\t\t- относятся к глаголу\n\t\t\t\t- обстоятельственные\n\t\t\t\t\t- времени и места\n\t\t\t\t\t- причины, следствия, условия, уступки, цели\n\t\t\t\t\t- образа действия, меры, степени, сравнения\n\t\t\t- Если глаголы непараллельны в аспекте, переходности или наличии связки, используй подчинение для их разбивки. Выбери, какой глагол поставить на передний план, т.е. главное предложение, а какой на задний, т.е. придаточное.\n\t- Связность или когезия\n\t  collapsed:: true\n\t\t- Лексическая когезия\n\t\t\t- Повторение\n\t\t\t\t- Параллелизм, т.е. структурное повторение фраз и клауз\n\t\t\t\t\t- Антитеза\n\t\t\t- Синонимы\n\t\t- Новая и известная информация\n\t\t\t- Оба рода упоминаются как подлежащие в соответствующих предложениях\n\t\t\t- Если известная информация - в предикате, нужна инверсия\n\t\t\t\t- То есть помести новую информацию в предикат предложения, а известную - в подлежащее\n\t\t\t\t- Или преврати изестное в сирконстант\n\t\t\t\t- Можно использовать пассивный залог, но осторожно\n\t\t\t- Тематическое предложение появляется в начале параграфа и раскрывается далее\n\t\t\t- Местоимения указывают на известную информацию или в случае притяжательных согласовываются с ней\n\t- Ритм\n\t  collapsed:: true\n\t\t- Из-за свободного порядка слов русский язык не имеет ограничений как английский.\n\t\t- Ударение в предложении падает на новую информацию, которая согласно когезии находится в конце предложения, а именно в качестве последнего или предпоследнего слова.\n\t\t\t- В английском языке речь идёт о предикате, но в русском это может быть и подлежащее. Также в русском перестановкой фраз можно сменить ударение.\n\t\t- Приоритет ударения на последнем слове может быть заменён запятой перед вводным словом, которая создаёт паузу\n\t\t- Отягощённые слова притягивают ударение и замедляют чтение\n\t\t\t- Превосходные прилагательные. Избегай их.\n\t\t\t- Наречия + прилагательные. Тоже исключи.\n\t\t\t- Именная группа. Можно, если найдёшь удачные слова.\n\t\t\t- Соотносительные союзы смещают внимание на подлежащее\n\t\t\t- Подчёркивающие наречия\n\t\t\t- Наречие только. Можно иногда.\n\t- Форма и функция\n\t  collapsed:: true\n\t\t- Форма\n\t\t  collapsed:: true\n\t\t\t- Слово\n\t\t\t\t- Существительное\n\t\t\t\t- Глагол\n\t\t\t\t- Прилагательное\n\t\t\t\t- Наречие\n\t\t\t- Фраза\n\t\t\t\t- Именная группа\n\t\t\t\t- Глагольная группа\n\t\t\t\t- Предложная группа\n\t\t\t- Клауза\n\t\t\t\t- Независимая (предложение)\n\t\t\t\t- Зависимая\n\t\t- Функция описания\n\t\t\t- Лучше, чем школьная разбивка на определения, обстоятельтва и дополнения\n\t\t\t- Виды морификаций каждой из функций\n\t\t\t\t- Адвербальные\n\t\t\t\t\t- Несогласованное определение глагола\n\t\t\t\t- Адъективные\n\t\t\t\t\t- Комплемент подлежащего\n\t\t\t\t\t- Комплемент дополнения\n\t\t\t\t\t- Определение существительного\n\t\t\t\t- Номинативные\n\t\t\t\t\t- Комплемент подлежащего\n\t\t\t\t\t  id:: 67bc2925-7f2f-4d8f-83e8-ec24789d0a63\n\t\t\t\t\t- Прямое дополнение\n\t\t\t\t\t- Косвенное дополнение\n\t\t\t\t\t- Комплемент дополнения\n\t\t\t\t\t  id:: 67bc29ba-5de7-4922-ab0a-fd309cdb01a2\n\t\t\t\t\t- Дополнение предлога\n\t\t\t\t\t- Приложение\n\t\t\t- Адвербальные\n\t\t\t\t- Вершина - глагольная группа.\n\t\t\t\t- Самая гибкая функция в плане расположения в предложении\n\t\t\t\t\t- Начинание предложения с него помогает...\n\t\t\t\t\t\t- задать тему\n\t\t\t\t\t\t- улучшить когезию...\n\t\t\t\t\t\t\t- связав предложение с предыдущей информацией\n\t\t\t\t\t\t\t- поместив указатели места и времени\n\t\t\t\t- Адвербальная группа\n\t\t\t\t\t- Наречие\n\t\t\t\t\t\t- Наречие образа действия\n\t\t\t\t\t\t\t- Если поместить зависимое наречие после вершины, то на него придётся больше ударения\n\t\t\t\t\t\t\t- Если поместить в начале, то наречие модифицирует всё предложение\n\t\t\t\t\t- Глагольная группа\n\t\t\t\t\t\t- Деепричастие\n\t\t\t\t- Предложная группа\n\t\t\t\t\t- При использовании нужно избегать...\n\t\t\t\t\t  id:: 67bc5281-4144-4f94-8d5d-38e427f770b0\n\t\t\t\t\t\t- ...смещения фокуса. Например, предложная фраза в конце обратит внимание на себя.\n\t\t\t\t\t\t- ...повторения известной информации. В предложной фразе легко дублировать информацию.\n\t\t\t\t- Именная группа...\n\t\t\t\t\t- часто схожа с предложной фразой без предлога\n\t\t\t\t- Группа с комплементатором (придаточное предложение или инфинитив сразу после глагола)\n\t\t\t\t\t- Подчинительный союз показывает, как обстоятельственное придаточное предложение соотносится с главным\n\t\t\t\t\t- Главная или новая может быть как в главном предложении, так и в придаточном\n\t\t\t\t\t- Оно может появляться не только в конце или начале предложения, но и в середине после вершины. В этом случае ударение падает на неё.\n\t\t\t\t\t- Если не передаётся новая информация, придаточное предложение может начинаться в отдельном предложении после точки\n\t\t\t- Адъективные\n\t\t\t\t- Вершина - именная группа\n\t\t\t\t- Детерминативная группа\n\t\t\t\t\t- тж. Именная группа...\n\t\t\t\t\t\t- ...после вершины, напр. [DP [NP чашка [DP чая]]]\n\t\t\t\t- Предложная группа\n\t\t\t\t\t- {{embed ((67bc5281-4144-4f94-8d5d-38e427f770b0))}}\n\t\t\t\t- Прилагательная группа\n\t\t\t\t\t- Прилагательное\n\t\t\t\t\t- Причастие\n\t\t\t\t\t  collapsed:: true\n\t\t\t\t\t\t- Оно передаёт содержание в более ёмком виде. Его можно развернуть в главное или придаточное предложение.\n\t\t\t\t\t\t\t- Однако в русском языке выполняет больше функцию, чем адвербиальную. Для последней используют деепричастие.\n\t\t\t\t\t\t- В начале или конце причастие - свободный модификатор.\n\t\t\t\t\t\t\t- В конце предложения причастный оборот даёт больше свободы развернуться используя больше слов или новых вложенных модификаторов.\n\t\t\t\t\t- Относительное придаточное предложение\n\t\t\t\t\t\t- Как и причастие оно позволяет заключить подлежащее и сказуемое в одну именную группу. В отличие от него такое предложение не так подвижно и начинается почти всегда сразу после существительного.\n\t\t\t- Номинативные\n\t\t\t\t- Именная группа\n\t\t\t\t\t- Причастие\n\t\t\t\t\t- Вершина - именная группа\n\t\t\t\t\t\t- Приложения\n\t\t\t\t\t\t  collapsed:: true\n\t\t\t\t\t\t\t- ...могут быть развёрнутыми\n\t\t\t\t\t\t\t- ...помимо существительного могут быть другой частью речи\n\t\t\t\t\t\t\t- Типы\n\t\t\t\t\t\t\t\t- Ограничивающее (указание)\n\t\t\t\t\t\t\t\t- Неограничивающее (примечание)\n\t\t\t\t- Инфинитивная группа\n\t\t\t\t\t- Вершина - именная или глагольная группа\n\t\t\t\t- Содержательное придаточное предложение\n\t\t\t\t\t- может быть подлежащим, комплементом сказуемого или приложением\n\t\t\t\t\t- Утвердительное\n\t\t\t\t\t- Вопросительное\n- Паттерны. Longknife, A., & Sullivan, K. D. (2002). *The art of styling sentences : 20 patterns for success*.\n  collapsed:: true\n\t- Сложное предложение\n\t\t- 1\n\t\t\t- S V ; (,) S V.\n\t\t\t- Сочетает несколько мыслей для возможности параллели.\n\t\t\t- Варианты\n\t\t\t  collapsed:: true\n\t\t\t\t- 1a\n\t\t\t\t\t- S V ; соединительное наречие S V.\n\t\t\t\t- 1b\n\t\t\t\t\t- S V ; союз S V.\n\t\t\t\t- 1c\n\t\t\t\t\t- S V ; S V; S V.\n\t\t- 2\n\t\t\t- S V DO (прямое дополнение) или SC (комплемент субъекта); S - (эллипсис) DO или SC.\n\t\t- 3 Общее утверждение : пояснение.\n\t- Предложение с рядом\n\t\t- 4\n\t\t\t- A, B, C.\n\t\t\t- Варианты\n\t\t\t\t- A и B и C.\n\t\t\t\t- A или B или C.\n\t\t- 5\n\t\t\t- A и (или, но) B, C и D, E и F.\n\t\t\t\t- Создаётся ритм. Чтобы прочувствовать его, читай предложение вслух.\n\t\t- 6\n\t\t\t- *Ряд приложений* - *обобщающее слово* (иногда S, иногда определение S) V.\n\t\t\t\t- Определения - те, которые; те, что.\n\t\t\t\t- Используй паттерны 4, 4a, 5 для построения серии приложений.\n\t\t- 7\n\t\t\t- S, *ряд приложений или определений*, V.\n\t\t\t\t- Паттерн 6 наоборот\n\t\t\t- Варианты\n\t\t\t  collapsed:: true\n\t\t\t\t- 7а\n\t\t\t\t\t- S, одно или два приложения с возможными определениями, V.\n\t\t- 8 *Ряд придаточных предложений*, S V. или S V, *ряд придаточных предложений*.\n\t- Повторение...\n\t\t- подчеркивает важные идеи или делает предложения более связными.\n\t\t- может передаваться через разные части речи и лексемы, если слова, отражённые в них, однокоренные.\n\t\t- 9\n\t\t\t- Повторение ключевого слова в разных позициях.\n\t\t- 9a\n\t\t\t- Повторение ключевого слова в одной позиции.\n\t\t- 10\n\t\t\t- Приложение в конце предложения после тире.\n\t\t\t\t- S V *слово*: *приложение с возможными определениями*.\n\t- Определение...\n\t\t- может быть одним словом, парой слов или фразой.\n\t\t- 11\n\t\t\t- Прерывающее определение между S и V\n\t\t\t\t- S, *определение*, V.\n\t\t\t\t- Вариант\n\t\t\t\t\t- 11a\n\t\t\t\t\t\t- Целое предложение (утверждение, вопрос или восклицание) как прерывающее определение.\n\t\t\t\t\t\t\t- S - *предложение* - V.\n\t\t- 12\n\t\t\t- Вводные или заключающие причастия\n\t\t\t\t- Такие причастия свободны.\n\t\t\t\t- *Причастный оборот*, S V.\n\t\t\t\t  S V, *причастный оборот*.\n\t- Инверсия...\n\t\t- может применяться к словам, фразам или придаточным предложениям.\n\t\t- не должна быть слишком частой, чтобы выглядеть уместной и естественной. Слишком большое разнообразие может оказаться хуже его полного отсутствия.\n\t\t- Читай предложения с инверсией вслух, чтобы уловить уместна ли она или нет.\n\t\t- 14\n\t\t\t- Предложная фраза перед S и V\n\t\t\t\t- *Предложная фраза* S V.\n\t\t\t\t- *Предложная фраза* V S.\n\t\t- 15\n\t\t\t- Объект или комплемент перед S и V\n\t\t\t\t- *Объект* или *комплемент* S V.\n\t\t\t- Вариант\n\t\t\t\t- 15a\n\t\t\t\t\t- Полная инверсия обычного паттерна\n\t\t\t\t\t- V S.\n\t\t\t\t\t- *Объект* или *комлемент* или *определение* V S.\n\t- Набор паттернов\n\t\t- 16\n\t\t\t- Парные конструкции...\n\t\t\t\t- используют корлелятивные союзы, слова, фразы и клаузы.\n\t\t\t\t- *Первый коррелят* S V, *второй коррелят* S V.\n\t\t\t- Вариант\n\t\t\t\t- 16a\n\t\t\t\t\t- Парные конструкции только для контраста\n\t\t\t\t\t- *Первое слово или фраза внутри предложения*, а не *второе слово или фаза*.\n\t\t- 17\n\t\t\t- Сложноподчинённое предложение как субъект, объект или комплемент...\n\t\t\t\t- начинаются со слов *кто, который, что, почему, где, когда, как*\n\t\t\t\t- S [сложноподчинённое предложение как субъект] V.\n\t\t\t\t- S V [сложноподчинённое предложение как объект или комплемент].\n\t\t- 18\n\t\t\t- Абсолютная конструкция...\n\t\t\t\t- не используется в русском языке\n\t\t- 19\n\t\t\t- Краткое простое предложение для разрядки или драматического эффекта...\n\t\t\t\t- будет эффективным только, если оно...\n\t\t\t\t\t- используется после нескольких долгих предложений.\n\t\t\t\t\t- суммирует сказанное.\n\t\t\t\t\t- предоставляет переход между одной ил более мыслями.\n\t\t- 19a\n\t\t\t- Краткий вопрос для драматического эффекта...\n\t\t\t\t- эффективен...\n\t\t\t\t\t- во введении, чтобы заинтересовать читателя.\n\t\t\t\t\t- как тематическое предложение в качестве введения параграфа.\n\t\t\t\t\t- внутри параграф для разнообразия.\n\t\t\t\t\t- как переход между параграфами.\n\t\t\t\t\t- в конце, как наводящее на мысли заключение.\n\t\t- 20\n\t\t\t- Метакомментарий...\n\t\t\t\t- нужо обычно избегать. Но иногда он к месту, если использовать умело.\n\t- Комбинации паттернов\n\t\t- 3, 4, 9a\n\t\t- 9, 11\n\t\t- 17, 10, 5\n\t\t- 4, 9, 9a, 15a\n\t\t- 1, 4, 4a, 9\n\t\t- 6, 8, 9, 19a\n\t\t- 1, 14, 15a\n\t\t- 4, 11, 9a, 16, 17\n\t\t- 11, 11a\n\t\t- 1, 4a, 9a, 20\n- Построение предложений. Landon, B. (2013). *Building great sentences: How to Write the Kinds of Sentences You Love to Read*.\n  collapsed:: true\n\t- Предложение, а не слово, словосочетание или параграф, - атом прозы.\n\t\t- Простое предложение - ядро длинного.\n\t\t\t- В свою очередь предложение состоит не только из слов и фраз, но из высказываний. Они логический срез предложения.\n\t\t- Более длинное предложение не всегда лучше. Но предложение, в котором больше полезной иформации, почти всегда лучше.\n\t- 1 Последовательность слов\n\t\t- Выбор слов - парадигматичный выбор, а их порядка - синтагматичный.\n\t\t\t- Парадигматичный\n\t\t\t\t- Лестница абстракции\n\t\t\t- Синтагматичный\n\t\t\t\t- Форма есть содержимое.\n\t- 2 Грамматика и реторика\n\t\t- Эффективность определяется тем, насколько хорошо писатель согласует выражаемые пропозиции с обстоятельствами ситуации, своими целями, а также требованиями и ожиданиями читателя.\n\t\t- Выразительность показывает, как успешно автор отражает эмоциональное измерение: себя, атмосферу, настроение и т.д.\n\t\t- Грамматика учит нас, как оперировать мёртвую птицу, а реторика - как воспринимать полёт живой. Реторика имеет дело с причинами, по которым мы пользуемся словами, чтобы достигнуть определённых целей, и степенью успешности их достижения. Согласно Ланему реторика - это \"наука структур человеческого внимания\".\n\t\t\t- \"Меня интересует намного, намного больше реторика.\"\n\t\t\t- Одной лишь гремметики не достаточно для эффективного пись\n\t\t\t- Стиль - то, что писатель пишет и читатель читает. Автору не следует предполагать, что читатель замечает и читает то же, что и он сам.\n\t- 3 Первоначальность высказываний\n\t\t- Элементарной единицей предложения являются не слова или фраза, а высказывание.\n\t\t- Высказывание - это элементарное высказывание, которое не имеет составляющих высказываний.\n\t\t- Предложение не всегда имеет лишь тот смысл, который можно извлечь из высказываний на поверхности. Его главным содержанием может быть то, на что они намекают.\n\t\t\t- Плотность пропозиций указывает на то, насколько они содержательны.\n\t- 4 Как строятся предложения\n\t\t- Простое предложение - ядро длинного.\n\t\t- Предикативный стиль использует мало деталей.\n\t\t\t- Он показывает, что герой видит, но не то, о чём он размышляет.\n\t\t- Виды развёртывания предложения\n\t\t\t- Сложное предложение\n\t\t\t\t- 1 Сочинение\n\t\t\t\t- 2 Подчинение\n\t\t\t- 3 Определение\n\t\t\t\t- Самый используемый в этой книге метод\n\t- 5 Собирательный синтаксис\n\t\t- Cumulative syntax\n\t\t- #+BEGIN_QUOTE\n\t\t  Ритм хорошей современной прозы исходит примерно поровну из одновременного прослеживания сочинительных конструкций и уточнения и возврата к вершинам свободных определений.\n\t\t  #+END_QUOTE\n\t\t  Фрэнсис Кристенсен\n\t\t- Существительное, глагол и главное предложение содержит информацию, известную читателю. Если он этого не знает, то это не твой читатель.\n\t\t\t- Читатель обнаруживает суть в определениях.\n\t\t- 4 принципа Кристенсена\n\t\t\t- 1 добавление\n\t\t\t- 2 направление определения\n\t\t\t\t- В предложениях ответвляющихся в левую сторону определение направлено вперёд, а в правую - назад.\n\t\t\t- 3 уточнение\n\t\t\t\t- После главного предложения движение вперёд останавливается. Дальше писатель идёт вниз по лестнице абстракции или к единичным концепциям, оглядываясь назад.\n\t\t\t- 4 плотность информации\n\t\t- Ритм собирательного предложения\n\t\t\t- Три параметра\n\t\t\t\t- число определений\n\t\t\t\t- длина определения\n\t\t\t\t- его глубина\n\t\t\t\t\t- парадигматический аспект\n\t\t\t\t- направление ответвления\n\t\t\t\t\t- синтагматический аспект\n\t\t\t\t\t\t- в правую сторону\n\t\t\t\t\t\t- в левую сторону\n\t\t\t\t\t\t- посередине\n\t\t\t- Несколько собирательных предложений образуют связки, с помощью которых в свою очередь строится больший ритм отливов и приливов.\n\t- 6 Сочинительные, подчинённые и смешанные собирательные паттерны\n\t\t- Собирательное предложение генеративно, так как каждое определение побуждает к написанию более подробного нового.\n\t\t- Причастие - это глагол в виде прилагательного.\n\t\t- Профессиональные писатели заканчивают предложения два из трёх раз.\n\t\t- Парадигматические паттерны собирательных предложений\n\t\t\t- Сочинительное\n\t\t\t\t- больше одного определения второго уровня\n\t\t\t\t\t- больше\n\t\t\t\t\t\t- новой информации\n\t\t\t\t\t\t- целей для определения\n\t\t\t\t\t\t- возможости для добавления определений\n\t\t\t\t- преимущества\n\t\t\t\t\t- очень ритмично\n\t\t\t\t\t- \"motion without movement\"\n\t\t\t\t\t\t- полирует ту же информацию без движения вперёд, но создавая впечатление движения\n\t\t\t- Подчинительное\n\t\t\t\t- следующее определение глубже предыдущего и ссылается на него\n\t\t\t\t\t- уточняет\n\t\t\t\t\t- может разбить целое на части как это в некоторых случаях делает запятая\n\t\t\t\t\t- подталкивает к новым мыслям\n\t\t\t\t\t- но может отвлечь на незначимые детали\n\t\t\t\t\t- но чем дальше определение от главого предложения, тем труднее предложение цельное писать и читать\n\t\t\t\t- преимущества\n\t\t\t\t\t- помогает двигаться в новые территории\n\t\t\t\t\t\t- особено эффективно, когда описывается\n\t\t\t\t\t\t\t- процесс\n\t\t\t\t\t\t\t- происходящее во времени\n\t\t\t- Смешанное\n\t\t\t\t- совмещает качества и преимущества сочинительного и подчинительного собирательных предложений\n\t- 7 Поправки собирательного предложения\n\t\t- Чтение вслух помогает выявить ошибки.\n\t\t- Чтобы предложение стало собирательным, нужно как минимум два определения.\n\t\t- Каждое новое определение даёт возможность добавить ещё одно собирательное или подчинительное определение.\n\t\t- Последним определением можно заключить итог предложения.\n\t\t- Повторение в сочинительных собирательных часто приветсвуется, в подчинительных и смешанных - наоборот.\n\t- 8 Побуждение к сопоставлению и предположению\n\t\t- Сравнение как...\n\t\t\t- сопоставление\n\t\t\t- предложение\n\t\t- Сравнение зачастую эффективно в конце собирательного предложения.\n\t\t- Сравнения как сопоставления...\n\t\t\t- отражают мышление автора на инстинктивном уровне.\n\t\t\t\t- Через них авторы дают прочувствовать читателю личность сочинителя.\n\t\t\t\t\t- #+BEGIN_QUOTE\n\t\t\t\t\t  Помни, что значит быть собой. В этом весь смысл.\n\t\t\t\t\t  #+END_QUOTE\n\t\t\t\t\t  Джоан Дидион\n\t\t\t- хоть и по форме не определения выполняют похожую функцию, помогая создавать ритм и добавлять новую информацию.\n\t\t- Сравнения как предположения...\n\t\t\t- тоже помогают открыть себя автору, только делают это более явно.\n\t\t\t- устанавливают особую связь между автором и читателем, потому что они предполагают вместе.\n\t- 9 Загадка ритма прозы\n\t\t- Читай вслух.\n\t\t- У каждого языка свой ритм.\n\t\t- Ритм  создаёт разнообразие...\n\t\t  id:: 68656f8e-0b7d-4bd0-bbef-4afea47a2bcf\n\t\t\t- длины предложений\n\t\t\t- длины групп внутри предложения\n\t\t\t\t- В данном случает полезно собирательное предложение.\n\t\t\t\t\t- Приведена аналогия с Морзе, где короткая группа - точка, а более длинная - тире.\n\t\t- Чувство ритма субъективно. Писатель должен его культивировать.\n\t- 10 Отлагательный синтаксис: ритм задержки\n\t\t- Suspensive syntax\n\t\t- Понятия \"накопительный\" и \"отлагательный\" не являются взаимоисключающими.\n\t\t- 3 паттерна\n\t\t\t- 1 обратный накопительный\n\t\t\t\t- ..., S V.\n\t\t\t- 2\n\t\t\t\t- S, ..., V.\n\t\t\t\t- 2.1 Именно в русском, редко в английском.\n\t\t\t\t\t- V, ..., S.\n\t\t\t\t- Трудно контролировать\n\t\t\t- 3\n\t\t\t\t- Если (хотя, когда, потому что и т.д.), S V.\n\t\t- В русском языке гораздо легче строить отлагательные предложения.\n\t- 11 Степени откладывания, значение неожиданности\n\t\t- Цели\n\t\t\t- подчёркивание значения\n\t\t\t\t- паттерн\n\t\t\t\t\t- нарастающий, ведущий к чему-то важному\n\t\t\t- создание неожиданности\n\t\t\t\t- паттерн\n\t\t\t\t\t- внезапный поворотный момент\n\t\t- Может быть в виде нескольких предложений, чаще всего в двух.\n\t\t- Фатические выражения могут использоваться в отлагательных предложениях.\n\t- 12 Сбалансированные предложения и сбалансированные формы\n\t  id:: 686825ec-ad7e-488c-9340-0984b58a03f1\n\t\t- Ценность параллелизма - больше в самих предложенях, чем в том, на что они указывают. Здесь уместно сравнение со смыслом поэзии.\n\t\t- Виды параллелизма\n\t\t\t- Баланс - это бинарный параллелизм\n\t\t\t- Ряд из трёх\n\t\t\t- Ряд из четырёх и более\n\t\t- Паттерны\n\t\t\t- Повторение параллельных слов\n\t\t\t- Их вариация, но с той же частью речи и похожим смыслом\n\t\t\t- Если (хотя, когда, потому что и т.д.), если (...), S V.\n\t\t\t  id:: 686bd481-6b8f-41a8-8de4-1ac6a1ae4521\n\t\t- Преимущества параллелизма\n\t\t\t- Порядок, если в предложении три и более фразы\n\t\t\t- Привлечение внимания\n\t\t\t- Ритм\n\t\t- Дополнительные преимущества баланса\n\t\t\t- Отражение\n\t\t\t\t- Симметрия\n\t\t\t- Дуализм\n\t\t\t- Гармония\n\t\t\t- Противопоставление\n\t\t- Недостаток баланса\n\t\t\t- #+BEGIN_QUOTE\n\t\t\t  The words are not fitted to the things, but the things to the words.\n\t\t\t  #+END_QUOTE The words are not fitted to the things, but the things to the words.\n\t\t\t  William Hazlitt\n\t- 13 Ритм трёх\n\t  id:: 686be35a-d2e6-46f7-ad49-19606fe3c613\n\t\t- Можно комбинировать с балансом.\n\t\t- Баланс создаёт гармонию или противоставляет.\n\t\t- Ряд трех создает логическую завершенность.\n\t\t- Паттерны с опущением или повторением союза, клаузы, членов предложения, группы\n\t\t\t- **Basic Patterns for Three-Part Serials** in 'The Rhythm of Threes' in Landon, B. (2013). *Building great sentences: How to Write the Kinds of Sentences You Love to Read*.\n\t- 14 Длинные предложения и искусные предложения\n\t\t- Длинные искусные предложения отражают не только детали повествования, но и мастерство самого писателя.\n\t\t- Длинные предложения громоздки, если в нем..\n\t\t\t- длинное простое предложение\n\t\t\t- длинная предложная фраза\n\t\t\t- много относительных придаточных предложений\n\t\t\t- много связанных, а не свободных определений\n\t\t- Длинные искусные предложения\n\t\t\t- редки даже у максималистов\n\t\t\t- зачастую отлагательны\n\t\t\t\t- внимание читателя должно быть вознаграждено\n- Анализ прозы. Lanham, R. A. (2003). *Analyzing prose*.\n\t- Глагольный слог вместо существительного слога\n\t\t- Существительный слог\n\t\t  id:: 687a5d5c-4f73-42f8-aca5-5e9178e87659\n\t\t\t- глагол-связка, тире или статичный глагол + предложная фраза + предложная фраза + ...\n\t\t\t- глагол + качество\n\t\t- #+BEGIN_QUOTE\n\t\t  We often observe this contrast between the absence of nominal inﬂection and the richness of the verbal inﬂection. This is due to the nature of the noun and the verb. The noun indicates an idea of permanent nature: a thing, a person, or a quality; the verb indicates a process. . . . For the very reason that it indicates a permanent notion, the noun has a sole form or at most a principal form from which the others are derived. On the other hand, the verb, which indicates a process, has personal forms and the expression of nuances which vary with languages, but can be numerous. The fact that the forms of the noun and verb obey divergent tendencies thus results from the nature of things.\n\t\t  #+END_QUOTE\n\t\t  A. Meillet, The Comparative Method in Historical Linguistics, p. 114\n\t- Паратаксис и гипотаксис\n\t\t- Это деление касается пропозиций, хоть и соотносится с синтаксисом.\n\t\t- Часто сочетаются в одном предложении.\n\t\t- В паратаксических предложениях синтаксические единицы равны.\n\t\t- Гипотаксис отражает...\n\t\t\t- причинно-следственную связь\n\t\t\t- хронологию\n\t\t\t- сравнение\n\t\t- Подчинительные союзы показывают логику, сочинительные (их повторение или отсутствие) - слог.\n\t\t- За несколькими паратаксическими предложениями часто стоит неумение свести их в одно гипотаксическое.\n\t- Цельный и текущий слоги\n\t\t- Periodic style and running style\n\t\t\t- #+BEGIN_QUOTE\n\t\t\t  Syntax follows sense, either a pattern of association, or of subject, or as here, a chronological sequence. What follows builds upon what went before, modiﬁes it, restates it. A diachronic style, we might call it, one that acknowledges the passage of time. It often creates immediacy and action\n\t\t\t  #+END_QUOTE\n\t\t\t- #+BEGIN_QUOTE\n\t\t\t  The periodic style works diﬀerently. It encloses time into a single, syntactically controllable unit, treats experience synchronically rather than diachronically. Here, arrangement controls, not time. In it, order triumphs; in the running style, order operates. The running style surprises the mind operating; in the periodic style, the mind has ﬁnished its work.\n\t\t\t  #+END_QUOTE\n\t\t\t- #+BEGIN_QUOTE\n\t\t\t  The periodic style, then, may represent pattern, and the running style, process.\n\t\t\t  #+END_QUOTE\n\t\t- Две крайности спектра\n\t\t- Единицей зачастую является несколько предложений.\n\t\t- Цельный слог в отличие от текущего упорядочен.\n\t\t- Качества цельного слога:\n\t\t\t- откладывание\n\t\t\t- параллелизм\n\t\t\t- баланс\n\t\t\t- кульминация\n\t\t\t- продуманность\n\t\t- Качества текущего слога:\n\t\t\t- как будто пишется в реальном времени\n\t\t\t\t- ощущение импровизации: остановки, мысли заново, ревизия сказанного\n\t\t\t- отступления внутри предложений (которые можно заключить в скобки)\n\t- Проза на слух\n\t\t- Два значения:\n\t\t\t- ритм и акцентирование слога\n\t\t\t  logseq.order-list-type:: number\n\t\t\t- голос персонажа или повествователя\n\t\t\t  logseq.order-list-type:: number\n\t\t- #+BEGIN_QUOTE\n\t\t  The rhythm of a passage does not simply exist, as does its imagery: reading has to create it.\n\t\t  #+END_QUOTE\n\t\t- #+BEGIN_QUOTE\n\t\t  Students of meter often refer to the tension between natural word stress and the stress pattern that meter imposes. In prose rhythm an analogous tension waits there for the exploiting. The reader must supply meaning, color it to a degree that poetry seldom permits. Because of this larger freedom, prose is often more fun to read aloud than poetry.\n\t\t  #+END_QUOTE\n\t- Форма предложенияй как содержимое\n\t\t- ... - это поиск знакомого паттерна известного смысла в новом \"удачном\" наборе слов.\n\t\t- ... - это имитация поэзии прозой.\n\t\t- Чтобы избежать поверхностности, нужно следовать от мысли к паттерну, а не наоборот. Выбирай паттерн, который поможет выразить мысль.\n\t\t- ABAB... или ABBA... по форме или смыслу, иногда в разных паттернах\n\t\t- Элементы\n\t\t\t- инверсия и повторение\n\t\t\t- кульминация или обратная кульминация, если A и B больше двух\n\t- Высокий, средний и низкий стиль\n\t\t- Средний может восприниматься как стиль...\n\t\t\t- между высоким и низким\n\t\t\t- нейтральный\n\t- Прозрачый и туманный стиль\n\t\t- Transparent style and opaque style\n\t\t- Смотреть на/сквозь слова\n\t\t\t- Looking at/through words\n\t\t\t- Плоскости\n\t\t\t\t- Переключатель\n\t\t\t\t- Спектр\n\t\t\t\t\t- Большинство читателей не видят двух срезов одновременно. Они либо смотрят сквозь слова на их значение, либо переключаются между at/through.\n\t\t\t- Аллитерация, рифма и другие похожие художественные элементы указывают на смутный стиль за исключением случаев, когда форма и есть содержание. Тогда произведение перемещается из плоскости переключатель в плоскость спектра.\n\t\t\t- Правильное чтение подразумевает быстрое переключение между at/through. Поэтому самосознание обязательно для хорошего читателя.",536884747]],["^15",[3953,"^17","~m1757524484755",536884760]],["^15",[3953,"^Z","journals/2025_09_09.md",536884738]],["^15",[3954,"^K",1757524450779,536884742]],["^15",[3954,"^@",false,536884742]],["^15",[3954,"^Y","writing/syntay",536884742]],["^15",[3954,"^A",846,536884742]],["^15",[3954,"^11","writing/syntay",536884742]],["^15",[3954,"^B",1757524450779,536884742]],["^15",[3955,"^K",1757524454485,536884744]],["^15",[3955,"^@",false,536884744]],["^15",[3955,"^Y","writing/syntax",536884744]],["^15",[3955,"^A",846,536884744]],["^15",[3955,"^11","writing/syntax",536884744]],["^15",[3955,"^B",1757524454485,536884744]],["^15",[3958,"^K",1757524666853,536884777]],["^15",[3958,"^O","^1;",536884777]],["^15",[3958,"^N",20250910,536884777]],["^15",[3958,"^@",true,536884777]],["^15",[3958,"^Y","sep 10th, 2025",536884777]],["^15",[3958,"^11","Sep 10th, 2025",536884777]],["^15",[3958,"^B",1757524666853,536884777]],["^15",[3958,"^;","~u68c1b2ba-a60f-4491-8bec-b48cbd66e9f3",536884777]],["^15",[3959,"^Q","",536884778]],["^15",[3959,"^O","^1;",536884778]],["^15",[3959,"^N",20250910,536884778]],["^15",[3959,"^@",true,536884778]],["^15",[3959,"^F",3958,536884778]],["^15",[3959,"^X",3958,536884778]],["^15",[3959,"^V",3958,536884778]],["^15",[3959,"^U",3958,536884779]],["^15",[3959,"^?",["^ "],536884778]],["^15",[3959,"^;","~u68c1b2ba-2b74-42a6-a029-9d7857a2c25d",536884778]],["^15",[3960,"^Q","Mechanical repetition",536884871]],["^15",[3960,"^O","^1;",536884811]],["^15",[3960,"^@",false,536884811]],["^15",[3960,"^F",3963,536884903]],["^15",[3960,"^X",3425,536884811]],["^15",[3960,"^V",3964,536884988]],["^15",[3960,"^U",3425,536885203]],["^15",[3960,"^?",["^ "],536884871]],["^15",[3960,"^;","~u68c1b57f-e477-4c4d-aadc-e6bb20070e6d",536884811]],["^15",[3961,"^Q","Repetition from your point of view",536884874]],["^15",[3961,"^O","^1;",536884833]],["^15",[3961,"^@",false,536884833]],["^15",[3961,"^F",3960,536884995]],["^15",[3961,"^X",3425,536884833]],["^15",[3961,"^V",3964,536884988]],["^15",[3961,"^U",3425,536885203]],["^15",[3961,"^?",["^ "],536884995]],["^15",[3961,"^;","~u68c1b5a0-cf42-41bd-800a-0dd6cf3c2354",536884833]],["^15",[3962,"^Q","Word repetition game",536884903]],["^15",[3962,"^O","^1;",536884861]],["^15",[3962,"^@",false,536884861]],["^15",[3962,"^F",3430,536885202]],["^15",[3962,"^X",3425,536884861]],["^15",[3962,"^V",3425,536884909]],["^15",[3962,"^U",3425,536884862]],["^15",[3962,"^?",["^ "],536884903]],["^15",[3962,"^;","~u68c1b5f3-d8d8-44da-bfcc-621589f48634",536884861]],["^15",[3963,"^Q","Listening, observing, commenting",536884940]],["^15",[3963,"^O","^1;",536884903]],["^15",[3963,"^@",false,536884903]],["^15",[3963,"^F",3964,536884981]],["^15",[3963,"^X",3425,536884903]],["^15",[3963,"^V",3964,536884988]],["^15",[3963,"^U",3425,536885203]],["^15",[3963,"^?",["^ "],536884940]],["^15",[3963,"^;","~u68c1b698-1124-42bb-bfe3-9a004c4b49f0",536884903]],["^15",[3964,"^Q","Process",536884985]],["^15",[3964,"^O","^1;",536884981]],["^15",[3964,"^@",false,536884981]],["^15",[3964,"^F",3962,536884981]],["^15",[3964,"^X",3425,536884981]],["^15",[3964,"^V",3962,536884981]],["^15",[3964,"^U",3425,536885203]],["^15",[3964,"^?",["^ "],536884985]],["^15",[3964,"^;","~u68c1baa3-64c2-48f5-b2ff-c50dfc687478",536884981]],["^15",[3966,"^Q","Instincts dictate the changes, not just the repetition.",536885067]],["^15",[3966,"^O","^1;",536884998]],["^15",[3966,"^@",false,536884998]],["^15",[3966,"^F",3964,536885000]],["^15",[3966,"^X",3425,536884998]],["^15",[3966,"^V",3962,536885000]],["^15",[3966,"^U",3425,536885203]],["^15",[3966,"^?",["^ "],536885067]],["^15",[3966,"^;","~u68c1baad-8329-4ec0-9b4f-1d0997340d09",536884998]],["^15",[3967,"^Q","Do not think.",536885093]],["^15",[3967,"^O","^1;",536885070]],["^15",[3967,"^@",false,536885070]],["^15",[3967,"^F",3966,536885070]],["^15",[3967,"^X",3425,536885070]],["^15",[3967,"^V",3966,536885074]],["^15",[3967,"^U",3425,536885203]],["^15",[3967,"^?",["^ "],536885093]],["^15",[3967,"^;","~u68c1bbbd-fb37-4b14-8f0d-e966e0d7c2dc",536885070]],["^15",[3968,"^Q","Do not compound.",536885106]],["^15",[3968,"^O","^1;",536885096]],["^15",[3968,"^@",false,536885096]],["^15",[3968,"^F",3967,536885096]],["^15",[3968,"^X",3425,536885096]],["^15",[3968,"^V",3966,536885096]],["^15",[3968,"^U",3425,536885203]],["^15",[3968,"^?",["^ "],536885106]],["^15",[3968,"^;","~u68c1bca2-adda-465b-b76a-c065a6d1244e",536885096]],["^15",[3969,"^Q","Instead of Repetition and X either repeat or say X.",536885180]],["^15",[3969,"^O","^1;",536885109]],["^15",[3969,"^@",false,536885109]],["^15",[3969,"^F",3968,536885116]],["^15",[3969,"^X",3425,536885109]],["^15",[3969,"^V",3968,536885119]],["^15",[3969,"^U",3425,536885203]],["^15",[3969,"^?",["^ "],536885180]],["^15",[3969,"^;","~u68c1bcad-ea78-469a-bee8-a0e6c8e8b11f",536885109]],["^15",[3970,"^Q","Of doing it as myself, not as an actor. Thus you become the character.",536885206]],["^15",[3970,"^O","^1;",536885189]],["^15",[3970,"^@",false,536885189]],["^15",[3970,"^F",3430,536885189]],["^15",[3970,"^X",3425,536885189]],["^15",[3970,"^V",3430,536885202]],["^15",[3970,"^U",3425,536885346]],["^15",[3970,"^?",["^ "],536885206]],["^15",[3970,"^;","~u68c1bce8-199d-4384-8368-1b2156609ad0",536885189]],["^15",[3971,"^Q","#+BEGIN_QUOTE\nDon’t do anything unless something happens to make you do it.\n#+END_QUOTE",536885220]],["^15",[3971,"^O","^1;",536885209]],["^15",[3971,"^@",false,536885209]],["^15",[3971,"^F",3972,536885223]],["^15",[3971,"^X",3425,536885209]],["^15",[3971,"^V",3972,536885233]],["^15",[3971,"^U",3425,536885210]],["^15",[3971,"^?",["^ "],536885220]],["^15",[3971,"^;","~u68c1bd70-44ab-4e02-b181-b73c9490ec2d",536885209]],["^15",[3972,"^Q","First principle",536885230]],["^15",[3972,"^O","^1;",536885223]],["^15",[3972,"^@",false,536885223]],["^15",[3972,"^F",3966,536885223]],["^15",[3972,"^X",3425,536885223]],["^15",[3972,"^V",3962,536885223]],["^15",[3972,"^U",3425,536885224]],["^15",[3972,"^?",["^ "],536885230]],["^15",[3972,"^;","~u68c1bd9a-7e05-4330-94b7-e8bf3e3e4fa0",536885223]],["^15",[3973,"^Q","Second principle",536885246]],["^15",[3973,"^O","^1;",536885236]],["^15",[3973,"^@",false,536885236]],["^15",[3973,"^F",3972,536885240]],["^15",[3973,"^X",3425,536885236]],["^15",[3973,"^V",3962,536885240]],["^15",[3973,"^U",3425,536885237]],["^15",[3973,"^?",["^ "],536885246]],["^15",[3973,"^;","~u68c1bda8-0a5b-437c-a7dd-4bdaa6fef1bc",536885236]],["^15",[3974,"^Q","#+BEGIN_QUOTE\nWhat you do doesn’t depend on you it depends on the other fellow.\n#+END_QUOTE",536885259]],["^15",[3974,"^O","^1;",536885247]],["^15",[3974,"^@",false,536885247]],["^15",[3974,"^F",3973,536885247]],["^15",[3974,"^X",3425,536885247]],["^15",[3974,"^V",3973,536885251]],["^15",[3974,"^U",3425,536885248]],["^15",[3974,"^?",["^ "],536885259]],["^15",[3974,"^;","~u68c1bdb1-5671-4498-97f8-1611a6789ad7",536885247]],["^15",[3975,"^Q","The approach is rooted in spontaneity and truthfulness.",536885338]],["^15",[3975,"^O","^1;",536885262]],["^15",[3975,"^@",false,536885262]],["^15",[3975,"^F",3426,536885262]],["^15",[3975,"^X",3425,536885262]],["^15",[3975,"^V",3425,536885262]],["^15",[3975,"^U",3425,536885263]],["^15",[3975,"^?",["^ "],536885338]],["^15",[3975,"^;","~u68c1be92-57c3-408f-9241-21a0bf332657",536885262]],["^15",[3976,"^Q","#+BEGIN_QUOTE\nI decided I wanted an exercise for actors where there is no intellectuality. I wanted to eliminate all that ‘head’ work, to take away all the mental manipulation and get to where the impulses come from. And I began with the premise that if I repeat what I hear you saying, my head is not working. I’m listening, and there is an absolute elimination of the brain.\n#+END_QUOTE",536885352]],["^15",[3976,"^O","^1;",536885341]],["^15",[3976,"^@",false,536885341]],["^15",[3976,"^F",3975,536885341]],["^15",[3976,"^X",3425,536885341]],["^15",[3976,"^V",3975,536885345]],["^15",[3976,"^U",3425,536885342]],["^15",[3976,"^?",["^ "],536885352]],["^15",[3976,"^;","~u68c1c014-bc4c-4bfe-9dbf-f27390f8cda9",536885341]],["^15",[3977,"^12",2,536885370]],["^15",[3978,"^K",1757792732853,536885371]],["^15",[3978,"^O","^1;",536885371]],["^15",[3978,"^N",20250913,536885371]],["^15",[3978,"^@",true,536885371]],["^15",[3978,"^Y","sep 13th, 2025",536885371]],["^15",[3978,"^11","Sep 13th, 2025",536885371]],["^15",[3978,"^B",1757792732853,536885371]],["^15",[3978,"^;","~u68c5c9dc-23fb-43b1-8e58-4903fa24abe4",536885371]],["^15",[3979,"^Q","",536885372]],["^15",[3979,"^O","^1;",536885372]],["^15",[3979,"^N",20250913,536885372]],["^15",[3979,"^@",true,536885372]],["^15",[3979,"^F",3978,536885372]],["^15",[3979,"^X",3978,536885372]],["^15",[3979,"^V",3978,536885372]],["^15",[3979,"^U",3978,536885373]],["^15",[3979,"^?",["^ "],536885372]],["^15",[3979,"^;","~u68c5c9dc-02c4-4b85-b242-ef71a86d3bdb",536885372]],["^15",[3980,"^Q","The embodied approach to understanding cognition shares a fundamental thesis with our approach — namely, that all human thought is rooted in the life experience of an individual, as well as in the shared experiences of social groups, linguistic communities, and entire cultures. In our formulation, the thesis asserts that people think through the medium of their concepts, which are built up and retrieved through nonstop analogy-making, which is carried out in response to the exigencies of living in a physical body embedded in the physical world. The embodied approach to cognition, however, places little stress on the notion of abstraction, as if to imply that raw experience suﬃces for thinking, with abstraction being merely a luxury add-on. Let’s recall, however, that abstraction is the result of recognizing and isolating what diﬀerent concrete concepts have in common. The fact that new situations constantly remind us of other ones that we (or our friends, family members, etc.) have encountered before, and the fact that complex situations constantly bring vivid, down-to-earth phrases to our lips, together show unmistakably that our minds are powerful engines built to seek hidden, deep commonalities linking one concrete thing to another one. This amounts to a drive to discover or create abstractions.\nls-type:: annotation\nhl-page:: 527\nhl-color:: yellow\nid:: 68c5d044-a103-48d9-962d-b661b26ce226",536885382]],["^15",[3980,"^O","^1;",536885382]],["^15",[3980,"^@",false,536885382]],["^15",[3980,"^F",3022,536885382]],["^15",[3980,"^X",2302,536885382]],["^15",[3980,"^V",2302,536885382]],["^15",[3980,"^U",2302,536885383]],["^15",[3980,"^?",["^ ","^1Y","annotation","^1Z",527,"^1[","yellow","^1D","68c5d044-a103-48d9-962d-b661b26ce226"],536885382]],["^15",[3980,"^J",["^14",["^1Y","^1Z","^1[","^1D"]],536885382]],["^15",[3980,"^4",["^ ","^1Y","annotation","^1Z","527","^1[","yellow","^1D","68c5d044-a103-48d9-962d-b661b26ce226"],536885382]],["^15",[3980,"^;","~u68c5d044-a103-48d9-962d-b661b26ce226",536885382]],["^15",[3981,"^Q","Embodiment and abstraction",536885443]],["^15",[3981,"^O","^1;",536885391]],["^15",[3981,"^F",3025,536885395]],["^15",[3981,"^X",1000,536885391]],["^15",[3981,"^V",1411,536885395]],["^15",[3981,"^U",1000,536885392]],["^15",[3981,"^?",["^ "],536885443]],["^15",[3981,"^;","~u68c5d065-01ca-4a1d-a5af-a6ac987beb12",536885391]],["^15",[3982,"^Q","((68c5d044-a103-48d9-962d-b661b26ce226))",536885451]],["^15",[3982,"^O","^1;",536885447]],["^15",[3982,"^F",3981,536885447]],["^15",[3982,"^X",1000,536885447]],["^15",[3982,"^V",3981,536885447]],["^15",[3982,"^U",1000,536885452]],["^15",[3982,"^U",3980,536885452]],["^15",[3982,"^?",["^ "],536885451]],["^15",[3982,"^H",3980,536885451]],["^15",[3982,"^;","~u68c5d085-ab35-4826-a9b0-ecec74d95399",536885447]],["^15",[3983,"^Q","Categories as Blinders",536885459]],["^15",[3983,"^O","^1;",536885455]],["^15",[3983,"^F",3981,536885460]],["^15",[3983,"^X",1000,536885455]],["^15",[3983,"^V",1411,536885460]],["^15",[3983,"^U",1000,536885456]],["^15",[3983,"^?",["^ "],536885459]],["^15",[3983,"^;","~u68c5d08a-15e8-4649-ba19-0d3d0e34ea4d",536885455]],["^15",[3984,"^Q","((68c5d0b6-d0db-4b6c-a8a0-980253e71743))((68c5d0c0-2238-4b01-b2fd-ade7da2975f3))",536885504]],["^15",[3984,"^O","^1;",536885466]],["^15",[3984,"^F",3983,536885466]],["^15",[3984,"^X",1000,536885466]],["^15",[3984,"^V",3983,536885466]],["^15",[3984,"^U",1000,536885505]],["^15",[3984,"^U",3986,536885505]],["^15",[3984,"^U",3987,536885505]],["^15",[3984,"^?",["^ "],536885504]],["^15",[3984,"^H",3986,536885504]],["^15",[3984,"^H",3987,536885504]],["^15",[3984,"^;","~u68c5d09e-3a9d-4f67-8f9a-3c8f4cef4d1c",536885466]],["^15",[3986,"^Q","Calling categories “blinders” is an admission that our categorization mechanisms, which help us navigate ﬂuidly through many a lofty realm of abstraction, can on occasion mislead us, via insuﬃciently ﬂexible insights. Sometimes such blinders impose a viewpoint on us that just doesn’t\nls-type:: annotation\nhl-page:: 530\nhl-color:: yellow\nid:: 68c5d0b6-d0db-4b6c-a8a0-980253e71743",536885481]],["^15",[3986,"^O","^1;",536885481]],["^15",[3986,"^@",false,536885481]],["^15",[3986,"^F",3980,536885481]],["^15",[3986,"^X",2302,536885481]],["^15",[3986,"^V",2302,536885481]],["^15",[3986,"^U",2302,536885482]],["^15",[3986,"^?",["^ ","^1Y","annotation","^1Z",530,"^1[","yellow","^1D","68c5d0b6-d0db-4b6c-a8a0-980253e71743"],536885481]],["^15",[3986,"^J",["^14",["^1Y","^1Z","^1[","^1D"]],536885481]],["^15",[3986,"^4",["^ ","^1Y","annotation","^1Z","530","^1[","yellow","^1D","68c5d0b6-d0db-4b6c-a8a0-980253e71743"],536885481]],["^15",[3986,"^;","~u68c5d0b6-d0db-4b6c-a8a0-980253e71743",536885481]],["^15",[3987,"^Q","dovetail accurately with the situation. Locked in, then, by our overly simplistic perception, we tend to miss things that are totally obvious to people who have categorized the situation in a more ﬁtting manner.\nls-type:: annotation\nhl-page:: 531\nhl-color:: yellow\nid:: 68c5d0c0-2238-4b01-b2fd-ade7da2975f3",536885495]],["^15",[3987,"^O","^1;",536885495]],["^15",[3987,"^@",false,536885495]],["^15",[3987,"^F",3986,536885495]],["^15",[3987,"^X",2302,536885495]],["^15",[3987,"^V",2302,536885495]],["^15",[3987,"^U",2302,536885496]],["^15",[3987,"^?",["^ ","^1Y","annotation","^1Z",531,"^1[","yellow","^1D","68c5d0c0-2238-4b01-b2fd-ade7da2975f3"],536885495]],["^15",[3987,"^J",["^14",["^1Y","^1Z","^1[","^1D"]],536885495]],["^15",[3987,"^4",["^ ","^1Y","annotation","^1Z","531","^1[","yellow","^1D","68c5d0c0-2238-4b01-b2fd-ade7da2975f3"],536885495]],["^15",[3987,"^;","~u68c5d0c0-2238-4b01-b2fd-ade7da2975f3",536885495]],["^15",[3988,"^Q","",536885506]],["^15",[3988,"^O","^1;",536885506]],["^15",[3988,"^F",3984,536885506]],["^15",[3988,"^X",1000,536885506]],["^15",[3988,"^V",3983,536885506]],["^15",[3988,"^U",1000,536885507]],["^15",[3988,"^?",["^ "],536885506]],["^15",[3988,"^;","~u68c5d0c8-0d87-4273-a390-dcf804394c09",536885506]]]]]]