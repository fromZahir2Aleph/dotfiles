9]],["^15",[1012,"^V",999,536870919]],["^15",[1012,"^U",999,536870919]],["^15",[1012,"^;","~u686ffd65-6a3b-4bff-a396-4a17ef60ef83",536870919]],["^15",[1013,"^Q","[[Philosopher's Toolkit]]",536870919]],["^15",[1013,"^O","^1;",536870919]],["^15",[1013,"^F",1010,536870919]],["^15",[1013,"^X",999,536870919]],["^15",[1013,"^V",1009,536870919]],["^15",[1013,"^U",999,536870919]],["^15",[1013,"^U",1001,536870919]],["^15",[1013,"^H",1001,536870919]],["^15",[1013,"^;","~u686ffd65-22b2-4ba7-b57b-5b9e5f884546",536870919]],["^15",[1014,"^Q","icon:: 📖\n\n",536870919]],["^15",[1014,"^O","^1;",536870919]],["^15",[1014,"^1<",["^19",[]],536870919]],["^15",[1014,"^F",999,536870919]],["^15",[1014,"^X",999,536870919]],["^15",[1014,"^V",999,536870919]],["^15",[1014,"^U",999,536870919]],["^15",[1014,"^:",true,536870919]],["^15",[1014,"^?",["^ ","^1O","📖"],536870919]],["^15",[1014,"^J",["^1O"],536870919]],["^15",[1014,"^4",["^ ","^1O","📖"],536870919]],["^15",[1014,"^;","~u686ffd65-f88c-47de-98ca-757289f2eb4b",536870919]],["^15",[1015,"^Q","Calibre",536870919]],["^15",[1015,"^O","^1;",536870919]],["^15",[1015,"^F",1009,536870919]],["^15",[1015,"^X",999,536870919]],["^15",[1015,"^V",999,536870919]],["^15",[1015,"^U",999,536870919]],["^15",[1015,"^;","~u686ffd65-f42e-43e8-bb96-8c45a5d91ce9",536870919]],["^15",[1017,"^Q","[[Fundamentals of Physics]]",536870919]],["^15",[1017,"^O","^1;",536870919]],["^15",[1017,"^F",1012,536880321]],["^15",[1017,"^X",999,536870919]],["^15",[1017,"^V",1012,536870919]],["^15",[1017,"^U",999,536880314]],["^15",[1017,"^U",1005,536880314]],["^15",[1017,"^H",1005,536870919]],["^15",[1017,"^;","~u686ffd65-ab0b-4709-bd92-afb7e5f66f6d",536870919]],["^15",[1018,"^3","- Vocabulary\n\t- Concept\n\t- Mind",536870919]],["^15",[1018,"^16",1752169829599,536870919]],["^15",[1018,"^Z","pages/Eberban.md",536870919]],["^15",[1019,"^K",1752169829598,536870919]],["^15",[1019,"^[",1018,536870919]],["^15",[1019,"^@",false,536870919]],["^15",[1019,"^Y","eberban",536870919]],["^15",[1019,"^11","Eberban",536870919]],["^15",[1019,"^B",1752169829598,536870919]],["^15",[1019,"^;","~u686ffd65-aa1c-42e1-9eb7-d432a16a0029",536870919]],["^15",[1020,"^Q","Vocabulary",536870919]],["^15",[1020,"^O","^1;",536870919]],["^15",[1020,"^F",1019,536870919]],["^15",[1020,"^X",1019,536870919]],["^15",[1020,"^V",1019,536870919]],["^15",[1020,"^U",1019,536870919]],["^15",[1020,"^;","~u686ffd65-ca3c-48d3-84dc-7a1521e9be64",536870919]],["^15",[1021,"^Q","Concept",536870919]],["^15",[1021,"^O","^1;",536870919]],["^15",[1021,"^F",1020,536870919]],["^15",[1021,"^X",1019,536870919]],["^15",[1021,"^V",1020,536870919]],["^15",[1021,"^U",1019,536870919]],["^15",[1021,"^;","~u686ffd65-149f-457b-af4e-0f9b253c776d",536870919]],["^15",[1022,"^Q","Mind",536870919]],["^15",[1022,"^O","^1;",536870919]],["^15",[1022,"^F",1021,536870919]],["^15",[1022,"^X",1019,536870919]],["^15",[1022,"^V",1020,536870919]],["^15",[1022,"^U",1019,536870919]],["^15",[1022,"^;","~u686ffd65-7671-4542-9b68-8834d4b3f5c5",536870919]],["^15",[1023,"^3","tags:: highlight\nsource:: movie\nauthor:: Richard Linklater\n\n- #+BEGIN_QUOTE\n  We came for a good time, not for a long time.\n  #+END_QUOTE\n- #+BEGIN_QUOTE\n  - What’d you write about?\n  \n  - The topic was to take a Greek myth and relate it to your own life.\n  \n  - So you wrote about Aphrodite and being a baseball slut.\n  \n  - Kind of.\n  \n  - Shit. No.\n  \n  - I just took Sisyphus and baseball, and just kinda…\n  \n  - You wrote about that for your essay… How did you even, like… …those two things together?\n  \n  - Yeah, I did, believe it or not. I mean, the point of the whole thing is that the gods intend for Sisyphus to suffer, right?\n  \n  - Right.\n  \n  - Well, my point was that they’d actually blessed him with something to focus on, you know, something that he could potentially find meaning in. You know, it’s a gift to be striving at all, you know, even if it looks futile to others.\n  \n  - Yeah, that’s true.\n  \n  - I mean, yeah, it’s ridiculous to roll a boulder up a mountain over and over and over again, but so is everything else in life. When you really think about it, especially a game. Things only mean as much as the meaningfulness that we allow them to have. That’s where I tie it in to baseball. Just accepting whatever comes my way, you know? Good, bad, doesn’t matter. What matters is just getting in that groove where the whole world kinda goes away, and I’m just doing what I’m supposed to be doing.\n  \n  - I feel the same way about performing. It’s putting yourself out there in art, in life, just participating.\n  \n  - Yeah.\n  \n  - Having the guts to look fucking stupid. It’s kind of beautiful, isn’t it?\n  \n  - What?\n  \n  - That we get to feel passion in this world, you know, about anything. And I like you.\n  \n  - I like you, too.\n  #+END_QUOTE",536870919]],["^15",[1023,"^16",1752169829642,536870919]],["^15",[1023,"^Z","pages/Everybody Wants Some!!.md",536870919]],["^15",[1024,"^K",1752169829641,536870919]],["^15",[1024,"^[",1023,536870919]],["^15",[1024,"^@",false,536870919]],["^15",[1024,"^Y","everybody wants some!!",536870919]],["^15",[1024,"^11","Everybody Wants Some!!",536870919]],["^15",[1024,"^?",["^ ","^18",["^19",["highlight"]],"~:source","movie","~:author","Richard Linklater"],536870919]],["^15",[1024,"^4",["^ ","^18","highlight","^1Q","movie","^1R","Richard Linklater"],536870919]],["^15",[1024,"^P",1025,536870919]],["^15",[1024,"^B",1752169829641,536870919]],["^15",[1024,"^;","~u68a60b9f-8c9d-40b6-9040-16e5d7df1be7",536880058]],["^15",[1025,"^K",1752169829641,536870919]],["^15",[1025,"^@",false,536870919]],["^15",[1025,"^Y","highlight",536870919]],["^15",[1025,"^11","highlight",536870919]],["^15",[1025,"^B",1752169829641,536870919]],["^15",[1025,"^;","~u686ffd68-dec9-4434-a784-ca2ed2f11bc0",536870920]],["^15",[1026,"^K",1752169829641,536870919]],["^15",[1026,"^@",false,536870919]],["^15",[1026,"^Y","source",536870919]],["^15",[1026,"^11","source",536870919]],["^15",[1026,"^B",1752169829641,536870919]],["^15",[1026,"^;","~u686ffd68-bb15-49c4-bfd6-673d3ed684c5",536870920]],["^15",[1027,"^K",1752169829641,536870919]],["^15",[1027,"^@",false,536870919]],["^15",[1027,"^Y","author",536870919]],["^15",[1027,"^11","author",536870919]],["^15",[1027,"^B",1752169829641,536870919]],["^15",[1027,"^;","~u686ffd68-3fd5-455f-a67d-f9f5185b276b",536870920]],["^15",[1028,"^Q","tags:: highlight\nsource:: movie\nauthor:: Richard Linklater\n\n",536870919]],["^15",[1028,"^O","^1;",536870919]],["^15",[1028,"^1<",["^19",[]],536870919]],["^15",[1028,"^F",1024,536870919]],["^15",[1028,"^X",1024,536870919]],["^15",[1028,"^V",1024,536870919]],["^15",[1028,"^U",1024,536870919]],["^15",[1028,"^U",1025,536870919]],["^15",[1028,"^U",1026,536870919]],["^15",[1028,"^U",1027,536870919]],["^15",[1028,"^:",true,536870919]],["^15",[1028,"^?",["^ ","^18",["^19",["highlight"]],"^1Q","movie","^1R","Richard Linklater"],536870919]],["^15",[1028,"^J",["^18","^1Q","^1R"],536870919]],["^15",[1028,"^4",["^ ","^18","highlight","^1Q","movie","^1R","Richard Linklater"],536870919]],["^15",[1028,"^H",1025,536870919]],["^15",[1028,"^H",1026,536870919]],["^15",[1028,"^H",1027,536870919]],["^15",[1028,"^;","~u686ffd65-9d1b-409b-b722-aedd6ae51784",536870919]],["^15",[1029,"^Q","#+BEGIN_QUOTE\nWe came for a good time, not for a long time.\n#+END_QUOTE",536870919]],["^15",[1029,"^O","^1;",536870919]],["^15",[1029,"^F",1028,536870919]],["^15",[1029,"^X",1024,536870919]],["^15",[1029,"^V",1024,536870919]],["^15",[1029,"^U",1024,536870919]],["^15",[1029,"^;","~u686ffd65-748f-4dbf-b349-5433de0d6c38",536870919]],["^15",[1030,"^Q","#+BEGIN_QUOTE\n- What’d you write about?\n\n- The topic was to take a Greek myth and relate it to your own life.\n\n- So you wrote about Aphrodite and being a baseball slut.\n\n- Kind of.\n\n- Shit. No.\n\n- I just took Sisyphus and baseball, and just kinda…\n\n- You wrote about that for your essay… How did you even, like… …those two things together?\n\n- Yeah, I did, believe it or not. I mean, the point of the whole thing is that the gods intend for Sisyphus to suffer, right?\n\n- Right.\n\n- Well, my point was that they’d actually blessed him with something to focus on, you know, something that he could potentially find meaning in. You know, it’s a gift to be striving at all, you know, even if it looks futile to others.\n\n- Yeah, that’s true.\n\n- I mean, yeah, it’s ridiculous to roll a boulder up a mountain over and over and over again, but so is everything else in life. When you really think about it, especially a game. Things only mean as much as the meaningfulness that we allow them to have. That’s where I tie it in to baseball. Just accepting whatever comes my way, you know? Good, bad, doesn’t matter. What matters is just getting in that groove where the whole world kinda goes away, and I’m just doing what I’m supposed to be doing.\n\n- I feel the same way about performing. It’s putting yourself out there in art, in life, just participating.\n\n- Yeah.\n\n- Having the guts to look fucking stupid. It’s kind of beautiful, isn’t it?\n\n- What?\n\n- That we get to feel passion in this world, you know, about anything. And I like you.\n\n- I like you, too.\n#+END_QUOTE",536870919]],["^15",[1030,"^O","^1;",536870919]],["^15",[1030,"^F",1029,536870919]],["^15",[1030,"^X",1024,536870919]],["^15",[1030,"^V",1024,536870919]],["^15",[1030,"^U",1024,536870919]],["^15",[1030,"^;","~u686ffd65-317a-4255-9c22-48a5b4b61c89",536870919]],["^15",[1031,"^3","id:: 647e407b-8040-47f6-a6b1-a3f5649e32f6\ntags:: mythology\nregion:: Greece\n\n- Я отсеял скучные или дублирующие других божества.\n  query-sort-by:: block\n  query-table:: false\n  query-sort-desc:: false\n\t- Книга Стивена Фрая следует теогонии Гесиода, самой известной и, по-моему, самой изящной. В Орфейской традиции всё врассыпку, а у Алкмана - надуманно.\n\t\t- Боги\n\t\t  id:: 647e4286-eb1f-4076-8a7d-e32e6d2020cb\n\t\t\t- Изначальные божества\n\t\t\t\t- χάος\n\t\t\t\t  id:: e8ecacc4-d1ea-46b7-b05c-6b335632645a\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /kʰá.os/\n\t\t\t\t  .translation:: Хаос\n\t\t\t\t  .flags:: primordial, personification\n\t\t\t\t- Γαῖα\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /ɡâi̯.a/\n\t\t\t\t  .translation:: Гея\n\t\t\t\t  .flags:: primordial, personification, chthonic\n\t\t\t\t  id:: 64e64a87-5607-4ebc-ad26-47231557940f\n\t\t\t\t- Τάρταρος\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /tár.ta.ros/\n\t\t\t\t  .translation:: Тартар\n\t\t\t\t  .flags:: primordial, personification\n\t\t\t\t- Ερος\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /é.ros/\n\t\t\t\t  .translation:: Эрос\n\t\t\t\t  .flags:: primordial, personification\n\t\t\t\t\t- Если представить Эроса как шопенгауэровскую Волю к жизни, то он хорошо вписывается в первое поколение, особенно в контексте [Chaoskampf](((64b9bd7a-92b2-4e98-9aa3-fe085f42caea))).\n\t\t\t\t- Ночь и тьма [предшествуют](((64a33c92-8913-4edc-93a2-a61abd1b9b1a))) дню и свету.\n\t\t\t\t\t- Νύξ\n\t\t\t\t\t  id:: 647e5126-54ad-4d16-8992-78a6a36c49b6\n\t\t\t\t\t  .tags::\n\t\t\t\t\t  .being:: god\n\t\t\t\t\t  .mythology:: Greece\n\t\t\t\t\t  .transcription:: /nýks/\n\t\t\t\t\t  .translation:: Нюкта\n\t\t\t\t\t  .flags:: primordial, personification\n\t\t\t\t\t\t- В некоторых орфических теогониях она самая первая.\n\t\t\t\t\t- Ἔρεβος\n\t\t\t\t\t  id:: 647e4372-af4a-4dd5-9a43-d40a6db63932\n\t\t\t\t\t  .tags::\n\t\t\t\t\t  .being:: god\n\t\t\t\t\t  .mythology:: Greece\n\t\t\t\t\t  .transcription:: /é.re.bos/\n\t\t\t\t\t  .translation:: Эреб\n\t\t\t\t\t  .flags:: primordial, personification\n\t\t\t\t\t- Ἡμέρα\n\t\t\t\t\t  .tags::\n\t\t\t\t\t  .being:: god\n\t\t\t\t\t  .mythology:: Greece\n\t\t\t\t\t  .transcription:: /hɛː.mé.raː/\n\t\t\t\t\t  .translation:: Гемера\n\t\t\t\t\t  .flags:: primordial, personification\n\t\t\t\t\t- Αἰθήρ\n\t\t\t\t\t  .tags::\n\t\t\t\t\t  .being:: god\n\t\t\t\t\t  .mythology:: Greece\n\t\t\t\t\t  .transcription:: /ai̯.tʰɛ̌ːr/\n\t\t\t\t\t  .translation:: Эфир\n\t\t\t\t\t  .flags:: primordial, personification\n\t\t\t\t- Οὐρανός\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /uː.ra.nós/\n\t\t\t\t  .translation:: Уран\n\t\t\t\t  .flags:: primordial, personification\n\t\t\t\t- Πόντος\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /pón.tos/\n\t\t\t\t  .translation:: Понт\n\t\t\t\t  .flags:: primordial, personification\n\t\t\t\t- Очень не хватает Хроноса. У орфиков и Алкмана он у самых истоков, а в одной орфической теогонии он даже самый первый.\n\t\t\t\t\t- Χρόνος\n\t\t\t\t\t  .tags::\n\t\t\t\t\t  .being:: god\n\t\t\t\t\t  .mythology:: Greece\n\t\t\t\t\t  .transcription:: /kʰró.nos/\n\t\t\t\t\t  .translation:: Хронос\n\t\t\t\t\t  .flags:: primordial, personification\n\t\t\t\t\t\t- [[Alternate mythology]]\n\t\t\t\t\t\t\t- Αἰών\n\t\t\t\t\t\t\t  .tags::\n\t\t\t\t\t\t\t  .being:: god\n\t\t\t\t\t\t\t  .mythology:: Greece\n\t\t\t\t\t\t\t  .transcription:: /ai̯.ɔ̌ːn/\n\t\t\t\t\t\t\t  .translation:: Эон\n\t\t\t\t\t\t\t  .flags::\n\t\t\t\t- [[Commentary]]\n\t\t\t\t  id:: 64a33c92-1eb1-4d62-bf4b-c413b504d8f3\n\t\t\t\t\t- Мотив придания миру формы появляется в разных мифологиях.\n\t\t\t\t\t  id:: 64b9bd7a-92b2-4e98-9aa3-fe085f42caea\n\t\t\t\t\t\t- Chaoskampf\n\t\t\t\t\t\t  id:: 64a5dc49-9f1c-472c-98f9-103a51fed1c6\n\t\t\t\t\t\t\t- Это обозначение не в обиходе, но звучит.\n\t\t\t\t\t- Ананке и прочие - это телеологические толкования.\n\t\t\t\t\t\t- Ἀνάγκη\n\t\t\t\t\t\t  .tags::\n\t\t\t\t\t\t  .being:: god\n\t\t\t\t\t\t  .mythology:: Greece\n\t\t\t\t\t\t  .transcription:: /a.náŋ.kɛː/\n\t\t\t\t\t\t  .translation:: Ананке\n\t\t\t\t\t\t  .flags:: primordial, personification\n\t\t\t\t\t- Среди детей Хаоса и первых двух внуков боги - это проекции состояний, богинь, их Действия. Связь между ними не причинно-следственная, а союзная. Ночь и Тьма, День и Свет, Земля и Бездна.\n\t\t\t\t\t  id:: 64a33c92-8913-4edc-93a2-a61abd1b9b1a\n\t\t\t- Титаны и Титаниды\n\t\t\t\t- Κρόνος\n\t\t\t\t  .tags:: \n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /kró.nos/\n\t\t\t\t  .translation:: Кронос\n\t\t\t\t  .flags:: titan\n\t\t\t\t- Ῥέα\n\t\t\t\t  .tags:: \n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /r̥é.aː/\n\t\t\t\t  .translation:: Рея\n\t\t\t\t  .flags:: titan\n\t\t\t\t- Προμηθεύς\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /pro.mɛː.tʰěu̯s/\n\t\t\t\t  .translation:: Прометей\n\t\t\t\t  .flags:: titan\n\t\t\t\t  id:: 655011bf-202c-4765-a16c-404b43766587\n\t\t\t\t- Επιμηθευς\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /e.pi.mɛː.tʰěu̯s/\n\t\t\t\t  .translation:: Эпиметей\n\t\t\t\t  .flags:: titan\n\t\t\t\t  id:: 655011bf-7aae-4201-abaa-518f4486a711\n\t\t\t- Олимпийцы\n\t\t\t\t- Ζεύς\n\t\t\t\t  id:: 64af0846-e1c6-440c-9c8c-0da4d05fc25d\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /zděu̯s/\n\t\t\t\t  .translation:: Зевс\n\t\t\t\t  .flags:: Olympian\n\t\t\t\t- Ἀθηνᾶ\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /a.tʰɛː.nâː/\n\t\t\t\t  .translation:: Афина\n\t\t\t\t  .flags:: Olympian\n\t\t\t\t  id:: 66ba0f9b-9bf9-4e3e-80ea-4bd53040a923\n\t\t\t\t- Ἀπόλλων\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /a.pól.lɔːn/\n\t\t\t\t  .translation:: Аполлон\n\t\t\t\t  .flags:: Olympian\n\t\t\t\t  id:: 3755fb37-1121-4a9c-a22d-2fee9141dc8e\n\t\t\t\t- Ἄρης\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /á.rɛːs/\n\t\t\t\t  .translation:: Арес\n\t\t\t\t  .flags:: Olympian\n\t\t\t\t  id:: 66ba0f9b-c626-486c-a58a-8467b5831845\n\t\t\t\t- Ἄρτεμις\n\t\t\t\t  id:: 64f10e8f-7931-4b80-9e4f-3e3ce7882297\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /ár.te.mis/\n\t\t\t\t  .translation:: Артемида\n\t\t\t\t  .flags:: Olympian\n\t\t\t\t- Ἀφροδίτη\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /a.pʰro.dǐː.tɛː/\n\t\t\t\t  .translation:: Афродита\n\t\t\t\t  .flags:: Olympian\n\t\t\t\t  id:: 64f25048-c96a-40fa-8c9e-293ba050bfe7\n\t\t\t\t- Δημήτηρ\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /dɛː.mɛ̌ː.tɛːr/\n\t\t\t\t  .translation:: Деметра\n\t\t\t\t  .flags:: Olympian\n\t\t\t\t- Διόνυσος\n\t\t\t\t  id:: 2f675fa9-98a6-470c-93e3-a065e08759ef\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /di.ó.nyː.sos/\n\t\t\t\t  .translation:: Дионис\n\t\t\t\t  .flags:: Olympian\n\t\t\t\t- Ἑρμῆς\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /her.mɛ̂ːs/\n\t\t\t\t  .translation:: Гермес\n\t\t\t\t  .flags:: Olympian\n\t\t\t\t- Ἥρα\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /hɛ̌ː.raː/ \n\t\t\t\t  .translation:: Гера\n\t\t\t\t  .flags:: Olympian\n\t\t\t\t\t- На сайте theoi.com у Геры нет пункта Loves, но есть Wrath. Издержки супружества Зевса.\n\t\t\t\t\t- Под её горячую руку часто попадали любовницы и незаконнорождённые мужа, например, Лето, [Дионис](((2f675fa9-98a6-470c-93e3-a065e08759ef))) и [Геракл](((67411a44-35d2-43c4-911e-359e8e34c7b9))).\n\t\t\t\t- Ἥφαιστος\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /hɛ̌ː.pʰai̯s.tos/\n\t\t\t\t  .translation:: Гефест\n\t\t\t\t  .flags:: Olympian\n\t\t\t\t  id:: 66ba0f9a-fa8e-429f-aaef-bca6524c1fe8\n\t\t\t\t- Ποσειδων\n\t\t\t\t  id:: 64af1cf7-5636-4536-917f-cb44f27037a8\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: god\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /po.seː.dɔ̂ːn/\n\t\t\t\t  .translation:: Посейдон\n\t\t\t\t  .flags:: Olympian\n\t\t\t- ᾍδης\n\t\t\t  id:: 64c03a7d-7892-4801-8d84-6c73af7c13ed\n\t\t\t  .tags::\n\t\t\t  .being:: god\n\t\t\t  .mythology:: Greece\n\t\t\t  .transcription:: /háːi̯.dɛːs/\n\t\t\t  .translation:: Аид\n\t\t\t  .flags:: chthonic\n\t\t\t- Ζαγρεύς\n\t\t\t  .tags:: \n\t\t\t  .being:: god\n\t\t\t  .mythology:: Greece\n\t\t\t  .transcription:: /zdag.rěu̯s/\n\t\t\t  .translation:: Загрей\n\t\t\t  .flags::\n\t\t\t\t- первый [Дионис](((2f675fa9-98a6-470c-93e3-a065e08759ef)))\n\t\t\t- Πάν\n\t\t\t  .tags::\n\t\t\t  .being:: god\n\t\t\t  .mythology:: Greece\n\t\t\t  .transcription:: /pǎːn/\n\t\t\t  .translation:: Пан\n\t\t\t  .flags::\n\t\t\t  id:: 66bd24c6-efdc-4fc5-bc54-c443a0a6f666\n\t\t\t- [[Alternate mythology]]\n\t\t\t\t- Ревизионистские боги\n\t\t\t\t\t- Πότνια Θηρῶν\n\t\t\t\t\t  .tags:: \n\t\t\t\t\t  .being:: god\n\t\t\t\t\t  .mythology:: Greece\n\t\t\t\t\t  .transcription:: /pó.tni.a tʰɛ̌ː.rɔːn/\n\t\t\t\t\t  .translation:: Потния Терон\n\t\t\t\t\t  .flags:: revisionist\n\t\t\t\t\t- Ἐνυάλιος\n\t\t\t\t\t  .tags::\n\t\t\t\t\t  .being:: god\n\t\t\t\t\t  .mythology:: Greece\n\t\t\t\t\t  .transcription:: /e.nyː.á.li.os/\n\t\t\t\t\t  .translation:: Эниалий\n\t\t\t\t\t  .flags:: revisionist\n\t\t\t\t\t  id:: 66ba0f9a-d9c7-4e4b-abbe-08bc129ac502\n\t\t\t\t- Евгеника\n\t\t\t\t  id:: 66d0e7e4-b3a2-468e-b63a-859d002b3409\n\t\t\t\t\t- [Гефест](((66ba0f9a-fa8e-429f-aaef-bca6524c1fe8))), [Афина](((66ba0f9b-9bf9-4e3e-80ea-4bd53040a923))), Талос, [Пандора](Πανδώρα) - генетические эксперименты олимпийцев.\n\t\t\t\t\t- Пропатчить пятку...\n\t\t\t\t\t\t- ...значило на Олимпе установить в творение бэкдор.\n\t\t\t\t\t\t\t- Калечение Гефеста\n\t\t\t\t\t\t\t  collapsed:: true\n\t\t\t\t\t\t\t\t- [Гефест](((66ba0f9a-fa8e-429f-aaef-bca6524c1fe8))) был сыном титана, но ему говорили, что он безотцовщина.\n\t\t\t\t\t\t\t\t\t- История его взросления подобна происхождению [Пандоры](Πανδώρα), только наоборот. Они дважды скидывали его с Олимпа, заковывали в ограничивающие рост цепи и сделали своим чернорабочим.\n\t\t\t\t\t\t\t\t\t\t- Он был другом [Прометея](((655011bf-202c-4765-a16c-404b43766587))), которого его обязали приковать к горе, потому что он оставил дверь в кузницу открытой.\n\t\t\t\t\t\t\t\t\t\t\t- См. \"Прометей прикованный\" Эсхила\n\t\t\t\t\t\t\t- Бесплодие Афины и её оптимальная мудрость без эмпатии к человечеству\n\t\t\t\t\t\t\t- [Пандора](Πανδώρα) как пята всего человеческого рода\n\t\t\t\t\t\t\t- Пятка Талоса\n\t\t\t\t\t\t\t  id:: 66d3325b-a10c-4876-a064-70e45a456087\n\t\t\t\t\t\t\t- Ахиллесова пята\n\t\t- Циклопы\n\t\t  id:: 64b3023f-8b20-4c07-93ec-f459024fd528\n\t\t  collapsed:: true\n\t\t\t- Их изделия\n\t\t\t\t- Перуны [Зевса](((64af0846-e1c6-440c-9c8c-0da4d05fc25d)))\n\t\t\t\t- Трезубец [Посейдона](((64af1cf7-5636-4536-917f-cb44f27037a8)))\n\t\t\t\t- Шлем [Аида](((64c03a7d-7892-4801-8d84-6c73af7c13ed)))\n\t\t- Гиганты, т.е. порождённые [землёй](((64e64a87-5607-4ebc-ad26-47231557940f)))\n\t\t\t- Участники Гигантомахии\n\t\t\t  id:: 64b4613c-6f4b-4166-929c-b7711cb73c7d\n\t\t\t- Циклопы в Одиссее\n\t\t\t- Τυφωευς\n\t\t\t  .tags:: \n\t\t\t  .being:: giant\n\t\t\t  .mythology:: Greece\n\t\t\t  .transcription:: /tyː.pʰɔ̂eu̯s/\n\t\t\t  .translation:: Тифон\n\t\t\t  .flags::\n\t\t\t\t- Отец монстров\n\t\t\t- Желая отомстить Зевсу за заключение в Тартар своих Титанов [Гея](((64e64a87-5607-4ebc-ad26-47231557940f))) натравила других детей, сначала гигантов Гигантомахии, а потом Тифона.\n\t\t\t\t- [[Alternate mythology]]\n\t\t\t\t\t- А вдруг Тифоня и [гиганты-антиолимпийцы](((64b4613c-6f4b-4166-929c-b7711cb73c7d))) были хорошими, а историки победителей их просто оклеветали.\n\t\t\t- [[Commentary]]\n\t\t\t\t- Месть Гейи и оросившие её капли полового члена Урана, брошенного Кроносом в море, произвели высокомерных, пошедших на Олимп, гигантов, мстительных Эриний и знойную [Афродиту](((64f25048-c96a-40fa-8c9e-293ba050bfe7))).\n\t\t- Люди\n\t\t\t- Века человечества\n\t\t\t  id:: 66d3325b-6610-42cf-9cca-88c34afc0264\n\t\t\t\t- Золотой век\n\t\t\t\t\t- У Кроноса получилось с первого раза. Беззаботная жизнь, безболезненная смерть. И в отличие от сына он не требовал, чтобы к нему ходили на поклон.\n\t\t\t\t- Серебряный век\n\t\t\t\t\t- Зевс тоже занялся генной инженерией. Мотивы - зависть к скилам отца и тщеславие. От людей без храмов и жертвоприношений нет прока богам, хоть храмы те и не посещают, а угощения не поедают. Они спускались, чтобы поваляться с нимфами или нашими девками и парнями, или погоняться за ними. Первый запуск был с большим багом, лишней хромосомой. Организм рос, но не самозапускался.\n\t\t\t\t- Бронзовый век\n\t\t\t\t\t- Вторая версия слетела согласно Гесиоду. Зевс установил слишком высокий параметр агрессии, и все наминимаксли боевые навыки и поубивали друг друга.\n\t\t\t\t\t\t- [[Alternate mythology]]\n\t\t\t\t\t\t\t- Он просто завидовал большей популярности Ареса и сам удалил прогу.\n\t\t\t\t- Век героев\n\t\t\t\t\t- Третья версия удалась. Зевс сделал еду человеческой необходимостью. Наверное, чтобы быть за что ему благодарным.\n\t\t\t\t\t\t- [[Alternate mythology]]\n\t\t\t\t\t\t\t- Зевс наказал человечество потопом за то, что герои стали почитаться больше жителей Олимпа. Люди Железного века жили меньше, и после истребления героев баг Пандоры, обременявший всех половыми нуждами и как следствие семейными узами, был неискореним.\n\t\t\t\t\t\t\t\t- Выжили только сын Прометея Девкалион и Пирра, дочь Эпиметея и Пандоры. Дети их детей - первое поколение человечества в современном его виде. Мы продукт инцеста без капли крови героев. Но в некоторых из нас ещё тлеет искра непокорного титана.\n\t\t\t\t- Железный век\n\t\t\t\t\t- Однако постепенно он забил на сопровождение кода - люди стали плодиться в геометрической прогрессии, как впрочем и баги.\n\t\t\t- Создание человека\n\t\t\t\t- Братьям [Эпиметею](((655011bf-7aae-4201-abaa-518f4486a711))) (Апослею) и [Прометею](((655011bf-202c-4765-a16c-404b43766587))) (Предвидею) было поручено создание людей и животных. Эпиметей раздал всем по орудию к выживанию: корни, клыки и т.д., а про человека по глупости забыл. Прометей, пожалев людей, своровал у Афины и Гефеста инструменты и огонь, без которых они бесполезны. За это наказали и Прометея, приковав к горе на Кавказе, и человечество, подослав к нему [первую женщину](((654bc199-217e-45ee-963f-fed1e320e9c7))).\n\t\t\t\t- Πανδώρα\n\t\t\t\t  id:: 654bc199-217e-45ee-963f-fed1e320e9c7\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: human\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /pan.dɔ̌ː.raː/\n\t\t\t\t  .translation:: Пандора\n\t\t\t\t  .flags::\n\t\t\t\t\t- До Гесиода она была \"вседающая\". Позже ей дали тот самый кувшин - и она стала \"всем одарённой\".\n\t\t\t\t\t- [[Alternate mythology]]\n\t\t\t\t\t\t- Переверни сюжет Пигмалиона, где каждый из богов учит её своей фирменной мерзости, чтобы она, собственно, и стала тем ящиком, и с другой стороны и чтобы навсегда подорвать доверие к женщине у мужчин и патриархия царила не только на Олимпе, но и внизу.\n\t\t\t- Герои\n\t\t\t\t- Ἡρακλῆς\n\t\t\t\t  .tags::\n\t\t\t\t  .being:: demigod\n\t\t\t\t  .mythology:: Greece\n\t\t\t\t  .transcription:: /hɛː.ra.klɛ̂ːs/\n\t\t\t\t  .translation:: Геракл\n\t\t\t\t  .flags:: hero\n\t\t\t\t  id:: 67411a44-35d2-43c4-911e-359e8e34c7b9\n\t\t\t\t- Среди греческих героев есть и варвары. Самые известные - фракиец Орфей и финикиец Кадм.\n- Махии\n  id:: b6329711-bd47-434b-8e33-fcd78b787bad\n\t- ...рас и поколений\n\t\t- Теомахия\n\t\t\t- Троянская война\n\t\t\t- Интриги на Олимпе\n\t\t- Титаномахия\n\t\t  collapsed:: true\n\t\t\t- Вызволенные Зевсом из Тартара, [Циклопы](((64b3023f-8b20-4c07-93ec-f459024fd528))) выковали ему молнии, а сторукие Гекатонхейры бросили в Титанов одновременно триста камней. После войны первые стали помощниками Гефеста, а вторые - стражами поверженных Титанов.\n\t\t- Гигантомахия\n\t\t- Кентавромахия\n\t\t  id:: 648f0280-37e6-4988-b4e8-a9e4ded94c61\n\t- ...в своей категории\n\t\t- Полисомахия\n\t\t  collapsed:: true\n\t\t\t- Пелопоннесская война\n\t\t\t- Фивано-Спартанская война\n\t\t- Атлономахия\n\t\t  collapsed:: true\n\t\t\t- Игры\n\t\t\t\t- Олимпийские в честь [Зевса](((64af0846-e1c6-440c-9c8c-0da4d05fc25d)))\n\t\t\t\t- Пифийские в честь [Аполлона](((3755fb37-1121-4a9c-a22d-2fee9141dc8e)))\n\t\t\t\t- Немейские в честь [Зевса](((64af0846-e1c6-440c-9c8c-0da4d05fc25d)))\n\t\t\t\t- Истмийские в честь [Посейдона](((64af1cf7-5636-4536-917f-cb44f27037a8)))\n\t- ...с природой\n\t\t- ((648f0280-37e6-4988-b4e8-a9e4ded94c61))\n\t\t- Механомахия\n\t\t  collapsed:: true\n\t\t\t- Талос\n\t\t\t- Троянский конь\n\t- ...в себе\n\t\t- Синорисомахия\n\t\t\t- Диалог Платона «Федр»\n- Дилос - сакральный и геометрический центр Киклад, место рождения [Аполлона](((3755fb37-1121-4a9c-a22d-2fee9141dc8e))) и [Артемиды](((64f10e8f-7931-4b80-9e4f-3e3ce7882297))).\n  collapsed:: true\n\t- После того как Гера из ревности мужа Зевса к Лето запретила земной тверди предоставить ей место для родов, та скиталась, пока плавучий остров Дилос не приютил её. Не привязанный к матушке Гее, он не был под запретом. Как только Лето опустилась на его поверхность, он остановился на месте, дал кров её двойняшкам Аполлону и Артемиде и возложил на себя ношу религиозных, административных и геометрических обязанностей. И долго затем грустил по океанам и грезил о неизведанных морях.\n\t- После окончания второй греко-персидской войны ещё и политический центр Дилосского союза. Полисы, входившие в него, собирались внутри храма острова как на нейтральной священной территории. Там же хранилась общая казна.\n\t- Несколько раз на Дилосе провели очищение.\n\t\t- 1. В VI в. до н. э. афинский тиран Писистрат приказал перенести на соседний остров Ринию  могилы в пределах видимости посетителей храма.\n\t\t- 2. В начале Пелопоннесской войны по наставлению оракула , переместив все могилы с острова. Также издали указ о запрете смерти и рождения на острове. Если же в окно стучался Кондратий или в пузо малёкв окно стучался Кондратий или в пузо малёк, то умирающего или беременную надлежало перевезти на Ринию.\n\t\t- 3. Так как последний багфикс не принёс Дилосскому союзу победу в войне, заподозрили, что проблема в живых, а не мёртвых, и спустя несколько лет провели генеральную очистку, выслав в Адрамитион всех дилосцев.\n\t- Тиран острова Самоса Поликрат подарил Ринию Аполлону, привязав между ней и Дилосом цепь.\n- [Аполлон](((3755fb37-1121-4a9c-a22d-2fee9141dc8e))) и некоторые другие боги имели несколько обликов.\n\t- Аполлон, которого когда-то принимали за Гелиоса\n\t\t- 1. \"Тhe god who punishes and destroys (oulios) the wicked and overbearing\"\n\t\t- 2. \"The god who affords help and wards off evil\"\n\t\t- 3. \"The god of prophecy\"\n\t\t- 4. \"The god of song and music\"\n\t\t- 5. \"The god who protects the flocks and cattle\n\t\t- 6. \"The god who delights in the foundation of towns and the establishment of civil constitutions\"\n\t\t- \"Müller′s view of Apollo, which is at least very ingenious, is briefly this. The original and essential feature in the character of Apollo is that of \"the averter of evil\" (Apellôn); he is originally a divinity peculiar to the Doric race; and the most ancient seats of his worship are the Thessalian Tempe and Delphi. From thence it was transplanted to Crete, the inhabitants of which spread it over the coasts of Asia Minor and parts of the continent of Greece, such as Boeotia and Attica. In the latter country it was introduced during the immigration of the Ionians, whence the god became the Apollôn patrpsos of the Athenians. The conquest of Peloponnesus by the Dorians raised Apollo to the rank of the principal divinity in the peninsula. The Apollôn nomios was originally a local divinity of the shepherds of Arcadia, who was transformed into and identified with the Dorian Apollo during the process in which the latter became the national divinity of the Peloponnesians. In the same manner as in this instance the god assumed the character of a god of herds and flocks, his character was changed and modified in other parts of Greece also: with the Hyperboreans he was the god of prophecy, and with the Cretans the god with bow and darts. In Egypt he was made to form a part of their astronomical system, which was afterwards introduced into Greece, where it became the prevalent opinion of the learned.\"\n\t\t\t- Маловероятно, но интересно\n\t- [[Alternate mythology]]\n\t\t- Разжалование бога по функциям и регионам\n\t\t\t- [Пана](((66bd24c6-efdc-4fc5-bc54-c443a0a6f666))) отправили следить за пастухами и природой в Аркадию. Он был талантливее всех олимпийцев и умел всё. Оттуда и имя. Но они дали ему козлиную внешность и посадили туда, где никому нет дела до его талантов.\n\t\t\t- [Гефест](((66ba0f9a-fa8e-429f-aaef-bca6524c1fe8))) был правой рукой Зевса. Его свержение было [бесщадным](((66d3325b-a10c-4876-a064-70e45a456087))). На Олимпе его не зовут по имени, а кличут Копчёным или Кривым.\n\t\t\t- [Арес](((66ba0f9b-c626-486c-a58a-8467b5831845))) унижает [Эниалия](((66ba0f9a-d9c7-4e4b-abbe-08bc129ac502))), т.е. спартанцы вторгаются в Месинию.\n- Приложение\n\t- ((648f1fab-91e8-4290-a5b5-b4da2733f087))\n\t- [[Alternate mythology]]\n\t- [[Commentary]]",536870919]],["^15",[1031,"^16",1752169829879,536870919]],["^15",[1031,"^Z","pages/Mythos.md",536870919]],["^15",[1032,"^K",1752169829875,536870919]],["^15",[1032,"^@",false,536870919]],["^15",[1032,"^Y",".mythology",536870919]],["^15",[1032,"^11",".mythology",536870919]],["^15",[1032,"^B",1752169829875,536870919]],["^15",[1032,"^;","~u686ffd65-bc88-49b3-a71b-e61a1ee4977e",536870919]],["^15",[1033,"^K",1752169829875,536870919]],["^15",[1033,"^@",false,536870919]],["^15",[1033,"^Y",".flags",536870919]],["^15",[1033,"^11",".flags",536870919]],["^15",[1033,"^B",1752169829875,536870919]],["^15",[1033,"^;","~u686ffd65-3c4a-4fa5-9265-baf7a2d1c58c",536870919]],["^15",[1034,"^K",1752169829877,536870919]],["^15",[1034,"^@",false,536870919]],["^15",[1034,"^Y","alternate mythology",536870919]],["^15",[1034,"^11","Alternate mythology",536870919]],["^15",[1034,"^B",1752169829877,536870919]],["^15",[1034,"^;","~u686ffd65-7824-4178-bfa4-299239b0d2e9",536870919]],["^15",[1035,"^K",1752169829877,536870919]],["^15",[1035,"^@",false,536870919]],["^15",[1035,"^Y","commentary",536870919]],["^15",[1035,"^11","Commentary",536870919]],["^15",[1035,"^B",1752169829877,536870919]],["^15",[1035,"^;","~u686ffd65-d811-49e5-be43-a5dec2191e50",536870919]],["^15",[1036,"^K",1752169829875,536870919]],["^15",[1036,"^@",false,536870919]],["^15",[1036,"^Y",".tags",536870919]],["^15",[1036,"^11",".tags",536870919]],["^15",[1036,"^B",1752169829875,536870919]],["^15",[1036,"^;","~u686ffd65-93db-4b54-a4ea-50f975fbe6ba",536870919]],["^15",[1037,"^K",1752169829856,536870919]],["^15",[1037,"^@",false,536870919]],["^15",[1037,"^Y","region",536870919]],["^15",[1037,"^11","region",536870919]],["^15",[1037,"^B",1752169829856,536870919]],["^15",[1037,"^;","~u686ffd65-4815-4b39-852a-260c895b9dd5",536870919]],["^15",[1038,"^K",1752169829875,536870919]],["^15",[1038,"^@",false,536870919]],["^15",[1038,"^Y",".translation",536870919]],["^15",[1038,"^11",".translation",536870919]],["^15",[1038,"^B",1752169829875,536870919]],["^15",[1038,"^;","~u686ffd65-ace8-4579-9ccb-e1ee8ccb875d",536870919]],["^15",[1039,"^K",1752169829856,536870919]],["^15",[1039,"^@",false,536870919]],["^15",[1039,"^Y","mythology",536870919]],["^15",[1039,"^11","mythology",536870919]],["^15",[1039,"^B",1752169829856,536870919]],["^15",[1039,"^;","~u686ffd65-a489-4290-9ad9-8ad0b8d8eb96",536870919]],["^15",[1040,"^K",1752169829875,536870919]],["^15",[1040,"^@",false,536870919]],["^15",[1040,"^Y",".transcription",536870919]],["^15",[1040,"^11",".transcription",536870919]],["^15",[1040,"^B",1752169829875,536870919]],["^15",[1040,"^;","