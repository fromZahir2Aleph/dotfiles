","#her То, что у меня нет друзей, для нее будет красным флагом, если она адекватная.",536870915]],["^15",[300,"^O","^17",536870915]],["^15",[300,"^F",299,536870915]],["^15",[300,"^X",299,536870915]],["^15",[300,"^V",299,536870915]],["^15",[300,"^U",247,536870915]],["^15",[300,"^U",299,536870915]],["^15",[300,"^H",247,536870915]],["^15",[300,"^;","~u69a845e2-55a9-4c7d-8c30-04f33740ea25",536870915]],["^15",[301,"^3","- #perfectionism Перфекционизм - причина того, что я вижу бревно в глазу чужом и своем. Боль многократно усилила это. Теперь я сродни пользователю Лурка: гнилой червь.",536871227]],["^15",[301,"^16",1772635619011,536870915]],["^15",[301,"^18","~m1772889614791",536871226]],["^15",[301,"^Z","journals/2026_01_03.md",536870915]],["^15",[302,"^K",1772635619010,536870915]],["^15",[302,"^[",301,536870915]],["^15",[302,"^N",20260103,536870915]],["^15",[302,"^@",true,536870915]],["^15",[302,"^Y","jan 3rd, 2026",536870915]],["^15",[302,"^11","Jan 3rd, 2026",536870915]],["^15",[302,"^B",1772889613820,536871219]],["^15",[302,"^;","~u69a845e3-026b-4838-820f-92d63239e0ee",536870915]],["^15",[303,"^Q","#perfectionism Перфекционизм - причина того, что я вижу бревно в глазу чужом и своем. Боль многократно усилила это. Теперь я сродни пользователю Лурка: гнилой червь.",536871219]],["^15",[303,"^O","^17",536870915]],["^15",[303,"^F",302,536870915]],["^15",[303,"^X",302,536870915]],["^15",[303,"^V",302,536870915]],["^15",[303,"^U",302,536871220]],["^15",[303,"^U",3904,536871220]],["^15",[303,"^?",["^ "],536871219]],["^15",[303,"^H",3904,536871219]],["^15",[303,"^;","~u69a845e3-863c-4495-ab01-96d9053f7dd8",536870915]],["^15",[304,"^3","- [[personality psychology/interpersonal skills]] [[action/anticipatory commitment/self-discipline/monitoring]]\n\t- Проверяй свои намерения.\n\t\t- Больше слушай.\n\t\t- Если ты не чувствуешь других, то попытайся прочувствовать. Если не получается, то отстранись и смирись с тем, что сегодня ты не можешь участвовать в беседе.\n\t\t\t- #kenophobia Не пытайся заполнить пустоту в себе встреванием в разговор.\n\t\t- Если нет энергии, то просто подыгрывай. Хотя бы другим будет весело.\n\t\t- Если ты расстроен, не заражай других своими эмоциями.",536870915]],["^15",[304,"^16",1772635619027,536870915]],["^15",[304,"^Z","journals/2026_01_02.md",536870915]],["^15",[305,"^K",1772635619025,536870915]],["^15",[305,"^[",304,536870915]],["^15",[305,"^N",20260102,536870915]],["^15",[305,"^@",true,536870915]],["^15",[305,"^Y","jan 2nd, 2026",536870915]],["^15",[305,"^11","Jan 2nd, 2026",536870915]],["^15",[305,"^B",1772635619025,536870915]],["^15",[305,"^;","~u69a845e3-bf6a-4741-8912-27cedd0be6d3",536870915]],["^15",[306,"^K",1772635619397,536870915]],["^15",[306,"^@",false,536870915]],["^15",[306,"^Y","personality psychology/interpersonal skills",536870915]],["^15",[306,"^A",150,536870915]],["^15",[306,"^11","personality psychology/interpersonal skills",536870915]],["^15",[306,"^B",1772635619397,536870915]],["^15",[306,"^;","~u69a845e3-4155-47ee-9e4e-1ca7ffed606f",536870915]],["^15",[307,"^K",1772635619027,536870915]],["^15",[307,"^@",false,536870915]],["^15",[307,"^Y","kenophobia",536870915]],["^15",[307,"^11","kenophobia",536870915]],["^15",[307,"^B",1772635619027,536870915]],["^15",[307,"^;","~u69a845e6-f60d-451a-95f0-3efc202525c1",536870917]],["^15",[308,"^Q","[[personality psychology/interpersonal skills]] [[action/anticipatory commitment/self-discipline/monitoring]]",536870915]],["^15",[308,"^O","^17",536870915]],["^15",[308,"^F",305,536870915]],["^15",[308,"^X",305,536870915]],["^15",[308,"^V",305,536870915]],["^15",[308,"^U",150,536870915]],["^15",[308,"^U",172,536870915]],["^15",[308,"^U",175,536870915]],["^15",[308,"^U",243,536870915]],["^15",[308,"^U",253,536870915]],["^15",[308,"^U",305,536870915]],["^15",[308,"^U",306,536870915]],["^15",[308,"^H",150,536870915]],["^15",[308,"^H",172,536870915]],["^15",[308,"^H",175,536870915]],["^15",[308,"^H",243,536870915]],["^15",[308,"^H",253,536870915]],["^15",[308,"^