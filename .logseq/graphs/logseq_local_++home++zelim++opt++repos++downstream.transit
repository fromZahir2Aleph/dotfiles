5",[1748,"^Q","Могу ли следовать им?\n+ [ ] ...",536870920]],["^15",[1748,"^O","^1;",536870920]],["^15",[1748,"^F",1700,536870920]],["^15",[1748,"^X",1684,536870920]],["^15",[1748,"^V",1691,536870920]],["^15",[1748,"^U",760,536870920]],["^15",[1748,"^U",1684,536870920]],["^15",[1748,"^;","~u686ffd67-cfbd-4009-9672-6ee293a1000d",536870920]],["^15",[1749,"^?",["^ ","^1E","renderer","^1F",[":slider_azxoggjg"]],536870920]],["^15",[1749,"^W","macro",536870920]],["^15",[1749,"^T","renderer :slider_azxoggjg",536870920]],["^15",[1751,"^K",1752169831534,536870920]],["^15",[1751,"^@",false,536870920]],["^15",[1751,"^Y","67bc5281-4144-4f94-8d5d-38e427f770b0",536870920]],["^15",[1751,"^11","67bc5281-4144-4f94-8d5d-38e427f770b0",536870920]],["^15",[1751,"^B",1752169831534,536870920]],["^15",[1751,"^;","~u686ffd67-1d33-4336-919e-13f0e3314d05",536870920]],["^15",[1885,"^Q","{{embed ((67bc5281-4144-4f94-8d5d-38e427f770b0))}}",536884735]],["^15",[1885,"^H",3552,536884735]],["^15",[2197,"^?",["^ ","^1E","embed","^1F",["((67bc5281-4144-4f94-8d5d-38e427f770b0))"]],536870920]],["^15",[2197,"^W","macro",536870920]],["^15",[2197,"^T","embed ((67bc5281-4144-4f94-8d5d-38e427f770b0))",536870920]],["^15",[2198,"^3","- ![📄 The Unfolding of Language - Guy Deutscher.pdf](../assets/The Unfolding of Language - Guy Deutscher.pdf)\n- ## Введение\n\t- Лингвистика следует принципу актуализма: язык меняется сегодня так же, как и в прошлом.\n\t- Две оговорки\n\t\t- Дословесная история языка не является предметом книги, так как лингвистика не может сегодня с какой либо уверенностью описать её\n\t\t- Гипотеза врождённости языковой способности остаётся гипотезой. Аргументы в пользу или против неё не влияют на содежание книги. Она описыает культурную эволюцию языка, а не биологическую.\n\t\t\t- Другими словами, наличие или отсутсвие гена языка не влияет на описанные факты.",536870920]],["^15",[2198,"^16",1752169831546,536870920]],["^15",[2198,"^Z","pages/The Unfolding of Language.md",536870920]],["^15",[219