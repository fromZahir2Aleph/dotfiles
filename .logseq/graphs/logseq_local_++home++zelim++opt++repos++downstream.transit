^15",[931,"^10","TODO",536881891]],["^15",[931,"^X",930,536870919]],["^15",[931,"^V",930,536870919]],["^15",[931,"^U",4,536870919]],["^15",[931,"^U",930,536870919]],["^15",[931,"^?",["^ "],536881891]],["^15",[931,"^H",4,536881891]],["^15",[931,"^C",true,536881891]],["^15",[931,"^I",20250928,536881891]],["^15",[931,"^;","~u686ffd65-95cb-4c32-995c-8642c5dc8bd7",536870919]],["^15",[932,"^3","- #PIM\n\t- ### Переплетённые иерархии\n\t\t- Trees do grow,\n\t\t  id:: 64b9bd7a-b308-4305-b197-a107adc889df\n\t\t  Web does stick:\n\t\t  Logseq's slow,\n\t\t  But does the trick.\n\t\t\t- Без контекста сеть концепций - это решето.\n\t\t\t  collapsed:: true\n\t\t\t\t- Иерархия - далеко не самая важный элемент контекста, но единственный, который можно себе навязать.\n\t\t\t\t\t- При работе с источниками её легко воспроизвести - спускайся сверху вниз: оглавление, главы, работа с блоками и ссылками на них.\n\t\t\t\t\t- А вот на уровне единичных заметок, иерархическое дерево должно вырасти само с самого низа с помощью тэгов и ссылок на уже созданные таким путём страницы и блоки.",536870919]],["^15",[932,"^16",1752169829464,536870919]],["^15",[932,"^Z","journals/2023_06_19.md",536870919]],["^15",[933,"^K",1752169829464,536870919]],["^15",[933,"^[",932,536870919]],["^15",[933,"^N",20230619,536870919]],["^15",[933,"^@",true,536870919]],["^15",[933,"^Y","jun 19th, 2023",536870919]],["^15",[933,"^11","Jun 19th, 2023",536870919]],["^15",[933,"^B",1752169829464,536870919]],["^15",[933,"^;","~u686ffd65-5fbb-4180-83f4-db401e19476c",536870919]],["^15",[934,"^Q","#PIM",536870919]],["^15",[934,"^O","^1;",536870919]],["^15",[934,"^F",933,536870919]],["^15",[934,"^X",933,536870919]],["^15",[934,"^V",933,536870919]],["^15",[934,"^U",867,536870919]],["^15",[934,"^U",933,536870919]],["^15",[934,"^H",867,536870919]],["^15",[934,"^;","~u686ffd65-629c-4ee9-94d3-6cc7f4b74200",536870919]],["^15",[935,"^Q","### Переплетённые иерархии",536870919]],["^15",[935,"^O","^1;",536870919]],["^15",[935,"^F",934,536870919]],["^15",[935,"^X",933,536870919]],["^15",[935,"^V",934,536870919]],["^15",[935,"^U",867,536870919]],["^15",[935,"^U",933,536870919]],["^15",[935,"^?",["^ ","^1C",3],536870919]],["^15",[935,"^J",[],536870919]],["^15",[935,"^;","~u686ffd65-a4e2-49b2-9b3f-918be1b84957",536870919]],["^15",[936,"^M",true,536870919]],["^15",[936,"^Q","Без контекста сеть концепций - это решето.\ncollapsed:: true",536870919]],["^15",[936,"^O","^1;",536870919]],["^15",[936,"^F",898,536870919]],["^15",[936,"^X",933,536870919]],["^15",[936,"^V",898,536870919]],["^15",[936,"^U",867,536870919]],["^15",[936,"^U",933,536870919]],["^15",[936,"^?",["^ "],536870919]],["^15",[936,"^J",[],536870919]],["^15",[936,"^4",["^ "],536870919]],["^15",[936,"^;","~u686ffd65-d23a-40f0-b131-5d8e1e6ec842",536870919]],["^15",[937,"^Q","Иерархия - далеко не самая важный элемент контекста, но единственный, который можно себе навязать.",536870919]],["^15",[937,"^O","^1;",536870919]],["^15",[937,"^F",936,536870919]],["^15",[937,"^X",933,536870919]],["^15",[937,"^V",936,536870919]],["^15",[937,"^U",867,536870919]],["^15",[937,"^U",933,536870919]],["^15",[937,"^;","~u686ffd65-7b50-4c86-b73e-92e841921ab2",536870919]],["^15",[938,"^Q","При работе с источниками её легко воспроизвести - спускайся сверху вниз: оглавление, главы, работа с блоками и ссылками на них.",536870919]],["^15",[938,"^O","^1;",536870919]],["^15",[938,"^F",937,536870919]],["^15",[938,"^X",933,536870919]],["^15",[938,"^V",937,536870919]],["^15",[938,"^U",867,536870919]],["^15",[938,"^U",933,536870919]],["^15",[938,"^;","~u686ffd65-a0be-4d59-9e09-4f148e581df5",536870919]],["^15",[939,"^Q","А вот на уровне единичных заметок, иерархическое дерево должно вырасти само с самого низа с помощью тэгов и ссылок на уже созданные таким путём страницы и блоки.",536870919]],["^15",[939,"^O","^1;",536870919]],["^15",[939,"^F",938,536870919]],["^15",[939,"^X",933,536870919]],["^15",[939,"^V",937,536870919]],["^15",[939,"^U",867,536870919]],["^15",[939,"^U",933,536870919]],["^15",[939,"^;","~u686ffd65-9e47-4e7e-aa03-0be7ae489e56",536870919]],["^15",[940,"^3","- [[Ударение в древнегреческом языке]]\n  id:: 648f1fab-91e8-4290-a5b5-b4da2733f087\n\t- В древнегреческом языке словесное ударение было музыкальным, то есть характеризовалось изменением тона подударного гласного. Краткий (одноморный) ударный гласный мог иметь только восходящий тон, обозначающийся знаком острого ударения ´, двухморный (долгий) гласный или дифтонг мог иметь как острое ударение (с поднимающимся на второй море тоном), так и облегчённое ˜ или ῀ с преломленным тоном, восходящим на первой море и нисходящим на второй.",536870919]],["^15",[940,"^16",1752169829475,536870919]],["^15",[940,"^Z","journals/2023_06_05.md",536870919]],["^15",[941,"^K",1752169829475,536870919]],["^15",[941,"^[",940,536870919]],["^15",[941,"^N",20230605,536870919]],["^15",[941,"^@",true,536870919]],["^15",[941,"^Y","jun 5th, 2023",536870919]],["^15",[941,"^11","Jun 5th, 2023",536870919]],["^15",[941,"^B",1752169829475,536870919]],["^15",[941,"^;","~u686ffd65-4829-427b-abe7-7f2d8cd6b61f",536870919]],["^15",[942,"^K",1752169829474,536870919]],["^15",[942,"^@",false,536870919]],["^15",[942,"^Y","ударение в древнегреческом языке",536870919]],["^15",[942,"^11","Ударение в древнегреческом языке",536870919]],["^15",[942,"^B",1752169829474,536870919]],["^15",[942,"^;","~u686ffd65-fb46-48ad-93a5-63354d2c6663",536870919]],["^15",[943,"^Q","[[Ударение в древнегреческом языке]]\nid:: 648f1fab-91e8-4290-a5b5-b4da2733f087",536870919]],["^15",[943,"^O","^1;",536870919]],["^15",[943,"^F",941,536870919]],["^15",[943,"^X",941,536870919]],["^15",[943,"^V",941,536870919]],["^15",[943,"^U",941,536870919]],["^15",[943,"^U",942,536870919]],["^15",[943,"^?",["^ ","^1D","648f1fab-91e8-4290-a5b5-b4da2733f087"],536870919]],["^15",[943,"^J",["^1D"],536870919]],["^15",[943,"^4",["^ ","^1D","648f1fab-91e8-4290-a5b5-b4da2733f087"],536870919]],["^15",[943,"^H",942,536870919]],["^15",[943,"^;","~u648f1fab-91e8-4290-a5b5-b4da2733f087",536870919]],["^15",[944,"^Q","В древнегреческом языке словесное ударение было музыкальным, то есть характеризовалось изменением тона подударного гласного. Краткий (одноморный) ударный гласный мог иметь только восходящий тон, обозначающийся знаком острого ударения ´, двухморный (долгий) гласный или дифтонг мог иметь как острое ударение (с поднимающимся на второй море тоном), так и облегчённое ˜ или ῀ с преломленным тоном, восходящим на первой море и нисходящим на второй.",536870919]],["^15",[944,"^O","^1;",536870919]],["^15",[944,"^F",943,536870919]],["^15",[944,"^X",941,536870919]],["^15",[944,"^V",943,536870919]],["^15",[944,"^U",941,536870919]],["^15",[944,"^U",942,536870919]],["^15",[944,"^;","~u686ffd65-b9d9-4494-9299-716755326ce9",536870919]],["^15",[945,"^3","tags:: diary\ntype:: reflection\nmood:: sad\n\n\t- #Седа \"Ты чаще дома, чем я.\"",536870919]],["^15",[945,"^16",1752169829485,536870919]],["^15",[945,"^Z","journals/2023_05_20.md",536870919]],["^15",[946,"^K",1752169829484,536870919]],["^15",[946,"^[",945,536870919]],["^15",[946,"^N",20230520,536870919]],["^15",[946,"^@",true,536870919]],["^15",[946,"^Y","may 20th, 2023",536870919]],["^15",[946,"^11","May 20th, 2023",536870919]],["^15",[946,"^?",["^ ","^18",["^19",["diary"]],"^1=","reflection","^1>","sad"],536870919]],["^15",[946,"^4",["^ ","^18","diary","^1=","reflection","^1>","sad"],536870919]],["^15",[946,"^P",69,536870919]],["^15",[946,"^B",1752169829484,536870919]],["^15",[946,"^;","~u686ffd65-b111-4c0a-8a89-ca42e1eca85a",536870919]],["^15",[947,"^K",1752169829485,536870919]],["^15",[947,"^@",false,536870919]],["^15",[947,"^Y","седа",536870919]],["^15",[947,"^11","Седа",536870919]],["^15",[947,"^B",1752169829485,536870919]],["^15",[947,"^;","~u686ffd65-627f-48f2-82c9-99a2e69f6efc",536870919]],["^15",[948,"^Q","tags:: diary\ntype:: reflection\nmood:: sad\n\n",536870919]],["^15",[948,"^O","^1;",536870919]],["^15",[948,"^1<",["^19",[]],536870919]],["^15",[948,"^F",946,536870919]],["^15",