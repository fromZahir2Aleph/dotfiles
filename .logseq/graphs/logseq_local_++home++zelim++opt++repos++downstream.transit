0919]],["^15",[1070,"^;","~u686ffd65-53df-4e97-9a2d-89634f7a6f67",536870919]],["^15",[1071,"^Q","...в своей категории",536870919]],["^15",[1071,"^O","^1;",536870919]],["^15",[1071,"^F",1079,536870919]],["^15",[1071,"^X",1003,536870919]],["^15",[1071,"^V",1201,536870919]],["^15",[1071,"^U",1003,536870919]],["^15",[1071,"^;","~u686ffd65-b1db-4616-b131-f361292f9fab",536870919]],["^15",[1072,"^Q","[[Alternate mythology]]",536870919]],["^15",[1072,"^O","^1;",536870919]],["^15",[1072,"^F",1136,536870919]],["^15",[1072,"^X",1003,536870919]],["^15",[1072,"^V",1190,536870919]],["^15",[1072,"^U",1003,536870919]],["^15",[1072,"^U",1034,536870919]],["^15",[1072,"^H",1034,536870919]],["^15",[1072,"^;","~u686ffd65-75f6-4761-aba5-87c3cc203c89",536870919]],["^15",[1073,"^Q","История его взросления подобна происхождению [Пандоры](Πανδώρα), только наоборот. Они дважды скидывали его с Олимпа, заковывали в ограничивающие рост цепи и сделали своим чернорабочим.",536870919]],["^15",[1073,"^O","^1;",536870919]],["^15",[1073,"^F",1093,536870919]],["^15",[1073,"^X",1003,536870919]],["^15",[1073,"^V",1093,536870919]],["^15",[1073,"^U",1003,536870919]],["^15",[1073,"^U",1034,536870919]],["^15",[1073,"^;","~u686ffd65-b7a4-4ac1-9898-4086a181a5d7",536870919]],["^15",[1074,"^Q","Зевс наказал человечество потопом за то, что герои стали почитаться больше жителей Олимпа. Люди Железного века жили меньше, и после истребления героев баг Пандоры, обременявший всех половыми нуждами и как следствие семейными узами, был неискореним.",536870919]],["^15",[1074,"^O","^1;",536870919]],["^15",[1074,"^F",1163,536870919]],["^15",[1074,"^X",1003,536870919]],["^15",[1074,"^V",1163,536870919]],["^15",[1074,"^U",1003,536870919]],["^15",[1074,"^U",1034,536870919]],["^15",[1074,"^;","~u686ffd65-daa1-4b65-9a1b-0d3a4581b462",536870919]],["^15",[1075,"^Q","...значило на Олимпе установить в творение бэкдор.",536870919]],["^15",[1075,"^O","^1;",536870919]],["^15",[1075,"^F",1084,536870919]],["^15",[1075,"^X",1003,536870919]