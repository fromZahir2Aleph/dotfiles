          {:x1 165.84375,\n                                   :y1 1034.984375,\n                                   :x2 229.40625,\n                                   :y2 1062.984375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 246.015625,\n                                   :y1 1034.984375,\n                                   :x2 434.53125,\n                                   :y2 1062.984375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 451.140625,\n                                   :y1 1034.984375,\n                                   :x2 514.390625,\n                                   :y2 1062.984375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 531,\n                                   :y1 1034.984375,\n                                   :x2 667.796875,\n                                   :y2 1062.984375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 684.40625,\n                                   :y1 1034.984375,\n                                   :x2 729.921875,\n                                   :y2 1062.984375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 746.53125,\n                                   :y1 1034.984375,\n                                   :x2 850.484375,\n                                   :y2 1062.984375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 867.09375,\n                                   :y1 1034.984375,\n                                   :x2 890.8447265625,\n                                   :y2 1062.984375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1068.78125,\n                                   :x2 891.139404296875,\n                                   :y2 1096.78125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1102.5625,\n                                   :x2 891.4742431640625,\n                                   :y2 1130.5625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1136.234375,\n                                   :x2 891.579345703125,\n                                   :y2 1164.234375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1170.015625,\n                                   :x2 891.975830078125,\n                                   :y2 1198.015625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}),\n                          :page 399},\n               :content {:text \"The next big leap — from sound to light — was of course a bold step, but the way had already been paved by the leap from water to sound. To put it diﬀerently, the sound-to-light leap was facilitated by a meta-analogy, even if it wasn’t spelled out explicitly — namely, the idea that one analogical leap (from water to sound) had already worked, and so why shouldn’t the analogous analogical leap (from sound to light) also work? Such meta-analogies have permeated the thinking of physicists in the last few centuries: an idea understood well in one domain is tentatively tried out in some new domain, and if it is found to work there, physicists hasten to try to export the old idea once again to even more exotic domains, with each daring\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"67b4094f-4ba5-44f2-8cb1-b446f8b3b27d\",\n               :page 400,\n               :position {:bounding {:x1 128.3125,\n                                     :y1 123.78125,\n                                     :x2 891.903564453125,\n                                     :y2 455.515625,\n                                     :width 1019.9999999999999,\n                                     :height 1319.9999999999998},\n                          :rects ({:x1 128.3125,\n                                   :y1 123.78125,\n                                   :x2 184.421875,\n                                   :y2 151.78125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 198.078125,\n                                   :y1 123.78125,\n                                   :x2 299.078125,\n                                   :y2 151.78125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 312.71875,\n                                   :y1 123.78125,\n                                   :x2 342.734375,\n                                   :y2 151.78125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n     