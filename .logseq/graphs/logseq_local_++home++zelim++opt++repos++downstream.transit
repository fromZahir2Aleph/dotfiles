",536870917]],["^15",[1834,"^Q","Место",536870917]],["^15",[1834,"^O","^17",536870917]],["^15",[1834,"^F",1833,536870917]],["^15",[1834,"^X",1814,536870917]],["^15",[1834,"^V",1838,536870917]],["^15",[1834,"^U",146,536870917]],["^15",[1834,"^U",172,536870917]],["^15",[1834,"^U",175,536870917]],["^15",[1834,"^U",1255,536870917]],["^15",[1834,"^U",1813,536870917]],["^15",[1834,"^U",1814,536870917]],["^15",[1834,"^;","~u69a845e6-785b-4289-911c-da484861b8fb",536870917]],["^15",[1835,"^Q","Интересы, переписка и остальное.",536870917]],["^15",[1835,"^O","^17",536870917]],["^15",[1835,"^F",1827,536870917]],["^15",[1835,"^X",1814,536870917]],["^15",[1835,"^V",1827,536870917]],["^15",[1835,"^U",146,536870917]],["^15",[1835,"^U",172,536870917]],["^15",[1835,"^U",175,536870917]],["^15",[1835,"^U",1255,536870917]],["^15",[1835,"^U",1813,536870917]],["^15",[1835,"^U",1814,536870917]],["^15",[1835,"^;","~u69a845e6-8e82-4192-93b7-013abd8a30d7",536870917]],["^15",[1836,"^Q","Firefox",536870917]],["^15",[1836,"^O","^17",536870917]],["^15",[1836,"^F",1843,536870917]],["^15",[1836,"^X",1814,536870917]],["^15",[1836,"^V",1843,536870917]],["^15",[1836,"^U",146,536870917]],["^15",[1836,"^U",172,536870917]],["^15",[1836,"^U",175,536870917]],["^15",[1836,"^U",1255,536870917]],["^15",[1836,"^U",1813,536870917]],["^15",[1836,"^U",1814,536870917]],["^15",[1836,"^;","~u69a845e6-0d2e-4c1e-9faa-7207084554a3",536870917]],["^15",[1837,"^Q","Не делай никаких пост-бустстреповских планов.",536870917]],["^15",[1837,"^O","^17",536870917]],["^15",[1837,"^F",1841,536870917]],["^15",[1837,"^X",1814,536870917]],["^15",[1837,"^V",1841,536870917]],["^15",[1837,"^U",146,536870917]],["^15",[1837,"^U",148,536870917]],["^15",[1837,"^U",150,536870917]],["^15",[1837,"^U",172,536870917]],["^15",[1837,"^U",175,536870917]],["^15",[1837,"^U",1255,536870917]],["^15",[1837,"^U",1779,536870917]],["^15",[1837,"^U",1813,536870917]],["^15",[1837,"^U",1814,536870917]],["^15",[1837,"^U",1815,536870917]],["^15",[1837,"^;","~u69a845e6-9b29-481a-8fd6-aa1a6b0b37da",536870917]],["^15",[1838,"^Q","На данном этапе жизни мне не стоит распыляться на те вещи, которые я могу реализовать только в здоровом состоянии, потому что я не самозапускаюсь. Только обретя покой я смогу это сделать. Пока нужно делать ставку на ортогональность времени и окружающей среды как границ, стимулирующих нужное мышления и поведение с привязкой областей внимания ко времени и месту.",536870917]],["^15",[1838,"^O","^17",536870917]],["^15",[1838,"^F",1818,536870917]],["^15",[1838,"^X",1814,536870917]],["^15",[1838,"^V",1818,536870917]],["^15",[1838,"^U",146,536870917]],["^15",[1838,"^U",172,536870917]],["^15",[1838,"^U",175,536870917]],["^15",[1838,"^U",1255,536870917]],["^15",[1838,"^U",1813,536870917]],["^15",[1838,"^U",1814,536870917]],["^15",[1838,"^;","~u69a845e6-653f-4f18-a55a-b9ed90520d7e",536870917]],["^15",[1839,"^Q","Никаких фантазий и раздумий до девяти вечера. После - переключись в режим таковости с помощью медитации, поделок или рисования. Если день не заладился или набрал слишком высокий для тебя темп двигайся к ночи тихим ходом. Обед и выходные режим \"не работа\".",536870917]],["^15",[1839,"^O","^17",536870917]],["^15",[1839,"^F",1821,536870917]],["^15",[1839,"^X",1814,536870917]],["^15",[1839,"^V",1833,536870917]],["^15",[1839,"^U",146,536870917]],["^15",[1839,"^U",172,536870917]],["^15",[1839,"^U",175,536870917]],["^15",[1839,"^U",1255,536870917]],["^15",[1839,"^U",1813,536870917]],["^15",[1839,"^U",1814,536870917]],["^15",[1839,"^;","~u69a845e6-ee85-4981-a34f-6992b03b7e19",536870917]],["^15",[1840,"^Q","Сначала начни с матраса, потом со своей комнаты, потом с маминой. Если будешь продолжать делать по-своему и негодовать о том, что ты не у дел в республике, так как и останешься на матрасе.",536870917]],["^15",[1840,"^O","^17",536870917]],["^15",[1840,"^F",1817,536870917]],["^15",[1840,"^X",1814,536870917]],["^15",[1840,"^V",1817,536870917]],["^15",[1840,"^U",146,536870917]],["^15",[1840,"^U",172,536870917]],["^15",[1840,"^U",175,536870917]],["^15",[1840,"^U",1814,536870917]],["^15",[1840,"^;","~u69a845e6-1a31-439a-be5a-1c5d32112cc0",536870917]],["^15",[1841,"^Q","Думай о следующем шаге только после реализации текущекого.",536870917]],["^15",[1841,"^O","^17",536870917]],["^15",[1841,"^F",1825,536870917]],["^15",[1841,"^X",1814,536870917]],["^15",[1841,"^V",1821,536870917]],["^15",[1841,"^U",146,536870917]],["^15",[1841,"^U",148,536870917]],["^15",[1841,"^U",150,536870917]],["^15",[1841,"^U",172,536870917]],["^15",[1841,"^U",175,536870917]],["^15",[1841,"^U",1255,536870917]],["^15",[1841,"^U",1779,536870917]],["^15",[1841,"^U",1813,536870917]],["^15",[1841,"^U",1814,536870917]],["^15",[1841,"^U",1815,536870917]],["^15",[1841,"^;","~u69a845e6-e3ad-4d24-ba41-1f62e0ccccae",536870917]],["^15",[1842,"^Q","Перестань беспокоиться и начни планировать. Но не смотри вперёд дальше сегодняшнего дня, если это не конец недели или месяца. Не смотри вообще никуда, когда закрываешь глаза, то есть в постели.",536870917]],["^15",[1842,"^O","^17",536870917]],["^15",[1842,"^F",1825,536870917]],["^15",[1842,"^X",1814,536870917]],["^15",[1842,"^V",1825,536870917]],["^15",[1842,"^U",146,536870917]],["^15",[1842,"^U",148,536870917]],["^15",[1842,"^U",150,536870917]],["^15",[1842,"^U",172,536870917]],["^15",[1842,"^U",175,536870917]],["^15",[1842,"^U",1255,536870917]],["^15",[1842,"^U",1779,536870917]],["^15",[1842,"^U",1813,536870917]],["^15",[1842,"^U",1814,536870917]],["^15",[1842,"^U",1815,536870917]],["^15",[1842,"^U",1816,536870917]],["^15",[1842,"^;","~u69a845e6-f570-4948-af41-84c128a1781c",536870917]],["^15",[1843,"^Q","Компьютер",536870917]],["^15",[1843,"^O","^17",536870917]],["^15",[1843,"^F",1830,536870917]],["^15",[1843,"^X",1814,536870917]],["^15",[1843,"^V",1820,536870917]],["^15",[1843,"^U",146,536870917]],["^15",[1843,"^U",172,536870917]],["^15",[1843,"^U",175,536870917]],["^15",[1843,"^U",1255,536870917]],["^15",[1843,"^U",1813,536870917]],["^15",[1843,"^U",1814,536870917]],["^15",[1843,"^;","~u69a845e6-23fc-43f4-9619-48a9ab795a22",536870917]],["^15",[1844,"^3","- #[[collector's fallacy]] #[[procrastination/sophisticated procrastination]]\n\t- Я собрал...\n\t\t- почти 220 000 слов в заметках.\n\t\t\t- Для сравнения в Улиссе 268 170 слов, в Каренине - 353 250.\n\t\t- более 26 000 книг и комиксов на Чердаке.\n\t\t\t- Прочитал около двухсот.\n\t\t- почти 25 000 файлов в Ранце.\n\t\t\t- Ничего не прочитано.\n\t\t- 450 фильмов в Movies.\n\t\t\t- 200 из них в To watch.\n\t\t- более 50 покупок в Стиме.\n\t\t\t- Играл по сути в девять игр.\n\t\t- в каталогах\n\t\t\t- около 770 фильмов. С учётом того, что эти, подлежащие к просмотру, у меня отдельно от моей коллекции и вовсе незалогенных, то это единственный пункт, где я получил хоть какую-то пользу.\n\t\t\t- около 450 видеоигр.\n\t\t\t\t- Поиграл примерно в пятнадцать.\n\t\t\t- 370 настольных.\n\t\t\t\t- Поиграл более двух раз в четыре.\n\t\t\t- кучу сериалов, музыки, лекций и прочего.\n\t- Я их постоянно организовывал, переименовывал и классифицировал.",536870917]],["^15",[1844,"^16",1772635622168,536870917]],["^15",[1844,"^Z","journals/2023_10_17.md",536870917]],["^15",[1845,"^K",1772635622167,536870917]],["^15",[1845,"^[",1844,536870917]],["^15",[1845,"^N",20231017,536870917]],["^15",[1845,"^@",true,536870917]],["^15",[1845,"^Y","oct 17th, 2023",536870917]],["^15",[1845,"^11","Oct 17th, 2023",536870917]],["^15",[1845,"^B",1772635622167,536870917]],["^15",[1845,"^;","~u69a845e6-8cfa-48c3-85b3-153b42f2daf2",536870917]],["^15",[1846,"^K",1772635622390,536870917]],["^15",[1846,"^@",false,536870917]],["^15",[1846,"^Y","procrastination/sophisticated procrastination",536870917]],["^15",[1846,"^A",176,536870917]],["^15",[1846,"^11","procrastination/sophisticated procrastination",536870917]],["^15",[1846,"^B",1772635622390,536870917]],["^15",[1846,"^;","~u69a845e6-95b6-4b2b-a866-f5033919183e",536870917]],["^15",[1847,"^Q","более 26 000 книг и комиксов на Чердаке.",536870917]],["^15",[1847,"^O","^17",5