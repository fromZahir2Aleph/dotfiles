knowledgement\nmood:: neutral",536877419]],["^15",[1180,"^O","^17",536870915]],["^15",[1180,"^1=",["^1:",[]],536877419]],["^15",[1180,"^F",1178,536870915]],["^15",[1180,"^X",1178,536870915]],["^15",[1180,"^V",1178,536870915]],["^15",[1180,"^U",185,536870915]],["^15",[1180,"^U",186,536870915]],["^15",[1180,"^U",187,536870915]],["^15",[1180,"^U",1178,536870915]],["^15",[1180,"^:",true,536877419]],["^15",[1180,"^?",["^ ","^19",["^1:",["diary"]],"^1;","acknowledgement","^1<","neutral"],536877419]],["^15",[1180,"^J",["^14",["^19","^1;","^1<"]],536877419]],["^15",[1180,"^4",["^ ","^19","diary","^1;","acknowledgement","^1<","neutral"],536877419]],["^15",[1180,"^H",185,536877419]],["^15",[1180,"^H",186,536877419]],["^15",[1180,"^H",187,536877419]],["^15",[1180,"^;","~u69a845e4-b580-4b43-ac9f-b5d69dc8d286",536870915]],["^15",[1181,"^Q","Псевдоним для [Священного палимпсеста]([[Палимпсест времени]]) - это всего лишь ещё одно проявление твоего [эскапизма]([[escapism]]).",536871504]],["^15",[1181,"^O","^17",536870915]],["^15",[1181,"^F",1180,536870915]],["^15",[1181,"^X",1178,536870915]],["^15",[1181,"^V",1178,536870915]],["^15",[1181,"^U",147,536871501]],["^15",[1181,"^U",472,536871501]],["^15",[1181,"^U",1178,536871501]],["^15",[1181,"^?",["^ "],536871504]],["^15",[1181,"^H",147,536871504]],["^15",[1181,"^H",472,536871504]],["^15",[1181,"^;","~u69a845e4-82a3-407a-92f7-ada901d055b9",536870915]],["^15",[1182,"^3","tags:: diary\ntype:: event\nmood:: sad\n\n- #isolation Вчера побежал за кинувшими мяч в окно. Это и последние два визита в библиотеку, что я снова асоциален. Уже во второй раз, не включая изначальное состояние. Если шизотипическая неприсособленность - из-за нейробиологии мозга, то асоциальность последних пяти лет исходит из моей изоляции. И в этот раз я не вижу выхода, если только мне не станет лучше.",536870915]],["^15",[1182,"^16",1772635620160,536870915]],["^15",[1182,"^Z","journals/2025_05_14.md",536870915]],["^15",[1183,"^K",1772635620160,536870915]],["^15",[1183,"^[",1182,536870915]],["^15",[1183,"^N",20250514,536870915]],["^15",[1183,"^@",true,536870915]],["^15",[1183,"^Y","may 14th, 2025",536870915]],["^15",[1183,"^11","May 14th, 2025",536870915]],["^15",[1183,"^?",["^ ","^19",["^1:",["diary"]],"^1;","event","^1<","sad"],536870915]],["^15",[1183,"^4",["^ ","^19","diary","^1;","event","^1<","sad"],536870915]],["^15",[1183,"^P",185,536870915]],["^15",[1183,"^B",1772635620160,536870915]],["^15",[1183,"^;","~u69a845e4-304d-4f22-ab38-1af0f04826f9",536870915]],["^15",[1184,"^Q","tags:: diary\ntype:: event\nmood:: sad\n\n",536870915]],["^15",[1184,"^O","^17",536870915]],["^15",[1184,"^1=",["^1:",[]],536870915]],["^15",[1184,"^F",1183,536870915]],["^15",[1184,"^X",1183,536870915]],["^15",[1184,"^V",1183,536870915]],["^15",[1184,"^U",185,536870915]],["^15",[1184,"^U",186,536870915]],["^15",[1184,"^U",187,536870915]],["^15",[1184,"^U",1183,536870915]],["^15",[1184,"^:",true,536870915]],["^15",[1184,"^?",["^ ","^19",["^1:",["diary"]],"^1;","event","^1<","sad"],536870915]],["^15",[1184,"^J",["^19","^1;","^1<"],536870915]],["^15",[1184,"^4",["^ ","^19","diary","^1;","event","^1<","sad"],536870915]],["^15",[1184,"^H",185,536870915]],["^15",[1184,"^H",186,536870915]],["^15",[1184,"^H",187,536870915]],["^15",[1184,"^;","~u69a845e4-e284-4ac9-a67a-9d72febef6a2",536870915]],["^15",[1185,"^Q","#isolation Вчера побежал за кинувшими мяч в окно. Это и последние два визита в библиотеку, что я снова асоциален. Уже во второй раз, не включая изначальное состояние. Если шизотипическая неприсособленность - из-за нейробиологии мозга, то асоциальность последних пяти лет исходит из моей изоляции. И в этот раз я не вижу выхода, если только мне не станет лучше.",536870915]],["^15",[1185,"^O","^17",536870915]],["^15",[1185,"^F",1184,536870915]],["^15",[1185,"^X",1183,536870915]],["^15",[1185,"^V",1183,536870915]],["^15",[1185,"^U",1142,536870915]],["^15",[1185,"^U",1183,536870915]],["^15",[1185,"^H",1142,536870915]],["^15",[1185,"^;","~u69a845e4-c4a7-4ea6-b4b7-521324b63602",536870915]],["^15",[1186,"^3","- #stoicism Теперь, когда ты остался без амбиций, своего ума и просто-напросто трудоспособности, стоицизм - оптимальное мировоззрение для тебя. Терпи до конца, и надейся на технологический прогресс.",536870915]],["^15",[1186,"^16",1772635620171,536870915]],["^15",[1186,"^Z","journals/2025_05_13.md",536870915]],["^15",[1187,"^K",1772635620171,536870915]],["^15",[1187,"^[",1186,536870915]],["^15",[1187,"^N",20250513,536870915]],["^15",[1187,"^@",true,536870915]],["^15",[1187,"^Y","may 13th, 2025",536870915]],["^15",[1187,"^11","May 13th, 2025",536870915]],["^15",[1187,"^B",1772635620171,536870915]],["^15",[1187,"^;","~u69a845e4-2da5-4ac3-9b60-1adab505fccd",536870915]],["^15",[1188,"^K",1772635620170,536870915]],["^15",[1188,"^@",false,536870915]],["^15",[1188,"^Y","stoicism",536870915]],["^15",[1188,"^11","stoicism",536870915]],["^15",[1188,"^B",1772635620170,536870915]],["^15",[1188,"^;","~u69a845e4-82fc-47f2-8b79-8b248d141533",536870915]],["^15",[1189,"^Q","#stoicism Теперь, когда ты остался без амбиций, своего ума и просто-напросто трудоспособности, стоицизм - оптимальное мировоззрение для тебя. Терпи до конца, и надейся на технологический прогресс.",536870915]],["^15",[1189,"^O","^17",536870915]],["^15",[1189,"^F",1187,536870915]],["^15",[1189,"^X",1187,536870915]],["^15",[1189,"^V",1187,536870915]],["^15",[1189,"^U",1187,536870915]],["^15",[1189,"^U",1188,536870915]],["^15",[1189,"^H",1188,536870915]],["^15",[1189,"^;","~u69a845e4-bb26-4e93-9eca-7cee7d90eb8d",536870915]],["^15",[1190,"^3","- [[personality psychology/accentuation]]\n\t- [[affect display]]\n\t\t- [[sign language]]\n\t\t- Регистры\n\t\t\t- На улице\n\t\t\t\t- Я слишком вежлив, и у этой вежливости элемент [[personality psychology/self-deception/riya]].\n\t\t- Речь\n\t\t\t- Замени мат неручными и неречевыми сигналами.\n\t\t\t- Не подчёркивай ударение на незнакомых словах. Это выдаёт твоё незнакомство с ними.\n\t- Внешность\n\t\t- Одежда\n\t- Смотри youtube *каналы* с молодыми людьми.",536870915]],["^15",[1190,"^16",1772635620189,536870915]],["^15",[1190,"^Z","journals/2025_05_12.md",536870915]],["^15",[1191,"^K",1772635620186,536870915]],["^15",[1191,"^[",1190,536870915]],["^15",[1191,"^N",20250512,536870915]],["^15",[1191,"^@",true,536870915]],["^15",[1191,"^Y","may 12th, 2025",536870915]],["^15",[1191,"^11","May 12th, 2025",536870915]],["^15",[1191,"^B",1772635620186,536870915]],["^15",[1191,"^;","~u69a845e4-c5c3-4897-b79e-4bd2d1712183",536870915]],["^15",[1192,"^K",1772635620186,536870915]],["^15",[1192,"^@",false,536870915]],["^15",[1192,"^Y","personality psychology/accentuation",536870915]],["^15",[1192,"^A",150,536870915]],["^15",[1192,"^11","personality psychology/accentuation",536870915]],["^15",[1192,"^B",1772635620186,536870915]],["^15",[1192,"^;","~u69a845e5-ffce-4d4b-a137-9fe094eae88c",536870917]],["^15",[1193,"^K",1772635620187,536870915]],["^15",[1193,"^@",false,536870915]],["^15",[1193,"^Y","affect display",536870915]],["^15",[1193,"^11","affect display",536870915]],["^15",[1193,"^B",1772635620187,536870915]],["^15",[1193,"^;","~u69a845e4-b717-4a5d-a40a-ab453373f626",536870915]],["^15",[1194,"^K",1772635620188,536870915]],["^15",[1194,"^[",3215,536870918]],["^15",[1194,"^@",false,536870915]],["^15",[1194,"^Y","sign language",536870915]],["^15",[1194,"^11","sign language",536870915]],["^15",[1194,"^B",1772635620188,536870915]],["^15",[1194,"^;","~u69a845ea-dc84-4411-b56a-d27f30948caa",536870918]],["^15",[1195,"^K",1772635620188,536870915]],["^15",[1195,"^@",false,536870915]],["^15",[1195,"^Y","personality psychology/self-deception/riya",536870915]],["^15",[1195,"^A",1196,536870915]],["^15",[1195,"^11","personality psychology/self-deception/riya",536870915]],["^15",[1195,"^B",1772635620188,536870915]],["^15",[1195,"^;","~u69a845ea-5235-4e99-bf40-8aab288805d1",536870918]],["^15",[1196,"^K",1772635620409,536870915]],["^15",[1196,"^@",false,536870915]],["^15",[1196,"^Y","personality psychology/self-dec