fd5-a4ed-f0708e8fe573",536870918]],["^15",[3367,"^Q","Counter treadmill. Spear and shield race.",536870918]],["^15",[3367,"^O","^17",536870918]],["^15",[3367,"^F",3471,536870918]],["^15",[3367,"^X",3364,536870918]],["^15",[3367,"^V",3405,536870918]],["^15",[3367,"^U",3364,536870918]],["^15",[3367,"^;","~u69a845ea-f002-4277-b0fc-a5ff6c49809e",536870918]],["^15",[3368,"^Q","Народы моря",536870918]],["^15",[3368,"^O","^17",536870918]],["^15",[3368,"^F",3483,536870918]],["^15",[3368,"^X",3364,536870918]],["^15",[3368,"^V",3448,536870918]],["^15",[3368,"^U",3364,536870918]],["^15",[3368,"^;","~u69a845ea-ea17-465e-9b38-390fcc8185fd",536870918]],["^15",[3369,"^Q","Районы, названные в честь героев, которые были бы по разные стороны, если бы жили сейчас.",536870918]],["^15",[3369,"^O","^17",536870918]],["^15",[3369,"^F",3469,536870918]],["^15",[3369,"^X",3364,536870918]],["^15",[3369,"^V",3443,536870918]],["^15",[3369,"^U",3364,536870918]],["^15",[3369,"^;","~u69a845ea-fe85-41e3-a209-896cc9218bb0",536870918]],["^15",[3370,"^Q","Лишь потоптанные сапогами смогут подняться над гражданскими. Если я не следующий за командующим по рангу, то я ничтожество, прошедшее через унижение зазря.",536870918]],["^15",[3370,"^O","^17",536870918]],["^15",[3370,"^F",3442,536870918]],["^15",[3370,"^X",3364,536870918]],["^15",[3370,"^V",3404,536870918]],["^15",[3370,"^U",3364,536870918]],["^15",[3370,"^;","~u69a845ea-a96b-41a7-8396-6d278864c82e",536870918]],["^15",[3371,"^Q","Израиль",536870918]],["^15",[3371,"^O","^17",536870918]],["^15",[3371,"^F",3423,536870918]],["^15",[3371,"^X",3364,536870918]],["^15",[3371,"^V",3437,536870918]],["^15",[3371,"^U",3361,536870918]],["^15",[3371,"^U",3364,536870918]],["^15",[3371,"^;","~u69a845ea-1cc7-4189-a068-c24c7130f934",536870918]],["^15",[3372,"^Q","Ему интересно поле, ей - каждая гора.",536870918]],["^15",[3372,"^O","^17",536870918]],["^15",[3372,"^F",3390,536870918]],["^15",[3372,"^X",3364,536870918]],["^15",[3372,"^V",3390,536870918]],["^15",[3372,"^U