4.984375,\n                                   :x2 418.3125,\n                                   :y2 1062.984375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 429.71875,\n                                   :y1 1034.984375,\n                                   :x2 492.875,\n                                   :y2 1062.984375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 504.28125,\n                                   :y1 1034.984375,\n                                   :x2 573.5625,\n                                   :y2 1062.984375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 584.859375,\n                                   :y1 1034.984375,\n                                   :x2 634.75,\n                                   :y2 1062.984375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 646.0625,\n                                   :y1 1034.984375,\n                                   :x2 730.125,\n                                   :y2 1062.984375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 741.53125,\n                                   :y1 1034.984375,\n                                   :x2 840.890625,\n                                   :y2 1062.984375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 852.296875,\n                                   :y1 1034.984375,\n                                   :x2 891.3232421875,\n                                   :y2 1062.984375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1068.78125,\n                                   :x2 891.494384765625,\n                                   :y2 1096.78125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1102.5625,\n                                   :x2 228.796875,\n                                   :y2 1130.5625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 243.5625,\n                                   :y1 1102.5625,\n                                   :x2 353.546875,\n                                   :y2 1130.5625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 368.3125,\n                                   :y1 1102.5625,\n                                   :x2 451.5625,\n                                   :y2 1130.5625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 466.34375,\n                                   :y1 1102.5625,\n                                   :x2 644.75,\n                                   :y2 1130.5625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 659.53125,\n                                   :y1 1102.5625,\n                                   :x2 775.828125,\n                                   :y2 1130.5625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 790.59375,\n                                   :y1 1102.5625,\n                                   :x2 890.73681640625,\n                                   :y2 1130.5625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1136.234375,\n                                   :x2 891.493408203125,\n                                   :y2 1164.234375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1170.015625,\n                                   :x2 891.047607421875,\n                                   :y2 1198.015625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 1330,\n                                   :x2 1020,\n                                   :y2 2650,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}),\n                          :page 315},\n               :content {:text \"A non-lexicalized category is born when a striking episode is encoded and committed to memory (such as Danny at the Grand Canyon). Then, as we have seen, this buried episode will automatically drift up to the surface if and when one encounters another situation whose freshly-minted encoding overlaps suﬃciently with the long-ago encoding of the ﬁrst episode. Although such idiosyncratic categories are deprived of lexical\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"670c2dd1-487c-4aff-a1b9-5c7f1bf4b6bb\",\n               :page 316,\n               :position {:bounding {:x1 128.3125,\n                                     :y1 123.78125,\n                                     :x2 891.42919921875,\n                                     :y2 253.03125,\n                                     :width 1019.9999999999999,\n                                     :height 1319.9999999999998},\n                          :rects ({:x1 128.3125,\n                                   :y1 123.78125,\n                                   :x2 891.0966796875,\n                                   :y2 151.78125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 157.578125,\n                                   :x2 890.997314453125,\n                                   :y2 185.578125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 191.234375,\n                                   :x2 891.42919921875,\n                                   :y2 219.234375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 225.03125,\n                                   :x2 613.94580078125,\n                                   :y2 253.03125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}),\n                          :page 316},\n               :content {:text \"labels and are grounded in unique, private experiences, they are no less solidly anchored in our memory than the thousands of public, lexicalized categories are. For each of us, they constitute our personal secret garden of categories.\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"670c2e21-7605-40d8-94a5-c8f957d355c6\",\n               :page 316,\n               :position {:bounding {:x1 128.3125,\n                                     :y1 848.734375,\n                                     :x2 891.913330078125,\n                                     :y2 1146.796875,\n                                     :width 1019.9999999999999,\n                                     :height 1319.9999999999998},\n                          :rects ({:x1 165.84375,\n                                   :y1 848.734375,\n                                   :x2 229.40625,\n                                   :y2 876.734375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 241.9375,\n                                   :y1 848.734375,\n                                   :x2 365.671875,\n                                   :y2 876.734375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 378.3125,\n                                   :y1 848.734375,\n                                   :x2 430.046875,\n                                   :y2 876.734375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 442.671875,\n                                   :y1 848.734375,\n                                   :x2 552.4375,\n                                   :y2 876.734375,\n                                   :width 1019.9999999999999,\n          