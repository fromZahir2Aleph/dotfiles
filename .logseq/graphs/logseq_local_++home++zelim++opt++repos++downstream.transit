^15",[2265,"^4",["^ ","^1>","64b9bd7a-92b2-4e98-9aa3-fe085f42caea"],536870917]],["^15",[2265,"^;","~u64b9bd7a-92b2-4e98-9aa3-fe085f42caea",536870917]],["^15",[2266,"^Q","Несколько раз на Дилосе провели очищение.",536870917]],["^15",[2266,"^O","^17",536870917]],["^15",[2266,"^F",2190,536870917]],["^15",[2266,"^X",2161,536870917]],["^15",[2266,"^V",2188,536870917]],["^15",[2266,"^U",2161,536870917]],["^15",[2266,"^;","~u69a845e6-859e-4c56-bf62-abb2c6411e4e",536870917]],["^15",[2267,"^Q","Братьям [Эпиметею](((655011bf-7aae-4201-abaa-518f4486a711))) (Апослею) и [Прометею](((655011bf-202c-4765-a16c-404b43766587))) (Предвидею) было поручено создание людей и животных. Эпиметей раздал всем по орудию к выживанию: корни, клыки и т.д., а про человека по глупости забыл. Прометей, пожалев людей, своровал у Афины и Гефеста инструменты и огонь, без которых они бесполезны. За это наказали и Прометея, приковав к горе на Кавказе, и человечество, подослав к нему [первую женщину](((654bc199-217e-45ee-963f-fed1e320e9c7))).",536870917]],["^15",[2267,"^O","^17",536870917]],["^15",[2267,"^F",2309,536870917]],["^15",[2267,"^X",2161,536870917]],["^15",[2267,"^V",2309,536870917]],["^15",[2267,"^U",2161,536870917]],["^15",[2267,"^H",2201,536870917]],["^15",[2267,"^H",2211,536870917]],["^15",[2267,"^H",2237,536870917]],["^15",[2267,"^;","~u69a845e6-aae2-4fbb-baf1-fb79ef2fb3f1",536870917]],["^15",[2268,"^Q","После того как Гера из ревности мужа Зевса к Лето запретила земной тверди предоставить ей место для родов, та скиталась, пока плавучий остров Дилос не приютил её. Не привязанный к матушке Гее, он не был под запретом. Как только Лето опустилась на его поверхность, он остановился на месте, дал кров её двойняшкам Аполлону и Артемиде и возложил на себя ношу религиозных, административных и геометрических обязанностей. И долго затем грустил по океанам и грезил о неизведанных морях.",536870917]],["^15",[2268,"^O","^17",536870917]],["^15",[2268,"^F",2188,536870917]],["^15",[2268,"^X",2161,536870917]],["^15",[2268,"^V",2188,536870917]],["^15",[2268,"^U",2161,536870917]],["^15",[2268,"^;","~u69a845e6-f39b-4bc5-b42c-1b877ad76eb4",536870917]],["^15",[2269,"^Q","Трезубец [Посейдона](((64af1cf7-5636-4536-917f-cb44f27037a8)))",536870917]],["^15",[2269,"^O","^17",536870917]],["^15",[2269,"^F",2171,536870917]],["^15",[2269,"^X",2161,536870917]],["^15",[2269,"^V",2310,536870917]],["^15",[2269,"^U",2161,536870917]],["^15",[2269,"^H",2312,536870917]],["^15",[2269,"^;","~u69a845e6-1dc5-4186-979b-aa5698e8b3bc",536870917]],["^15",[2270,"^Q","...в себе",536870917]],["^15",[2270,"^O","^17",536870917]],["^15",[2270,"^F",2213,536870917]],["^15",[2270,"^X",2161,536870917]],["^15",[2270,"^V",2328,536870917]],["^15",[2270,"^U",2161,536870917]],["^15",[2270,"^;","~u69a845e6-a7f0-4c0a-951a-ab4b79b57cef",536870917]],["^15",[2271,"^Q","Истмийские в честь [Посейдона](((64af1cf7-5636-4536-917f-cb44f27037a8)))",536870917]],["^15",[2271,"^O","^17",536870917]],["^15",[2271,"^F",2185,536870917]],["^15",[2271,"^X",2161,536870917]],["^15",[2271,"^V",2296,536870917]],["^15",[2271,"^U",2161,536870917]],["^15",[2271,"^H",2312,536870917]],["^15",[2271,"^;","~u69a845e6-549e-4b3f-898d-c467c545b50f",536870917]],["^15",[2272,"^Q","...значило на Олимпе установить в творение бэкдор.",536870917]],["^15",[2272,"^O","^17",536870917]],["^15",[2272,"^F",2313,536870917]],["^15",[2272,"^X",2161,536870917]],["^15",[2272,"^V",2313,536870917]],["^15",[2272,"^U",2159,536870917]],["^15",[2272,"^U",2161,536870917]],["^15",[2272,"^;","~u69a845e6-5f4c-444b-9679-e685e3f253d4",536870917]],["^15",[2273,"^Q","Ἔρεβος\nid:: 647e4372-af4a-4dd5-9a43-d40a6db63932\n.tags::\n.being:: god\n.mythology:: Greece\n.transcription:: /é.re.bos/\n.translation:: Эреб\n.flags:: primordial, personification",536870917]],["^15",[2273,"^O","^17",536870917]],["^15",[2273,"^F",2240,536870917]],["^15",[2273,"^X",2161,536870917]],["^15",[2273,"^V",2244,536870917]],["^15",[2273,"^U",2157,536870917]],["^15",[2273,"^U",2158,536870917]],["^15",[2273,"