4,"^Z","journals/2025_10_02.md",536870915]],["^15",[475,"^K",1772635619472,536870915]],["^15",[475,"^[",474,536870915]],["^15",[475,"^N",20251002,536870915]],["^15",[475,"^@",true,536870915]],["^15",[475,"^Y","oct 2nd, 2025",536870915]],["^15",[475,"^11","Oct 2nd, 2025",536870915]],["^15",[475,"^B",1772635619472,536870915]],["^15",[475,"^;","~u69a845e3-d0f4-48ff-b0eb-b103d4d2cd04",536870915]],["^15",[476,"^Q","",536870915]],["^15",[476,"^O","^17",536870915]],["^15",[476,"^F",475,536870915]],["^15",[476,"^X",475,536870915]],["^15",[476,"^V",475,536870915]],["^15",[476,"^U",475,536870915]],["^15",[476,"^;","~u69a845e3-1d64-443b-9a86-8ce4105f46b3",536870915]],["^15",[477,"^Q","",536870915]],["^15",[477,"^O","^17",536870915]],["^15",[477,"^F",476,536870915]],["^15",[477,"^X",475,536870915]],["^15",[477,"^V",475,536870915]],["^15",[477,"^U",475,536870915]],["^15",[477,"^;","~u69a845e3-eb3d-4bbe-b664-c10985f44d31",536870915]],["^15",[478,"^Q","",536870915]],["^15",[478,"^O","^17",536870915]],["^15",[478,"^F",477,536870915]],["^15",[478,"^X",475,536870915]],["^15",[478,"^V",475,536870915]],["^15",[478,"^U",475,536870915]],["^15",[478,"^;","~u69a845e3-c0ff-4ab4-af62-3880b66da3c1",536870915]],["^15",[479,"^Q","",536870915]],["^15",[479,"^O","^17",536870915]],["^15",[479,"^F",478,536870915]],["^15",[479,"^X",475,536870915]],["^15",[479,"^V",475,536870915]],["^15",[479,"^U",475,536870915]],["^15",[479,"^;","~u69a845e3-d1df-4ee5-8ea4-be1a7b3477ab",536870915]],["^15",[480,"^3","tags:: OCD, escapism\n\n- Что общего в следующих историях?\n\t- Студентом я ковырял в носу настолько усердно, что у меня порвался сосуд. Не обратился к врачу, и само зажило.\n\t- Студетом я вытерпел зубную боль в двух зубах, настаивая, что это болят десны. Когда же наконец обратился к врачу, оказалось, что оба нерва сгнили. Удалили оба зуба.\n\t- Намучался с анальной трещиной. Остановилось, когда перестал следовать позывам в туалет.\n- Ответ: обсессиво-компульсивный эскапизм.\n- #insomnia Связана ли моя бессоница с этим?\n\t- #[[personality psychology/anxiety]] Каждый день я ежесекундно нахожусь в тревоге?",536870915]],["^15",[480,"^16",1772635619493,536870915]],["^15",[480,"^Z","journals/2025_10_01.md",536870915]],["^15",[481,"^K",1772635619492,536870915]],["^15",[481,"^[",480,536870915]],["^15",[481,"^N",20251001,536870915]],["^15",[481,"^@",true,536870915]],["^15",[481,"^Y","oct 1st, 2025",536870915]],["^15",[481,"^11","Oct 1st, 2025",536870915]],["^15",[481,"^?",["^ ","^19",["^1:",["OCD","escapism"]]],536870915]],["^15",[481,"^4",["^ ","^19","OCD, escapism"],536870915]],["^15",[481,"^P",147,536870915]],["^15",[481,"^P",170,536870915]],["^15",[481,"^B",1772635619492,536870915]],["^15",[481,"^;","~u69a845e3-1615-4936-a6bc-c5502f7c0727",536870915]],["^15",[482,"^Q","tags:: OCD, escapism\n\n",536870915]],["^15",[482,"^O","^17",536870915]],["^15",[482,"^1=",["^1:",[]],536870915]],["^15",[482,"^F",481,536870915]],["^15",[482,"^X",481,536870915]],["^15",[482,"^V",481,536870915]],["^15",[482,"^U",147,536870915]],["^15",[482,"^U",170,536870915]],["^15",[482,"^U",481,536870915]],["^15",[482,"^:",true,536870915]],["^15",[482,"^?",["^ ","^19",["^1:",["OCD","escapism"]]],536870915]],["^15",[482,"^J",["^19"],536870915]],["^15",[482,"^4",["^ ","^19","OCD, escapism"],536870915]],["^15",[482,"^H",147,536870915]],["^15",[482,"^H",170,536870915]],["^15",[482,"^;","~u69a845e3-b44d-4d24-8323-d3a6c8fe066f",536870915]],["^15",[483,"^Q","Что общего в следующих историях?",536870915]],["^15",[483,"^O","^17",536870915]],["^15",[483,"^F",482,536870915]],["^15",[483,"^X",481,536870915]],["^15",[483,"^V",481,536870915]],["^15",[483,"^U",481,536870915]],["^15",[483,"^;","~u69a845e3-572d-410e-862f-25d0ebd1bc5e",536870915]],["^15",[484,"^Q","Студентом я ковырял в носу настолько усердно, что у меня порвался сосуд. Не обратился к врачу, и само зажило.",536870915]],["^15",[484,"^O","^17",536870915]],["^15",[484,"^F",483,536870915]],["^15",[484,"^X",481,536870915]],["^15",[484,"^V",483,536870915]],["^15",[484,"^U",481,536870915]],["^15",[484,"^;","~u69a845e3-d91f-4bf1-943a-e8c554346f98",536870915]],["^15",[485,"^Q","Студетом я вытерпел зубную боль в двух зубах, настаивая, что это болят десны. Когда же наконец обратился к врачу, оказалось, что оба нерва сгнили. Удалили оба зуба.",536870915]],["^15",[485,"^O","^17",536870915]],["^15",[485,"^F",484,536870915]],["^15",[485,"^X",481,536870915]],["^15",[485,"^V",483,536870915]],["^15",[485,"^U",481,536870915]],["^15",[485,"^;","~u69a845e3-8243-42ae-87be-1b3337d056e5",536870915]],["^15",[486,"^Q","Намучался с анальной трещиной. Остановилось, когда перестал следовать позывам в туалет.",536870915]],["^15",[486,"^O","^17",536870915]],["^15",[486,"^F",485,536870915]],["^15",[486,"^X",481,536870915]],["^15",[486,"^V",483,536870915]],["^15",[486,"^U",481,536870915]],["^15",[486,"^;","~u69a845e3-d7e3-4650-8697-7a537ab9679f",536870915]],["^15",[487,"^Q","Ответ: обсессиво-компульсивный эскапизм.",536870915]],["^15",[487,"^O","^17",536870915]],["^15",[487,"^F",483,536870915]],["^15",[487,"^X",481,536870915]],["^15",[487,"^V",481,536870915]],["^15",[487,"^U",481,536870915]],["^15",[487,"^;","~u69a845e3-d569-465d-bbe6-965a36f45c4b",536870915]],["^15",[488,"^Q","#insomnia Связана ли моя бессоница с этим?",536870915]],["^15",[488,"^O","^17",536870915]],["^15",[488,"^F",487,536870915]],["^15",[488,"^X",481,536870915]],["^15",[488,"^V",481,536870915]],["^15",[488,"^U",146,536870915]],["^15",[488,"^U",481,536870915]],["^15",[488,"^H",146,536870915]],["^15",[488,"^;","~u69a845e3-da9c-4b71-a7d1-e4a43579b4c5",536870915]],["^15",[489,"^Q","#[[personality psychology/anxiety]] Каждый день я ежесекундно нахожусь в тревоге?",536870915]],["^15",[489,"^O","^17",536870915]],["^15",[489,"^F",488,536870915]],["^15",[489,"^X",481,536870915]],["^15",[489,"^V",488,536870915]],["^15",[489,"^U",146,536870915]],["^15",[489,"^U",148,536870915]],["^15",[489,"^U",150,536870915]],["^15",[489,"^U",481,536870915]],["^15",[489,"^H",148,536870915]],["^15",[489,"^H",150,536870915]],["^15",[489,"^;","~u69a845e3-b3f7-4646-8654-54aadfd04f7f",536870915]],["^15",[490,"^3","- #her Ей будет как миниму за 30. В этом возрасте они знают, чего хотят от жизни. И не детей уж точно. То, что для тебя оргазм, для них беременность и роды. Затем у тебя счастливые моменты с ребенком, у них ежечасная опека, даже если они пришли с работы",536870915]],["^15",[490,"^16",1772635619506,536870915]],["^15",[490,"^Z","journals/2025_09_30.md",536870915]],["^15",[491,"^K",1772635619506,536870915]],["^15",[491,"^[",490,536870915]],["^15",[491,"^N",20250930,536870915]],["^15",[491,"^@",true,536870915]],["^15",[491,"^Y","sep 30th, 2025",536870915]],["^15",[491,"^11","Sep 30th, 2025",536870915]],["^15",[491,"^B",1772635619506,536870915]],["^15",[491,"^;","~u69a845e3-7f1f-4416-913f-11263550977f",536870915]],["^15",[492,"^Q","#her Ей будет как миниму за 30. В этом возрасте они знают, чего хотят от жизни. И не детей уж точно. То, что для тебя оргазм, для них беременность и роды. Затем у тебя счастливые моменты с ребенком, у них ежечасная опека, даже если они пришли с работы",536870915]],["^15",[492,"^O","^17",536870915]],["^15",[492,"^F",491,536870915]],["^15",[492,"^X",491,536870915]],["^15",[492,"^V",491,536870915]],["^15",[492,"^U",247,536870915]],["^15",[492,"^U",491,536870915]],["^15",[492,"^H",247,536870915]],["^15",[492,"^;","~u69a845e3-1d27-48fd-b598-5705365aadd7",536870915]],["^15",[493,"^3","- [[chariot allegory]] [[personality psychology/virtue]]\n\t- Мне ближе аллегория колесничего из платоновского диалога Федр, чем аристотелевская этика. В ней человек должен стать лучше, воспитывая в себе добродетель и прилагая ее к жизни. Я же должен держать в уздах  свои пороки с помощью сознательности, заученных поведений или фармацевтики.\n\t- Я прочитал кучу книг, чтобы стать лучше: самопомощь, пикап, буддизм. В пикаперском сообществе я увидел, что в разговоре есть грамматика, и я хотел научаться общаться. В конце концов помогла мне фармацевтика: антипсихотики, нормотимики и антидепрессанты. Моей заслуги в этом нет никакой.",536874122]],["^15",[493,"^16",1772635619522,536870915]],["^15",[493,"^18","~m1774107461185",536874121]],["^15",[493,"^Z","journals/2025_09_29.md",536870915]],["^15",[494,"^K",1772635619521,536870915]],["^15",[494,"^[",493,536870915]],["^15",[494,"^N",20250929,536870915]],["^15",[494,"^@",true,536870915]],["^15",[494,"^Y","sep 29th, 2025",536870915]],["^15",[494,"^11","Sep 29th, 2025",536870915]],["^15",[494,"^B",1774107460527,536874120]],["^15",[494,"^;","~u69a845e3-00f1-4448-b401-6586de5de3b5",536870915]],["^15",[496,"^K",1772635619521,536870915]],["^15",[496,"^@",false,536870915]],["^15",[496,"^Y","chariot allegory",536870915]],["^15",[496,"^11","chariot allegory",536870915]],["^15",[496,"^B",1772635619521,536870915]],["^15",[496,"^;","~u69a845e3-386a-4323-b5fb-b0b416588896",536870915]],["^15",[497,"^Q","[[chariot allegory]] [[personality psychology/virtue]]",536873654]],["^15",[497,"^O","^17",536870915]],["^15",[497,"^F",494,536870915]],["^15",[497,"^X",494,536870915]],["^15",[497,"^V",494,536870915]],["^15",[497,"^U",150,536873479]],["^15",[497,"^U",494,536873479]],["^15",[497,"^U",496,536873479]],["^15",[497,"^U",3983,536873479]],["^15",[497,"^?",["^ "],536873654]],["^15",[497,"^H",150,536873654]],["^15",[497,"^H",496,536873654]],["^15",[497,"^H",3983,536873654]],["^15",[497,"^;","~u69a845e3-dd65-45c7-a66d-ce898d204d5c",536870915]],["^15",[498,"^3","- [[writing/reference]] Используй как референс отрывки хорошей прозы. Особенно из рассказов, так как слог образца должен быть емким. По сути, это референс только с виду, так как ты заимствоваешь форму для своего содержания.",536870915]],["^15",[498,"^16",1772635619533,536870915]],["^15",[498,"^Z","journals/2025_09_13.md",536870915]],["^15",[499,"^K",1772635619533,536870915]],["^15",[499,"^[",498,536870915]],["^15",[499,"^N",20250913,536870915]],["^15",[499,"^@",true,536870915]],["^15",[499,"^Y","sep 13th, 2025",536870915]],["^15",[499,"^11","Sep 13th, 2025",536870915]],["^15",[499,"^B",1772635619533,536870915]],["^15",[499,"^;","~u69a845e3-46f2-45b1-b15b-9a757f66e6ed",536870915]],["^15",[500,"^K",1772635619532,536870915]],["^15",[500,"^@",false,536870915]],["^15",[500,"^Y","writing/reference",536870915]],["^15",[500,"^A",197,536870915]],["^15",[500,"^11","writing/reference",536870915]],["^15",[500,"^B",1772635619532,536870915]],["^15",[500,"^;","~u69a845e3-f500-4b7c-ad6b-2d0b3e43499a",536870915]],["^15",[501,"^Q","[[writing/reference]] Используй как референс отрывки хорошей прозы. Особенно из рассказов, так как слог образца должен быть емким. По сути, это референс только с виду, так как ты заимствоваешь форму для своего содержания.",536870915]],["^15",[501,"^O","^17",536870915]],["^15",[501,"^F",499,536870915]],["^15",[501,"^X",499,536870915]],["^15",[501,"^V",499,536870915]],["^15",[501,"^U",197,536870915]],["^15",[501,"^U",499,536870915]],["^15",[501,"^U",500,536870915]],["^15",[501,"^H",197,536870915]],["^15",[501,"^H",500,536870915]],["^15",[501,"^;","~u69a845e3-4306-407a-9f66-bc9f578def65",536870915]],["^15",[502,"^3","tags:: writing/syntax\n\n- #+BEGIN_QUOTE\n  Goethe, in his conversations with Eckermann, is reputed to have said that “if any man would write in a noble style let him ﬁrst possess a noble soul.” Wonderful, but not much help. It may be, though some wise men have denied it, that virtue can be taught, but it seems unlikely that it can be taught in Freshman Composition. Nor sincerity. Nor spontaneity. Nor true grit. What can be taught is words. And they must be taught in the full matrix of human utterance, written and spoken, accompanied by a theory of style equally broad. A student bright enough to be taught style needs a context for it beyond didactic precept, an intelligible and sound context. Style cannot be taught only by lists of self-contradicting proverbs, strings of dos and don’ts. Students so instructed are not being taught; they are being housebroken. I recommend, in what follows, a particular strategy for a particular time and place. Prose style cannot be taught, as it has been, in—and as—a vacuum. It will simply end up, as has been happening with increasing frequency (vacuums being hard to teach), not being taught at all. It cannot be taught as a duty, for you cannot teach as duty what society does not feel a duty. Style must be taught for and as what it is—a pleasure, a grace, a joy, a delight. Pleasure will not, it is true, teach the dumb to speak, the stupid to write, or the bad to practice goodness. But neither will anything else.\n  #+END_QUOTE\n  Lanham, R. A. (2018). *Style: An anti-textbook*.\n- Стилистические приёмы всегда могут быть перевёрнуты, чтобы обмануть ожидания читателя.\n- Реторическая грамматика. Kolln, M. J., & Gray, L. S. (n.d.). *Rhetorical Grammar: Grammatical Choices, Rhetorical Effects*.\n\t- Короткие элементарные предложения: подлежащее, составное сказуемое (глагол и комплемент) и возможный сирконстант (адвербальное или номинативное приложение),\n\t  collapsed:: true\n\t\t- где глагол - ...\n\t\t\t- Связующий\n\t\t\t\t- Копула\n\t\t\t- Непереходный\n\t\t\t- Переходный с прямым дополнением и возможным косвенным дополнением или сирконстантом дополнения\n\t\t- Первые три глагола обычно используются для описания или ёмкого обозначения, а последний - часто для действия или описания перемены.\n\t\t- Копула,\n\t\t\t- где лексическая часть составного сказуемого, в данном случае только комплемент, - ...\n\t\t\t\t- Вид метонимии\n\t\t\t\t\t- Напр., синекдоха\n\t\t\t\t- Метафора, где комплемент - ...\n\t\t\t\t\t- Существительное\n\t\t\t\t\t- Прилагательное\n\t\t\t\t\t- Наречие или наречная группа\n\t\t\t\t\t- Предложная группа\n\t\t- В случае копулы и связующего глагола лексическое ударение падает на комплемент.\n\t\t- В плане стиля короткое предложение, одно или более, может...\n\t\t\t- обращать на себя внимание\n\t\t\t- задать тему или тон для последующего, например, абзаца\n\t\t\t- менять тему или тон посередине, действуя как ось вращения\n\t\t\t- ставить точку в конце абзаца\n\t\t\t- быть частью ритма или драмы в контрасте с более длинными предложениями\n\t\t- Рядом с развёрнутым определением короткое простое предложение - ядро целого сложного.\n\t- Сложное предложение\n\t\t- Сочинение\n\t\t  collapsed:: true\n\t\t\t- В простом предложении\n\t\t\t\t- Однородных членов\n\t\t\t\t\t- Градация\n\t\t\t\t\t\t- По насыщенности\n\t\t\t\t\t\t- По длине\n\t\t- Подчинение\n\t\t  collapsed:: true\n\t\t\t- Придаточное предложение\n\t\t\t\t- относительные\n\t\t\t\t\t- существительного\n\t\t\t\t\t- главного предложения\n\t\t\t\t\t\t- Присоединяются с помощью союзных слов: *что, куда, откуда, где, когда, как, почему*. Дополняют и поясняют содержание основной части. Нередко обладают значением следствия.\n\t\t\t\t- изъяснительные\n\t\t\t\t\t- относятся к глаголу\n\t\t\t\t- обстоятельственные\n\t\t\t\t\t- времени и места\n\t\t\t\t\t- причины, следствия, условия, уступки, цели\n\t\t\t\t\t- образа действия, меры, степени, сравнения\n\t\t\t- Если глаголы непараллельны в аспекте, переходности или наличии связки, используй подчинение для их разбивки. Выбери, какой глагол поставить на передний план, т.е. главное предложение, а какой на задний, т.е. придаточное.\n\t- Связность или когезия\n\t  collapsed:: true\n\t\t- Лексическая когезия\n\t\t\t- Повторение\n\t\t\t\t- Параллелизм, т.е. структурное повторение фраз и клауз\n\t\t\t\t\t- Антитеза\n\t\t\t- Синонимы\n\t\t- Новая и известная информация\n\t\t\t- Оба рода упоминаются как подлежащие в соответствующих предложениях\n\t\t\t- Если известная информация - в предикате, нужна инверсия\n\t\t\t\t- То есть помести новую информацию в предикат предложения, а известную - в подлежащее\n\t\t\t\t- Или преврати изестное в сирконстант\n\t\t\t\t- Можно использовать пассивный залог, но осторожно\n\t\t\t- Тематическое предложение появляется в начале параграфа и раскрывается далее\n\t\t\t- Местоимения указывают на известную информацию или в случае притяжательных согласовываются с ней\n\t- Ритм\n\t  collapsed:: true\n\t\t- Из-за свободного порядка слов русский язык не имеет ограничений как английский.\n\t\t- Ударение в предложении падает на новую информацию, которая согласно когезии находится в конце предложения, а именно в качестве последнего или предпоследнего слова.\n\t\t\t- В английском языке речь идёт о предикате, но в русском это может быть и подлежащее. Также в русском перестановкой фраз можно сменить ударение.\n\t\t- Приоритет ударения на последнем слове может быть заменён запятой перед вводным словом, которая создаёт паузу\n\t\t- Отягощённые слова притягивают ударение и замедляют чтение\n\t\t\t- Превосходные прилагательные. Избегай их.\n\t\t\t- Наречия + прилагательные. Тоже исключи.\n\t\t\t- Именная группа. Можно, если найдёшь удачные слова.\n\t\t\t- Соотносительные союзы смещают внимание на подлежащее\n\t\t\t- Подчёркивающие наречия\n\t\t\t- Наречие только. Можно иногда.\n\t- Форма и функция\n\t  collapsed:: true\n\t\t- Форма\n\t\t  collapsed:: true\n\t\t\t- Слово\n\t\t\t\t- Существительное\n\t\t\t\t- Глагол\n\t\t\t\t- Прилагательное\n\t\t\t\t- Наречие\n\t\t\t- Фраза\n\t\t\t\t- Именная группа\n\t\t\t\t- Глагольная группа\n\t\t\t\t- Предложная группа\n\t\t\t- Клауза\n\t\t\t\t- Независимая (предложение)\n\t\t\t\t- Зависимая\n\t\t- Функция описания\n\t\t\t- Лучше, чем школьная разбивка на определения, обстоятельтва и дополнения\n\t\t\t- Виды морификаций каждой из функций\n\t\t\t\t- Адвербальные\n\t\t\t\t\t- Несогласованное определение глагола\n\t\t\t\t- Адъективные\n\t\t\t\t\t- Комплемент подлежащего\n\t\t\t\t\t- Комплемент дополнения\n\t\t\t\t\t- Определение существительного\n\t\t\t\t- Номинативные\n\t\t\t\t\t- Комплемент подлежащего\n\t\t\t\t\t  id:: 67bc2925-7f2f-4d8f-83e8-ec24789d0a63\n\t\t\t\t\t- Прямое дополнение\n\t\t\t\t\t- Косвенное дополнение\n\t\t\t\t\t- Комплемент дополнения\n\t\t\t\t\t  id:: 67bc29ba-5de7-4922-ab0a-fd309cdb01a2\n\t\t\t\t\t- Дополнение предлога\n\t\t\t\t\t- Приложение\n\t\t\t- Адвербальные\n\t\t\t\t- Вершина - глагольная группа.\n\t\t\t\t- Самая гибкая функция в плане расположения в предложении\n\t\t\t\t\t- Начинание предложения с него помогает...\n\t\t\t\t\t\t- задать тему\n\t\t\t\t\t\t- улучшить когезию...\n\t\t\t\t\t\t\t- связав предложение с предыдущей информацией\n\t\t\t\t\t\t\t- поместив указатели места и времени\n\t\t\t\t- Адвербальная группа\n\t\t\t\t\t- Наречие\n\t\t\t\t\t\t- Наречие образа действия\n\t\t\t\t\t\t\t- Если поместить зависимое наречие после вершины, то на него придётся больше ударения\n\t\t\t\t\t\t\t- Если поместить в начале, то наречие модифицирует всё предложение\n\t\t\t\t\t- Глагольная группа\n\t\t\t\t\t\t- Деепричастие\n\t\t\t\t- Предложная группа\n\t\t\t\t\t- При использовании нужно избегать...\n\t\t\t\t\t  id:: 67bc5281-4144-4f94-8d5d-38e427f770b0\n\t\t\t\t\t\t- ...смещения фокуса. Например, предложная фраза в конце обратит внимание на себя.\n\t\t\t\t\t\t- ...повторения известной информации. В предложной фразе легко дублировать информацию.\n\t\t\t\t- Именная группа...\n\t\t\t\t\t- часто схожа с предложной фразой без предлога\n\t\t\t\t- Группа с комплементатором (придаточное предложение или инфинитив сразу после глагола)\n\t\t\t\t\t- Подчинительный союз показывает, как обстоятельственное придаточное предложение соотносится с главным\n\t\t\t\t\t- Главная или новая может быть как в главном предложении, так и в придаточном\n\t\t\t\t\t- Оно может появляться не только в конце или начале предложения, но и в середине после вершины. В этом случае ударение падает на неё.\n\t\t\t\t\t- Если не передаётся новая информация, придаточное предложение может начинаться в отдельном предложении после точки\n\t\t\t- Адъективные\n\t\t\t\t- Вершина - именная группа\n\t\t\t\t- Детерминативная группа\n\t\t\t\t\t- тж. Именная группа...\n\t\t\t\t\t\t- ...после вершины, напр. [DP [NP чашка [DP чая]]]\n\t\t\t\t- Предложная группа\n\t\t\t\t\t- {{embed ((67bc5281-4144-4f94-8d5d-38e427f770b0))}}\n\t\t\t\t- Прилагательная группа\n\t\t\t\t\t- Прилагательное\n\t\t\t\t\t- Причастие\n\t\t\t\t\t  collapsed:: true\n\t\t\t\t\t\t- Оно передаёт содержание в более ёмком виде. Его можно развернуть в главное или придаточное предложение.\n\t\t\t\t\t\t\t- Однако в русском языке выполняет больше функцию, чем адвербиальную. Для последней используют деепричастие.\n\t\t\t\t\t\t- В начале или конце причастие - свободный модификатор.\n\t\t\t\t\t\t\t- В конце предложения причастный оборот даёт больше свободы развернуться используя больше слов или новых вложенных модификаторов.\n\t\t\t\t\t- Относительное придаточное предложение\n\t\t\t\t\t\t- Как и причастие оно позволяет заключить подлежащее и сказуемое в одну именную группу. В отличие от него такое предложение не так подвижно и начинается почти всегда сразу после существительного.\n\t\t\t- Номинативные\n\t\t\t\t- Именная группа\n\t\t\t\t\t- Причастие\n\t\t\t\t\t- Вершина - именная группа\n\t\t\t\t\t\t- Приложения\n\t\t\t\t\t\t  collapsed:: true\n\t\t\t\t\t\t\t- ...могут быть развёрнутыми\n\t\t\t\t\t\t\t- ...помимо существительного могут быть другой частью речи\n\t\t\t\t\t\t\t- Типы\n\t\t\t\t\t\t\t\t- Ограничивающее (указание)\n\t\t\t\t\t\t\t\t- Неограничивающее (примечание)\n\t\t\t\t- Инфинитивная группа\n\t\t\t\t\t- Вершина - именная или глагольная группа\n\t\t\t\t- Содержательное придаточное предложение\n\t\t\t\t\t- может быть подлежащим, комплементом сказуемого или приложением\n\t\t\t\t\t- Утвердительное\n\t\t\t\t\t- Вопросительное\n- Паттерны. Longknife, A., & Sullivan, K. D. (2002). *The art of styling sentences : 20 patterns for success*.\n  collapsed:: true\n\t- Сложное предложение\n\t\t- 1\n\t\t\t- S V ; (,) S V.\n\t\t\t- Сочетает несколько мыслей для возможности параллели.\n\t\t\t- Варианты\n\t\t\t  collapsed:: true\n\t\t\t\t- 1a\n\t\t\t\t\t- S V ; соединительное наречие S V.\n\t\t\t\t- 1b\n\t\t\t\t\t- S V ; союз S V.\n\t\t\t\t- 1c\n\t\t\t\t\t- S V ; S V; S V.\n\t\t- 2\n\t\t\t- S V DO (прямое дополнение) или SC (комплемент субъекта); S - (эллипсис) DO или SC.\n\t\t- 3 Общее утверждение : пояснение.\n\t- Предложение с рядом\n\t\t- 4\n\t\t\t- A, B, C.\n\t\t\t- Варианты\n\t\t\t\t- A и B и C.\n\t\t\t\t- A или B или C.\n\t\t- 5\n\t\t\t- A и (или, но) B, C и D, E и F.\n\t\t\t\t- Создаётся ритм. Чтобы прочувствовать его, читай предложение вслух.\n\t\t- 6\n\t\t\t- *Ряд приложений* - *обобщающее слово* (иногда S, иногда определение S) V.\n\t\t\t\t- Определения - те, которые; те, что.\n\t\t\t\t- Используй паттерны 4, 4a, 5 для построения серии приложений.\n\t\t- 7\n\t\t\t- S, *ряд приложений или определений*, V.\n\t\t\t\t- Паттерн 6 наоборот\n\t\t\t- Варианты\n\t\t\t  collapsed:: true\n\t\t\t\t- 7а\n\t\t\t\t\t- S, одно или два приложения с возможными определениями, V.\n\t\t- 8 *Ряд придаточных предложений*, S V. или S V, *ряд придаточных предложений*.\n\t- Повторение...\n\t\t- подчеркивает важные идеи или делает предложения более связными.\n\t\t- может передаваться через разные части речи и лексемы, если слова, отражённые в них, однокоренные.\n\t\t- 9\n\t\t\t- Повторение ключевого слова в разных позициях.\n\t\t- 9a\n\t\t\t- Повторение ключевого слова в одной позиции.\n\t\t- 10\n\t\t\t- Приложение в конце предложения после тире.\n\t\t\t\t- S V *слово*: *приложение с возможными определениями*.\n\t- Определение...\n\t\t- может быть одним словом, парой слов или фразой.\n\t\t- 11\n\t\t\t- Прерывающее определение между S и V\n\t\t\t\t- S, *определение*, V.\n\t\t\t\t- Вариант\n\t\t\t\t\t- 11a\n\t\t\t\t\t\t- Целое предложение (утверждение, вопрос или восклицание) как прерывающее определение.\n\t\t\t\t\t\t\t- S - *предложение* - V.\n\t\t- 12\n\t\t\t- Вводные или заключающие причастия\n\t\t\t\t- Такие причастия свободны.\n\t\t\t\t- *Причастный оборот*, S V.\n\t\t\t\t  S V, *причастный оборот*.\n\t- Инверсия...\n\t\t- может применяться к словам, фразам или придаточным предложениям.\n\t\t- не должна быть слишком частой, чтобы выглядеть уместной и естественной. Слишком большое разнообразие может оказаться хуже его полного отсутствия.\n\t\t- Читай предложения с инверсией вслух, чтобы уловить уместна ли она или нет.\n\t\t- 14\n\t\t\t- Предложная фраза перед S и V\n\t\t\t\t- *Предложная фраза* S V.\n\t\t\t\t- *Предложная фраза* V S.\n\t\t- 15\n\t\t\t- Объект или комплемент перед S и V\n\t\t\t\t- *Объект* или *комплемент* S V.\n\t\t\t- Вариант\n\t\t\t\t- 15a\n\t\t\t\t\t- Полная инверсия обычного паттерна\n\t\t\t\t\t- V S.\n\t\t\t\t\t- *Объект* или *комлемент* или *определение* V S.\n\t- Набор паттернов\n\t\t- 16\n\t\t\t- Парные конструкции...\n\t\t\t\t- используют корлелятивные союзы, слова, фразы и клаузы.\n\t\t\t\t- *Первый коррелят* S V, *второй коррелят* S V.\n\t\t\t- Вариант\n\t\t\t\t- 16a\n\t\t\t\t\t- Парные конструкции только для контраста\n\t\t\t\t\t- *Первое слово или фраза внутри предложения*, а не *второе слово или фаза*.\n\t\t- 17\n\t\t\t- Сложноподчинённое предложение как субъект, объект или комплемент...\n\t\t\t\t- начинаются со слов *кто, который, что, почему, где, когда, как*\n\t\t\t\t- S [сложноподчинённое предложение как субъект] V.\n\t\t\t\t- S V [сложноподчинённое предложение как объект или комплемент].\n\t\t- 18\n\t\t\t- Абсолютная конструкция...\n\t\t\t\t- не используется в русском языке\n\t\t- 19\n\t\t\t- Краткое простое предложение для разрядки или драматического эффекта...\n\t\t\t\t- будет эффективным только, если оно...\n\t\t\t\t\t- используется после нескольких долгих предложений.\n\t\t\t\t\t- суммирует сказанное.\n\t\t\t\t\t- предоставляет переход между одной ил более мыслями.\n\t\t- 19a\n\t\t\t- Краткий вопрос для драматического эффекта...\n\t\t\t\t- эффективен...\n\t\t\t\t\t- во введении, чтобы заинтересовать читателя.\n\t\t\t\t\t- как тематическое предложение в качестве введения параграфа.\n\t\t\t\t\t- внутри параграф для разнообразия.\n\t\t\t\t\t- как переход между параграфами.\n\t\t\t\t\t- в конце, как наводящее на мысли заключение.\n\t\t- 20\n\t\t\t- Метакомментарий...\n\t\t\t\t- нужо обычно избегать. Но иногда он к месту, если использовать умело.\n\t- Комбинации паттернов\n\t\t- 3, 4, 9a\n\t\t- 9, 11\n\t\t- 17, 10, 5\n\t\t- 4, 9, 9a, 15a\n\t\t- 1, 4, 4a, 9\n\t\t- 6, 8, 9, 19a\n\t\t- 1, 14, 15a\n\t\t- 4, 11, 9a, 16, 17\n\t\t- 11, 11a\n\t\t- 1, 4a, 9a, 20\n- Построение предложений. Landon, B. (2013). *Building great sentences: How to Write the Kinds of Sentences You Love to Read*.\n  collapsed:: true\n\t- Предложение, а не слово, словосочетание или параграф, - атом прозы.\n\t\t- Простое предложение - ядро длинного.\n\t\t\t- В свою очередь предложение состоит не только из слов и фраз, но из высказываний. Они логический срез предложения.\n\t\t- Более длинное предложение не всегда лучше. Но предложение, в котором больше полезной иформации, почти всегда лучше.\n\t- 1 Последовательность слов\n\t\t- Выбор слов - парадигматичный выбор, а их порядка - синтагматичный.\n\t\t\t- Парадигматичный\n\t\t\t\t- Лестница абстракции\n\t\t\t- Синтагматичный\n\t\t\t\t- Форма есть содержимое.\n\t- 2 Грамматика и реторика\n\t\t- Эффективность определяется тем, насколько хорошо писатель согласует выражаемые пропозиции с обстоятельствами ситуации, своими целями, а также требованиями и ожиданиями читателя.\n\t\t- Выразительность показывает, как успешно автор отражает эмоциональное измерение: себя, атмосферу, настроение и т.д.\n\t\t- Грамматика учит нас, как оперировать мёртвую птицу, а реторика - как воспринимать полёт живой. Реторика имеет дело с причинами, по которым мы пользуемся словами, чтобы достигнуть определённых целей, и степенью успешности их достижения. Согласно Ланему реторика - это \"наука структур человеческого внимания\".\n\t\t\t- \"Меня интересует намного, намного больше реторика.\"\n\t\t\t- Одной лишь гремметики не достаточно для эффективного пись\n\t\t\t- Стиль - то, что писатель пишет и читатель читает. Автору не следует предполагать, что читатель замечает и читает то же, что и он сам.\n\t- 3 Первоначальность высказываний\n\t\t- Элементарной единицей предложения являются не слова или фраза, а высказывание.\n\t\t- Высказывание - это элементарное высказывание, которое не имеет составляющих высказываний.\n\t\t- Предложение не всегда имеет лишь тот смысл, который можно извлечь из высказываний на поверхности. Его главным содержанием может быть то, на что они намекают.\n\t\t\t- Плотность пропозиций указывает на то, насколько они содержательны.\n\t- 4 Как строятся предложения\n\t\t- Простое предложение - ядро длинного.\n\t\t- Предикативный стиль использует мало деталей.\n\t\t\t- Он показывает, что герой видит, но не то, о чём он размышляет.\n\t\t- Виды развёртывания предложения\n\t\t\t- Сложное предложение\n\t\t\t\t- 1 Сочинение\n\t\t\t\t- 2 Подчинение\n\t\t\t- 3 Определение\n\t\t\t\t- Самый используемый в этой книге метод\n\t- 5 Собирательный синтаксис\n\t\t- Cumulative syntax\n\t\t- #+BEGIN_QUOTE\n\t\t  Ритм хорошей современной прозы исходит примерно поровну из одновременного прослеживания сочинительных конструкций и уточнения и возврата к вершинам свободных определений.\n\t\t  #+END_QUOTE\n\t\t  Фрэнсис Кристенсен\n\t\t- Существительное, глагол и главное предложение содержит информацию, известную читателю. Если он этого не знает, то это не твой читатель.\n\t\t\t- Читатель обнаруживает суть в определениях.\n\t\t- 4 принципа Кристенсена\n\t\t\t- 1 добавление\n\t\t\t- 2 направление определения\n\t\t\t\t- В предложениях ответвляющихся в левую сторону определение направлено вперёд, а в правую - назад.\n\t\t\t- 3 уточнение\n\t\t\t\t- После главного предложения движение вперёд останавливается. Дальше писатель идёт вниз по лестнице абстракции или к единичным концепциям, оглядываясь назад.\n\t\t\t- 4 плотность информации\n\t\t- Ритм собирательного предложения\n\t\t\t- Три параметра\n\t\t\t\t- число определений\n\t\t\t\t- длина определения\n\t\t\t\t- его глубина\n\t\t\t\t\t- парадигматический аспект\n\t\t\t\t- направление ответвления\n\t\t\t\t\t- синтагматический аспект\n\t\t\t\t\t\t- в правую сторону\n\t\t\t\t\t\t- в левую сторону\n\t\t\t\t\t\t- посередине\n\t\t\t- Несколько собирательных предложений образуют связки, с помощью которых в свою очередь строится больший ритм отливов и приливов.\n\t- 6 Сочинительные, подчинённые и смешанные собирательные паттерны\n\t\t- Собирательное предложение генеративно, так как каждое определение побуждает к написанию более подробного нового.\n\t\t- Причастие - это глагол в виде прилагательного.\n\t\t- Профессиональные писатели заканчивают предложения два из трёх раз.\n\t\t- Парадигматические паттерны собирательных предложений\n\t\t\t- Сочинительное\n\t\t\t\t- больше одного определения второго уровня\n\t\t\t\t\t- больше\n\t\t\t\t\t\t- новой информации\n\t\t\t\t\t\t- целей для определения\n\t\t\t\t\t\t- возможости для добавления определений\n\t\t\t\t- преимущества\n\t\t\t\t\t- очень ритмично\n\t\t\t\t\t- \"motion without movement\"\n\t\t\t\t\t\t- полирует ту же информацию без движения вперёд, но создавая впечатление движения\n\t\t\t- Подчинительное\n\t\t\t\t- следующее определение глубже предыдущего и ссылается на него\n\t\t\t\t\t- уточняет\n\t\t\t\t\t- может разбить целое на части как это в некоторых случаях делает запятая\n\t\t\t\t\t- подталкивает к новым мыслям\n\t\t\t\t\t- но может отвлечь на незначимые детали\n\t\t\t\t\t- но чем дальше определение от главого предложения, тем труднее предложение цельное писать и читать\n\t\t\t\t- преимущества\n\t\t\t\t\t- помогает двигаться в новые территории\n\t\t\t\t\t\t- особено эффективно, когда описывается\n\t\t\t\t\t\t\t- процесс\n\t\t\t\t\t\t\t- происходящее во времени\n\t\t\t- Смешанное\n\t\t\t\t- совмещает качества и преимущества сочинительного и подчинительного собирательных предложений\n\t- 7 Поправки собирательного предложения\n\t\t- Чтение вслух помогает выявить ошибки.\n\t\t- Чтобы предложение стало собирательным, нужно как минимум два определения.\n\t\t- Каждое новое определение даёт возможность добавить ещё одно собирательное или подчинительное определение.\n\t\t- Последним определением можно заключить итог предложения.\n\t\t- Повторение в сочинительных собирательных часто приветсвуется, в подчинительных и смешанных - наоборот.\n\t- 8 Побуждение к сопоставлению и предположению\n\t\t- Сравнение как...\n\t\t\t- сопоставление\n\t\t\t- предложение\n\t\t- Сравнение зачастую эффективно в конце собирательного предложения.\n\t\t- Сравнения как сопоставления...\n\t\t\t- отражают мышление автора на инстинктивном уровне.\n\t\t\t\t- Через них авторы дают прочувствовать читателю личность сочинителя.\n\t\t\t\t\t- #+BEGIN_QUOTE\n\t\t\t\t\t  Помни, что значит быть собой. В этом весь смысл.\n\t\t\t\t\t  #+END_QUOTE\n\t\t\t\t\t  Джоан Дидион\n\t\t\t- хоть и по форме не определения выполняют похожую функцию, помогая создавать ритм и добавлять новую информацию.\n\t\t- Сравнения как предположения...\n\t\t\t- тоже помогают открыть себя автору, только делают это более явно.\n\t\t\t- устанавливают особую связь между автором и читателем, потому что они предполагают вместе.\n\t- 9 Загадка ритма прозы\n\t\t- Читай вслух.\n\t\t- У каждого языка свой ритм.\n\t\t- Ритм  создаёт разнообразие...\n\t\t  id:: 68656f8e-0b7d-4bd0-bbef-4afea47a2bcf\n\t\t\t- длины предложений\n\t\t\t- длины групп внутри предложения\n\t\t\t\t- В данном случает полезно собирательное предложение.\n\t\t\t\t\t- Приведена аналогия с Морзе, где короткая группа - точка, а более длинная - тире.\n\t\t- Чувство ритма субъективно. Писатель должен его культивировать.\n\t- 10 Отлагательный синтаксис: ритм задержки\n\t\t- Suspensive syntax\n\t\t- Понятия \"накопительный\" и \"отлагательный\" не являются взаимоисключающими.\n\t\t- 3 паттерна\n\t\t\t- 1 обратный накопительный\n\t\t\t\t- ..., S V.\n\t\t\t- 2\n\t\t\t\t- S, ..., V.\n\t\t\t\t- 2.1 Именно в русском, редко в английском.\n\t\t\t\t\t- V, ..., S.\n\t\t\t\t- Трудно контролировать\n\t\t\t- 3\n\t\t\t\t- Если (хотя, когда, потому что и т.д.), S V.\n\t\t- В русском языке гораздо легче строить отлагательные предложения.\n\t- 11 Степени откладывания, значение неожиданности\n\t\t- Цели\n\t\t\t- подчёркивание значения\n\t\t\t\t- паттерн\n\t\t\t\t\t- нарастающий, ведущий к чему-то важному\n\t\t\t- создание неожиданности\n\t\t\t\t- паттерн\n\t\t\t\t\t- внезапный поворотный момент\n\t\t- Может быть в виде нескольких предложений, чаще всего в двух.\n\t\t- Фатические выражения могут использоваться в отлагательных предложениях.\n\t- 12 Сбалансированные предложения и сбалансированные формы\n\t  id:: 686825ec-ad7e-488c-9340-0984b58a03f1\n\t\t- Ценность параллелизма - больше в самих предложенях, чем в том, на что они указывают. Здесь уместно сравнение со смыслом поэзии.\n\t\t- Виды параллелизма\n\t\t\t- Баланс - это бинарный параллелизм\n\t\t\t- Ряд из трёх\n\t\t\t- Ряд из четырёх и более\n\t\t- Паттерны\n\t\t\t- Повторение параллельных слов\n\t\t\t- Их вариация, но с той же частью речи и похожим смыслом\n\t\t\t- Если (хотя, когда, потому что и т.д.), если (...), S V.\n\t\t\t  id:: 686bd481-6b8f-41a8-8de4-1ac6a1ae4521\n\t\t- Преимущества параллелизма\n\t\t\t- Порядок, если в предложении три и более фразы\n\t\t\t- Привлечение внимания\n\t\t\t- Ритм\n\t\t- Дополнительные преимущества баланса\n\t\t\t- Отражение\n\t\t\t\t- Симметрия\n\t\t\t- Дуализм\n\t\t\t- Гармония\n\t\t\t- Противопоставление\n\t\t- Недостаток баланса\n\t\t\t- #+BEGIN_QUOTE\n\t\t\t  The words are not fitted to the things, but the things to the words.\n\t\t\t  #+END_QUOTE The words are not fitted to the things, but the things to the words.\n\t\t\t  William Hazlitt\n\t- 13 Ритм трёх\n\t  id:: 686be35a-d2e6-46f7-ad49-19606fe3c613\n\t\t- Можно комбинировать с балансом.\n\t\t- Баланс создаёт гармонию или противоставляет.\n\t\t- Ряд трех создает логическую завершенность.\n\t\t- Паттерны с опущением или повторением союза, клаузы, членов предложения, группы\n\t\t\t- **Basic Patterns for Three-Part Serials** in 'The Rhythm of Threes' in Landon, B. (2013). *Building great sentences: How to Write the Kinds of Sentences You Love to Read*.\n\t- 14 Длинные предложения и искусные предложения\n\t\t- Длинные искусные предложения отражают не только детали повествования, но и мастерство самого писателя.\n\t\t- Длинные предложения громоздки, если в нем..\n\t\t\t- длинное простое предложение\n\t\t\t- длинная предложная фраза\n\t\t\t- много относительных придаточных предложений\n\t\t\t- много связанных, а не свободных определений\n\t\t- Длинные искусные предложения\n\t\t\t- редки даже у максималистов\n\t\t\t- зачастую отлагательны\n\t\t\t\t- внимание читателя должно быть вознаграждено\n- Анализ прозы. Lanham, R. A. (2003). *Analyzing prose*.\n\t- Глагольный слог вместо существительного слога\n\t\t- Существительный слог\n\t\t  id:: 687a5d5c-4f73-42f8-aca5-5e9178e87659\n\t\t\t- глагол-связка, тире или статичный глагол + предложная фраза + предложная фраза + ...\n\t\t\t- глагол + качество\n\t\t- #+BEGIN_QUOTE\n\t\t  We often observe this contrast between the absence of nominal inﬂection and the richness of the verbal inﬂection. This is due to the nature of the noun and the verb. The noun indicates an idea of permanent nature: a thing, a person, or a quality; the verb indicates a process. . . . For the very reason that it indicates a permanent notion, the noun has a sole form or at most a principal form from which the others are derived. On the other hand, the verb, which indicates a process, has personal forms and the expression of nuances which vary with languages, but can be numerous. The fact that the forms of the noun and verb obey divergent tendencies thus results from the nature of things.\n\t\t  #+END_QUOTE\n\t\t  A. Meillet, The Comparative Method in Historical Linguistics, p. 114\n\t- Паратаксис и гипотаксис\n\t\t- Это деление касается пропозиций, хоть и соотносится с синтаксисом.\n\t\t- Часто сочетаются в одном предложении.\n\t\t- В паратаксических предложениях синтаксические единицы равны.\n\t\t- Гипотаксис отражает...\n\t\t\t- причинно-следственную связь\n\t\t\t- хронологию\n\t\t\t- сравнение\n\t\t- Подчинительные союзы показывают логику, сочинительные (их повторение или отсутствие) - слог.\n\t\t- За несколькими паратаксическими предложениями часто стоит неумение свести их в одно гипотаксическое.\n\t- Цельный и текущий слоги\n\t\t- Periodic style and running style\n\t\t\t- #+BEGIN_QUOTE\n\t\t\t  Syntax follows sense, either a pattern of association, or of subject, or as here, a chronological sequence. What follows builds upon what went before, modiﬁes it, restates it. A diachronic style, we might call it, one that acknowledges the passage of time. It often creates immediacy and action\n\t\t\t  #+END_QUOTE\n\t\t\t- #+BEGIN_QUOTE\n\t\t\t  The periodic style works diﬀerently. It encloses time into a single, syntactically controllable unit, treats experience synchronically rather than diachronically. Here, arrangement controls, not time. In it, order triumphs; in the running style, order operates. The running style surprises the mind operating; in the periodic style, the mind has ﬁnished its work.\n\t\t\t  #+END_QUOTE\n\t\t\t- #+BEGIN_QUOTE\n\t\t\t  The periodic style, then, may represent pattern, and the running style, process.\n\t\t\t  #+END_QUOTE\n\t\t- Две крайности спектра\n\t\t- Единицей зачастую является несколько предложений.\n\t\t- Цельный слог в отличие от текущего упорядочен.\n\t\t- Качества цельного слога:\n\t\t\t- откладывание\n\t\t\t- параллелизм\n\t\t\t- баланс\n\t\t\t- кульминация\n\t\t\t- продуманность\n\t\t- Качества текущего слога:\n\t\t\t- как будто пишется в реальном времени\n\t\t\t\t- ощущение импровизации: остановки, мысли заново, ревизия сказанного\n\t\t\t- отступления внутри предложений (которые можно заключить в скобки)\n\t- Проза на слух\n\t\t- Два значения:\n\t\t\t- ритм и акцентирование слога\n\t\t\t  logseq.order-list-type:: number\n\t\t\t- голос персонажа или повествователя\n\t\t\t  logseq.order-list-type:: number\n\t\t- #+BEGIN_QUOTE\n\t\t  The rhythm of a passage does not simply exist, as does its imagery: reading has to create it.\n\t\t  #+END_QUOTE\n\t\t- #+BEGIN_QUOTE\n\t\t  Students of meter often refer to the tension between natural word stress and the stress pattern that meter imposes. In prose rhythm an analogous tension waits there for the exploiting. The reader must supply meaning, color it to a degree that poetry seldom permits. Because of this larger freedom, prose is often more fun to read aloud than poetry.\n\t\t  #+END_QUOTE\n\t- Форма предложенияй как содержимое\n\t\t- ... - это поиск знакомого паттерна известного смысла в новом \"удачном\" наборе слов.\n\t\t- ... - это имитация поэзии прозой.\n\t\t- Чтобы избежать поверхностности, нужно следовать от мысли к паттерну, а не наоборот. Выбирай паттерн, который поможет выразить мысль.\n\t\t- ABAB... или ABBA... по форме или смыслу, иногда в разных паттернах\n\t\t- Элементы\n\t\t\t- инверсия и повторение\n\t\t\t- кульминация или обратная кульминация, если A и B больше двух\n\t- Высокий, средний и низкий стиль\n\t\t- Средний может восприниматься как стиль...\n\t\t\t- между высоким и низким\n\t\t\t- нейтральный\n\t- Прозрачый и туманный стиль\n\t\t- Transparent style and opaque style\n\t\t- Смотреть на/сквозь слова\n\t\t\t- Looking at/through words\n\t\t\t- Плоскости\n\t\t\t\t- Переключатель\n\t\t\t\t- Спектр\n\t\t\t\t\t- Большинство читателей не видят двух срезов одновременно. Они либо смотрят сквозь слова на их значение, либо переключаются между at/through.\n\t\t\t- Аллитерация, рифма и другие похожие художественные элементы указывают на смутный стиль за исключением случаев, когда форма и есть содержание. Тогда произведение перемещается из плоскости переключатель в плоскость спектра.\n\t\t\t- Правильное чтение подразумевает быстрое переключение между at/through. Поэтому самосознание обязательно для хорошего читателя.",536870915]],["^15",[502,"^16",1772635619862,536870915]],["^15",[502,"^Z","journals/2025_09_09.md",536870915]],["^15",[503,"^K",1772635619852,536870915]],["^15",[503,"^[",502,536870915]],["^15",[503,"^N",20250909,536870915]],["^15",[503,"^@",true,536870915]],["^15",[503,"^Y","sep 9th, 2025",536870915]],["^15",[503,"^11","Sep 9th, 2025",536870915]],["^15",[503,"^?",["^ ","^19",["^1:",["writing/syntax"]]],536870915]],["^15",[503,"^4",["^ ","^19","writing/syntax"],536870915]],["^15",[503,"^P",504,536870915]],["^15",[503,"^B",1772635619852,536870915]],["^15",[503,"^;","~u69a845e3-3b97-49d7-9d4b-5a65d89ee907",536870915]],["^15",[504,"^K",1772635619851,536870915]],["^15",[504,"^@",false,536870915]],["^15",[504,"^Y","writing/syntax",536870915]],["^15",[504,"^A",197,536870915]],["^15",[504,"^11","writing/syntax",536870915]],["^15",[504,"^B",1772635619851,536870915]],["^15",[504,"^;","~u69a845e3-6121-4ffe-90a3-cfa08bc39604",536870915]],["^15",[505,"^K",1772635619856,536870915]],["^15",[505,"^@",false,536870915]],["^15",[505,"^Y","67bc5281-4144-4f94-8d5d-38e427f770b0",536870915]],["^15",[505,"^11","67bc5281-4144-4f94-8d5d-38e427f770b0",536870915]],["^15",[505,"^B",1772635619856,536870915]],["^15",[505,"^;","~u69a845e3-263d-43a2-af20-e95e4408314f",536870915]],["^15",[506,"^Q","Ритм собирательного предложения",536870915]],["^15",[506,"^O","^17",536870915]],["^15",[506,"^F",906,536870915]],["^15",[506,"^X",503,536870915]],["^15",[506,"^V",774,536870915]],["^15",[506,"^U",503,536870915]],["^15",[506,"^;","~u69a845e3-e5dc-4c39-b905-8133eeec044e",536870915]],["^15",[507,"^Q","Комплемент дополнения\nid:: 67bc29ba-5de7-4922-ab0a-fd309cdb01a2",536870915]],["^15",[507,"^O","^17",536870915]],["^15",[507,"^F",596,536870915]],["^15",[507,"^X",503,536870915]],["^15",[507,"^V",777,536870915]],["^15",[507,"^U",503,536870915]],["^15",[507,"^?",["^ ","^1>","67bc29ba-5de7-4922-ab0a-fd309cdb01a2"],536870915]],["^15",[507,"^J",["^1>"],536870915]],["^15",[507,"^4",["^ ","^1>","67bc29ba-5de7-4922-ab0a-fd309cdb01a2"],536870915]],["^15",[507,"^;","~u67bc29ba-5de7-4922-ab0a-fd309cdb01a2",536870915]],["^15",[508,"^Q","Утвердительное",536870915]],["^15",[508,"^O","^17",536870915]],["^15",[508,"^F",931,536870915]],["^15",[508,"^X",503,536870915]],["^15",[508,"^V",641,536870915]],["^15",[508,"^U",503,536870915]],["^15",[508,"^;","~u69a845e3-0691-45b1-8d77-b6a6812431e3",536870915]],["^15",[509,"^Q","