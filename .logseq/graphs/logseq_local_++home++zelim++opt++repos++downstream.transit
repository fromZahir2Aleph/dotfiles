]],["^15",[483,"^U",436,536870919]],["^15",[483,"^U",473,536870919]],["^15",[483,"^;","~u686ffd64-b4e5-4a7c-b1a3-6e19ee74d6e6",536870919]],["^15",[484,"^Q","Во время",536870919]],["^15",[484,"^O","^1;",536870919]],["^15",[484,"^F",480,536870919]],["^15",[484,"^X",473,536870919]],["^15",[484,"^V",478,536870919]],["^15",[484,"^U",434,536870919]],["^15",[484,"^U",436,536870919]],["^15",[484,"^U",473,536870919]],["^15",[484,"^;","~u686ffd64-00f6-490e-9da1-94ae67554ab6",536870919]],["^15",[485,"^3","tags:: diary, [[roguelike vs metroidvania]] \ntype:: reflection\nmood:: neutral\n\n- #+BEGIN_QUOTE\n  Life is a tragedy when seen in closeup, but a comedy in long-shot.\n  #+END_QUOTE\n  Charlie Chaplin\n\t- Можно поставить вместо трагедии рогалик, а вместо комедии - метроидванию. Чем лучше игрок, тем больше второго.\n\t- В социальном взаимодействии обстоятельста генерируются процедурно.\n\t- Я получил наилучшую и наиредкую реликвию, когда поехал на учёбу в Англию. Нужен был лишь грайнд, чтобы не просрать её.",536870919]],["^15",[485,"^16",1752169828908,536870919]],["^15",[485,"^Z","journals/2025_01_05.md",536870919]],["^15",[486,"^K",1752169828907,536870919]],["^15",[486,"^[",485,536870919]],["^15",[486,"^N",20250105,536870919]],["^15",[486,"^@",true,536870919]],["^15",[486,"^Y","jan 5th, 2025",536870919]],["^15",[486,"^11","Jan 5th, 2025",536870919]],["^15",[486,"^?",["^ ","^18",["^19",["roguelike vs metroidvania","diary"]],"^1=","reflection","^1>","neutral"],536870919]],["^15",[486,"^4",["^ ","^18","diary, [[roguelike vs metroidvania]]","^1=","reflection","^1>","neutral"],536870919]],["^15",[486,"^P",69,536870919]],["^15",[486,"^P",487,536870919]],["^15",[486,"^B",1752169828907,536870919]],["^15",[486,"^;","~u686ffd64-cee8-41d1-b6c4-d27b7f5f2dfb",536870919]],["^15",[487,"^K",1752169828928,536870919]],["^15",[487,"^@",false,536870919]],["^15",[487,"^Y","roguelike vs metroidvania",536870919]],["^15",[487,"^11","roguelike vs metroidvania",536870919]],["^15",[487,"^B",17521698