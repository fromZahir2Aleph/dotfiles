915]],["^15",[227,"^U",205,536870915]],["^15",[227,"^U",225,536870915]],["^15",[227,"^H",205,536870915]],["^15",[227,"^;","~u69a845e2-4e47-4eb0-8f92-fdba6d66ec59",536870915]],["^15",[228,"^3","- [[action/anticipatory commitment/planfulness/next action]] Думай в сценариях действий. Так думает большинство.\n\t- Куда вел старый? Или куда ведет новый?\n\t- #[[mind wandering/maladaptive daydreaming]] #OCD Куда ведут действие, слово или мысль?\n\t- Не каждое действие должно быть обязанностью. Научись предвкушать такие действия. Получай от них больше удовольствия, чем от речи, размышленний или фантазий.\n\t\t- Например, если ты будешь воспринимать игру на гитаре как отдых, то ты насладишься как преддверием, так и самой игрой.\n\t- Как бы я поступил в такой-то ситуации? Что бы я сделал на его месте?",536879763]],["^15",[228,"^16",1772635618846,536870915]],["^15",[228,"^18","~m1775842160498",536879762]],["^15",[228,"^Z","journals/2026_01_14.md",536870915]],["^15",[229,"^K",1772635618845,536870915]],["^15",[229,"^[",228,536870915]],["^15",[229,"^N",20260114,536870915]],["^15",[229,"^@",true,536870915]],["^15",[229,"^Y","jan 14th, 2026",536870915]],["^15",[229,"^11","Jan 14th, 2026",536870915]],["^15",[229,"^B",1772635618845,536870915]],["^15",[229,"^;","~u69a845e2-3632-416d-8fc9-b6e4e45849cd",536870915]],["^15",[230,"^Q","[[action/anticipatory commitment/planfulness/next action]] Думай в сценариях действий. Так думает большинство.",536870915]],["^15",[230,"^O","^17",536870915]],["^15",[230,"^F",229,536870915]],["^15",[230,"^X",229,536870915]],["^15",[230,"^V",229,536870915]],["^15",[230,"^U",169,536870915]],["^15",[230,"^U",172,536870915]],["^15",[230,"^U",173,536870915]],["^15",[230,"^U",175,536870915]],["^15",[230,"^U",229,536870915]],["^15",[230,"^H",169,536870915]],["^15",[230,"^H",172,536870915]],["^15",[230,"^H",173,536870915]],["^15",[230,"^H",175,536870915]],["^15",[230,"^;","~u69a845e2-fbb2-4800-b935-7840cfe6961d",536870915]],["^15",[231,"^Q","Куда вел старый? Или ку