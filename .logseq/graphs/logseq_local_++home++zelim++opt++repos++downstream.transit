,"^F",96,536870919]],["^15",[102,"^X",85,536870919]],["^15",[102,"^V",99,536870919]],["^15",[102,"^U",34,536870919]],["^15",[102,"^U",85,536870919]],["^15",[102,"^U",86,536870919]],["^15",[102,"^U",87,536870919]],["^15",[102,"^;","~u686ffd64-2ac4-4097-a41f-1d0b023b0a93",536870919]],["^15",[103,"^3","- [[cognitive dialectic]]\n\t- Рассеивай и записывай мысли, наблюдения и умозаключения, потом собирай их в единое. Рассеивать станет сложнее с возрастом по мере того, как ты станешь более ригидным и менее любопытным.\n\t- Я всегда любил строить воздушные замки, но лет пять назад я полюбил разрушать их. Стремясь упорядочить новоприобретённые концепции, ты начинаешь как их адепт. Затем твоё критическое мышление вносит поправки.в разных странах мира",536870934]],["^15",[103,"^16",1752169828499,536870919]],["^15",[103,"^17","~m1752170026576",536870933]],["^15",[103,"^Z","journals/2025_05_08.md",536870919]],["^15",[104,"^K",1752169828498,536870919]],["^15",[104,"^[",103,536870919]],["^15",[104,"^N",20250508,536870919]],["^15",[104,"^@",true,536870919]],["^15",[104,"^Y","may 8th, 2025",536870919]],["^15",[104,"^11","May 8th, 2025",536870919]],["^15",[104,"^B",1752170025953,536870932]],["^15",[104,"^;","~u686ffd64-a523-4bba-8781-cecf3a1bd336",536870919]],["^15",[105,"^K",1752169828540,536870919]],["^15",[105,"^@",false,536870919]],["^15",[105,"^Y","cognitive dialectic",536870919]],["^15",[105,"^11","cognitive dialectic",536870919]],["^15",[105,"^B",1752169828540,536870919]],["^15",[105,"^;","~u686ffd64-a668-434a-b346-8de2d9f55c66",536870919]],["^15",[106,"^Q","[[cognitive dialectic]]",536870919]],["^15",[106,"^O","^1;",536870919]],["^15",[106,"^F",104,536870919]],["^15",[106,"^X",104,536870919]],["^15",[106,"^V",104,536870919]],["^15",[106,"^U",104,536870919]],["^15",[106,"^U",105,536870919]],["^15",[106,"^H",105,536870919]],["^15",[106,"^;","~u686ffd64-7f53-4078-84d0-639d29bb7ba0",536870919]],["^15",[107,"^Q","Рассеивай и записывай мысли, наблюдения и умозаключения, потом собирай их в единое. Рассеивать станет сложнее с возрастом по мере того, как ты станешь более ригидным и менее любопытным.",536870919]],["^15",[107,"^O","^1;",536870919]],["^15",[107,"^F",106,536870919]],["^15",[107,"^X",104,536870919]],["^15",[107,"^V",106,536870919]],["^15",[107,"^U",104,536870919]],["^15",[107,"^U",105,536870919]],["^15",[107,"^;","~u686ffd64-14db-4876-894c-12f065eead4e",536870919]],["^15",[108,"^Q","Я всегда любил строить воздушные замки, но лет пять назад я полюбил разрушать их. Стремясь упорядочить новоприобретённые концепции, ты начинаешь как их адепт. Затем твоё критическое мышление вносит поправки.в разных странах мира",536870932]],["^15",[108,"^O","^1;",536870919]],["^15",[108,"^F",107,536870919]],["^15",[108,"^X",104,536870919]],["^15",[108,"^V",106,536870919]],["^15",[108,"^U",104,536870919]],["^15",[108,"^U",105,536870919]],["^15",[108,"^?",["^ "],536870932]],["^15",[108,"^;","~u686ffd64-7ada-429f-a047-23bf7068d9c5",536870919]],["^15",[110,"^3","- [[letter to Nika]]\n\t- Отрывки\n\t\t- Моя первая учительница, доктор Давал и ты Ника - три человека вне моей семьи, которые сформировали мою личность соответственно образованием, психотерапией и советом.\n\t\t- Запоздалое, несвоевроменное, но искреннее спасибо. Хотел приберечь его и высказаться, когда моя жизнь наладится, чтобы ты записался меня в актив, в список пациентов, которым ты помогла.\n\t\t\t- Может, этого никогда не случится, потому что на данный момент СХУ/постковид неизлечиваем. Но благодаря тебе годы первые годы после Феникса и даже то, как я справляюсь сегодня с болезнью.\n\t\t- Личный портной\n\t\t\t- Задним числом\n\t\t\t\t- Аутентичность, акцентуация\n\t\t\t\t- Отверг превосходсто интеллекта\n\t\t\t\t- Малодушие, токсичность, истероидность\n\t\t\t\t- Культ карго\n\t\t- Я не прохожу мимо, просто присяду на скамейку.",536870919]],["^15",[110,"^16",1752169828511,536870919]],["^15",[110,"^Z","journals/2025_04_28.md",536870919]],["^15",[111,"^K",1752169828510,536870919]],["^15",[111,"^[",110,536870919]],["^15",[111,"^N",20250428,536870919]],["^15",[111,"^@",true,536870919]],["^15",[111,"^Y","apr 28th, 2025",536870919]],["^15",[111,"^11","Apr 28th, 2025",536870919]],["^15",[111,"^B",1752169828510,536870919]],["^15",[111,"^;","~u686ffd64-21f5-4b25-939d-a38e90fcc8eb",536870919]],["^15",[112,"^K",1752169828510,536870919]],["^15",[112,"^@",false,536870919]],["^15",[112,"^Y","letter to nika",536870919]],["^15",[112,"^11","letter to Nika",536870919]],["^15",[112,"^B",1752169828510,536870919]],["^15",[112,"^;","~u686ffd64-f5e1-4ceb-8d2b-0ba4480edff6",536870919]],["^15",[113,"^Q","Я не прохожу мимо, просто присяду на скамейку.",536870919]],["^15",[113,"^O","^1;",536870919]],["^15",[113,"^F",123,536870919]],["^15",[113,"^X",111,536870919]],["^15",[113,"^V",122,536870919]],["^15",[113,"^U",111,536870919]],["^15",[113,"^U",112,536870919]],["^15",[113,"^;","~u686ffd64-965c-4da4-bb73-2061dbc00931",536870919]],["^15",[114,"^Q","Малодушие, токсичность, истероидность",536870919]],["^15",[114,"^O","^1;",536870919]],["^15",[114,"^F",120,536870919]],["^15",[114,"^X",111,536870919]],["^15",[114,"^V",116,536870919]],["^15",[114,"^U",111,536870919]],["^15",[114,"^U",112,536870919]],["^15",[114,"^;","~u686ffd64-50f6-45f2-914b-cf6cc3260599",536870919]],["^15",[115,"^Q","Моя первая учительница, доктор Давал и ты Ника - три человека вне моей семьи, которые сформировали мою личность соответственно образованием, психотерапией и советом.",536870919]],["^15",[115,"^O","^1;",536870919]],["^15",[115,"^F",122,536870919]],["^15",[115,"^X",111,536870919]],["^15",[115,"^V",122,536870919]],["^15",[115,"^U",111,536870919]],["^15",[115,"^U",112,536870919]],["^15",[115,"^;","~u686ffd64-ebf6-4e0d-8d59-daa3a30beb59",536870919]],["^15",[116,"^Q","Задним числом",536870919]],["^15",[116,"^O","^1;",536870919]],["^15",[116,"^F",123,536870919]],["^15",[116,"^X",111,536870919]],["^15",[116,"^V",123,536870919]],["^15",[116,"^U",111,536870919]],["^15",[116,"^U",112,536870919]],["^15",[116,"^;","~