^15",[356,"^Q","недоПсевдосноб",536870915]],["^15",[356,"^O","^17",536870915]],["^15",[356,"^F",355,536870915]],["^15",[356,"^X",350,536870915]],["^15",[356,"^V",352,536870915]],["^15",[356,"^U",350,536870915]],["^15",[356,"^U",351,536870915]],["^15",[356,"^;","~u69a845e3-9a8f-4ae4-8029-9793fa41a180",536870915]],["^15",[357,"^Q","criptoateo",536870915]],["^15",[357,"^O","^17",536870915]],["^15",[357,"^F",356,536870915]],["^15",[357,"^X",350,536870915]],["^15",[357,"^V",352,536870915]],["^15",[357,"^U",350,536870915]],["^15",[357,"^U",351,536870915]],["^15",[357,"^;","~u69a845e3-2b65-401d-a360-46d23212966f",536870915]],["^15",[358,"^3","id:: 6934a046-2b2c-4665-8f06-24ac1438c5ea\n",536870915]],["^15",[358,"^16",1772635619178,536870915]],["^15",[358,"^Z","journals/2025_12_07.md",536870915]],["^15",[359,"^K",1772635619178,536870915]],["^15",[359,"^[",358,536870915]],["^15",[359,"^N",20251207,536870915]],["^15",[359,"^@",true,536870915]],["^15",[359,"^Y","dec 7th, 2025",536870915]],["^15",[359,"^11","Dec 7th, 2025",536870915]],["^15",[359,"^?",["^ ","^1>","6934a046-2b2c-4665-8f06-24ac1438c5ea"],536870915]],["^15",[359,"^4",["^ ","^1>","6934a046-2b2c-4665-8f06-24ac1438c5ea"],536870915]],["^15",[359,"^B",1772635619178,536870915]],["^15",[359,"^;","~u69a845e3-0d55-4bba-9636-8807dbe5356c",536870915]],["^15",[360,"^Q","id:: 6934a046-2b2c-4665-8f06-24ac1438c5ea\n",536870915]],["^15",[360,"^O","^17",536870915]],["^15",[360,"^1=",["^1:",[]],536870915]],["^15",[360,"^F",359,536870915]],["^15",[360,"^X",359,536870915]],["^15",[360,"^V",359,536870915]],["^15",[360,"^U",359,536870915]],["^15",[360,"^:",true,536870915]],["^15",[360,"^?",["^ ","^1>","6934a046-2b2c-4665-8f06-24ac1438c5ea"],536870915]],["^15",[360,"^J",["^1>"],536870915]],["^15",[360,"^4",["^ ","^1>","6934a046-2b2c-4665-8f06-24ac1438c5ea"],536870915]],["^15",[360,"^;","~u6934a046-2b2c-4665-8f06-24ac1438c5ea",536870915]],["^15",[361,"^3","tags:: diary\ntype:: event\nmood:: sad\n\n- Посмотрел Louis Theroux: A Place for pdfs. Всмонил, как я смотрел на свою эрекцию в зеркале на двери шкафа. Ее отражение возбуждало меня еще больше. Потом увидел как девочка на балконе противоположного дома пялится в ступоре то ли на меня, то ли на отражение. Я продолжал лежать и смотреть на девочку. Вскочил, только когда на балкон вышла ее мама. Мне было тогда, наверняка, больше двадцати пяти лет. То есть взрослый парень. Это самый постыдный день в моей жизни.\n\t- Никогда не иди на поводу у похоти. Особен буден осторожен, когда она внезапная в незнакомой обстановке и незнакомым человеком.",536870915]],["^15",[361,"^16",1772635619199,536870915]],["^15",[361,"^Z","journals/2025_11_29.md",536870915]],["^15",[362,"^K",1772635619198,536870915]],["^15",[362,"^[",361,536870915]],["^15",[362,"^N",20251129,536870915]],["^15",[362,"^@",true,536870915]],["^15",[362,"^Y","nov 29th, 2025",536870915]],["^15",[362,"^11","Nov 29th, 2025",536870915]],["^15",[362,"^?",["^ ","^19",["^1:",["diary"]],"^1;","event","^1<","sad"],536870915]],["^15",[362,"^4",["^ ","^19","diary","^1;","event","^1<","sad"],536870915]],["^15",[362,"^P",185,536870915]],["^15",[362,"^B",1772635619198,536870915]],["^15",[362,"^;","~u69a845e3-18a5-48c6-b1b9-93fa75fa6369",536870915]],["^15",[363,"^Q","tags:: diary\ntype:: event\nmood:: sad\n\n",536870915]],["^15",[363,"^O","^17",536870915]],["^15",[363,"^1=",["^1:",[]],536870915]],["^15",[363,"^F",362,536870915]],["^15",[363,"^X",362,536870915]],["^15",[363,"^V",362,536870915]],["^15",[363,"^U",185,536870915]],["^15",[363,"^U",186,536870915]],["^15",[363,"^U",187,536870915]],["^15",[363,"^U",362,536870915]],["^15",[363,"^:",true,536870915]],["^15",[363,"^?",["^ ","^19",["^1:",["diary"]],"^1;","event","^1<","sad"],536870915]],["^15",[363,"^J",["^19","^1;","^1<"],536870915]],["^15",[363,"^4",["^ ","^19","diary","^1;","event","^1<","sad"],536870915]],["^15",[363,"^H",185,536870915]],["^15",[363,"^H",186,536870915]],["^15",[363,"^H",187,536870915]],["^15",[363,"^;","~u69a845e3-cba1-412c-a336-677719c27623",536870915]],["^15",[364,"^Q","Посмотрел Louis Theroux: A Place for pdfs. Всмонил, как я смотрел на свою эрекцию в зеркале на двери шкафа. Ее отражение возбуждало меня еще больше. Потом увидел как девочка на балконе противоположного дома пялится в ступоре то ли на меня, то ли на отражение. Я продолжал лежать и смотреть на девочку. Вскочил, только когда на балкон вышла ее мама. Мне было тогда, наверняка, больше двадцати пяти лет. То есть взрослый парень. Это самый постыдный день в моей жизни.",536870915]],["^15",[364,"^O","^17",536870915]],["^15",[364,"^F",363,536870915]],["^15",[364,"^X",362,536870915]],["^15",[364,"^V",362,536870915]],["^15",[364,"^U",362,536870915]],["^15",[364,"^;","~u69a845e3-4066-4860-bbb1-1a484c0cf3c5",536870915]],["^15",[365,"^Q","Никогда не иди на поводу у похоти. Особен буден осторожен, когда она внезапная в незнакомой обстановке и незнакомым человеком.",536870915]],["^15",[365,"^O","^17",536870915]],["^15",[365,"^F",364,536870915]],["^15",[365,"^X",362,536870915]],["^15",[365,"^V",364,536870915]],["^15",[365,"^U",362,536870915]],["^15",[365,"^;","~u69a845e3-639f-41d1-a9dc-708a197feeae",536870915]],["^15",[366,"^3","- [[communication]] Мои собеседники не обязательно должны быть друзьями. Просто наслаждайся беседой.",536870915]],["^15",[366,"^16",1772635619208,536870915]],["^15",[366,"^Z","journals/2025_11_27.md",536870915]],["^15",[367,"^K",1772635619207,536870915]],["^15",[367,"^[",366,536870915]],["^15",[367,"^N",20251127,536870915]],["^15",[367,"^@",true,536870915]],["^15",[367,"^Y","nov 27th, 2025",536870915]],["^15",[367,"^11","Nov 27th, 2025",536870915]],["^15",[367,"^B",1772635619207,536870915]],["^15",[367,"^;","~u69a845e3-144d-4929-8bb9-b079cb0d381d",536870915]],["^15",[368,"^Q","[[communication]] Мои собеседники не обязательно должны быть друзьями. Просто наслаждайся беседой.",536870915]],["^15",[368,"^O","^17",536870915]],["^15",[368,"^F",367,536870915]],["^15",[368,"^X",367,536870915]],["^15",[368,"^V",367,536870915]],["^15",[368,"^U",327,536870915]],["^15",[368,"^U",367,536870915]],["^15",[368,"^H",327,536870915]],["^15",[368,"^;","~u69a845e3-c7a1-4063-8baa-e17dddcef5b9",536870915]],["^15",[369,"^3","- [[Питер 2025]]\n\t- ~~HBOT или гипербарическая оксигенация~~\n\t\t- Слабые доказательства и может стать хуже\n\t- *Лаборатория сна*\n\t- [[bekhterevka]]\n\t\t- #insomnia #me|cfs\n\t\t\t- Даже не стали разбирать бессонницу. В следующий раз сразу начни с этого.\n\t\t\t- Депривация сна ведет к ПНИ. Излечение бессонницы поможет мне с СХУ.\n\t\t- Информация для бехтеревки\n\t\t\t- Перед поездкой\n\t\t\t\t- Pocketbook highlights\n\t\t\t\t- Ручная кладь\n\t\t\t\t\t- Карандаши и точилка\n\t\t\t\t\t- \"Онегин\"\n\t\t\t\t\t  id:: 696a40eb-9f37-45d8-8f8e-9d64a3c15c6a\n\t\t\t- Симптомы\n\t\t\t\t- Сон\n\t\t\t\t\t- Сплю 10-12 часов\n\t\t\t\t\t- Невосстанавливающий сон\n\t\t\t\t\t- Одновременно сильно возбужден и тянет ко сну\n\t\t\t\t\t- Гиперчувствительность к седативным\n\t\t\t- Лечение\n\t\t\t\t- Нефармацевтическое физическое\n\t\t\t\t\t- Блокада звездчатого ганглия\n\t\t\t\t\t- *Электросудорожая терапия*\n\t\t\t\t\t- Магнитная стимуляция\n\t\t\t\t\t\t- Low frequency\n\t\t\t\t\t- Электростимуляция блуждающего нерва\n\t\t\t\t\t\t- \"In patients with long COVID, VNS is efficacious in reducing inflammatory markers and chronic fatigue.\"\n\t\t\t\t\t\t- Non-invasive lowest intensity possible\n\t\t\t\t\t- Внутривеннoе вливание кетамина\n\t\t\t\t- Психотерапевтическое\n\t\t\t\t\t- Как вернуться к жизни?",536876917]],["^15",[369,"^16",1772635619237,536870915]],["^15",[369,"^18","~m1774451347345",536876916]],["^15",[369,"^Z","journals/2025_11_26.md",536870915]],["^15",[370,"^K",1772635619234,536870915]],["^15",[370,"^[",369,536870915]],["^15",[370,"^N",20251126,536870915]],["^15",[370,"^@",true,536870915]],["^15",[370,"^Y","nov 26th, 2025",536870915]],["^15",[370,"^11","Nov 26th, 2025",536870915]],["^15",[370,"^B",1774451346262,536876915]],["^15",[370,"^;","~u69a845e3-12d5-456f-ab2b-e9cb4b8538ef",536870915]],