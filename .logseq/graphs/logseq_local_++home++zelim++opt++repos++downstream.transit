],["^15",[3344,"^Q","\"Чтобы эта библиотека ожила, достаточно прочитать одну страницу одной рукописи.\"",536870918]],["^15",[3344,"^O","^17",536870918]],["^15",[3344,"^F",3353,536870918]],["^15",[3344,"^X",3339,536870918]],["^15",[3344,"^V",3339,536870918]],["^15",[3344,"^U",3339,536870918]],["^15",[3344,"^;","~u69a845ea-5f37-41bc-982c-23b224c148fb",536870918]],["^15",[3345,"^Q","Музей аваторов Борхеса",536870918]],["^15",[3345,"^O","^17",536870918]],["^15",[3345,"^F",3344,536870918]],["^15",[3345,"^X",3339,536870918]],["^15",[3345,"^V",3339,536870918]],["^15",[3345,"^U",3339,536870918]],["^15",[3345,"^;","~u69a845ea-ade0-4f21-b604-9b8c9d0c12f4",536870918]],["^15",[3346,"^Q","Рассказы о тропах",536870918]],["^15",[3346,"^O","^17",536870918]],["^15",[3346,"^F",3357,536870918]],["^15",[3346,"^X",3339,536870918]],["^15",[3346,"^V",3339,536870918]],["^15",[3346,"^U",3339,536870918]],["^15",[3346,"^;","~u69a845ea-d0f4-4d27-ad72-9dfe3f77f35f",536870918]],["^15",[3347,"^Q","Mr. Swiddler's Flip-Flap",536870918]],["^15",[3347,"^O","^17",536870918]],["^15",[3347,"^F",3356,536870918]],["^15",[3347,"^X",3339,536870918]],["^15",[3347,"^V",3356,536870918]],["^15",[3347,"^U",3339,536870918]],["^15",[3347,"^;","~u69a845ea-734b-4858-b914-75bd4c9f55f0",536870918]],["^15",[3348,"^Q","Paper cuts",536870918]],["^15",[3348,"^O","^17",536870918]],["^15",[3348,"^F",3352,536870918]],["^15",[3348,"^X",3339,536870918]],["^15",[3348,"^V",3352,536870918]],["^15",[3348,"^U",3339,536870918]],["^15",[3348,"^;","~u69a845ea-37d5-4593-b014-4c29db676cca",536870918]],["^15",[3349,"^Q","Эпистолярный рассказ на заметках книги",536870918]],["^15",[3349,"^O","^17",536870918]],["^15",[3349,"^F",3346,536870918]],["^15",[3349,"^X",3339,536870918]],["^15",[3349,"^V",3339,536870918]],["^15",[3349,"^U",3339,536870918]],["^15",[3349,"^;","~u69a845ea-9fef-46f0-a156-022824784678",536870918]],["^15",[3350,"^Q","Breadcrumbs",536870918]],["^15",[3350,"^O","^17",536870918]],["^15",[3350,"^F",3356,536870918]],["^15",[3350,"^X",3339,536870918]],["^15",[3350,"^V",3346,536870918]],["^15",[3350,"^U",3339,536870918]],["^15",[3350,"^;","~u69a845ea-d166-4e98-9943-dea8e152b6ee",536870918]],["^15",[3351,"^Q","[[Са дога-ойла нохчийн маттахь хезара юй те суна]]",536870918]],["^15",[3351,"^O","^17",536870918]],["^15",[3351,"^F",3341,536870918]],["^15",[3351,"^X",3339,536870918]],["^15",[3351,"^V",3339,536870918]],["^15",[3351,"^U",3339,536870918]],["^15",[3351,"^U",3340,536870918]],["^15",[3351,"^H",3340,536870918]],["^15",[3351,"^;","~u69a845ea-5383-4e37-a47f-72b945e32b86",536870918]],["^15",[3352,"^Q","Резаясь бумагой каждой страницы",536870918]],["^15",[3352,"^O","^17",536870918]],["^15",[3352,"^F",3343,536870918]],["^15",[3352,"^X",3339,536870918]],["^15",[3352,"^V",3339,536870918]],["^15",[3352,"^U",3339,536870918]],["^15",[3352,"^;","~u69a845ea-65ea-43f3-9f3e-ace8f4eb5bb3",536870918]],["^15",[3353,"^Q","tags:: workshop\nstatus:: backlog\ntype:: writing\nform:: novel\n\n",536870918]],["^15",[3353,"^O","^17",536870918]],["^15",[3353,"^1=",["^1:",[]],536870918]],["^15",[3353,"^F",3339,536870918]],["^15",[3353,"^X",3339,536870918]],["^15",[3353,"^V",3339,536870918]],["^15",[3353,"^U",186,536870918]],["^15",[3353,"^U",2859,536870918]],["^15",[3353,"^U",2861,536870918]],["^15",[3353,"^U",2863,536870918]],["^15",[3353,"^U",3339,536870918]],["^15",[3353,"^:",true,536870918]],["^15",[3353,"^?",["^ ","^19",["^1:",["workshop"]],"^1A","backlog","^1;","writing","^1B","novel"],536870918]],["^15",[3353,"^J",["^19","^1A","^1;","^1B"],536870918]],["^15",[3353,"^4",["^ ","^19","workshop","^1A","backlog","^1;","writing","^1B","novel"],536870918]],["^15",[3353,"^H",186,536870918]],["^15",[3353,"^H",2859,536870918]],["^15",[3353,"^H",2861,536870918]],["^15",[3353,"^H",2863,536870918]],["^15",[3353,"^;","~u69a845ea-6a4c-4e00-a76e-f444bb3b3f7b",536870918]],["^15",[3354,"^Q","All Along the Watchtower by Bob Dylan\nid:: 68b05b48-9b49-4837-b7e5-155680fc36e3",536870918]],["^15",[3354,"^O","^17",536870918]],["^15",[3354,"^F",3350,536870918]],["^15",[3354,"^X",3339,536870918]],["^15",[3354,"^V",3350,536870918]],["^15",[3354,"^U",3339,536870918]],["^15",[3354,"^?",["^ ","^1>","68b05b48-9b49-4837-b7e5-155680fc36e3"],536870918]],["^15",[3354,"^J",["^1>"],536870918]],["^15",[3354,"^4",["^ ","^1>","68b05b48-9b49-4837-b7e5-155680fc36e3"],536870918]],["^15",[3354,"^;","~u68b05b48-9b49-4837-b7e5-155680fc36e3",536870918]],["^15",[3355,"^Q","офисная обыденность + что-то экзистенциальное или лирическое",536870918]],["^15",[3355,"^O","^17",536870918]],["^15",[3355,"^F",3348,536870918]],["^15",[3355,"^X",3339,536870918]],["^15",[3355,"^V",3352,536870918]],["^15",[3355,"^U",3339,536870918]],["^15",[3355,"^;","~u69a845ea-1034-4109-a2a4-b9b101d2c07c",536870918]],["^15",[3356,"^Q","Твист",536870918]],["^15",[3356,"^O","^17",536870918]],["^15",[3356,"^F",3346,536870918]],["^15",[3356,"^X",3339,536870918]],["^15",[3356,"^V",3346,536870918]],["^15",[3356,"^U",3339,536870918]],["^15",[3356,"^;","~u69a845ea-1bbe-47c8-ae1c-594ecf4219b6",536870918]],["^15",[3357,"^Q","Лего строителя-автора в сравнении с рогаликом и метроидванией читателя.",536870918]],["^15",[3357,"^O","^17",536870918]],["^15",[3357,"^F",3345,536870918]],["^15",[3357,"^X",3339,536870918]],["^15",[3357,"^V",3339,536870918]],["^15",[3357,"^U",3339,536870918]],["^15",[3357,"^;","~u69a845ea-fe5a-41af-ade0-41b56b4b92d7",536870918]],["^15",[3358,"^3","tags:: workshop\nstatus:: backlog\ntype:: writing\nform:: novel\n\n- Мета\n\t- Памяти Наталье Эстемировой, настоящей къонах.\n\t- Книга еще до черновика берет крен в сторону поучительства. Как избежать этого, если она о геополитике? Как превратить все эти предпосылки в прозу?\n\t\t- Межличностные, соседские и междугрупповые отношения\n\t- Параллельное повествование двух героев. Они встречают друг друга на полпути и влюбляются.\n\t\t- Протагонисты: лесной бродяга и геолог. Прототипы - Комаров, Натанзон и Катя Крафт.\n\t\t\t- Ему интересно поле, ей - каждая гора.\n- Потоп гонит людей в горы. Вода спадает - появляются острова. Остров Беной, островок Нихалой, континент, архипелаг Веденой. После спада уровня моря появляется Веденская лига, что меняет баланс сил.\n- Два отлива. Международное законодательство появляется во время между ними.\n\t- Время отлива\n\t\t- Если раньше собирались вокруг гор, то теперь вокруг озер.\n\t- Большое озеро - нейтральная территория до некоторых пор.\n\t\t- Озерный остров как место переговоров\n\t- Во второй отлив наступает мировая война. Дагонахи работали над оружием, пока остальные пытались объединиться вокруг международного законодательства.\n\t\t- Нахи и даги вступают в союз с дагами против Адыгсой Федерации.\n- Есть возможность для моей версии чеченской письменности.\n- Фракции или Стадии\n\t- Люди руды\n\t- Народы моря\n\t- Наездники козлов, славы\n\t\t- Заведомая селекция. Их высокий интеллект требует сильной, электрической, уздечки.\n\t- Пилоты орлов\n\t- Укротители огня (пороха)\n\t- Демоны (носители инфекций)\n\t\t- Смертники в вингсьютах, катапультирующие себя через проливы\n\t- Выделяющийся как негры народ\n\t\t- Встреча Амана\n- Регионы\n\t- Две горы подобно греческому Дилосу создают миф о своей сакральности. Одна - самая высокая и ближе к Господу, другая - в центре, а это в отличие от высоты фактор объединяющий. Первая имеет стратегическое преимущесво в обороне, а вторая - в торговле.\n\t\t- После мегаприлива Киклады превращются в Тауантинсу́йу, страну из четырех частей. Может, пяти.\n\t\t\t- Или Четыре угла как в США\n\t- Биорегион типа Каскадии, антагонисты сокольников и козловсадников.\n\t- Гора-пирамида с серпантином вокруг в виде спирали. У них культ цикла. Напр., перед коронацией нового правителя, они поджигают на самой вершине старого.\n\t\t- Местные думают, что нашествие - это тоже часть цикла. Чтобы искоренить это поверье, серпантин и храм разрушаются.\n\t\t  id:: 686ffd65-42f0-4edb-a394-ab85c7f3fa19\n\t- Уоллесия, Сахул и Сундаланд с приливами и отливами раз в несколько веков.\n\t\t- После мегаприлива горы-острова растаскивают себе Диадохи.\n\t- Нахская империя\n\t\t- Девиз\n\t\t\t- Маци лах\n\t\t- Большая Гора\n\t\t\t- Единственный искуственный и безуловно самый красивый остров, величие которого основано на эксплуатации колонизированных островов, достопримечательности которых перевезены в столицу.\n\t\t- Инверсия собственных имен\n\t\t\t- Великие Атаги\n\t\t\t- Три Болвана\n\t\t- Сказка о титанах\n\t\t\t- На самом деле титаны - они сами.\n\t\t- Районы, названные в честь героев, которые были бы по разные стороны, если бы жили сейчас.\n\t\t\t- Шейх Мансур и Байсангур против Мовлади Висаитова и Ахмада Кадырова\n\t\t- Диктатор\n\t\t\t- С не самодур и самодостаточен. Умеет маскировать импульсы. Позволяет премыскаться только тогда, когда это нужно самим подхалимам.\n\t\t\t- Он хочет оставить память о себе. Он видел, как разрушают памятники. Как стирают имена. Но от присоединенной территории даже последующий за ним оппозиционер не откажется.\n\t- Пограничные Нахской империи районы\n\t  collapsed:: true\n\t\t- [[Диадохи]]\n\t\t- Вять\n\t\t\t- Вятичи\n\t\t- Радимия\n\t\t\t- Радимичи\n\t\t- Древ\n\t\t\t- Древляне\n\t\t- Радинтомей Вятославич сочинил легенду, что родился от вятича и радимки и вырос в Древе. На самом деле он беглый раб нахов, поставивший целью создать Троеславию.\n\t- [[Планета-муравейник]]\n\t\t- Гора-муравейник\n\t\t\t- Муравьиное гнездо\n\t\t\t\t- Палестина\n\t\t\t\t\t- 'uṣsh\n\t\t\t\t\t\t- 'uṣshu an-naml\n\t\t\t\t\t\t\t- عُشّ النَّمْلِ\n\t\t\t\t\t\t\t  id:: 68cae8ea-046b-4c23-a07c-b114dad15aed\n\t\t\t\t- Израиль\n\t\t\t\t\t- ken\n\t\t\t\t\t\t- ken han-nemalim\n\t\t\t\t\t\t\t- קֵן הַנְּמָלִים\n\t\t\t\t- Евреи потеряли гору во время предпоследнего отлива\n\t\t\t- Алия, накба и накса\n- Политика\n\t- [[nation-building]] Хилларг хилла делла. Первый мир успел первым вследствие географических, исторических, даже биологических и других причин. Эксплуатация колонизованных земель создала новые области досуга и открыла к нему доступ большему числу людей. В результате они смогли прийти к демократии и свободе слова. Сегодня они должны быть не западными ценностями, а универсальными. И чтобы их заимствовать, нам не надо платить за них угнетением других.\n\t  id:: 68f06c6b-9356-4a8f-a261-329240c362db\n\t- Интерговертализм с сохранением прав на самоопредение и суверенитет.\n\t\t- Два референдума на присоединие, присоединящего и присоединяемого народов.\n\t- Дружественный фронтир, предупреждающий об агрессорах\n\t- Великое расхождение\n- Война\n\t- Воздух и вода вместо (ядерной) триады.\n\t- Counter treadmill. Spear and shield race.\n\t- Если твоя страна имеет большой капитал и сильную индустрию, то солдаты - это просто наемные убийцы по требованию.\n\t\t- Что выживание для одних, то кайф экстрима для других. Шансы быть убитым недостаточно высоки, чтобы бояться за нее, но достаточно низки, чтобы испытывать тот самый больной кайф.\n\t\t- Их войны - это не более чем пробный опыт.\n\t- Переходная экономика во время мира (до отлива) спонсирует следующий этап - войну. Только в нашем случае нет неопределенности. Все знают, что отлив будет.\n\t- Туман войны\n\t\t- Будет первая мировая война в новом ландшафте, так как научились быстро пересекать местность. Также стали дополнять горы и рыть. Как итог - туман.\n\t\t\t- Появляется суша, а потом подсушье\n\t\t\t\t- Президент одной из сторон взрывает подземную территорию битвы.\n\t\t\t\t\t- \"Он доказал сегодня, что изначально послал нас на смерть себе в угоду. Что для нас важнее: земля, которая достанется его шайке или память по нашим братьям?\"\n\t\t- От него может выиграть как маленький, так и большой. В партизанской войне туман войны приносит больше пользе слабой стороне. Поэтому может быть ей усилена.\n\t\t- Ускорение синдрома Кесслера\n\t- Multi-Domain Operations\n\t\t- Освоение космоса во время следующего прилива открывает новую территорию сражения.\n\t- Из-за Набиуллиной не пал режим, но и народ не голодает.\n\t\t- На Нюрнбергском процессе министра экономики нацистской Германии Ялмара Шахта оправдали.\n\t\t- Последняя брошка\n\t- Солдаты\n\t\t- Навязанный обществом стереотип мужчины делает стезю солдата желательной. Помогает этому и государство. Воевавшие - герои, павшие - вдвойне. День Защистника ~~Отечества~~ Правительства не забываем отмечать. К тому же веселее армии альтернатив для 18-летнего нет. Там управляют тобой 23-летние. Никто из них в этом возрасте неспособен осмыслить, прав он или нет потом в войне. Но он рационализирует сделанный за него выбор. Не для убийства же невиновных проводились учения, не другим в угоду же умирают соратники.\n\t\t- Лишь потоптанные сапогами смогут подняться над гражданскими. Если я не следующий за командующим по рангу, то я ничтожество, прошедшее через унижение зазря.\n\t\t- Профессия солдата всегда была престижна среди мужчин, даже среди дворян. Служившие в армии или войсках не захотят работать на ферме. Хуже всего те, кто превращаю войну в ремесло. Но времена меняются, и правящим нужно найти им применение в менее \"благородном\".\n\t\t- В битве ты не думаешь о политике. Если не убьешь, то будешь убит.\n\t\t- Лишь защита - приемлемая форма насилия. В геополитическом конфликте агрессором обычно выступает большой сосед.\n\t- Не облекай сюжет в постмодернизм. В этот раз на правой стороне славяне, поэтому в этой драке герои - они.\n- RNGesus:\n\t- стихия\n\t\t- засуха\n\t\t- Один из мегаотливов случается преждевременно.\n\t- микробы, изобретения, др.\n\t\t- [[real history]]\n\t\t\t- {{embed ((658db9b5-1d39-4457-a4b4-26ca5f887aad))}}\n\t- личности: генералы, пророки, др.\n- [[real history]]\n\t- Конкистадоры зачистили Чичимеков центральной Мексики так, что от них остались только имена поселений, значение которых никому не известно. От языка туземцев остались лишь эти наборы звуков, и нет даже записей того, чем местные торговали, как приветствовали и прощались, о чём думали. Даже лингвистам нечем полакомиться - ни следа речи, чтобы расставить россыпь местных языков по полочкам.\n\t- Ирокезы и французы - наилучшие враги\n\t  collapsed:: true\n\t\t- У голландцев качественнее товар, у алгонкинов и гуронов - меха. Ирокезы - почти соседи голландцев. Алгонкины же граничат с французами. Если бы ирокезы не получали оружие получше и не совершали набеги на союзников французов, алгонкины и гуроны смогли бы беспрепятсвенно торговать с голландцами, что исключало бы и французов с товарами меньшего качества, и уже более слабых ирокезов.\n\t\t\t- Alan Taylor (2002). Canada and The five nations in Canada and Iroquoia 1500-1660. In *American Colonies: The Settling of North America, Vol. 1*.\n\t- Лесные бродяги - Coureur des bois\n\t- Казаки и Дикое поле. Их объединяла не нация, а образ жизни. Только они потеряли свой истинный дух, когда пошли на служение царю.\n- Tropes\n\t- Morality Kitchen Sink\n\t\t- Гуманитарная интервенция и терроризм\n\t- Shades of Conflict\n\t- A lighter shade of...\n- Приложение\n\t- Прочитай на вики Invasion literature",536872968]],["^15",[3358,"^16",1772635626581,536870918]],["^15",[3358,"^18","~m1773081479553",536872967]],["^15",[3358,"^Z","pages/Отлив.md",536870918]],["^15",[3359,"^K",1772635626580,536870918]],["^15",[3359,"^@",false,536870918]],["^15",[3359,"^Y","658db9b5-1d39-4457-a4b4-26ca5f887aad",536870918]],["^15",[3359,"^11","658db9b5-1d39-4457-a4b4-26ca5f887aad",536870918]],["^15",[3359,"^B",1772635626580,536870918]],["^15",[3359,"^;","~u69a845ea-e36a-4b27-9430-375c7f158e0e",536870918]],["^15",[3360,"^K",1772635626577,536870918]],["^15",[3360,"^@",false,536870918]],["^15",[3360,"^Y","диадохи",536870918]],["^15",[3360,"^11","Диадохи",536870918]],["^15",[3360,"^B",1772635626577,536870918]],["^15",[3360,"^;","~u69a845ea-2a1d-43c3-a53c-5e8db11c8da1",536870918]],["^15",[3361,"^K",1772635626782,536870918]],["^15",[3361,"^[",3747,536870918]],["^15",[3361,"^@",false,536870918]],["^15",[3361,"^Y","планета-муравейник",536870918]],["^15",[3361,"^11","Планета-муравейник",536870918]],["^15",[3361,"^?",["^ ","^19",["^1:",["workshop"]],"^1A","backlog","^1;","writing","^1