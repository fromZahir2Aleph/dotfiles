1089,"^H",1033,536870919]],["^15",[1089,"^H",1036,536870919]],["^15",[1089,"^H",1038,536870919]],["^15",[1089,"^H",1040,536870919]],["^15",[1089,"^H",1041,536870919]],["^15",[1089,"^;","~u655011bf-202c-4765-a16c-404b43766587",536870919]],["^15",[1090,"^Q","Аполлон, которого когда-то принимали за Гелиоса",536870919]],["^15",[1090,"^O","^1;",536870919]],["^15",[1090,"^F",1130,536870919]],["^15",[1090,"^X",1003,536870919]],["^15",[1090,"^V",1130,536870919]],["^15",[1090,"^U",1003,536870919]],["^15",[1090,"^;","~u686ffd65-9b55-47d6-bfec-41d37e3fa213",536870919]],["^15",[1091,"^Q","Переверни сюжет Пигмалиона, где каждый из богов учит её своей фирменной мерзости, чтобы она, собственно, и стала тем ящиком, и с другой стороны и чтобы навсегда подорвать доверие к женщине у мужчин и патриархия царила не только на Олимпе, но и внизу.",536870919]],["^15",[1091,"^O","^1;",536870919]],["^15",[1091,"^F",1182,536870919]],["^15",[1091,"^X",1003,536870919]],["^15",[1091,"^V",1182,536870919]],["^15",[1091,"^U",1003,536870919]],["^15",[1091,"^U",1032,536870919]],["^15",[1091,"^U",1033,536870919]],["^15",[1091,"^U",1034,536870919]],["^15",[1091,"^U",1036,536870919]],["^15",[1091,"^U",1038,536870919]],["^15",[1091,"^U",1040,536870919]],["^15",[1091,"^U",1041,536870919]],["^15",[1091,"^;","~u686ffd65-2fc0-4ed6-8b7d-9830d293a34a",536870919]],["^15",[1092,"^Q","Среди детей Хаоса и первых двух внуков боги - это проекции состояний, богинь, их Действия. Связь между ними не причинно-следственная, а союзная. Ночь и Тьма, День и Свет, Земля и Бездна.\nid:: 64a33c92-8913-4edc-93a2-a61abd1b9b1a",536870919]],["^15",[1092,"^O","^1;",536870919]],["^15",[1092,"^F",1199,536870919]],["^15",[1092,"^X",1003,536870919]],["^15",[1092,"^V",1076,536870919]],["^15",[1092,"^U",1003,536870919]],["^15",[1092,"^U",1035,536870919]],["^15",[1092,"^?",["^ ","^1D","64a33c92-8913-4edc-93a2-a61abd1b9b1a"],536870919]],["^15",[1092,"^J",["^1D"],536870919]],["^15",[1092,"^4",["^ ","^1D","64a33c92-8913-4edc-93a2-a61abd1b9b1a