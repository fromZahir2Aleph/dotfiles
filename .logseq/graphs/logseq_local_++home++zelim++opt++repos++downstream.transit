22cff0bb61",536870919]],["^15",[122,"^Q","Отрывки",536870919]],["^15",[122,"^O","^1;",536870919]],["^15",[122,"^F",118,536870919]],["^15",[122,"^X",111,536870919]],["^15",[122,"^V",118,536870919]],["^15",[122,"^U",111,536870919]],["^15",[122,"^U",112,536870919]],["^15",[122,"^;","~u686ffd64-7c02-47f0-bad1-34950826f848",536870919]],["^15",[123,"^Q","Личный портной",536870919]],["^15",[123,"^O","^1;",536870919]],["^15",[123,"^F",117,536870919]],["^15",[123,"^X",111,536870919]],["^15",[123,"^V",122,536870919]],["^15",[123,"^U",111,536870919]],["^15",[123,"^U",112,536870919]],["^15",[123,"^;","~u686ffd64-0bea-489c-839d-6cfc2126d99b",536870919]],["^15",[124,"^Q","Аутентичность, акцентуация",536870919]],["^15",[124,"^O","^1;",536870919]],["^15",[124,"^F",116,536870919]],["^15",[124,"^X",111,536870919]],["^15",[124,"^V",116,536870919]],["^15",[124,"^U",111,536870919]],["^15",[124,"^U",112,536870919]],["^15",[124,"^;","~u686ffd64-7ff9-4347-9d06-780456b2ebe3",536870919]],["^15",[125,"^3","tags:: diary\ntype:: acknowledgement\nmood:: positive\n\n- В чём-то обстоятельства, в чём-то твои черты личности стёрли твою социальную жизнь. Но ты не будешь жить её с нуля. Это не рестарт, а новый ран, возможно, последний. Если он вообще случится.",536870919]],["^15",[125,"^16",1752169828521,536870919]],["^15",[125,"^Z","journals/2025_04_23.md",536870919]],["^15",[126,"^K",1752169828520,536870919]],["^15",[126,"^[",125,536870919]],["^15",[126,"^N",20250423,536870919]],["^15",[126,"^@",true,536870919]],["^15",[126,"^Y","apr 23rd, 2025",536870919]],["^15",[126,"^11","Apr 23rd, 2025",536870919]],["^15",[126,"^?",["^ ","^18",["^19",["diary"]],"^1=","acknowledgement","^1>","positive"],536870919]],["^15",[126,"^4",["^ ","^18","diary","^1=","acknowledgement","^1>","positive"],536870919]],["^15",[126,"^P",69,536870919]],["^15",[126,"^B",1752169828520,536870919]],["^15",[126,"^;","~u686ffd64-8b97-4dcf-849e-cf95187d5014",536870919]],["^15",[127,"^Q","tags:: diary\ntype:: acknowledgement\nmood:: positive\n\n",536870919]],["^15",[127,"^O","^1;",536870919]],["^15",[127,"^1<",["^19",[]],536870919]],["^15",[127,"^F",126,536870919]],["^15",[127,"^X",126,536870919]],["^15",[127,"^V",126,536870919]],["^15",[127,"^U",69,536870919]],["^15",[127,"^U",70,536870919]],["^15",[127,"^U",71,536870919]],["^15",[127,"^U",126,536870919]],["^15",[127,"^:",true,536870919]],["^15",[127,"^?",["^ ","^18",["^19",["diary"]],"^1=","acknowledgement","^1>","positive"],536870919]],["^15",[127,"^J",["^18","^1=","^1>"],536870919]],["^15",[127,"^4",["^ ","^18","diary","^1=","acknowledgement","^1>","positive"],536870919]],["^15",[127,"^H",69,536870919]],["^15",[127,"^H",70,536870919]],["^15",[127,"^H",71,536870919]],["^15",[127,"^;","~u686ffd64-8c15-435a-ae72-7a510bb3b6f5",536870919]],["^15",[128,"^Q","В чём-то обстоятельства, в чём-то твои черты личности стёрли твою социальную жизнь. Но ты не будешь жить её с нуля. Это не рестарт, а новый ран, возможно, последний. Если он вообще случится.",536870919]],["^15",[128,"^O","^1;",536870919]],["^15",[128,"^F",127,536870919]],["^15",[128,"^X",126,536870919]],["^15",[128,"^V",126,536870919]],["^15",[128,"^U",126,536870919]],["^15",[128,"^;","~u686ffd64-1806-4c9d-b9a5-10403a3eefd1",536870919]],["^15",[129,"^3","tags:: diary\ntype:: reflection\nmood:: neutral\n\n- Социальная тревога не есть интровертизм. Ты тянешься всеми фибрами к компании, но тревога делает общение сложным.",536870919]],["^15",[129,"^16",1752169828534,536870919]],["^15",[129,"^Z","journals/2025_04_20.md",536870919]],["^15",[130,"^K",1752169828534,536870919]],["^15",[130,"^[",129,536870919]],["^15",[130,"^N",20250420,536870919]],["^15",[130,"^@",true,536870919]],["^15",[130,"^Y","apr 20th, 2025",536870919]],["^15",[130,"^11","Apr 20th, 2025",536870919]],["^15",[130,"^?",["^ ","^18",["^19",["diary"]],"^1=","reflection","^1>","neutral"],536870919]],["^15",[130,"^4",["^ ","^18","diary","^1=","reflection","^1>","neutral"],536870919]],["^15",[130,"^P",69,536870919]],["^15",[130,"^B",1752169828534,536870919]],["^15",[130,"^;","~u686ffd64-115a-4e5a-b026-eb6e80003944",536870919]],["^15",[131,"^Q","tags:: diary\ntype:: reflection\nmood:: neutral\n\n",536870919]],["^15",[131,"^O","^1;",536870919]],["^15",[131,"^1<",["^19",[]],536870919]],["^15",[131,"^F",130,536870919]],["^15",[131,"^X",130,536870919]],["^15",[131,"^V",130,536870919]],["^15",[131,"^U",69,536870919]],["^15",[131,"^U",70,536870919]],["^15",[131,"^U",71,536870919]],["^15",[131,"^U",130,536870919]],["^15",[131,"^:",true,536870919]],["^15",[131,"^?",["^ ","^18",["^19",["diary"]],"^1=","reflection","^1>","neutral"],536870919]],["^15",[131,"^J",["^18","^1=","^1>"],536870919]],["^15",[131,"^4",["^ ","^18","diary","^1=","reflection","^1>","neutral"],536870919]],["^15",[131,"^H",69,536870919]],["^15",[131,"^H",70,536870919]],["^15",[131,"^H",71,536870919]],["^15",[131,"^;","~u686ffd64-13ae-4af2-8e18-d90d044d962b",536870919]],["^15",[132,"^Q","Социальная тревога не есть интровертизм. Ты тянешься всеми фибрами к компании, но тревога делает общение сложным.",536870919]],["^15",[132,"^O","^1;",536870919]],["^15",[132,"^F",131,536870919]],["^15",[132,"^X",130,536870919]],["^15",[132,"^V",130,536870919]],["^15",[132,"^U",130,536870919]],["^15",[132,"^;","~u686ffd64-2779-4c4f-afd1-a7bb31ebe5b8",536870919]],["^15",[133,"^3","- [[personality psychology/self-concept]] [[cognitive bias/splitting]] [[cognitive dialectic]] Расщепление эго и когнитивная диалектика размывают твою „я“-концепцию.",536870919]],["^15",[133,"^16",1752169828543,536870919]],["^15",[133,"^Z","journals/2025_04_12.md",536870919]],["^15",[134,"^K",1752169828543,536870919]],["^15",[134,"^[",133,536870919]],["^15",[134,"^N",20250412,536870919]],["^15",[134,"^@",true,536870919]],["^15",[134,"^Y","apr 12th, 2025",536870919]],["^15",[134,"^11","Apr 12th, 2025",536870919]],["^15",[134,"^B",1752169828543,536870919]],["^15",[134,"^;","~u686ffd64-48e7-4e8e-b51e-274844e7697b",536870919]],["^15",[135,"^K",1752169828562,536870919]],["^15",[135,"^@",false,536870919]],["^15",[135,"^Y","cognitive bias/splitting",536870919]],["^15",[135,"^A",137,536870919]],["^15",[135,"^11","cognitive bias/splitting",536870919]],["^15",[135,"^B",1752169828562,536870919]],["^15",[135,"^;","~u686ffd64-cb7f-47eb-9d64-7d295c48665c",536870919]],["^15",[136,"^K",1752169828840,536870919]],["^15",[136,"^@",false,536870919]],["^15",[136,"^Y","personality psychology/self-concept",536870919]],["^15",[136,"^A",34,536870919]],["^15",[136,"^11","personality psychology/self-concept",536870919]],["^15",[136,"^B",1752169828840,536870919]],["^15",[136,"^;","~u686ffd64-b693-4dfe-b80f-f759425aceba",536870919]],["^15",[137,"^K",1752169828562,536870919]],["^15",[137,"^@",false,536870919]],["^15",[137,"^Y","cognitive bias",536870919]],["^15",[137,"^11","cognitive bias",536870919]],["^15",[137,"^B",1752169828562,536870919]],["^15",[137,"^;","~u686ffd64-2bdd-4450-a3c4-efcbd4f08c3b",536870919]],["^15",[138,"^Q","[[personality psychology/self-concept]] [[cognitive bias/splitting]] [[cognitive dialectic]] Расщепление эго и когнитивная диалектика размывают твою „я“-концепцию.",536870919]],["^15",[138,"^O","^1;",536870919]],["^15",[138,"^F",134,536870919]],["^15",[138,"^X",134,536870919]],["^15",[138,"^V",134,536870919]],["^15",[138,"^U",34,536870919]],["^15",[138,"^U",105,536870919]],["^15",[138,"^U",134,536870919]],["^15",[138,"^U",135,536870919]],["^15",[138,"^U",136,536870919]],["^15",[138,"^U",137,536870919]],["^15",[138,"^H",34,536870919]],["^15",[138,"^H",105,536870919]],["^15",[138,"^H",135,536870919]],["^15",[138,"^H",136,536870919]],["^15",[138,"^H",137,536870919]],["^15",[138,"^;","~u686ffd64-55f7-4993-b2c6-8cecf0be012b",536870919]],["^15",[139,"^3","- [[personality psychology/toxicity]] Во мне всегда был этот тролль. Вспомни спор с Горягиным в школе и подшучивание над Галбацевым. Над Никой даже пытался стебаться. Просто раньше из-за смущения я не мог связать два слова вместе и некому кроме было присесть на уши. На других замахнуться кишка тонка.",536870919]],["^15",[139,"^16",1752169828551,536870919]],["^15",[139,"^Z","journals/2025_04_11.md",536870919]],["^15",[140,"^K",1752169828550,536870919]],["^15",[140,"^[",139,536870919]],["^15",[140,"^N",20250411,536870919]],["^15",[140,"^@",true,536870919]],["^15",[140,"^Y","apr 11th, 2025",536870919]],["^15",[140,"^11","Apr 11th, 2025",536870919]],["^15",[140,"^B",1752169828550,536870919]],["^15",[140,"^;","~u686ffd64-d92e-4929-99bf-4ced23fb12f1",536870919]],["^15",[141,"^K",1752169828550,536870919]],["^15",[141,"^@",false,536870919]],["^15",[141,"^Y","personality psychology/toxicity",536870919]],["^15",[141,"^A",34,536870919]],["^15",[141,"^11","personality psychology/toxicity",536870919]],["^15",[141,"^B",1752169828550,536870919]],["^15",[141,"^;","~u686ffd64-cb2a-4b11-a465-844d532515db",536870919]],["^15",[142,"^Q","[[personality psychology/toxicity]] Во мне всегда был этот тролль. Вспомни спор с Горягиным в школе и подшучивание над Галбацевым. Над Никой даже пытался стебаться. Просто раньше из-за смущения я не мог связать два слова вместе и некому кроме было присесть на уши. На других замахнуться кишка тонка.",536870919]],["^15",[142,"^O","^1;",536870919]],["^15",[142,"^F",140,536870919]],["^15",[142,"^X",140,536870919]],["^15",[142,"^V",140,536870919]],["^15",[142,"^U",34,536870919]],["^15",[142,"^U",140,536870919]],["^15",[142,"^U",141,536870919]],["^15",[142,"^H",34,536870919]],["^15",[142,"^H",141,536870919]],["^15",[142,"^;","~u686ffd64-8ea6-4f8c-8c4b-5775b21e8b6e",536870919]],["^15",[143,"^3","- [[cognitive bias/splitting]] [[personality psychology/independence]] Самые тяжёлые последствия расщепление имеет, когда ты применяешь его к людям. В начале общения ты идеализируешь человека. Потом, когда видишь доказательства несоотвествия его выдуманному идеалу, ты начинаешь к нему относится отрицательно и отталкиваешь. Избегай этого искажения, вместе с тем сохраняя свою самодостаточность в общении.",536870919]],["^15",[143,"^16",1752169828563,536870919]],["^15",[143,"^Z","journals/2025_04_09.md",536870919]],["^15",[144,"^K",1752169828562,536870919]],["^15",[144,"^[",143,536870919]],["^15",[144,"^N",20250409,536870919]],["^15",[144,"^@",true,536870919]],["^15",[144,"^Y","apr 9th, 2025",536870919]],["^15",[144,"^11","Apr 9th, 2025",536870919]],["^15",[144,"^B",1752169828562,536870919]],["^15",[144,"^;","~u686ffd64-9829-448b-9188-90fc079dd52b",536870919]],["^15",[145,"^K",1752169829225,536870919]],["^15",[145,"^@",false,536870919]],["^15",[145,"^Y","personality psychology/independence",536870919]],["^15",[145,"^A",34,536870919]],["^15",[145,"^11","personality psychology/independence",536870919]],["^15",[145,"^B",1752169829225,536870919]],["^15",[145,"^;","~u686ffd65-0322-480e-91f7-18814798bff9",536870919]],["^15",[146,"^Q","[[cognitive bias/splitting]] [[personality psychology/independence]] Самые тяжёлые последствия расщепление имеет, когда ты применяешь его к людям. В начале общения ты идеализируешь человека. Потом, когда видишь доказательства несоотвествия его выдуманному идеалу, ты начинаешь к нему относится отрицательно и отталкиваешь. Избегай этого искажения, вместе с тем сохраняя свою самодостаточность в общении.",536870919]],["^15",[146,"^O","^1;",536870919]],["^15",[146,"^F",144,536870919]],["^15",[146,"^X",144,536870919]],["^15",[146,"^V",144,536870919]],["^15",[146,"^U",34,536870919]],["^15",[146,"^U",135,536870919]],["^15",[146,"^U",137,536870919]],["^15",[146,"^U",144,536870919]],["^15",[146,"^U",145,536870919]],["^15",[146,"^H",34,536870919]],["^15",[146,"^H",135,536870919]],["^15",[146,"^H",137,536870919]],["^15",[146,"^H",145,536870919]],["^15",[146,"^;","~u686ffd64-e3c0-420d-a528-3cb6371391f6",536870919]],["^15",[147,"^3","- #[[opportunity cost]] Держи в голове, что каждое распределение ресурсов, например, денег или времени, есть альтернативные издержки. Говоря одному последствию \"да\", ты скажешь другому \"нет\".",536870919]],["^15",[147,"^16",1752169828572,536870919]],["^15",[147,"^Z","journals/2025_03_18.md",536870919]],["^15",[148,"^K",1752169828572,536870919]],["^15",[148,"^[",147,536870919]],["^15",[148,"^N",20250318,536870919]],["^15",[148,"^@",true,536870919]],["^15",[148,"^Y","mar 18th, 2025",536870919]],["^15",[148,"^11","Mar 18th, 2025",536870919]],["^15",[148,"^B",1752169828572,536870919]],["^15",[148,"^;","~u686ffd64-5487-4597-ad9b-c83666277b4e",536870919]],["^15",[149,"^K",1752169828599,536870919]],["^15",[149,"^@",false,536870919]],["^15",[149,"^Y","opportunity cost",536870919]],["^15",[149,"^11","opportunity cost",536870919]],["^15",[149,"^B",1752169828599,536870919]],["^15",[149,"^;","~u686ffd64-6114-40cb-87e1-be8b1778117a",536870919]],["^15",[150,"^Q","#[[opportunity cost]] Держи в голове, что каждое распределение ресурсов, например, денег или времени, есть альтернативные издержки. Говоря одному последствию \"да\", ты скажешь другому \"нет\".",536870919]],["^15",[150,"^O","^1;",536870919]],["^15",[150,"^F",148,536870919]],["^15",[150,"^X",148,536870919]],["^15",[150,"^V",148,536870919]],["^15",[150,"^U",148,536870919]],["^15",[150,"^U",149,536870919]],["^15",[150,"^H",149,536870919]],["^15",[150,"^;","~u686ffd64-6724-46dd-8547-8601b289c620",536870919]],["^15",[151,"^3","- #daydreaming\n\t- Причины\n\t\t- отсутствие #[[personality psychology/independence]]\n\t\t- Средства противодействия\n\t\t\t- Первый ряд\n\t\t- #[[personality psychology/anxiety]]\n\t- Средства противодействия\n\t\t- Первый ряд\n\t\t\t- #[[opportunity cost]]\n\t\t\t\t- Ты теряешь не только время затраченное на саму фантазию, но и на застраиваемый ей воздушный замок. Отказавшись от фантазии ты получишь как кратко- так и долгосрочную выгоду.\n\t\t\t- #authenticity\n\t\t\t- #[[grounding/breathing]]\n\t\t\t- Как бы всё случилось на самом деле.\n\t\t\t- Прекрати...\n\t\t\t\t- отвлекать своё внимание от ответственности.\n- #insomnia\n\t- Причины\n\t\t- #[[personality psychology/anxiety]]\n\t- Средства противодействия\n\t\t- Первый ряд\n\t\t\t- #orthogonality\n\t\t\t- #[[opportunity cost]]\n\t\