]],["^15",[3934,"^11","linguistics/grammar/morphology/morphological typology",536872270]],["^15",[3934,"^B",1772895977868,536872573]],["^15",[3934,"^;","~u69ac3bdf-04df-40b9-86a2-616365a86268",536872270]],["^15",[3935,"^Q","[[languages/Chechen language]] [[languages/English language]] Чеченский язык агглюнативен с элементами флективности в частности в глаголах. Русский крайне флективен, японский почти полностью агглюнативен, английский аналитичен.",536872573]],["^15",[3935,"^O","^17",536872274]],["^15",[3935,"^@",false,536872274]],["^15",[3935,"^F",3934,536872274]],["^15",[3935,"^X",3934,536872274]],["^15",[3935,"^V",3934,536872274]],["^15",[3935,"^U",20,536872574]],["^15",[3935,"^U",22,536872574]],["^15",[3935,"^U",3162,536872574]],["^15",[3935,"^U",3934,536872574]],["^15",[3935,"^?",["^ "],536872573]],["^15",[3935,"^H",20,536872573]],["^15",[3935,"^H",22,536872573]],["^15",[3935,"^H",3162,536872573]],["^15",[3935,"^;","~u69ac3be8-91e8-48e9-aa61-986f5c0b663e",536872274]],["^15",[3938,"^Q","ИИ помещает чеченский язык в в плане свободы порядка слов находится над испанским и японским и ниже русского.",536872276]],["^15",[3938,"^O","^17",536872276]],["^15",[3938,"^F",3935,536872540]],["^15",[3938,"^X",3934,536872276]],["^15",[3938,"^V",3935,536872577]],["^15",[3938,"^U",20,536872578]],["^15",[3938,"^U",22,536872578]],["^15",[3938,"^U",3162,536872578]],["^15",[3938,"^U",3934,536872578]],["^15",[3938,"^?",["^ "],536872540]],["^15",[3938,"^;","~u2c939de7-0325-45ee-954e-bd41d785a629",536872276]],["^15",[3939,"^3","- [[languages/Chechen language]] [[languages/English language]] Чеченский язык агглюнативен с элементами флективности в частности в глаголах. Русский крайне флективен, японский почти полностью агглюнативен, английский аналитичен.\n\t- ИИ помещает чеченский язык в в плане свободы порядка слов находится над испанским и японским и ниже русского.\n- Язык может выражать, что относится к чему:\n\t- упаковыванием инфомации в сами слова, освобождая порядок слов для акцен