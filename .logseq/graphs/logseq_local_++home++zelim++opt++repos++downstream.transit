,[3432,"^X",3364,536870918]],["^15",[3432,"^V",3419,536870918]],["^15",[3432,"^U",3363,536870918]],["^15",[3432,"^U",3364,536870918]],["^15",[3432,"^;","~u69a845ea-0174-4d0d-9a74-8c7f8b16c532",536870918]],["^15",[3433,"^Q","Переходная экономика во время мира (до отлива) спонсирует следующий этап - войну. Только в нашем случае нет неопределенности. Все знают, что отлив будет.",536870918]],["^15",[3433,"^O","^17",536870918]],["^15",[3433,"^F",3400,536870918]],["^15",[3433,"^X",3364,536870918]],["^15",[3433,"^V",3405,536870918]],["^15",[3433,"^U",3364,536870918]],["^15",[3433,"^;","~u69a845ea-3150-4def-8ca7-82678b88fa8c",536870918]],["^15",[3434,"^Q","Наездники козлов, славы",536870918]],["^15",[3434,"^O","^17",536870918]],["^15",[3434,"^F",3368,536870918]],["^15",[3434,"^X",3364,536870918]],["^15",[3434,"^V",3448,536870918]],["^15",[3434,"^U",3364,536870918]],["^15",[3434,"^;","~u69a845ea-bc75-4bde-8d14-68b57c2f3d23",536870918]],["^15",[3435,"^Q","Лесные бродяги - Coureur des bois",536870918]],["^15",[3435,"^O","^17",536870918]],["^15",[3435,"^F",3488,536870918]],["^15",[3435,"^X",3364,536870918]],["^15",[3435,"^V",3460,536870918]],["^15",[3435,"^U",3363,536870918]],["^15",[3435,"^U",3364,536870918]],["^15",[3435,"^;","~u69a845ea-2d75-428b-a213-998f0aa6f84b",536870918]],["^15",[3436,"^Q","Биорегион типа Каскадии, антагонисты сокольников и козловсадников.",536870918]],["^15",[3436,"^O","^17",536870918]],["^15",[3436,"^F",3478,536870918]],["^15",[3436,"^X",3364,536870918]],["^15",[3436,"^V",3463,536870918]],["^15",[3436,"^U",3364,536870918]],["^15",[3436,"^;","~u69a845ea-5964-4818-b7a3-39eb6327ffb5",536870918]],["^15",[3437,"^Q","Муравьиное гнездо",536870918]],["^15",[3437,"^O","^17",536870918]],["^15",[3437,"^F",3380,536870918]],["^15",[3437,"^X",3364,536870918]],["^15",[3437,"^V",3380,536870918]],["^15",[3437,"^U",3361,536870918]],["^15",[3437,"^U",3364,536870918]],["^15",[3437,"^;","~u69a845ea-993c-4281-9bb8-e9848a7f4ae3",536870918]],["^15",[3438,"^Q","Прочитай на вики Invasion literature",536870918]],["^15",[3438,"^O","^17",536870918]],["^15",[3438,"^F",3473,536870918]],["^15",[3438,"^X",3364,536870918]],["^15",[3438,"^V",3473,536870918]],["^15",[3438,"^U",3364,536870918]],["^15",[3438,"^;","~u69a845ea-37ea-4fb1-8a67-28dd910abd5c",536870918]],["^15",[3439,"^Q","[[Диадохи]]",536870918]],["^15",[3439,"^O","^17",536870918]],["^15",[3439,"^F",3427,536870918]],["^15",[3439,"^X",3364,536870918]],["^15",[3439,"^V",3427,536870918]],["^15",[3439,"^U",3360,536870918]],["^15",[3439,"^U",3364,536870918]],["^15",[3439,"^H",3360,536870918]],["^15",[3439,"^;","~u69a845ea-1528-4565-b600-9a2fb02fbf93",536870918]],["^15",[3440,"^Q","Памяти Наталье Эстемировой, настоящей къонах.",536870918]],["^15",[3440,"^O","^17",536870918]],["^15",[3440,"^F",3366,536870918]],["^15",[3440,"^X",3364,536870918]],["^15",[3440,"^V",3366,536870918]],["^15",[3440,"^U",3364,536870918]],["^15",[3440,"^;","~u69a845ea-f74d-4879-b63a-d6db081015d4",536870918]],["^15",[3441,"^Q","Он хочет оставить память о себе. Он видел, как разрушают памятники. Как стирают имена. Но от присоединенной территории даже последующий за ним оппозиционер не откажется.",536870918]],["^15",[3441,"^O","^17",536870918]],["^15",[3441,"^F",3449,536870918]],["^15",[3441,"^X",3364,536870918]],["^15",[3441,"^V",3446,536870918]],["^15",[3441,"^U",3364,536870918]],["^15",[3441,"^;","~u69a845ea-e8b5-424c-8f9d-cc1bf6437684",536870918]],["^15",[3442,"^Q","Навязанный обществом стереотип мужчины делает стезю солдата желательной. Помогает этому и государство. Воевавшие - герои, павшие - вдвойне. День Защистника ~~Отечества~~ Правительства не забываем отмечать. К тому же веселее армии альтернатив для 18-летнего нет. Там управляют тобой 23-летние. Никто из них в этом возрасте неспособен осмыслить, прав он или нет потом в войне. Но он рационализирует сделанный за него выбор. Не для убийства же невиновных проводились учения, не другим в угоду же умирают соратники.",536870918]],["^15",[3442,"^O","^17",536870918]],["^15",[3442,"^F",3404,536870918]],["^15",[3442,"^X",3364,536870918]],["^15",[3442,"^V",3404,536870918]],["^15",[3442,"^U",3364,536870918]],["^15",[3442,"^;","~u69a845ea-fb33-4212-b858-2d027ab4e4f9",536870918]],["^15",[3443,"^Q","Нахская империя",536870918]],["^15",[3443,"^O","^17",536870918]],["^15",[3443,"^F",3387,536870918]],["^15",[3443,"^X",3364,536870918]],["^15",[3443,"^V",3463,536870918]],["^15",[3443,"^U",3364,536870918]],["^15",[3443,"^;","~u69a845ea-c9d9-43bf-b5b4-e1dfe5e942f4",536870918]],["^15",[3444,"^Q","Большая Гора",536870918]],["^15",[3444,"^O","^17",536870918]],["^15",[3444,"^F",3493,536870918]],["^15",[3444,"^X",3364,536870918]],["^15",[3444,"^V",3443,536870918]],["^15",[3444,"^U",3364,536870918]],["^15",[3444,"^;","~u69a845ea-63d9-4e8a-badf-773a568180f1",536870918]],["^15",[3445,"^Q","Маци лах",536870918]],["^15",[3445,"^O","^17",536870918]],["^15",[3445,"^F",3493,536870918]],["^15",[3445,"^X",3364,536870918]],["^15",[3445,"^V",3493,536870918]],["^15",[3445,"^U",3364,536870918]],["^15",[3445,"^;","~u69a845ea-5b59-49e4-b2a2-1e94f4534c3b",536870918]],["^15",[3446,"^Q","Диктатор",536870918]],["^15",[3446,"^O","^17",536870918]],["^15",[3446,"^F",3369,536870918]],["^15",[3446,"^X",3364,536870918]],["^15",[3446,"^V",3443,536870918]],["^15",[3446,"^U",3364,536870918]],["^15",[3446,"^;","~u69a845ea-4d06-4072-b54a-a521f720712c",536870918]],["^15",[3447,"^Q","[[real history]]",536870918]],["^15",[3447,"^O","^17",536870918]],["^15",[3447,"^F",3458,536870918]],["^15",[3447,"^X",3364,536870918]],["^15",[3447,"^V",3458,536870918]],["^15",[3447,"^U",3363,536870918]],["^15",[3447,"^U",3364,536870918]],["^15",[3447,"^H",3363,536870918]],["^15",[3447,"^;","~u69a845ea-bb39-4422-9c48-cbbe1c3fb5d2",536870918]],["^15",[3448,"^Q","Фракции или Стадии",536870918]],["^15",[3448,"^O","^17",536870918]],["^15",[3448,"^F",3467,536870918]],["^15",[3448,"^X",3364,536870918]],["^15",[3448,"^V",3364,536870918]],["^15",[3448,"^U",3364,536870918]],["^15",[3448,"^;","~u69a845ea-44a3-4562-93ba-4b3763cc6070",536870918]],["^15",[3449,"^Q","С не самодур и самодостаточен. Умеет маскировать импульсы. Позволяет премыскаться только тогда, когда это нужно самим подхалимам.",536870918]],["^15",[3449,"^O","^17",536870918]],["^15",[3449,"^F",3446,536870918]],["^15",[3449,"^X",3364,536870918]],["^15",[3449,"^V",3446,536870918]],["^15",[3449,"^U",3364,536870918]],["^15",[3449,"^;","~u69a845ea-2794-431b-ad5c-674f1c769c5a",536870918]],["^15",[3450,"^Q","Ускорение синдрома Кесслера",536870918]],["^15",[3450,"^O","^17",536870918]],["^15",[3450,"^F",3452,536870918]],["^15",[3450,"^X",3364,536870918]],["^15",[3450,"^V",3393,536870918]],["^15",[3450,"^U",3364,536870918]],["^15",[3450,"^;","~u69a845ea-7e22-4076-a7b7-b010280cf81a",536870918]],["^15",[3451,"^Q","Что выживание для одних, то кайф экстрима для других. Шансы быть убитым недостаточно высоки, чтобы бояться за нее, но достаточно низки, чтобы испытывать тот самый больной кайф.",536870918]],["^15",[3451,"^O","^17",536870918]],["^15",[3451,"^F",3400,536870918]],["^15",[3451,"^X",3364,536870918]],["^15",[3451,"^V",3400,536870918]],["^15",[3451,"^U",3364,536870918]],["^15",[3451,"^;","~u69a845ea-927a-43b9-8518-93412ee8aa72",536870918]],["^15",[3452,"^Q","От него может выиграть как маленький, так и большой. В партизанской войне туман войны приносит больше пользе слабой стороне. Поэтому может быть ей усилена.",536870918]],["^15",[3452,"^O","^17",536870918]],["^15",[3452,"^F",3410,536870918]],["^15",[3452,"^X",3364,536870918]],["^15",[3452,"^V",3393,536870918]],["^15",[3452,"^U",3364,536870918]],["^15",[3452,"^;","~u69a845ea-9cbd-4796-8335-24d6465f0d33",536870918]],["^15",[3453,"^Q","Morality Kitchen Sink",536870918]],["^15",[3453,"^O","^17",536870918]],["^15",[3453,"^F",3429,536870918]],["^15",[3453,"^X",3364,536870918]],["^15",[3453,"^V",3429,536870918]],["^15",[3453,"^U",3364,536870918]],["^15",[3453,"^;","~u69a845ea-635f-4790-9ca2-5dec7e7071e7",536870918]],["^15",[3454,"^Q","Президент одной из сторон взрывает подземную территорию битвы.",536870918]],["^15",[3454,"^O","^17",536870918]],["^15",[3454,"^F",3383,536870918]],["^15",[3454,"^X",3364,536870918]],["^15",[3454,"^V",3383,536870918]],["^15",[3454,"^U",3364,536870918]],["^15",[3454,"^;","~u69a845ea-d02e-4a0a-8cbb-36b1c16f5c18",536870918]],["^15",[3455,"^Q","Укротители огня (пороха)",536870918]],["^15",[3455,"^O","^17",536870918]],["^15",[3455,"^F",3402,536870918]],["^15",[3455,"^X",3364,536870918]],["^15",[3455,"^V",3448,536870918]],["^15",[3455,"^U",3364,536870918]],["^15",[3455,"^;","~u69a845ea-c413-4b1a-afa2-1d2b373a23a0",536870918]],["^15",[3456,"^Q","Потоп гонит людей в горы. Вода спадает - появляются острова. Остров Беной, островок Нихалой, континент, архипелаг Веденой. После спада уровня моря появляется Веденская лига, что меняет баланс сил.",536870918]],["^15",[3456,"^O","^17",536870918]],["^15",[3456,"^F",3366,536870918]],["^15",[3456,"^X",3364,536870918]],["^15",[3456,"^V",3364,536870918]],["^15",[3456,"^U",3364,536870918]],["^15",[3456,"^;","~u69a845ea-943d-459d-b11a-091a75f6a125",536870918]],["^15",[3457,"^Q","Смертники в вингсьютах, катапультирующие себя через проливы",536870918]],["^15",[3457,"^O","^17",536870918]],["^15",[3457,"^F",3418,536870918]],["^15",[3457,"^X",3364,536870918]],["^15",[3457,"^V",3418,536870918]],["^15",[3457,"^U",3364,536870918]],["^15",[3457,"^;","~u69a845ea-944a-4d56-99ad-c6a6212f5501",536870918]],["^15",[3458,"^Q","микробы, изобретения, др.",536870918]],["^15",[3458,"^O","^17",536870918]],["^15",[3458,"^F",3421,536870918]],["^15",[3458,"^X",3364,536870918]],["^15",[3458,"^V",3406,536870918]],["^15",[3458,"^U",3364,536870918]],["^15",[3458,"^;","~u69a845ea-afc2-49d9-aad7-52428ea0460d",536870918]],["^15",[3459,"^Q","'uṣsh",536870918]],["^15",[3459,"^O","^17",536870918]],["^15",[3459,"^F",3423,536870918]],["^15",[3459,"^X",3364,536870918]],["^15",[3459,"^V",3423,536870918]],["^15",[3459,"^U",3361,536870918]],["^15",[3459,"^U",3364,536870918]],["^15",[3459,"^;","~u69a845ea-508e-47fb-b546-d85a8f8eab93",536870918]],["^15",[3460,"^Q","[[real history]]",536870918]],["^15",[3460,"^O","^17",536870918]],["^15",[3460,"^F",3406,536870918]],["^15",[3460,"^X",3364,536870918]],["^15",[3460,"^V",3364,536870918]],["^15",[3460,"^U",3363,536870918]],["^15",[3460,"^U",3364,536870918]],["^15",[3460,"^H",3363,536870918]],["^15",[3460,"^;","~u69a845ea-02ce-4b29-9288-cd3853c30dbc",536870918]],["^15",[3461,"^Q","[[nation-building]] Хилларг хилла делла. Первый мир успел первым вследствие географических, исторических, даже биологических и других причин. Эксплуатация колонизованных земель создала новые области досуга и открыла к нему доступ большему числу людей. В результате они смогли прийти к демократии и свободе слова. Сегодня они должны быть не западными ценностями, а универсальными. И чтобы их заимствовать, нам не надо платить за них угнетением других.\nid:: 68f06c6b-9356-4a8f-a261-329240c362db",536870918]],["^15",[3461,"^O","^17",536870918]],["^15",[3461,"^F",3468,536870918]],["^15",[3461,"^X",3364,536870918]],["^15",[3461,"^V",3468,536870918]],["^15",[3461,"^U",3362,536870918]],["^15",[3461,"^U",3364,536870918]],["^15",[3461,"^?",["^ ","^1>","68f06c6b-9356-4a8f-a261-329240c362db"],536870918]],["^15",[3461,"^J",["^1>"],536870918]],["^15",[3461,"^4",["^ ","^1>","68f06c6b-9356-4a8f-a261-329240c362db"],536870918]],["^15",[3461,"^H",3362,536870918]],["^15",[3461,"^;","~u68f06c6b-9356-4a8f-a261-329240c362db",536870918]],["^15",[3462,"^Q","Из-за Набиуллиной не пал режим, но и народ не голодает.",536870918]],["^15",[3462,"^O","^17",536870918]],["^15",[3462,"^F",3392,536870918]],["^15",[3462,"^X",3364,536870918]],["^15",[3462,"^V",3405,536870918]],["^15",[3462,"^U",3364,536870918]],["^15",[3462,"^;","~u69a845ea-c8f1-4d08-8f3c-c5658ede208e",536870918]],["^15",[3463,"^Q","Регионы",536870918]],["^15",[3463,"^O","^17",536870918]],["^15",[3463,"^F",3448,536870918]],["^15",[3463,"^X",3364,536870918]],["^15",[3463,"^V",3364,536870918]],["^15",[3463,"^U",3364,536870918]],["^15",[3463,"^;","~u69a845ea-f166-49f4-aa77-214a3be87b39",536870918]],["^15",[3464,"^Q","Алия, накба и накса",536870918]],["^15",[3464,"^O","^17",536870918]],["^15",[3464,"^F",3437,536870918]],["^15",[3464,"^X",3364,536870918]],["^15",[3464,"^V",3380,536870918]],["^15",[3464,"^U",3361,536870918]],["^15",[3464,"^U",3364,536870918]],["^15",[3464,"^;","~u69a845ea-977e-462b-8cde-dcb0b47fcc40",536870918]],["^15",[3465,"^Q","В битве ты не думаешь о политике. Если не убьешь, то будешь убит.",536870918]],["^15",[3465,"^O","^17",536870918]],["^15",[3465,"^F",3480,536870918]],["^15",[3465,"^X",3364,536870918]],["^15",[3465,"^V",3404,536870918]],["^15",[3465,"^U",3364,536870918]],["^15",[3465,"^;","~u69a845ea-6043-4d2a-a047-00a65e6507cb",536870918]],["^15",[3466,"^Q","Радимичи",536870918]],["^15",[3466,"^O","^17",536870918]],["^15",[3466,"^F",3408,536870918]],["^15",[3466,"^X",3364,536870918]],["^15",[3466,"^V",3408,536870918]],["^15",[3466,"^U",3364,536870918]],["^15",[3466,"^;","~u69a845ea-130e-4db4-82e1-44292a753d07",536870918]],["^15",[3467,"^Q","Есть возможность для моей версии чеченской письменности.",536870918]],["^15",[3467,"^O","^17",536870918]],["^15",[3467,"^F",3417,536870918]],["^15",[3467,"^X",3364,536870918]],["^15",[3467,"^V",3364,536870918]],["^15",[3467,"^U",3364,536870918]],["^15",[3467,"^;","~u69a845ea-8752-46aa-8dd7-1787c4894dfe",536870918]],["^15",[3468,"^Q","Политика",536870918]],["^15",[3468,"^O","^17",536870918]],["^15",[3468,"^F",3463,536870918]],["^15",[3468,"^X",3364,536870918]],["^15",[3468,"^V",3364,536870918]],["^15",[3468,"^U",3364,536870918]],["^15",[3468,"^;","~u69a845ea-7104-4862-9424-9c2a8146542e",536870918]],["^15",[3469,"^Q","Сказка о титанах",536870918]],["^15",[3469,"^O","^17",536870918]],["^15",[3469,"^F",3379,536870918]],["^15",[3469,"^X",3364,536870918]],["^15",[3469,"^V",3443,536870918]],["^15",[3469,"^U",3364,536870918]],["^15",[3469,"^;","~u69a845ea-8bbd-4d31-bebc-f8da9723ba7f",536870918]],["^15",[3470,"^Q","Три Болвана",536870918]],["^15",[3470,"^O","^17",536870918]],["^15",[3470,"^F",3385,536870918]],["^15",[3470,"^X",3364,536870918]],["^15",[3470,"^V",3379,536870918]],["^15",[3470,"^U",3364,536870918]],["^15",[3470,"^;","~u69a845ea-f290-48d7-bc13-ba376b318507",536870918]],["^15",[3471,"^Q","Воздух и вода вместо (ядерной) триады.",536870918]],["^15",[3471,"^O","^17",536870918]],["^15",[3471,"^F",3405,536870918]],["^15",[3471,"^X",3364,536870918]],["^15",[3471,"^V",3405,536870918]],["^15",[3471,"^U",3364,536870918]],["^15",[3471,"^;","~u69a845ea-4f9f-4c5f-a163-c9d9305b5d25",536870918]],["^15",[3472,"^Q","Параллельное повествование двух героев. Они встречают друг друга на полпути и влюбляются.",536870918]],["^15",[3472,"^O","^17",536870918]],["^15",[3472,"^F",3420,536870918]],["^15",[3472,"^X",3364,536870918]],["^15",[3472,"^V",3366,536870918]],["^15",[3472,"^U",3364,536870918]],["^15",[3472,"^;","~u69a845ea-62be-4ab3-8e25-fe4a8f62f207",536870918]],["^15",[3473,"^Q","Приложение",536870918]],["^15",[3473,"^O","^17",536870918]],["^15",[3473,"^F",3429,536870918]],["^15",[3473,"^X",3364,536870918]],["^15",[3473,"^V",3364,536870918]],["^15",[3473,"^U",3364,536870918]],["^15",[3473,"^;","~u69a845ea-6154-4cbc-83af-b14feab9e549",536870918]],["^15",[3474,"^Q","Радинтомей Вятославич сочинил легенду, что родился от вятича и радимки и вырос в Древе. На самом деле он беглый раб нахов, поставивший целью создать Троеславию.",536870918]],["^15",[3474,"^O","^17",536870918]],["^15",[3474,"^F",3430,536870918]],["^15",[3474,"^X",3364,536870918]],["^15",[3474,"^V",3427,536870918]],["^15",[3474,"^U",3364,536870918]],["^15",[3474,"^;","~u69a845ea-e248-440a-97fb-5363be9ddb48",536870918]],["^15",[3475,"^Q","Встреча Амана",536870918]],["^15",[3475,"^O","^17",536870918]],["^15",[3475,"^F",3401,536870918]],["^15",[3475,"^X",3364,536870918]],["^15",[3475,"^V",3401,536870918]],["^15",[3475,"^U",3364,536870918]],["^15",[3475,"^;","~u69a845ea-8bf6-4ea2-b5af-5f711fdfebe9",536870918]],["^15",[3476,"^Q","[[Планета-муравейник]]",536870918]],["^15",[3476,"^O","^17",536870918]],["^15",[3476,"^F",3427,536870918]],["^15",[3476,"^X",3364,536870918]],["^15",[3476,"^V",3463,536870918]],["^15",[3476,"^U",3361,536870918]],["^15",[3476,"^U",3364,536870918]],["^15",[3476,"^H",3361,536870918]],["^15",[3476,"^;","~u69a845ea-c093-4c4a-8273-f96bdfd7492d",536870918]],["^15",[3477,"^Q","Вять",536870918]],["^15",[3477,"^O","^17",536870918]],["^15",[3477,"^F",3439,536870918]],["^15",[3477,"^X",3364,536870918]],["^15",[3477,"^V",3427,536870918]],["^15",[3477,"^U",3364,536870918]],["^15",[3477,"^;","~u69a845ea-385a-411e-b141-f8272ab2472a",536870918]],["^15",[3478,"^Q","Две горы подобно греческому Дилосу создают миф о своей сакральности. Одна - самая высокая и ближе к Господу, другая - в центре, а это в отличие от высоты фактор объединяющий. Первая имеет стратегическое преимущесво в обороне, а вторая - в торговле.",536870918]],["^15",[3478,"^O","^17",536870918]],["^15",[3478,"^F",3463,536870918]],["^15",[3478,"^X",3364,536870918]],["^15",[3478,"^V",3463,536870918]],["^15",[3478,"^U",3364,536870918]],["^15",[3478,"^;","~u69a845ea-283b-4ac4-bc10-171dcd50640f",536870918]],["^15",[3479,"^Q","личности: генералы, пророки, др.",536870918]],["^15",[3479,"^O","^17",536870918]],["^15",[3479,"^F",3458,536870918]],["^15",[3479,"^X",3364,536870918]],["^15",[3479,"^V",3406,536870918]],["^15",[3479,"^U",3364,536870918]],["^15",[3479,"^;","~u69a845ea-8f39-48fc-b331-8fe99a9b7d47",536870918]],["^15",[3480,"^Q","Профессия солдата всегда была престижна среди мужчин, даже среди дворян. Служившие в армии или войсках не захотят работать на ферме. Хуже всего те, кто превращаю войну в ремесло. Но времена меняются, и правящим нужно найти им применение в менее \"благородном\".",536870918]],["^15",[3480,"^O","^17",536870918]],["^15",[3480,"^F",3370,536870918]],["^15",[3480,"^X",3364,536870918]],["^15",[3480,"^V",3404,536870918]],["^15",[3480,"^U",3364,536870918]],["^15",[3480,"^;","~u69a845ea-c5cd-4598-b2e0-bd93f3bdb7f0",536870918]],["^15",[3481,"^Q","Если раньше собирались вокруг гор, то теперь вокруг озер.",536870918]],["^15",[3481,"^O","^17",536870918]],["^15",[3481,"^F",3490,536870918]],["^15",[3481,"^X",3364,536870918]],["^15",[3481,"^V",3490,536870918]],["^15",[3481,"^U",3364,536870918]],["^15",[3481,"^;","~u69a845ea-3db0-451e-849a-f22c732444df",536870918]],["^15",[3482,"^Q","Или Четыре угла как в США",536870918]],["^15",[3482,"^O","^17",536870918]],["^15",[3482,"^F",3382,536870918]],["^15",[3482,"^X",3364,536870918]],["^15",[3482,"^V",3382,536870918]],["^15",[3482,"^U",3364,536870918]],["^15",[3482,"^;","~u69a845ea-3451-4363-9492-2899f300220a",536870918]],["^15",[3483,"^Q","Люди руды",536870918]],["^15",[3483,"^O","^17",536870918]],["^15",[3483,"^F",3448,536870918]],["^15",[3483,"^X",3364,536870918]],["^15",[3483,"^V",3448,536870918]],["^15",[3483,"^U",3364,536870918]],["^15",[3483,"^;","~u69a845ea-f78d-4426-8823-574dde3734bf",536870918]],["^15",[3484,"^Q","Казаки и Дикое поле. Их объединяла не нация, а образ жизни. Только они потеряли свой истинный дух, когда пошли на служение царю.",536870918]],["^15",[3484,"^O","^17",536870918]],["^15",[3484,"^F",3435,536870918]],["^15",[3484,"^X",3364,536870918]],["^15",[3484,"^V",3460,536870918]],["^15",[3484,"^U",3363,536870918]],["^15",[3484,"^U",3364,536870918]],["^15",[3484,"^;","~u69a845ea-9276-4620-8877-50e5126c3949",536870918]],["^15",[3485,"^Q","Гуманитарная интервенция и терроризм",536870918]],["^15",[3485,"^O","^17",536870918]],["^15",[3485,"^F",3453,536870918]],["^15",[3485,"^X",3364,536870918]],["^15",[3485,"^V",3453,536870918]],["^15",[3485,"^U",3364,536870918]],["^15",[3485,"^;","~u69a845ea-e8a8-4adb-9d23-8c83a4434daa",536870918]],["^15",[3486,"^Q","Межличностные, соседские и междугрупповые отношения",536870918]],["^15",[3486,"^O","^17",536870918]],["^15",[3486,"^F",3420,536870918]],["^15",[3486,"^X",3364,536870918]],["^15",[3486,"^V",3420,536870918]],["^15",[3486,"^U",3364,536870918]],["^15",[3486,"^;","~u69a845ea-10bf-4747-b43e-27d88c623488",536870918]],["^15",[3487,"^Q","Большое озеро - нейтральная территория до некоторых пор.",536870918]],["^15",[3487,"^O","^17",536870918]],["^15",[3487,"^F",3490,536870918]],["^15",[3487,"^X",3364,536870918]],["^15",[3487,"^V",3417,536870918]],["^15",[3487,"^U",3364,536870918]],["^15",[3487,"^;","~u69a845ea-f778-4ec0-8ba3-83a0897d12e4",536870918]],["^15",[3488,"^M",true,536870918]],["^15",[3488,"^Q","Ирокезы и французы - наилучшие враги\ncollapsed:: true",536870918]],["^15",[3488,"^O","^17",536870918]],["^15",[3488,"^F",3373,536870918]],["^15",[3488,"^X",3364,536870918]],["^15",[3488,"^V",3460,536870918]],["^15",[3488,"^U",3363,536870918]],["^15",[3488,"^U",3364,536870918]],["^15",[3488,"^?",["^ "],536870918]],["^15",[3488,"^J",[],536870918]],["^15",[3488,"^4",["^ "],536870918]],["^15",[3488,"^;","~u69a845ea-e895-4dee-a602-d9cbafc8e00f",536870918]],["^15",[3489,"^Q","Последняя брошка",536870918]],["^15",[3489,"^O","^17",536870918]],["^15",[3489,"^F",3384,536870918]],["^15",[3489,"^X",3364,536870918]],["^15",[3489,"^V",3462,536870918]],["^15",[3489,"^U",3364,536870918]],["^15",[3489,"^;","~u69a845ea-b441-460e-9693-71bbd23713c9",536870918]],["^15",[3490,"^Q","Время отлива",536870918]],["^15",[3490,"^O","^17",536870918]],["^15",[3490,"^F",3417,536870918]],["^15",[3490,"^X",3364,536870918]],["^15",[3490,"^V",3417,536870918]],["^15",[3490,"^U",3364,536870918]],["^15",[3490,"^;","~u69a845ea-1ce9-4913-b960-1814a660181e",536870918]],["^15",[3491,"^Q","Дружественный фронтир, предупреждающий об агрессорах",536870918]],["^15",[3491,"^O","^17",536870918]],["^15",[3491,"^F",3365,536870918]],["^15",[3491,"^X",3364,536870918]],["^15",[3491,"^V",3468,536870918]],["^15",[3491,"^U",3364,536870918]],["^15",[3491,"^;","~u69a845ea-27ad-4e3c-883e-fe01f8626993",536870918]],["^15",[3492,"^Q","tags:: workshop\nstatus:: backlog\ntype:: writing\nform:: novel\n\n",536870918]],["^15",[3492,"^O","^17",536870918]],["^15",[3492,"^1=",["^1:",[]],536870918]],["^15",[3492,"^F",3364,536870918]],["^15",[3492,"^X",3364,536870918]],["^15",[3492,"^V",3364,536870918]],["^15",[3492,"^U",186,536870918]],["^15",[3492,"^U",2859,536870918]],["^15",[3492,"^U",2861,536870918]],["^15",[3492,"^U",2863,536870918]],["^15",[3492,"^U",3364,536870918]],["^15",[3492,"^:",true,536870918]],["^15",[3492,"^?",["^ ","^19",["^1:",["workshop"]],"^1A","backlog","^1;","writing","^1B","novel"],536870918]],["^15",[3492,"^J",["^19","^1A","^1;","^1B"],536870918]],["^15",[3492,"^4",["^ ","^19","workshop","^1A","backlog","^1;","writing","^1B","novel"],536870918]],["^15",[3492,"^H",186,536870918]],["^15",[3492,"^H",2859,536870918]],["^15",[3492,"^H",2861,536870918]],["^15",[3492,"^H",2863,536870918]],["^15",[3492,"^;","~u69a845ea-1aa4-4444-ac29-74ab87fd27b3",536870918]],["^15",[3493,"^Q","Девиз",536870918]],["^15",[3493,"^O","^17",536870918]],["^15",[3493,"^F",3443,536870918]],["^15",[3493,"^X",3364,536870918]],["^15",[3493,"^V",3443,536870918]],["^15",[3493,"^U",3364,536870918]],["^15",[3493,"^;","~u69a845ea-04ed-459c-b040-5957da613234",536870918]],["^15",[3494,"^?",["^ ","^1D","embed","^1E",["((658db9b5-1d39-4457-a4b4-26ca5f887aad))"]],536870918]],["^15",[3494,"^W","macro",536870918]],["^15",[3494,"^T","embed ((658db9b5-1d39-4457-a4b4-26ca5f887aad))",536870918]],["^15",[3495,"^3","tags:: workshop\nstatus:: stack\ntype:: writing\nform:: novel\n\n- #+BEGIN_QUOTE\n  Посвящается тем, кто пишет историю моей жизни: маме и сестре.\n  #+END_QUOTE\n- Мета\n\t- 30 слов в среднем, то есть 200000 слов в общем и 130000 - после редактирования. Всего лишь ориентиры.\n\t\t- Используй программу для подсчета слов или сравни количество страниц с уже прочитанными произведениями.\n\t- Пиши нелинейно и рывками. Например, страница для одного художественного тропа, абзац для другой синтаксической конструкции.\n\t- Мораль сей басни - занавес неведения или версия кольца Гига.\n\t\t- Зачастую история не сохраняет правду или искажает её. Даже если история не рассудит, ты сам свидетель своих действий и мыслей.\n\t- Спроси ИИ, какой слог подходит каждому герою.\n\t\t- Современник перевёл с древнегреческого.\n\t\t- Слог палимпсеста меняется в зависимости от читателя.\n- Маркетинг\n\t- Белая, но узнаваемая обложка\n\t- Нужно все-таки завести аккаунт\n- Черновик\n\t- Рамка\n\t\t- Время\n\t\t\t- Разные времена\n\t\t\t- Одно время\n\t\t\t- Аналогия с грамматическим временем?\n\t\t\t\t- Эвиденциальность чеченского языка и письмо\n\t\t\t- Будущее\n\t\t- Лейтмотив времени и его факелоносцы\n\t\t\t- Самопожертвование и маккивелианизм\n\t\t\t\t- Гефест и Прометей - терпила-добряк и самоотверженный идеалист, горе семье\n\t\t\t- Свой полис и космополис\n\t\t\t\t- Крит - лавирующий дипломат и закормленный друид\n\t\t\t\t- Детство баловня и зрелость жертвы\n\t\t\t- Слуга музы и её сутенёр\n\t\t\t\t- Гомер и Псевдо-Гомер - стоик и поющий оды кормилец семьи\n\t\t\t\t- Параллельный ход событий\n\t\t\t- Люди слова, одного лишь слова\n\t\t\t\t- Однокашники Пропаг и Теролексий - малодушный продажный своих принципов и остов круговой поруки в контрасте со словоблудом, для кого слово важнее дела, тоже не страдающим отвагой\n\t\t- Забракованные пов, которые преломляются через того, кто нашёл палимпсест, а потом уже читателя этой книги.\n\t\t\t- Жена или дочь Прометея\n\t\t\t\t- В виде признания, где много \"он\".\n\t\t\t\t- Женщина высокого социального стиля, но не в словах\n\t\t\t- Рабыня жрицы после разграбления Миноса. Можно противоставить в той же главе привилегированному детству хозяйки.\n\t\t\t\t- В виде разговора, где много \"мы\" от третьего лица\n\t\t\t\t- Проза высокого стиля повествователем низкого социального\n\t\t\t\t- Изобилие художественных приемов\n\t\t\t- Варвар-фракиец, которого внешне не отличить от грека, но разговаривающий на греческом с акцентом\n\t\t\t\t- В виде безличностного повествования\n\t\t\t- Ребёнок, сын Тералексия\n\t\t\t\t- В виде безличностного наблюдения\n\t\t\t- Тералексий\n\t\t\t\t- В виде признания, где много \"я\" под видом \"ты\"\n\t\t\t- Ребенок после театра\n\t\t- Стили прозы\n\t\t\t- Минимализм\n\t\t\t\t- Косвенный, сдержаный\n\t\t\t- Цельный\n\t\t\t\t- Параллелизм\n\t\t\t\t\t- Противоставление баланса и ряда трех отступлениям\n\t\t\t\t\t\t- ((686825ec-ad7e-488c-9340-0984b58a03f1))\n\t\t\t\t\t\t- ((686be35a-d2e6-46f7-ad49-19606fe3c613))\n\t\t\t\t\t- Пары слов типа поговорок (умереть не встать, part and parcel, thick and thin, ков-керт)\n\t\t\t\t\t- Почитай Уильяма Гэсса\n\t\t\t- Потоковый\n\t\t\t\t- Поток сознания\n\t\t\t- Лирицизм\n\t\t\t\t- Туманный\n\t\t\t\t- Аллитерация\n\t\t\t- Публицистика\n\t\t\t\t- Нейтральная\n\t\t\t- Драма\n\t\t- Эпиграфы\n\t\t\t- Августин\n\t\t\t- Камю\n\t\t\t- #+BEGIN_QUOTE\n\t\t\t  В истории всегда есть четыре стороны: ваша сторона, их сторона, правда и то, что произошло на самом деле.\n\t\t\t  #+END_QUOTE\n\t\t\t  якобы Жан-Жак Руссо\n\t\t\t- id:: 68714778-26c9-43f1-acf5-4d28c3cf93b7\n\t\t\t  #+BEGIN_QUOTE\n\t\t\t  Civilization is a stream with banks. The stream is sometimes filled with blood from people killing, stealing, shouting and doing things historians usually record; while on the banks, unnoticed, people build homes, make love, raise children, sing songs, write poetry and even whittle statues. The story of civilization is the story of what happened on the banks.\n\t\t\t  #+END_QUOTE\n\t\t\t  Уилл Дюрант\n\t\t\t- #+BEGIN_QUOTE\n\t\t\t  They called it 'natural law' when convenient, and 'human nature' when challenged - the perfect circular logic of domination.\n\t\t\t  #+END_QUOTE\n\t\t\t  Талос\n\t\t- Пов-иллюстрации\n\t- Пролог\n\t\t- Священный палимпсест\n\t\t\t- Антикитерский механизм использовался, чтобы просматривать историю согласно разным источникам. Путём введения имени правителя получали доступ к его нарративу, а напечатав \"Хаос\" - к виду с высоты космоса.\n\t\t- Люди оседлали необуздаемое, время. Вожжи - в руках наездниках, но удила - не в зубах лошади.\n\t- По кругу вверх или дежавю анахронизма: Классическая Греция\n\t\t- Хаос 3\n\t\t\t- Эволюция цивилизации посредством диалектики или повторение этапов, винт или цикл. Хронос выигрывает в этой шахматной партии, но Эон предупреждает, что цивилизация не несёт позитивного содержания и вектор спирали не движется вверх. Развивается медицина, искусство, но и оружие и войны тоже. Хронос отвечает ему: \"Люди запрягли тебя в плуг и точно знают, когда Персефона вернётся к ним. Что толку от твоего движения по кругам, если это цикл разложения и возрождения, который с новым витком не захватывает больше пространства.\"\n\t\t- Древняя Греция, архаический период, или Римская Греция\n\t\t\t- Feels like Dice Chess but actually Viennese Chess\n\t\t\t- Цензура\n\t\t\t\t- Если ресурс не экслюзивен как Фестский диск, а общедоступен, то государство будет его контролировать.\n\t\t\t\t- Лишь тот, кто боится, использует в качестве оружия страх. Вместо битвы на равных условиях он лишает противника силы. Даже если тот не собирается нападать, тиран предполагает, что это случится. Поэтому паранойя - его привычное состояние.\n\t\t\t\t- Устное слово\n\t\t\t\t\t- Гомер и Псевдо-Гомер\n\t\t\t\t\t\t- Псевдо-Гомер - лизоблюд Олимпа, автор гомеровских гимнов. Гомеру выкололи глаза за освещение Троянской войны.\n\t\t\t\t\t\t\t- Можно всего лишь отрезать язык. Правда он может научиться грамоте. Затем придётся и отрубить правую руку. Тогда он станет писать левой. Обезглавив, мы одним махом получим нужное. К тому же другие подумают, прежде чем повторять. И сочинители, и переводчики. Но язык Гомера слишком дорог. Столько же, сколько и его голова. Поэтому для начала выколи ему глаза, а там посмотрим. Смешно будет слушать, как он распинается и поёт о том, чего больше не видит.\n\t\t\t\t\t\t- Последую некоторым из легенд и выберу Киму в Эолиде как родину Гесиода, а Гомер будет из неподалёку лежащей Смирны в Ионии. Позже Гомер переезжает на остров Хиос, где и проводит большую часть жизни.\n\t\t\t\t\t\t- В соревновании поэтов Гесиод побеждает, потому что он поёт о мире, а Гомер - о войне. На самом деле, не Труды и дни выигрывают, а Теогония. Гесиод просто желал, чтобы люди запомнили его автором первого произведения.\n\t\t\t\t\t\t- Рея скрывала Зевса у кретян. Зевс дал слово, что вернёт им славу. Но он ур-трикстер. Он выколол глаза Гомеру за упоминание Эры Титанов как лучшей и приказал ему и остальным рапсодам читать I 396–406; VIII 477–83.\n\t\t\t\t\t\t- -- Я вижу иногда как мы с тобой сидим за этим столом за кружкой вина цвета моря. А вино, разбавленное дружеской беседой, слаще нектара. Мы спорим о том, голоса каких рапсодов подходят нашим поэмам. Но есть Олимп... Правдолюбу даже храп тирана на его далёкой горе мешает.\n\t\t\t\t\t\t  id:: 680560d8-f44e-4a73-9ca1-6514323cd80d\n\t\t\t\t\t\t  -- Вину я вкуса не прибавлю. Но поболтать я с тобой всегда рад. Ты царь слова и на земле, и на Олимпе.\n\t\t\t\t\t\t  -- Всем известно, что это звание присудили тебе. Загвоздки же суть в непубличном.\n\t\t\t\t\t- Неграмотные рассказывают. Их беседы не записываются, а пересказы недостоверны.\n\t\t\t\t\t\t- Победители напишут и твое прошлое, если ты неграмотен.\n\t\t\t\t- #+BEGIN_QUOTE\n\t\t\t\t  Разум человеческий владеет тремя ключами, открывающими все: цифрой, буквой, нотой. Знать, думать, мечтать. Все в этом.\n\t\t\t\t  #+END_QUOTE\n\t\t\t\t  Виктор Гюго\n\t\t\t\t\t- Орфей принёс в Македонию лиру.\n\t\t\t\t\t\t- Чтение нараспев как предпосылка музыки\n\t\t\t\t\t\t\t- Орфические гимны, т.е. религия\n\t\t\t\t\t\t\t\t- \"Пусть себе поют гимны Олимпу. О делах житейских им не надо беспокоиться. Не их дело, а наше. Всех и каждого жизни научим. Если на том свете они ждут Орфея, то на этом их хоть в зад дери - не почешутся. Но есть такие, которым одного мира мало. И тут, и там им надо успеть. Вот их я больше спартанцев боюсь.\"\n\t\t\t\t\t\t\t\t\t- {{embed ((685eaedb-34cd-42f0-9388-03df01503d72))}}\n\t\t\t\t\t\t\t\t- Культ Диониса был предверием Орфизма. Власть использует религию, как шулер алкоголь - чтобы сидящие напротив не загадывали вперёд.\n\t\t\t\t\t\t- Устное слово + нота\n\t\t\t\t\t\t\t- Курируется Минкультом.\n\t\t\t\t\t\t- Катабасис\n\t\t\t\t\t\t\t- Круговое перерождение Персефоны в Элевсинских мистериях идёт по Эону. А конечное teletē (τελετή) Орфея и особенно Диониса, освобождение от перерождения сродни нирване, - по Хроносу.\n\t\t\t\t\t\t- Басня о солдате, потерявшем богов и которому всё стало дозволено\n\t\t\t\t\t\t\t- После сражения он грабит все могилы воинов, забрав оболы Харона и золотые тотенпасы. За обол можо было купить примеро булку хлеба.\n\t\t\t\t\t- Кадм научил фивян алфавиту.\n\t\t\t\t\t\t- Письменное слово\n\t\t\t\t\t\t\t- Рукописи воспроизводимы, поэтому их нужно изымать и сжигать.\n\t\t\t\t\t\t\t- Письмо - это мост не только между людьми одного языка, но и разных.\n\t\t\t\t\t\t\t- Размышления о переводе\n\t\t\t\t\t\t\t\t- \"Любому, кто переведёт это на греческий, я оторву голову.\"\n\t\t\t\t\t\t\t\t\t- ... чтобы не выносить сор из избы.\n\t\t\t\t\t\t\t\t\t- -- Скромность - не твоя добродетель. Думаешь, какой-то грек купит это говно, прочитает его, а затем станет переписывать на варварский, чтобы ещё больше людей восторгалось им?\n\t\t\t\t\t\t\t\t\t  -- Иначе и не сел бы писать.\n\t\t\t\t\t- Король Ливии Данай убежал от брата Египта в Аргос, раскрыв местным коммерческие тайны исчисления и судоходства.\n\t\t\t\t\t\t- Письменное слово + цифра\n\t\t\t\t\t\t\t- Вне цензуры, поэтому не следует уделять цифре много внимания.\n\t\t\t\t\t\t\t- Фундаментальная математика\n\t\t\t\t\t\t\t\t- \"Плевать мне на этих блаженных, а им на нас тем паче.\"\n\t\t\t\t\t\t\t- Прикладная математика\n\t\t\t\t\t\t\t\t- \"Вот полетит стрела по прямой линии, вот станет она больше во сто крат... Настолько огромной, что приземлившись будет сметать фалангу. Да хоть полис. Суть лишь в том, в чьих руках лук.\"\n\t- Пока он был прикован\n\t  collapsed:: true\n\t\t- Хаос 1\n\t\t\t- Ходят по-разному.\n\t\t\t- -- Мы сыграем в игру, которую люди еще не придумали.\n\t\t\t  id:: 68dc5870-132d-4e2c-bb4c-0fd1f9084334\n\t\t\t- Интересен гипотетический контраст линейного Хроноса с цикличным Эоном и их борьба. Они шахматные противники. Эона интересует только миттельшпиль и тактика.\n\t\t- Не должна быть первой главой, чтобы не решили, что вся книга - это феминистская ревизия истории.\n\t\t- Олимп и человечество - до летоисчисления вместо до вашей эры или до огня\n\t\t\t- Infinite chess\n\t\t\t- Возложи на нее часть вины.\n\t\t\t- Гефест и Прометей\n\t\t\t\t- Гефест\n\t\t\t\t\t- Легенда об Эрихтонии - это сокрытие инцеста Посейдона и Афины. Образ девственно зачатой и девственной дочери важен для Зевса. Поэтому испугавшись гнева Зевса, Посейдон и Гера назначают козлом отпущения Гефеста. Он и сам на это соглашаются, так как Афродита обещают ему своё руку, но не сердце, как мы узнаём позже. Не потому ли его столкнули с Олимпа.\n\t\t\t\t\t- \"It was a moment of sweet revenge for Hephaestus, but his essential good nature kept him from gloating. Despite – or perhaps because of – the pangs of rejection he had endured all his life, he was motivated not by anger or resentment but only by a desire to please, to make himself useful and give delight. He knew that he was ugly and he knew Aphrodite did not love him. He knew that if he claimed her as his prize she would betray him and slip often into the bed of his brother Ares. But he was simply happy to be home.\" (Fry, Stephen. *Mythos*)\n\t\t\t\t- Прометей\n\t\t\t\t\t- \"Для чего ты дал им огонь? Чтобы они придумали атомную бомбу?\"\n\t\t\t\t\t\t- Обыграно в фильме Оппенгеймер.\n\t\t\t\t\t- \"Я сын Прометея, который (длинная серия придаточных предложений). Я дочь Прометея, который (длинная серия придаточных предложений).\"\n\t\t\t\t\t- Важно, чтобы человечество знало, что он страдает. Поначалу он, наверное, даже получал удовольствие от своих мучений.\n\t\t\t\t\t- Ему хотелось бы быть смертным, чтобы умереть ради человечества.\n\t\t\t- Навальный\n\t\t\t\t- Вернулся, чтобы зажечь в народе порыв к свободе. Ему даже не сказали \"Спасибо\". А ему оно было так нужно.\n\t\t\t- ((66d3325b-6610-42cf-9cca-88c34afc0264))\n\t\t\t- \"Потому что он герой, которого Готэм заслуживает, но не тот, который нужен городу сейчас.\" Неважно, какой герой превращается в созвездие, главное, чтобы людям было куда смотреть.\n\t- Хаос 2\n\t\t- Диалектика Хроноса\n\t\t\t- ((b6329711-bd47-434b-8e33-fcd78b787bad))\n\t\t\t- Неравенства\n\t\t\t\t- Классовое\n\t\t\t\t- Гендерное\n\t- Петля спирали: Минойская и Микенская цивилизации\n\t\t- Alice chess\n\t\t- Сначала было слово. Нет, сначала была немая истина.\n\t\t\t- Цензура не всегда следует первому неудобному слову, иногда она его упреждает и сама есть первое слово.\n\t\t\t- Китера - центр пропаганды из-за удобного его расположения. Сразу за островом находится материк. Маяк на острове светит даже днём, лишая возможности произносить то, что происходит на крите, а также существование самого маяка, чтобы не прознал Безымянный. К огню добавляет субстанцию каждые тысячный критянин, чтобы горело. Первый костер был такого размера, что всем на острове его было видно. Тогда и забыли бога, давшему Криту атрефакты. Можно маяк безнаказанно обогнуть, но никто не хочет этого делать.\n\t\t- Золотой век богов\n\t\t- Эры\n\t\t\t- Критская эра\n\t\t\t\t- Минойская цивилизация - это эксперимент наивного Прометея.\n\t\t\t\t- Фестский диск - двухмерная логарифмическая спираль Хроноса с влагалищем-розеткой посередине и символ прогресса человечества. Фестский член-цилиндр - винтовая линия или двойная спираль Эона в трёхмерном пространстве, которая символизирует жизнь. Гендерный образ обоих артефактов контрастирует с их смыслом.\n\t\t\t\t- Прометей передал два Фестских артефакта критянам на условии того, что те будут уважать природу и ими будет править анакт, священник-король, а посредником с Космосом будет Вторая Потния, викарий Потнии Терон. Царь Загрей хранит зашифрованный диск, а потнифия Персефона - ключ в виде члена. Потнии должны делать маковые приношения, не забывая, что для самих людей мак - это запретный плод. Ещё одним условием является равенство людей, что было нарушено долговым рабством.\n\t\t\t\t- На Крите сегрегация полов. Мужчины - носители прогресса, а женщины - хранительници природы и очага. К этому пришли, потому что разделение полов и труда между ними было реализовать легче, чем предитовать одинаковые права мужчинам и женщнам в общем пространстве.\n\t\t\t\t- Есть ещё опция: поделиться секретами диска. Но тогда бы они потеряли фору. Один рывок цивилизации с невзламываемым ядром - и они гегемоны Средиземного моря. Среди прочего их мзда включает человеческие жертвоприношения. Критяне нарушают принцин неприкосновенности природы, так как человек - её часть.\n\t\t\t- Микенская эра\n\t\t\t\t- Микенцы украдкой добираются до артефактов. Они не могут его использовать, потому что не умеют читать. Они кидают жребий, кто будет учиться грамоте. Ключ достаётся самому слабому, а диск самому хитрому. Самый \"тупой\", не будучи готовым учить картинки, лишает всех возможности сделать это, отобрав ключ и разбив его.\n\t\t\t\t- Насилуют последнюю Вторую Потнию, Персефону, и расчленяют первого Диониса, Загрея. В конце отдают священному быку, Минотавру. Появляется прототип орфиков, дионсийский культ. Для имитации катабасиса они употребляют мак.\n\t\t\t- ~~Дорийское нашествие~~ Доклассическая гегемония Спарты и игры Олимпийцев\n\t\t\t\t- Потомки Гераклидов, дорийцы, уничтожают Микены и превращают их пантеон в своих илотов. Арес нагнул Эниалия. Позже распространяется миф о дорийском нашествии и их расовом превосходстве.\n\t\t\t\t- То, что она сменила одежду, подразумевает то, что ее изнасиловали.\n\t\t\t- Тёмные века... Тут и сказке конец, а кто выжил - молодец.\n\t\t- Вода камень точит - в его щелях история волн.\n\t- Хаос 4\n\t\t- Махия в себе\n\t\t\t- Диалог Платона «Федр»\n\t\t\t\t- Во время гона время выходит из-под их контроля.\n\t\t\t\t\t- \"Читал я тут Платона. Людям легко: конский член не меж возничих ног.\"\n\t- Дежавю анахронизма: эллинская цивлизация\n\t  collapsed:: true\n\t\t- Присоединить к последней главе?\n\t\t- Если бы не последняя глава, для которой эта служит контекстом, от нее можно было бы избавиться.\n\t\t- Peasants' Revolt\n\t\t- Структура древнегреческого театра\n\t\t\t- Парод, эпизоды, стасимы\n\t\t- Ребенок пришел с театра домой, где и произошла встреча.\n\t\t\t- Переводчик главы - наш современник и по сути ее соавтор.\n\t\t- Пропаг и Теролексий\n\t\t\t- Пропаг\n\t\t\t\t- Προπᾰγής /pro.pa.ɡɛ̌ːs/ from [πρό] (*pró*, “before”) +‎ [πήγνυμι] (*pḗgnumi*, “set\").\n\t\t\t\t- Прометей - кумир его отца, который нарёк сына Пропагом. Как и каждый отец, он надеялся, что сын превзойдёт его. Он будет не только думать заранее, но и действовать так.\n\t\t\t\t- Император постановил, что Пропаг не имеет права где-либо зваться по имени или должности - иначе пропаганда не будет эффективной. Противодействие начинается с определения того, против чего ты. Поэтому он использовал имена для каждых собеседников или публики разные, зачастую оскорбляющие слушающих или издевающиеся над именами тех. Например, \"Спарта-имела-Фивы\". Его единственной сверхсилой, за которую он заплатил чувством запаха, был запрет на упоминание его другим именем, поэтому об этих беседах умалчивали. Отчитывается перед Гермесом как представителем интересов Олимпа на Земле.\n\t\t\t\t- Играет свадьбу в день свадьбы сына императора, потому что в тот день раздавали молодожёнам деньги. Он как посвящённый в закулисные секреты, знал об этом. В свою брачную ночь зачал сына, которого назвал в честь своего учителя риторики, который часто цитировал Платона: \"...я только и делаю то, что хожу и убеждаю вас, и молодых и старых, не заботиться ни о теле, ни о деньгах прежде всего и так сильно, как заботиться о душе, чтобы она была, как можно лучше. И говорю я вам: „Не от денег добродетель рождается, а от добродетели и деньги, и все прочие блага для людей и в частной жизни и в общественной\". (Апология Сократа, 30b)\n\t\t\t\t- Фанат комедии, когда дело касается театра\n\t\t\t- Теролексий\n\t\t\t\t- θηρολέξης /te.ro.le.kse:s/ - word-chaser from [θήρα] (thḗrā, \"hunting\") + λέξῐς (léxis, \"word\"), любитель красного словца; тот, кто изощряется в словах.\n\t\t\t- -- Мы живём во время, когда история чертит недвусмысленные границы.\n\t\t\t  -- Главное, не преступать линию невозврата.\n\t\t\t  -- Твой страх и корысть передвигали её так часто, что вы уже и не вспомните, где эта линия была с самого начала.\n\t\t\t- \"Варвары присвоили себе наше прошлое. Они переписали нашу Илиаду.\"\n\t\t\t- Когда возвращются к себе, оба пишут друг о друге. Пропаг строчит компромат, и он же фигурирует в Священном палимпсесте у Теролексия.\n\t\t\t- Присутсвие раба подчёркивает, что \"досуг - это роскошь, а культура и науки - следствие экспуатации классов и других наций.\"\n\t\t\t- В Афинах есть храмы Геи, Кроноса и Зевса. А клянуся зачатую Ураном.\n\t\t\t\t- Пропаг - также скульптор. Изваял царя-бога Александра и кумира Демосфена. Спрятал вторую статую после Хремонидовой войны.\n\t\t\t- Когда был в Александрийской библиотеке, Пропаг посвятил поэму Птолемею и преклонился перед статуей его и его сестры-жены Theoi Adelphoi.\n\t\t\t- Тиран-демагог дарит внушительную сумму денег празднующим свадьбу в день женитьбы своего сына. Те, кто ближе к нему, узнают о такой будущей щедрости и приурачивают свою свадьбу подобным образом. Возможно, зачатие некоторых детей случилось на деньги тирана. Тиран умрет, а род Пропага продолжится.\n\t\t\t- Корабль дураков - это аллегория из Республики Платона.\n\t\t\t\t- У Пропага есть амфора или кратер с изображением корабля. Он любит связывать сосуд с платоновской аллегорией.\n\t\t\t\t\t- -- Почему аллегория?\n\t\t\t\t\t  -- Потому что не герой.\n\t\t\t\t\t- или\n\t\t\t\t\t  -- Почему ты разговариваешь намёками? Лишь страдание и наказание превращают слово в реальность и доказывают честность произносящего его. Иначе это лишь пустословие.\n\t\t\t- - Больше не буду якшаться с тобой, пока от меня запахло твоими деньгами, теми, которые не пахнут.\n\t- Хаос 5\n\t\t- Будущее время\n\t\t- - Мы знаем с кем из них мы смогли бы сыграть в шахматы, будь они даже игроками получше нас с тобой, но не в жизнь не разделили бы амфору вина.\n\t\t- Обсуждают пьесу Теролексия.\n\t- Пролог эпилога\n\t  collapsed:: true\n\t\t- 5D Chess with Multiverse Time Travel\n\t\t- Я говорю с бумагой. И она не молчит.\n\t\t- Субверсия дисса\n\t\t- Сравение того, что слышали, что было сказано и что было в намерениях. Я пишу письмо, чтобы то, что ты услышишь, а вернее прочитаешь, было ближе к правде.\n\t\t- Письмо\n\t\t\t- Разбить многоточиями на несколько дней.\n\t\t\t- Заученные оправдания, заимствованные из нового круга друзей.\n\t\t\t\t- По части морали вы в помойке. Но новые блага и привилегии позволяют вам смотреть на остальных сверху вниз. Но даже в в плане морали некоторым из вас важно видеть себя в выгодном ключе.\n\t\t\t\t\t- \"Главное, не пересекать красные границы.\"\n\t\t\t\t\t\t- Ты не нырнул в канаву. Сначала ты постоял рядом. Не стал спускаться, потому что чувствовал запах. Привыкнув к нему, ты спустился в канаву. Подружился с теми, кто там. А друзья ведь не могут быть подлецами.\n\t\t\t\t\t\t\t- А когда ты обзаведешься детьми, то у тебя и последнее сомнение пропадет. Ведь каждый отец - образец для подражания, а твои дети не могут быть отпрысками подлеца. Заметь, я не называю их наследниками. У них своя дорога в жизни. Но ты, блага вашего дома, их статус в обществе будут для препятствием в поиске правды.\n\t\t\t\t\t- У них изначально не было принципов, и им нечего было продавать. Ты же продал свои. Это не смена парадигмы, а сделка.\n\t\t\t\t\t- У тех, кому надлежить проверять книги на крамолу, не могут не просыпаться противоречия мыслях. Ведь одни достаточны умны, чтобы увидеть крамолу, потому что знают, как власть имущие попирают нравы, зачастую лучше среднего человека. Но в чувства этот диссонанс не переходит, потому что либо совесть заснула, либо никогда не просыпалась. Ты из первых. У обеих категорий гнет позволяет стать гражданином несколькими ступенями, чем они были бы при обычном состоянии дел, когда слово сбодно.\n\t\t\t- Непродуманная и хаотичная часть\n\t\t\t\t- Из-за болезни я живу впечатлениями от моментов девятилетней давности: а именно последними беседами. В начале недуга они были в основном позивные, но со временем болезнь обострилась и оставила только окрашенное черным. Поначалу в архиве моего разума были песни. Я не умел петь, но любил слушать. Также меня будоражили танцы. Из-за стеснения я им не научился. Только наблюдал. Но зачем было учиться.  Встал в круг, взялся за руки - и танцуй. Безусловно, я выделялся бы в кругу своей несуразностью. Но зато я был бы в первом ряду. Да что там в первом ряду - на сцене!\n\t\t\t\t- Я ненавижу тебя несоразмерно тому, что ты делаешь. Ты стал для меня символом сегодняшней несправедливости в Афинах, персонификацией неправедного слова. Ты являешь его мне, как Нюкта - ночь, Гемера - день. Нет! Как Нюкта - ночь, Эреб - мрак, Эрида - раздор, так ты для меня искажение истории прошлого и лжесвидетельства настоящего в угоду тем, кто платит тебе за это. Я ненавижу себя за ненависть к тебе. Твоя смена знамени последовала пару лет спустя после моей болезни, С тех пор я брызжу желчью, а в моих венах течет яд. Но искажает ли он реальность? Или как линза, делает несправедливость нашего времени более явными? Ведь живем-то мы не в славные времена. В любом случае я преломляю мое негодование на положение дел именно через тебя, мое последнее крупное и мрачное столкновение с темной стороной этого мира. Которая пока выигрывает.\n\t\t\t\t\t- Я себе противен, когда я рядом с тобой. Ведь если ты не чуешь, что поющие оды не по заслугам, - говно, значит, от тебя несёт тем же.\n\t\t\t\t- Каждый раз, когда ко мне заходил гость, я понимал по его неловкости всю скудность и неопрятность моего жилья. Никто больше не навещает меня. В этом нет их вины: человека, которого они знали, больше нет.\n\t\t\t- Трагедия не поставлена. Просто Пропаг прочёл черновик.\n\t\t\t\t- Я хотел написать трагедию под псведонимом. Под ним я был адептом, врал о красной гривне, под ней пишу трагедию и письмо.\n\t\t\t\t- -- Трагедия обо мне?\n\t\t\t\t  -- Я виноват, что ты сподвиг меня на написание пьесы? Если бы тебя в ней не было, я бы солгал себе и читателям. Мне стоиля написать книгу ради одного лишь эпиграфа.\n\t\t\t\t  -- Значит, обо мне.\n\t\t\t\t  -- Прошлое можно переписать, но всё равно ты будешь знать правду. Правда будущего создаётся сегодня в настоящем. Если ты не занимаешься больше воспеванием тех, кого ты когда-то презирал, и раскаялся, что сделать никогда не поздно, то нет. Если же к твоей душе всё ещё привязан ценник и останется там, то я тебя увековечил.\n\t\t\t\t\t- Со времени разговора все могло поменяться. Когда ты прочитал трагедию, ты был раздосадован. Месяц спустя я уехал из Афин, попрощался с тобой и сказал тебе, что нас больше ничего не объединяет. Ты ответил, что я не первый с кем твои пути разошлись. Возможно, уже в тот день была тебе смешна твоя реакция на трагедию. Вдруг, узнав о моей болезни, ты нашел объяснение таким нелепым промахам в моей работе, вплоть до орфографических ошибок. Что я не смогу закончить начатое. Может, к тому дню тебе стало наплевать на меня, на свои былые принципы и на то, что ты посчитал свое новое призвание по молодой наивности как компромисс с совестью, а не как само собой разумеющееся. Я искал в твоем лице доказательств об обратном, но не нашел ничего кроме равнодушия, как впрочем и на главных воротах нашего некогда великого города.\n\t\t\t\t- Я писал пьесу девять лет из-за мозгового тумана. Я грежу тем днем, когда я увижу свою пьесу в театре. Не знаю для чего больше: славы, гонорара, катарсиса или дани истине. Проведем эксперимент, в котором мне предоставлен выбор. Либо я увижу воплощение написанного, прослыву мастером, получу солидный гонорар, который положит конец безденежью или даже вылечит меня. Либо умру в нищете, преследуемый призраками несбывшегося, а о смерти моей узнают через несколько дней по смраду моего тела, но застану победу демоса. Все лучше, чем жизнь твоя и жизнь тебе подобных.\n\t\t\t\t\t- Да отстань уже от меня. Мне этот катарсис нужен больше, чем тебе твои деньги.\n\t\t\t- То, что выше, я написал тебе впопыхах и с обидой две недели назад. Я хотел его передать моему соседу, который уезжал в Афины на следующее. Боясь что он уедет без письма, я отправился к нему передать его в полночь. Громкими стуками в дверь я разбудил его. Он вышел в гневе и отпинал меня. Я рад, что он сделал это. Хоть и побои не зажили, мой рассудок вернулся. Стыдно перечитывать письмо, и первым порывом было сжечь его и переписать. Но можем ли мы меняться в лучшую сторону, если не будем признавать свои ошибки?\n\t\t\t\t- Впервые, я обратил на тебя внимание в нашей Академии, когда учитель попросил у нас пример любимой метафоры. Ты поднял руку и ответил, что для тебя это был феникс. Я в своем уме дал тот же ответ, но постеснялся поднимать руку. Ты вообще всегда претворял только что задуманное в жизнь, пока я анализировал возможные варианты развития событий, их успеха и провала, реакцию на них или ее отсутствие. В твоем сердце всегда пылал палящий зной. Если сейчас он угнетает в чужих руках наших земляков, то раньше этот жар превращался в тепло достигнув сердец тех, кто был рядом. Такие люди могут переродиться с большим пылом как во что-то светлое, так и в темное. Новая фаза луны всегда определяется старой. В этот раз ты сможешь вернуться к старым идеалам с новым опытом. Человек может измениться несколько раз за жизнь, но в отличие от луны и феникса человек он может переродиться в оставленное им однажды только раз.\n\t\t\t\t\t- Я всегда называл твои литературные вкусы эзоповскими. Если книгу нельзя было закончить словами: \"Мораль сей басни такова.\", то зря читал, выходило. В каждой сатире есть мораль, поэтому ты зачитывался и перечитывал Аристофана. Ты же всегда подшучивал, что для меня слово имеет смысл, только если я увижу его там. Каждое такое слово - кирпич, предложение - ряд из них, страница - стена. И после того, как я прочту книгу, я не смогу заснуть без крыши над головой. Поэтому я любил n, так как он недвусмысленно разрешал x. Но провидцем для меня был Аристотель, у которого все по полочкам. Мы вечно спорили, какой Аристо лучше, кто видит этот мир правильней.\n\t\t\t\t\t\t- Твоей любимой нравоучтельноной сатирой была n.\n\t\t\t\t\t- Если ты уже изменился, то я, к счастью, зря написал это письмо. Но, может, прочитав имя отправителя, ты кинешь его в костер. Наверняка, я об этом не узнаю. Но тебе будет оно известно. Даже если письмо не дойдет до тебя. Или дойдет, но ты его не прочтешь. Или ты увидишь мою драму. Или ее поставят, но ты не придешь.\n\t\t- Путешествие в Гиперборею.\n\t\t\t- Гекатей Абдерский прав, что она находится в Британии.\n\t\t\t- Теролексий соврал, что приехал с якобы подаренным кельтским вождём торквесом,  который на самом деле нашёл его на поле сражения, когда на них напало соседнее племя, только в Греции поняв, что обладаеля обезглавили. Он не сбежал и не бился, а просто стоял как вкопанный.\n\t\t\t- За Тирасом торквес называется гривной, и у вождя такого же статуса она красная.\n\t\t- id:: 685eaedb-34cd-42f0-9388-03df01503d72\n\t\t  #+BEGIN_QUOTE\n\t\t  Каким образом Ты, правящий миром, Тобою созданным, объясняешь душам будущее? А Ты объяснял его пророкам Своим. Каким же образом объясняешь Ты будущее, Ты, для Которого будущего нет? или, вернее, через настоящее объясняешь Ты будущее? Ибо того, чего нет, никак невозможно объяснить. Не так остры глаза мои, чтобы рассмотреть, как Ты действуешь, это выше сил моих, не могу постичь сам, но смогу с Твоей помощью, когда Ты подашь ее, сладостный свет внутреннего взора моего.\n\t\t  Совершенно ясно теперь одно: ни будущего, ни прошлого нет, и неправильно говорить о существовании трех времен: прошедшего, настоящего и будущего. Правильнее было бы, пожалуй, говорить так: есть три времени - настоящее прошедшего, настоящее настоящего и настоящее будущего. Некие три времени эти существуют в нашей душе, и нигде в другом месте я их не вижу: настоящее прошедшего - это память; настоящее настоящего - его непосредственное созерцание; настоящее будущего - его ожидание. Если мне позволено будет говорить так, то я согласен, что есть три времени; признаю, что их три. Пусть даже говорят, как принято, хотя это и неправильно, что есть три времени: прошедшее, настоящее и будущее; пусть говорят. Не об этом сейчас моя забота, не спорю с этим и не возражаю; пусть только люди понимают то, что они говорят и знают, что ни будущего нет, ни прошлого. Редко ведь слова употребляются в их собственном смысле; в большинстве случаев мы выражаемся неточно, но нас понимают.\n\t\t  #+END_QUOTE\n\t\t  Августин. *Исповедь*.\n\t\t\t- Не принимаю. Люди, живущие исключительно в настоящем аполитичны, в общем, безучастны и не влияют на будущее. Мы создаем будущее.\n\t\t\t\t- Не пленник прошлого, иногда мига, а его хозяин. Он не только разделяет жар ложа с настоящим, но и тепло очага с будущим. Он не ждёт будущего сидя, а шагает навстречу ему с уверенностью.\n\t\t\t- Слово, будь-то заготовленное или реакция на сказанное, находится в настоящем в момент произношения. Запись слов - мост с прошлым. Полезна она только в приложении к будущему.\n\t\t- Мы должны быть рады, что завтра приносит возможность измениться.\n\t\t- ((69a1ab66-70ab-473a-bf8d-94a9b6555735))\n\t- Отрывки\n\t\t- - Аресу стоило бы научиться играть в полис у своей сестры.\n\t\t- El Truco por Jorge Luis Borges - настоящее настоящее.\n\t\t- Троянская война - это пари между богами, шахматная партия, где два народа - это фигуры.",536879509]],["^15",[3495,"^16",1772635626758,536870918]],["^15",[3495,"^18","~m1775740818774",536879508]],["^15",[3495,"^Z","pages/Палимпсест времени.md",536870918]],["^15",[3496,"^K",1772635626755,536870918]],["^15",[3496,"^@",false,536870918]],["^15",[3496,"^Y","685eaedb-34cd-42f0-9388-03df01503d72",536870918]],["^15",[3496,"^11","685eaedb-34cd-42f0-9388-03df01503d72",536870918]],["^15",[3496,"^B",1772635626755,536870918]],["^15",[3496,"^;","~u69a845ea-9f1f-407d-9602-e06d15255e5b",536870918]],["^15",[3497,"^Q","Из-за болезни я живу впечатлениями от моментов девятилетней давности: а именно последними беседами. В начале недуга они были в основном позивные, но со временем болезнь обострилась и оставила только окрашенное черным. Поначалу в архиве моего разума были песни. Я не умел петь, но любил слушать. Также меня будоражили танцы. Из-за стеснения я им не научился. Только наблюдал. Но зачем было учиться.  Встал в круг, взялся за руки - и танцуй. Безусловно, я выделялся бы в кругу своей несуразностью. Но зато я был бы в первом ряду. Да что там в первом ряду - на сцене!",536870918]],["^15",[3497,"^O","^17",536870918]],["^15",[3497,"^F",3531,536870918]],["^15",[3497,"^X",472,536870918]],["^15",[3497,"^V",3531,536870918]],["^15",[3497,"^U",472,536871724]],["^15",[3497,"^;","~u69a845ea-e94d-4b12-8511-9521d75b9306",536870918]],["^15",[3498,"^Q","Feels like Dice Chess but actually Viennese Chess",536870918]],["^15",[3498,"^O","^17",536870918]],["^15",[3498,"^F",3674,536870918]],["^15",[3498,"^X",472,536870918]],["^15",[3498,"^V",3674,536870918]],["^15",[3498,"^U",472,536875938]],["^15",[3498,"^;","~u69a845ea-768b-4c62-a0a4-2c83191111d9",536870918]],["^15",[3499,"^Q","У Пропага есть амфора или кратер с изображением корабля. Он любит связывать сосуд с платоновской аллегорией.",536870918]],["^15",[3499,"^O","^17",536870918]],["^15",[3499,"^F",3535,536870918]],["^15",[3499,"^X",472,536870918]],["^15",[3499,"^V",3535,536870918]],["^15",[3499,"^U",472,536875882]],["^15",[3499,"^;","~u69a845ea-4623-4ad7-86c3-242601469da5",536870918]],["^15",[3500,"^Q","\"Я сын Прометея, который (длинная серия придаточных предложений). Я дочь Прометея, который (длинная серия придаточных предложений).\"",536870918]],["^15",[3500,"^O","^17",536870918]],["^15",[3500,"^F",3555,536870918]],["^15",[3500,"^X",472,536870918]],["^15",[3500,"^V",3571,536870918]],["^15",[3500,"^U",472,536871724]],["^15",[3500,"^;","~u69a845ea-dae5-4162-ab55-814e80857881",536870918]],["^15",[3501,"^Q","Теролексий",536870918]],["^15",[3501,"^O","^17",536870918]],["^15",[3501,"^F",3601,536870918]],["^15",[3501,"^X",472,536870918]],["^15",[3501,"^V",3518,536870918]],["^15",[3501,"^U",472,536875882]],["^15",[3501,"^;","~u69a845ea-16cb-4ef1-976c-3ba51571e353",536870918]],["^15",[3502,"^Q","Будущее время",536870918]],["^15",[3502,"^O","^17",536870918]],["^15",[3502,"^F",3678,536870918]],["^15",[3502,"^X",472,536870918]],["^15",[3502,"^V",3678,536870918]],["^15",[3502,"^U",472,536871724]],["^15",[3502,"^;","~u69a845ea-ecb4-470f-ab79-432231efbc27",536870918]],["^15",[3503,"^Q","... чтобы не выносить сор из избы.",536870918]],["^15",[3503,"^O","^17",536870918]],["^15",[3503,"^F",3692,536870918]],["^15",[3503,"^X",472,536870918]],["^15",[3503,"^V",3692,536870918]],["^15",[3503,"^U",472,536875938]],["^15",[3503,"^;","~u69a845ea-404b-4bfb-b133-3f71dbbf306c",536870918]],["^15",[3504,"^Q","Забракованные пов, которые преломляются через того, кто нашёл палимпсест, а потом уже читателя этой книги.",536870918]],["^15",[3504,"^O","^17",536870918]],["^15",[3504,"^F",3544,536870918]],["^15",[3504,"^X",472,536870918]],["^15",[3504,"^V",3707,536870918]],["^15",[3504,"^U",472,536871724]],["^15",[3504,"^;","~u69a845ea-5701-4ecc-a2c6-51bc1e6d3a27",536870918]],["^15",[3505,"^Q","Детство баловня и зрелость жертвы",536870918]],["^15",[3505,"^O","^17",536870918]],["^15",[3505,"^F",3549,536870918]],["^15",[3505,"^X",472,536870918]],["^15",[3505,"^V",3533,536870918]],["^15",[3505,"^U",472,536871724]],["^15",[3505,"^;","~u69a845ea-05ee-44d5-84e3-69db7877c5b7",536870918]],["^15",[3506,"^Q","Фестский диск - двухмерная логарифмическая спираль Хроноса с влагалищем-розеткой посередине и символ прогресса человечества. Фестский член-цилиндр - винтовая линия или двойная спираль Эона в трёхмерном пространстве, которая символизирует жизнь. Гендерный образ обоих артефактов контрастирует с их смыслом.",536870918]],["^15",[3506,"^O","^17",536870918]],["^15",[3506,"^F",3736,536870918]],["^15",[3506,"^X",472,536870918]],["^15",[3506,"^V",3532,536870918]],["^15",[3506,"^U",472,536879486]],["^15",[3506,"^;","~u69a845ea-55d1-46dc-a84c-36edfd73aef0",536870918]],["^15",[3507,"^Q","Каждый раз, когда ко мне заходил гость, я понимал по его неловкости всю скудность и неопрятность моего жилья. Никто больше не навещает меня. В этом нет их вины: человека, которого они знали, больше нет.",536870918]],["^15",[3507,"^O","^17",536870918]],["^15",[3507,"^F",3541,536870918]],["^15",[3507,"^X",472,536870918]],["^15",[3507,"^V",3531,536870918]],["^15",[3507,"^U",472,536871724]],["^15",[3507,"^;","~u69a845ea-1de6-446e-94b8-3aea5221e965",536870918]],["^15",[3508,"^Q","Нейтральная",536870918]],["^15",[3508,"^O","^17",536870918]],["^15",[3508,"^F",3602,536870918]],["^15",[3508,"^X",472,536870918]],["^15",[3508,"^V",3602,536870918]],["^15",[3508,"^U",472,536871724]],["^15",[3508,"^;","~u69a845ea-7c82-4605-9c3f-8dcd209fed46",536870918]],["^15",[3509,"^Q","Трагедия не поставлена. Просто Пропаг прочёл черновик.",536870918]],["^15",[3509,"^O","^17",536870918]],["^15",[3509,"^F",3531,536870918]],["^15",[3509,"^X",472,536870918]],["^15",[3509,"^V",3711,536870918]],["^15",[3509,"^U",472,536871724]],["^15",[3509,"^;","~u69a845ea-39c9-4a82-bfa9-347348a376bf",536870918]],["^15",[3510,"^Q","Переводчик главы - наш современник и по сути ее соавтор.",536870918]],["^15",[3510,"^O","^17",536870918]],["^15",[3510,"^F",3606,536870918]],["^15",[3510,"^X",472,536870918]],["^15",[3510,"^V",3606,536870918]],["^15",[3510,"^U",472,536875882]],["^15",[3510,"^;","~u69a845ea-4292-4ea1-a56b-7c603bc3b2df",536870918]],["^15",[3511,"^M",false,536879478]],["^15",[3511,"^Q","Петля спирали: Минойская и Микенская цивилизации",536875993]],["^15",[3511,"^O","^17",536870918]],["^15",[3511,"^F",3649,536870918]],["^15",[3511,"^X",472,536870918]],["^15",[3511,"^V",3679,536870918]],["^15",[3511,"^U",472,536871724]],["^15",[3511,"^?",["^ "],536875993]],["^15",[3511,"^;","~u69a845ea-a578-46b3-a6f7-af750252fc3e",536870918]],["^15",[3512,"^Q","Косвенный, сдержаный",536870918]],["^15",[3512,"^O","^17",536870918]],["^15",[3512,"^F",3643,536870918]],["^15",[3512,"^X",472,536870918]],["^15",[3512,"^V",3643,536870918]],["^15",[3512,"^U",472,536871724]],["^15",[3512,"^;","~u69a845ea-e357-4475-bbec-5938fbda3282",536870918]],["^15",[3513,"^Q","Вне цензуры, поэтому не следует уделять цифре много внимания.",536870918]],["^15",[3513,"^O","^17",536870918]],["^15",[3513,"^F",3703,536870918]],["^15",[3513,"^X",472,536870918]],["^15",[3513,"^V",3703,536870918]],["^15",[3513,"^U",472,536875938]],["^15",[3513,"^;","~u69a845ea-ecd1-499c-87ba-5fdfa4b2ffcf",536870918]],["^15",[3515,"^Q","Драма",536870918]],["^15",[3515,"^O","^17",536870918]],["^15",[3515,"^F",3602,536870918]],["^15",[3515,"^X",472,536870918]],["^15",[3515,"^V",3690,536870918]],["^15",[3515,"^U",472,536871724]],["^15",[3515,"^;","~u69a845ea-4e47-4907-bd22-2824c776eb34",536870918]],["^15",[3516,"^Q","-- Мы живём во время, когда история чертит недвусмысленные границы.\n-- Главное, не преступать линию невозврата.\n-- Твой страх и корысть передвигали её так часто, что вы уже и не вспомните, где эта линия была с самого начала.",536870918]],["^15",[3516,"^O","^17",536870918]],["^15",[3516,"^F",3501,536870918]],["^15",[3516,"^X",472,536870918]],["^15",[3516,"^V",3518,536870918]],["^15",[3516,"^U",472,536875882]],["^15",[3516,"^;","~u69a845ea-296a-48bf-8255-74088c41270f",536870918]],["^15",[3517,"^Q","Люди оседлали необуздаемое, время. Вожжи - в руках наездниках, но удила - не в зубах лошади.",536870918]],["^15",[3517,"^O","^17",536870918]],["^15",[3517,"^F",3646,536870918]],["^15",[3517,"^X",472,536870918]],["^15",[3517,"^V",3704,536870918]],["^15",[3517,"^U",472,536871724]],["^15",[3517,"^;","~u69a845ea-a74f-4d0c-bf4a-f2dd7d6bc18b",536870918]],["^15",[3518,"^Q","Пропаг и Теролексий",536870918]],["^15",[3518,"^O","^17",536870918]],["^15",[3518,"^F",3606,536870918]],["^15",[3518,"^X",472,536870918]],["^15",[3518,"^V",3739,536875881]],["^15",[3518,"^U",472,536875878]],["^15",[3518,"^;","~u69a845ea-b44f-48cb-81f0-3aa20a3e807c",536870918]],["^15",[3519,"^Q","Слово, будь-то заготовленное или реакция на сказанное, находится в настоящем в момент произношения. Запись слов - мост с прошлым. Полезна она только в приложении к будущему.",536870918]],["^15",[3519,"^O","^17",536870918]],["^15",[3519,"^F",3695,536870918]],["^15",[3519,"^X",472,536870918]],["^15",[3519,"^V",3581,536870918]],["^15",[3519,"^U",472,536871724]],["^15",[3519,"^;","~u69a845ea-6247-42d7-b56d-6d9eb8744bb9",536870918]],["^15",[3520,"^Q","Рея скрывала Зевса у кретян. Зевс дал слово, что вернёт им славу. Но он ур-трикстер. Он выколол глаза Гомеру за упоминание Эры Титанов как лучшей и приказал ему и остальным рапсодам читать I 396–406; VIII 477–83.",536870918]],["^15",[3520,"^O","^17",536870918]],["^15",[3520,"^F",3633,536870918]],["^15",[3520,"^X",472,536870918]],["^15",[3520,"^V",3600,536870918]],["^15",[3520,"^U",472,536875938]],["^15",[3520,"^;","~u69a845ea-bb6e-4650-bbb5-35e1ab201eca",536870918]],["^15",[3521,"^Q","~~~Дорийское нашествие~~ Доклассическая гегемония Спарты и игры Олимпийцев",536870918]],["^15",[3521,"^O","^17",536870918]],["^15",[3521,"^F",3669,536870918]],["^15",[3521,"^X",472,536870918]],["^15",[3521,"^V",3691,536870918]],["^15",[3521,"^U",472,536879486]],["^15",[3521,"^;","~u69a845ea-7534-4d61-87ab-8334aaaaab8f",536870918]],["^15",[3522,"^Q","Есть ещё опция: поделиться секретами диска. Но тогда бы они потеряли фору. Один рывок цивилизации с невзламываемым ядром - и они гегемоны Средиземного моря. Среди прочего их мзда включает человеческие жертвоприношения. Критяне нарушают принцин неприкосновенности природы, так как человек - её часть.",536870918]],["^15",[3522,"^O","^17",536870918]],["^15",[3522,"^F",3618,536870918]],["^15",[3522,"^X",472,536870918]],["^15",[3522,"^V",3532,536870918]],["^15",[3522,"^U",472,536879486]],["^15",[3522,"^;","~u69a845ea-ebc9-4b15-9412-21fc67c49aa9",536870918]],["^15",[3523,"^Q","Ребёнок, сын Тералексия",536870918]],["^15",[3523,"^O","^17",536870918]],["^15",[3523,"^F",3709,536870918]],["^15",[3523,"^X",472,536870918]],["^15",[3523,"^V",3504,536870918]],["^15",[3523,"^U",472,536871724]],["^15",[3523,"^;","~u69a845ea-e2cc-4e04-9944-38a346afab59",536870918]],["^15",[3524,"^Q","Тёмные века... Тут и сказке конец, а кто выжил - молодец.",536870918]],["^15",[3524,"^O","^17",536870918]],["^15",[3524,"^F",3521,536877490]],["^15",[3524,"^X",472,536870918]],["^15",[3524,"^V",3691,536870918]],["^15",[3524,"^U",472,536879486]],["^15",[3524,"^;","~u69a845ea-8a0b-442f-825a-90196c4e8b89",536870918]],["^15",[3525,"^Q","Разные времена",536870918]],["^15",[3525,"^O","^17",536870918]],["^15",[3525,"^F",3615,536870918]],["^15",[3525,"^X",472,536870918]],["^15",[3525,"^V",3615,536870918]],["^15",[3525,"^U",472,536871724]],["^15",[3525,"^;","~u69a845ea-9c7e-433d-ae00-d143c2534d75",536870918]],["^15",[3526,"^Q","Проза высокого стиля повествователем низкого социального",536870918]],["^15",[3526,"^O","^17",536870918]],["^15",[3526,"^F",3527,536870918]],["^15",[3526,"^X",472,536870918]],["^15",[3526,"^V",3573,536870918]],["^15",[3526,"^U",472,536871724]],["^15",[3526,"^;","~u69a845ea-5127-4e6b-9ee2-e5ac59707f12",536870918]],["^15",[3527,"^Q","В виде разговора, где много \"мы\" от третьего лица",536870918]],["^15",[3527,"^O","^17",536870918]],["^15",[3527,"^F",3573,536870918]],["^15",[3527,"^X",472,536870918]],["^15",[3527,"^V",3573,536870918]],["^15",[3527,"^U",472,536871724]],["^15",[3527,"^;","~u69a845ea-91d2-473d-b722-10b935927b84",536870918]],["^15",[3528,"^Q","Поток сознания",536870918]],["^15",[3528,"^O","^17",536870918]],["^15",[3528,"^F",3738,536870918]],["^15",[3528,"^X",472,536870918]],["^15",[3528,"^V",3738,536870918]],["^15",[3528,"^U",472,536871724]],["^15",[3528,"^;","~u69a845ea-a097-48ea-b1a5-31dd728b4a70",536870918]],["^15",[3529,"^Q","Обсуждают пьесу Теролексия.",536870918]],["^15",[3529,"^O","^17",536870918]],["^15",[3529,"^F",3635,536870918]],["^15",[3529,"^X",472,536870918]],["^15",[3529,"^V",3678,536870918]],["^15",[3529,"^U",472,536871724]],["^15",[3529,"^;","~u69a845ea-61ff-495f-9d29-d2c30e029ddf",536870918]],["^15",[3530,"^Q","Диалектика Хроноса",536870918]],["^15",[3530,"^O","^17",536870918]],["^15",[3530,"^F",3649,536870918]],["^15",[3530,"^X",472,536870918]],["^15",[3530,"^V",3649,536870918]],["^15",[3530,"^U",472,536871724]],["^15",[3530,"^;","~u69a845ea-d540-4ecf-89b7-8061c33dd41d",536870918]],["^15",[3531,"^Q","Непродуманная и хаотичная часть",536870918]],["^15",[3531,"^O","^17",536870918]],["^15",[3531,"^F",3624,536870918]],["^15",[3531,"^X",472,536870918]],["^15",[3531,"^V",3711,536870918]],["^15",[3531,"^U",472,536871724]],["^15",[3531,"^;","~u69a845ea-b777-4fb6-94da-e31775965598",536870918]],["^15",[3532,"^Q","Критская эра",536870918]],["^15",[3532,"^O","^17",536870918]],["^15",[3532,"^F",3691,536870918]],["^15",[3532,"^X",472,536870918]],["^15",[3532,"^V",3691,536870918]],["^15",[3532,"^U",472,536879486]],["^15",[3532,"^;","~u69a845ea-0cdc-41be-8890-d9784b8fc1d4",536870918]],["^15",[3533,"^Q","Свой полис и космополис",536870918]],["^15",[3533,"^O","^17",536870918]],["^15",[3533,"^F",3563,536870918]],["^15",[3533,"^X",472,536870918]],["^15",[3533,"^V",3544,536870918]],["^15",[3533,"^U",472,536871724]],["^15",[3533,"^;","~u69a845ea-4d1a-45fa-8792-44314895109b",536870918]],["^15",[3534,"^Q","За Тирасом торквес называется гривной, и у вождя такого же статуса она красная.",536870918]],["^15",[3534,"^O","^17",536870918]],["^15",[3534,"^F",3671,536870918]],["^15",[3534,"^X",472,536870918]],["^15",[3534,"^V",3718,536870918]],["^15",[3534,"^U",472,536871724]],["^15",[3534,"^;","~u69a845ea-8f4f-453f-8d94-b37c7dc0c66d",536870918]],["^15",[3535,"^Q","Корабль дураков - это аллегория из Республики Платона.",536870918]],["^15",[3535,"^O","^17",536870918]],["^15",[3535,"^F",3687,536870918]],["^15",[3535,"^X",472,536870918]],["^15",[3535,"^V",3518,536870918]],["^15",[3535,"^U",472,536875882]],["^15",[3535,"^;","~u69a845ea-51ce-479c-9002-2487dc8182f0",536870918]],["^15",[3536,"^Q","{{embed ((685eaedb-34cd-42f0-9388-03df01503d72))}}",536870918]],["^15",[3536,"^O","^17",536870918]],["^15",[3536,"^F",3625,536870918]],["^15",[3536,"^S",3743,536870918]],["^15",[3536,"^X",472,536870918]],["^15",[3536,"^V",3625,536870918]],["^15",[3536,"^U",472,536875938]],["^15",[3536,"^U",3496,536875938]],["^15",[3536,"^U",3581,536875938]],["^15",[3536,"^H",3496,536870918]],["^15",[3536,"^H",3581,536870918]],["^15",[3536,"^;","~u69a845ea-8d70-4f05-b98a-c4d92ef9b52f",536870918]],["^15",[3537,"^Q","Неравенства",536870918]],["^15",[3537,"^O","^17",536870918]],["^15",[3537,"^F",3699,536870918]],["^15",[3537,"^X",472,536870918]],["^15",[3537,"^V",3530,536870918]],["^15",[3537,"^U",472,536871724]],["^15",[3537,"^;","~u69a845ea-d783-435c-a53f-25e865558075",536870918]],["^15",[3538,"^Q","Легенда об Эрихтонии - это сокрытие инцеста Посейдона и Афины. Образ девственно зачатой и девственной дочери важен для Зевса. Поэтому испугавшись гнева Зевса, Посейдон и Гера назначают козлом отпущения Гефеста. Он и сам на это соглашаются, так как Афродита обещают ему своё руку, но не сердце, как мы узнаём позже. Не потому ли его столкнули с Олимпа.",536870918]],["^15",[3538,"^O","^17",536870918]],["^15",[3538,"^F",3583,536870918]],["^15",[3538,"^X",472,536870918]],["^15",[3538,"^V",3583,536870918]],["^15",[3538,"^U",472,536871724]],["^15",[3538,"^;","~u69a845ea-5932-4af1-87db-b417f4148e52",536870918]],["^15",[3539,"^Q","Пов-иллюстрации",536870918]],["^15",[3539,"^O","^17",536870918]],["^15",[3539,"^F",3542,536870918]],["^15",[3539,"^X",472,536870918]],["^15",[3539,"^V",3707,536870918]],["^15",[3539,"^U",472,536871724]],["^15",[3539,"^;","~u69a845ea-a4c6-408c-bdbe-0613370d972f",536870918]],["^15",[3540,"^Q","или\n-- Почему ты разговариваешь намёками? Лишь страдание и наказание превращают слово в реальность и доказывают честность произносящего его. Иначе это лишь пустословие.",536870918]],["^15",[3540,"^O","^17",536870918]],["^15",[3540,"^F",3623,536870918]],["^15",[3540,"^X",472,536870918]],["^15",[3540,"^V",3499,536870918]],["^15",[3540,"^U",472,536875882]],["^15",[3540,"^;","~u69a845ea-da6b-45d6-9e70-8e6b21b6b112",536870918]],["^15",[3541,"^Q","Я ненавижу тебя несоразмерно тому, что ты делаешь. Ты стал для меня символом сегодняшней несправедливости в Афинах, персонификацией неправедного слова. Ты являешь его мне, как Нюкта - ночь, Гемера - день. Нет! Как Нюкта - ночь, Эреб - мрак, Эрида - раздор, так ты для меня искажение истории прошлого и лжесвидетельства настоящего в угоду тем, кто платит тебе за это. Я ненавижу себя за ненависть к тебе. Твоя смена знамени последовала пару лет спустя после моей болезни, С тех пор я брызжу желчью, а в моих венах течет яд. Но искажает ли он реальность? Или как линза, делает несправедливость нашего времени более явными? Ведь живем-то мы не в славные времена. В любом случае я преломляю мое негодование на положение дел именно через тебя, мое последнее крупное и мрачное столкновение с темной стороной этого мира. Которая пока выигрывает.",536870918]],["^15",[3541,"^O","^17",536870918]],["^15",[3541,"^F",3497,536870918]],["^15",[3541,"^X",472,536870918]],["^15",[3541,"^V",3531,536870918]],["^15",[3541,"^U",472,536871724]],["^15",[3541,"^;","~u69a845ea-599c-4dbd-8580-83bf840ef051",536870918]],["^15",[3542,"^Q","Эпиграфы",536870918]],["^15",[3542,"^O","^17",536870918]],["^15",[3542,"^F",3690,536870918]],["^15",[3542,"^X",472,536870918]],["^15",[3542,"^V",3707,536870918]],["^15",[3542,"^U",472,536871724]],["^15",[3542,"^;","~u69a845ea-dd46-449d-bd0a-4406cf070e7e",536870918]],["^15",[3543,"^Q","Пиши нелинейно и рывками. Например, страница для одного художественного тропа, абзац для другой синтаксической конструкции.",536870918]],["^15",[3543,"^O","^17",536870918]],["^15",[3543,"^F",4053,536878035]],["^15",[3543,"^X",472,536870918]],["^15",[3543,"^V",3683,536877936]],["^15",[3543,"^U",472,536870918]],["^15",[3543,"^;","~u69a845ea-39a4-42c8-9122-7c86e5afaf20",536870918]],["^15",[3544,"^Q","Лейтмотив времени и его факелоносцы",536870918]],["^15",[3544,"^O","^17",536870918]],["^15",[3544,"^F",3615,536870918]],["^15",[3544,"^X",472,536870918]],["^15",[3544,"^V",3707,536870918]],["^15",[3544,"^U",472,536871724]],["^15",[3544,"^;","~u69a845ea-3c27-4427-89c5-38a115b959fc",536870918]],["^15",[3545,"^Q","Да отстань уже от меня. Мне этот катарсис нужен больше, чем тебе твои деньги.",536870918]],["^15",[3545,"^O","^17",536870918]],["^15",[3545,"^F",3554,536870918]],["^15",[3545,"^X",472,536870918]],["^15",[3545,"^V",3554,536870918]],["^15",[3545,"^U",472,536871724]],["^15",[3545,"^;","~u69a845ea-a97b-4458-ad0c-ec535f798f1c",536870918]],["^15",[3546,"^Q","А когда ты обзаведешься детьми, то у тебя и последнее сомнение пропадет. Ведь каждый отец - образец для подражания, а твои дети не могут быть отпрысками подлеца. Заметь, я не называю их наследниками. У них своя дорога в жизни. Но ты, блага вашего дома, их статус в обществе будут для препятствием в поиске правды.",536870918]],["^15",[3546,"^O","^17",536870918]],["^15",[3546,"^F",3638,536870918]],["^15",[3546,"^X",472,536870918]],["^15",[3546,"^V",3638,536870918]],["^15",[3546,"^U",472,536871724]],["^15",[3546,"^;","~u69a845ea-ef80-45e3-91ac-3836a8f2235d",536870918]],["^15",[3547,"^Q","Субверсия дисса",536870918]],["^15",[3547,"^O","^17",536870918]],["^15",[3547,"^F",4093,536879281]],["^15",[3547,"^X",472,536870918]],["^15",[3547,"^V",3611,536870918]],["^15",[3547,"^U",472,536871724]],["^15",[3547,"^;","~u69a845ea-ebcd-476b-a787-ee12ea43c1bf",536870918]],["^15",[3548,"^Q","((69a1ab66-70ab-473a-bf8d-94a9b6555735))",536870918]],["^15",[3548,"^O","^17",536870918]],["^15",[3548,"^F",3576,536870918]],["^15",[3548,"^X",472,536870918]],["^15",[3548,"^V",3611,536870918]],["^15",[3548,"^U",193,536871724]],["^15",[3548,"^U",472,536871724]],["^15",[3548,"^H",193,536870918]],["^15",[3548,"^;","~u69a845ea-716c-47f1-b5a9-9368d5853c1e",536870918]],["^15",[3549,"^Q","Крит - лавирующий дипломат и закормленный друид",536870918]],["^15",[3549,"^O","^17",536870918]],["^15",[3549,"^F",3533,536870918]],["^15",[3549,"^X",472,536870918]],["^15",[3549,"^V",3533,536870918]],["^15",[3549,"^U",472,536871724]],["^15",[3549,"^;","~u69a845ea-52b3-4587-a1ec-3adfe23f68bd",536870918]],["^15",[3550,"^Q","Зачастую история не сохраняет правду или искажает её. Даже если история не рассудит, ты сам свидетель своих действий и мыслей.",536870918]],["^15",[3550,"^O","^17",536870918]],["^15",[3550,"^F",3655,536870918]],["^15",[3550,"^X",472,536870918]],["^15",[3550,"^V",3655,536870918]],["^15",[3550,"^U",472,536877937]],["^15",[3550,"^;","~u69a845ea-f4ff-4462-9293-989fb68f9190",536870918]],["^15",[3551,"^Q","Возложи на нее часть вины.",536870918]],["^15",[3551,"^O","^17",536870918]],["^15",[3551,"^F",3634,536870918]],["^15",[3551,"^X",472,536870918]],["^15",[3551,"^V",3672,536870918]],["^15",[3551,"^U",472,536871724]],["^15",[3551,"^;","~u69a845ea-b458-4b78-b702-004dde2b0c13",536870918]],["^15",[3552,"^Q","Люди слова, одного лишь слова",536870918]],["^15",[3552,"^O","^17",536870918]],["^15",[3552,"^F",3584,536870918]],["^15",[3552,"^X",472,536870918]],["^15",[3552,"^V",3544,536870918]],["^15",[3552,"^U",472,536871724]],["^15",[3552,"^;","~u69a845ea-ad59-47a5-946c-b83b17a61e19",536870918]],["^15",[3553,"^Q","Интересен гипотетический контраст линейного Хроноса с цикличным Эоном и их борьба. Они шахматные противники. Эона интересует только миттельшпиль и тактика.",536870918]],["^15",[3553,"^O","^17",536870918]],["^15",[3553,"^F",3641,536870918]],["^15",[3553,"^X",472,536870918]],["^15",[3553,"^V",3712,536870918]],["^15",[3553,"^U",472,536871724]],["^15",[3553,"^;","~u69a845ea-be93-4efc-bbcc-25e5bba9ea86",536870918]],["^15",[3554,"^Q","Я писал пьесу девять лет из-за мозгового тумана. Я грежу тем днем, когда я увижу свою пьесу в театре. Не знаю для чего больше: славы, гонорара, катарсиса или дани истине. Проведем эксперимент, в котором мне предоставлен выбор. Либо я увижу воплощение написанного, прослыву мастером, получу солидный гонорар, который положит конец безденежью или даже вылечит меня. Либо умру в нищете, преследуемый призраками несбывшегося, а о смерти моей узнают через несколько дней по смраду моего тела, но застану победу демоса. Все лучше, чем жизнь твоя и жизнь тебе подобных.",536870918]],["^15",[3554,"^O","^17",536870918]],["^15",[3554,"^F",3658,536870918]],["^15",[3554,"^X",472,536870918]],["^15",[3554,"^V",3509,536870918]],["^15",[3554,"^U",472,536871724]],["^15",[3554,"^;","~u69a845ea-6112-4cf1-8e35-677b5b87c472",536870918]],["^15",[3555,"^Q","\"Для чего ты дал им огонь? Чтобы они придумали атомную бомбу?\"",536870918]],["^15",[3555,"^O","^17",536870918]],["^15",[3555,"^F",3571,536870918]],["^15",[3555,"^X",472,536870918]],["^15",[3555,"^V",3571,536870918]],["^15",[3555,"^U",472,536871724]],["^15",[3555,"^;","~u69a845ea-0132-46e2-bc57-c5ae26ab88bc",536870918]],["^15",[3556,"^Q","Почитай Уильяма Гэсса",536870918]],["^15",[3556,"^O","^17",536870918]],["^15",[3556,"^F",3597,536870918]],["^15",[3556,"^X",472,536870918]],["^15",[3556,"^V",3561,536870918]],["^15",[3556,"^U",472,536871724]],["^15",[3556,"^;","~u69a845ea-21cf-4b39-adbe-c3011b4495a6",536870918]],["^15",[3557,"^Q","Цензура не всегда следует первому неудобному слову, иногда она его упреждает и сама есть первое слово.",536870918]],["^15",[3557,"^O","^17",536870918]],["^15",[3557,"^F",3731,536870918]],["^15",[3557,"^X",472,536870918]],["^15",[3557,"^V",3731,536870918]],["^15",[3557,"^U",472,536875994]],["^15",[3557,"^;","~u69a845ea-3837-4c7e-9169-d34d452297ba",536870918]],["^15",[3558,"^Q","\"Варвары присвоили себе наше прошлое. Они переписали нашу Илиаду.\"",536870918]],["^15",[3558,"^O","^17",536870918]],["^15",[3558,"^F",3516,536870918]],["^15",[3558,"^X",472,536870918]],["^15",[3558,"^V",3518,536870918]],["^15",[3558,"^U",472,536875882]],["^15",[3558,"^;","~u69a845ea-4c26-4cc6-b02f-d83310a552c0",536870918]],["^15",[3559,"^Q","θηρολέξης /te.ro.le.kse:s/ - word-chaser from [θήρα] (thḗrā, \"hunting\") + λέξῐς (léxis, \"word\"), любитель красного словца; тот, кто изощряется в словах.",536870918]],["^15",[3559,"^O","^17",536870918]],["^15",[3559,"^F",3501,536870918]],["^15",[3559,"^X",472,536870918]],["^15",[3559,"^V",3501,536870918]],["^15",[3559,"^U",472,536875882]],["^15",[3559,"^;","~u69a845ea-8c66-484b-be65-b6f26cc054ec",536870918]],["^15",[3560,"^Q","Китера - центр пропаганды из-за удобного его расположения. Сразу за островом находится материк. Маяк на острове светит даже днём, лишая возможности произносить то, что происходит на крите, а также существование самого маяка, чтобы не прознал Безымянный. К огню добавляет субстанцию каждые тысячный критянин, чтобы горело. Первый костер был такого размера, что всем на острове его было видно. Тогда и забыли бога, давшему Криту атрефакты. Можно маяк безнаказанно обогнуть, но никто не хочет этого делать.",536870918]],["^15",[3560,"^O","^17",536870918]],["^15",[3560,"^F",3557,536870918]],["^15",[3560,"^X",472,536870918]],["^15",[3560,"^V",3731,536870918]],["^15",[3560,"^U",472,536875994]],["^15",[3560,"^;","~u69a845ea-0ada-4219-86e4-b31edd1d2c67",536870918]],["^15",[3561,"^Q","Параллелизм",536870918]],["^15",[3561,"^O","^17",536870918]],["^15",[3561,"^F",3717,536870918]],["^15",[3561,"^X",472,536870918]],["^15",[3561,"^V",3717,536870918]],["^15",[3561,"^U",472,536871724]],["^15",[3561,"^;","~u69a845ea-44e2-4378-851e-945150c7bcca",536870918]],["^15",[3562,"^Q","Когда возвращются к себе, оба пишут друг о друге. Пропаг строчит компромат, и он же фигурирует в Священном палимпсесте у Теролексия.",536870918]],["^15",[3562,"^O","^17",536870918]],["^15",[3562,"^F",3558,536870918]],["^15",[3562,"^X",472,536870918]],["^15",[3562,"^V",3518,536870918]],["^15",[3562,"^U",472,536875882]],["^15",[3562,"^;","~u69a845ea-a395-41b9-a95a-059bdb63570e",536870918]],["^15",[3563,"^Q","Самопожертвование и маккивелианизм",536870918]],["^15",[3563,"^O","^17",536870918]],["^15",[3563,"^F",3544,536870918]],["^15",[3563,"^X",472,536870918]],["^15",[3563,"^V",3544,536870918]],["^15",[3563,"^U",472,536871724]],["^15",[3563,"^;","~u69a845ea-971d-4162-ae8b-c9a0ef50f449",536870918]],["^15",[3564,"^Q","Фанат комедии, когда дело касается театра",536870918]],["^15",[3564,"^O","^17",536870918]],["^15",[3564,"^F",3685,536870918]],["^15",[3564,"^X",472,536870918]],["^15",[3564,"^V",3601,536870918]],["^15",[3564,"^U",472,536875882]],["^15",[3564,"^;","~u69a845ea-6aa6-404c-98ae-bf8623b7b3f6",536870918]],["^15",[3565,"^Q","Прометей передал два Фестских артефакта критянам на условии того, что те будут уважать природу и ими будет править анакт, священник-король, а посредником с Космосом будет Вторая Потния, викарий Потнии Терон. Царь Загрей хранит зашифрованный диск, а потнифия Персефона - ключ в виде члена. Потнии должны делать маковые приношения, не забывая, что для самих людей мак - это запретный плод. Ещё одним условием является равенство людей, что было нарушено долговым рабством.",536870918]],["^15",[3565,"^O","^17",536870918]],["^15",[3565,"^F",3506,536870918]],["^15",[3565,"^X",472,536870918]],["^15",[3565,"^V",3532,536870918]],["^15",[3565,"^U",472,536879486]],["^15",[3565,"^;","~u69a845ea-64ce-4ba6-ac15-10ed7f612bb1",536870918]],["^15",[3566,"^Q","Круговое перерождение Персефоны в Элевсинских мистериях идёт по Эону. А конечное teletē (τελετή) Орфея и особенно Диониса, освобождение от перерождения сродни нирване, - по Хроносу.",536870918]],["^15",[3566,"^O","^17",536870918]],["^15",[3566,"^F",3688,536870918]],["^15",[3566,"^X",472,536870918]],["^15",[3566,"^V",3688,536870918]],["^15",[3566,"^U",472,536875938]],["^15",[3566,"^;","~u69a845ea-4eea-4199-a5e1-e099e9bdd5da",536870918]],["^15",[3567,"^Q","Последую некоторым из легенд и выберу Киму в Эолиде как родину Гесиода, а Гомер будет из неподалёку лежащей Смирны в Ионии. Позже Гомер переезжает на остров Хиос, где и проводит большую часть жизни.",536870918]],["^15",[3567,"^O","^17",536870918]],["^15",[3567,"^F",3714,536870918]],["^15",[3567,"^X",472,536870918]],["^15",[3567,"^V",3600,536870918]],["^15",[3567,"^U",472,536875938]],["^15",[3567,"^;","~u69a845ea-c851-4c52-a180-0eeac5baf184",536870918]],["^15",[3568,"^Q","#+BEGIN_QUOTE\nThey called it 'natural law' when convenient, and 'human nature' when challenged - the perfect circular logic of domination.\n#+END_QUOTE\nТалос",536870918]],["^15",[3568,"^O","^17",536870918]],["^15",[3568,"^F",3626,536870918]],["^15",[3568,"^X",472,536870918]],["^15",[3568,"^V",3542,536870918]],["^15",[3568,"^U",472,536871724]],["^15",[3568,"^;","~u69a845ea-b65c-469c-98ed-6db5270b0b60",536870918]],["^15",[3569,"^Q","В Афинах есть храмы Геи, Кроноса и Зевса. А клянуся зачатую Ураном.",536870918]],["^15",[3569,"^O","^17",536870918]],["^15",[3569,"^F",3595,536870918]],["^15",[3569,"^X",472,536870918]],["^15",[3569,"^V",3518,536870918]],["^15",[3569,"^U",472,536875882]],["^15",[3569,"^;","~u69a845ea-c47b-4cd0-8478-d14a58b23f10",536870918]],["^15",[3570,"^Q","В виде безличностного наблюдения",536870918]],["^15",[3570,"^O","^17",536870918]],["^15",[3570,"^F",3523,536870918]],["^15",[3570,"^X",472,536870918]],["^15",[3570,"^V",3523,536870918]],["^15",[3570,"^U",472,536871724]],["^15",[3570,"^;","~u69a845ea-b083-458a-a6f4-963b9ee5edc7",536870918]],["^15",[3571,"^Q","Прометей",536870918]],["^15",[3571,"^O","^17",536870918]],["^15",[3571,"^F",3583,536870918]],["^15",[3571,"^X",472,536870918]],["^15",[3571,"^V",3577,536870918]],["^15",[3571,"^U",472,536871724]],["^15",[3571,"^;","~u69a845ea-6943-4ee1-941c-aa65db70a0f4",536870918]],["^15",[3572,"^Q","- Больше не буду якшаться с тобой, пока от меня запахло твоими деньгами, теми, которые не пахнут.",536877044]],["^15",[3572,"^O","^17",536870918]],["^15",[3572,"^F",3535,536875881]],["^15",[3572,"^X",472,536870918]],["^15",[3572,"^V",3518,536875881]],["^15",[3572,"^U",472,536875882]],["^15",[3572,"^?",["^ "],536877044]],["^15",[3572,"^;","~u69a845ea-fba6-4fc7-9a40-35cf4cdd4451",536870918]],["^15",[3573,"^Q","Рабыня жрицы после разграбления Миноса. Можно противоставить в той же главе привилегированному детству хозяйки.",536870918]],["^15",[3573,"^O","^17",536870918]],["^15",[3573,"^F",3700,536870918]],["^15",[3573,"^X",472,536870918]],["^15",[3573,"^V",3504,536870918]],["^15",[3573,"^U",472,536871724]],["^15",[3573,"^;","~u69a845ea-3790-4597-97c6-a61a683b0bd8",536870918]],["^15",[3574,"^Q","Можно всего лишь отрезать язык. Правда он может научиться грамоте. Затем придётся и отрубить правую руку. Тогда он станет писать левой. Обезглавив, мы одним махом получим нужное. К тому же другие подумают, прежде чем повторять. И сочинители, и переводчики. Но язык Гомера слишком дорог. Столько же, сколько и его голова. Поэтому для начала выколи ему глаза, а там посмотрим. Смешно будет слушать, как он распинается и поёт о том, чего больше не видит.",536870918]],["^15",[3574,"^O","^17",536870918]],["^15",[3574,"^F",3714,536870918]],["^15",[3574,"^X",472,536870918]],["^15",[3574,"^V",3714,536870918]],["^15",[3574,"^U",472,536875938]],["^15",[3574,"^;","~u69a845ea-5299-4d9e-928c-1161ef31043d",536870918]],["^15",[3575,"^Q","Ему хотелось бы быть смертным, чтобы умереть ради человечества.",536870918]],["^15",[3575,"^O","^17",536870918]],["^15",[3575,"^F",3680,536870918]],["^15",[3575,"^X",472,536870918]],["^15",[3575,"^V",3571,536870918]],["^15",[3575,"^U",472,536871724]],["^15",[3575,"^;","~u69a845ea-c634-4944-829f-233f5cc9541d",536870918]],["^15",[3576,"^Q","Мы должны быть рады, что завтра приносит возможность измениться.",536870918]],["^15",[3576,"^O","^17",536870918]],["^15",[3576,"^F",3581,536870918]],["^15",[3576,"^X",472,536870918]],["^15",[3576,"^V",3611,536870918]],["^15",[3576,"^U",472,536871724]],["^15",[3576,"^;","~u69a845ea-1196-40e2-b65b-4fb196ae6d53",536870918]],["^15",[3577,"^Q","Гефест и Прометей",536870918]],["^15",[3577,"^O","^17",536870918]],["^15",[3577,"^F",3551,536870918]],["^15",[3577,"^X",472,536870918]],["^15",[3577,"^V",3672,536870918]],["^15",[3577,"^U",472,536871724]],["^15",[3577,"^;","~u69a845ea-3ddf-4acb-b363-81997c6ec9a6",536870918]],["^15",[3578,"^Q","Изобилие художественных приемов",536870918]],["^15",[3578,"^O","^17",536870918]],["^15",[3578,"^F",3526,536870918]],["^15",[3578,"^X",472,536870918]],["^15",[3578,"^V",3573,536870918]],["^15",[3578,"^U",472,536871724]],["^15",[3578,"^;","~u69a845ea-985f-423f-bdd8-b35f7b208b4d",536870918]],["^15",[3579,"^Q","Победители напишут и твое прошлое, если ты неграмотен.",536870918]],["^15",[3579,"^O","^17",536870918]],["^15",[3579,"^F",3589,536870918]],["^15",[3579,"^X",472,536870918]],["^15",[3579,"^V",3589,536870918]],["^15",[3579,"^U",472,536875938]],["^15",[3579,"^;","~u69a845ea-5de8-4ebd-a15c-5303bc7e2738",536870918]],["^15",[3580,"^Q","В виде безличностного повествования",536870918]],["^15",[3580,"^O","^17",536870918]],["^15",[3580,"^F",3709,536870918]],["^15",[3580,"^X",472,536870918]],["^15",[3580,"^V",3709,536870918]],["^15",[3580,"^U",472,536871724]],["^15",[3580,"^;","~u69a845ea-7238-4f0e-a9ad-fd9a5139f72a",536870918]],["^15",[3581,"^Q","id:: 685eaedb-34cd-42f0-9388-03df01503d72\n#+BEGIN_QUOTE\nКаким образом Ты, правящий миром, Тобою созданным, объясняешь душам будущее? А Ты объяснял его пророкам Своим. Каким же образом объясняешь Ты будущее, Ты, для Которого будущего нет? или, вернее, через настоящее объясняешь Ты будущее? Ибо того, чего нет, никак невозможно объяснить. Не так остры глаза мои, чтобы рассмотреть, как Ты действуешь, это выше сил моих, не могу постичь сам, но смогу с Твоей помощью, когда Ты подашь ее, сладостный свет внутреннего взора моего.\nСовершенно ясно теперь одно: ни будущего, ни прошлого нет, и неправильно говорить о существовании трех времен: прошедшего, настоящего и будущего. Правильнее было бы, пожалуй, говорить так: есть три времени - настоящее прошедшего, настоящее настоящего и настоящее будущего. Некие три времени эти существуют в нашей душе, и нигде в другом месте я их не вижу: настоящее прошедшего - это память; настоящее настоящего - его непосредственное созерцание; настоящее будущего - его ожидание. Если мне позволено будет говорить так, то я согласен, что есть три времени; признаю, что их три. Пусть даже говорят, как принято, хотя это и неправильно, что есть три времени: прошедшее, настоящее и будущее; пусть говорят. Не об этом сейчас моя забота, не спорю с этим и не возражаю; пусть только люди понимают то, что они говорят и знают, что ни будущего нет, ни прошлого. Редко ведь слова употребляются в их собственном смысле; в большинстве случаев мы выражаемся неточно, но нас понимают.\n#+END_QUOTE\nАвгустин. *Исповедь*.",536870918]],["^15",[3581,"^O","^17",536870918]],["^15",[3581,"^F",3718,536870918]],["^15",[3581,"^X",472,536870918]],["^15",[3581,"^V",3611,536870918]],["^15",[3581,"^U",472,536871724]],["^15",[3581,"^?",["^ ","^1>","685eaedb-34cd-42f0-9388-03df01503d72"],536870918]],["^15",[3581,"^J",["^1>"],536870918]],["^15",[3581,"^4",["^ ","^1>","685eaedb-34cd-42f0-9388-03df01503d72"],536870918]],["^15",[3581,"^;","~u685eaedb-34cd-42f0-9388-03df01503d72",536870918]],["^15",[3582,"^Q","Пропаг - также скульптор. Изваял царя-бога Александра и кумира Демосфена. Спрятал вторую статую после Хремонидовой войны.",536870918]],["^15",[3582,"^O","^17",536870918]],["^15",[3582,"^F",3569,536870918]],["^15",[3582,"^X",472,536870918]],["^15",[3582,"^V",3569,536870918]],["^15",[3582,"^U",472,536875882]],["^15",[3582,"^;","~u69a845ea-1898-40ac-8700-793e2a29898d",536870918]],["^15",[3583,"^Q","Гефест",536870918]],["^15",[3583,"^O","^17",536870918]],["^15",[3583,"^F",3577,536870918]],["^15",[3583,"^X",472,536870918]],["^15",[3583,"^V",3577,536870918]],["^15",[3583,"^U",472,536871724]],["^15",[3583,"^;","~u69a845ea-c100-4e84-83a5-0e1636fae499",536870918]],["^15",[3584,"^Q","Слуга музы и её сутенёр",536870918]],["^15",[3584,"^O","^17",536870918]],["^15",[3584,"^F",3533,536870918]],["^15",[3584,"^X",472,536870918]],["^15",[3584,"^V",3544,536870918]],["^15",[3584,"^U",472,536871724]],["^15",[3584,"^;","~u69a845ea-e39c-46d6-a270-3bafde6038b7",536870918]],["^15",[3585,"^Q","Махия в себе",536870918]],["^15",[3585,"^O","^17",536870918]],["^15",[3585,"^F",3728,536870918]],["^15",[3585,"^X",472,536870918]],["^15",[3585,"^V",3728,536870918]],["^15",[3585,"^U",472,536877491]],["^15",[3585,"^;","~u69a845ea-ce5a-42e6-94bc-b6b721872b5c",536870918]],["^15",[3586,"^Q","Орфей принёс в Македонию лиру.",536870918]],["^15",[3586,"^O","^17",536870918]],["^15",[3586,"^F",3603,536870918]],["^15",[3586,"^X",472,536870918]],["^15",[3586,"^V",3603,536870918]],["^15",[3586,"^U",472,536875938]],["^15",[3586,"^;","~u69a845ea-d370-4baf-9cb3-c52403c58b1d",536870918]],["^15",[3587,"^Q","Противоставление баланса и ряда трех отступлениям",536870918]],["^15",[3587,"^O","^17",536870918]],["^15",[3587,"^F",3561,536870918]],["^15",[3587,"^X",472,536870918]],["^15",[3587,"^V",3561,536870918]],["^15",[3587,"^U",472,536871724]],["^15",[3587,"^;","~u69a845ea-f4c6-4be7-9911-9a5faf52adc9",536870918]],["^15",[3588,"^Q","Аллитерация",536870918]],["^15",[3588,"^O","^17",536870918]],["^15",[3588,"^F",3715,536870918]],["^15",[3588,"^X",472,536870918]],["^15",[3588,"^V",3651,536870918]],["^15",[3588,"^U",472,536871724]],["^15",[3588,"^;","~u69a845ea-e443-41a7-a4d2-162860d689ae",536870918]],["^15",[3589,"^Q","Неграмотные рассказывают. Их беседы не записываются, а пересказы недостоверны.",536870918]],["^15",[3589,"^O","^17",536870918]],["^15",[3589,"^F",3600,536870918]],["^15",[3589,"^X",472,536870918]],["^15",[3589,"^V",3632,536870918]],["^15",[3589,"^U",472,536875938]],["^15",[3589,"^;","~u69a845ea-e7a4-4d90-aa8b-8aa5977c1441",536870918]],["^15",[3590,"^Q","После сражения он грабит все могилы воинов, забрав оболы Харона и золотые тотенпасы. За обол можо было купить примеро булку хлеба.",536870918]],["^15",[3590,"^O","^17",536870918]],["^15",[3590,"^F",3726,536870918]],["^15",[3590,"^X",472,536870918]],["^15",[3590,"^V",3726,536870918]],["^15",[3590,"^U",472,536875938]],["^15",[3590,"^;","~u69a845ea-f9d1-4fa5-baa5-8452e8a84434",536870918]],["^15",[3591,"^Q","Камю",536870918]],["^15",[3591,"^O","^17",536870918]],["^15",[3591,"^F",3670,536870918]],["^15",[3591,"^X",472,536870918]],["^15",[3591,"^V",3542,536870918]],["^15",[3591,"^U",472,536871724]],["^15",[3591,"^;","~u69a845ea-6d6a-4f50-b537-12938f296ee0",536870918]],["^15",[3592,"^Q","tags:: workshop\nstatus:: stack\ntype:: writing\nform:: novel\n\n",536870918]],["^15",[3592,"^O","^17",536870918]],["^15",[3592,"^1=",["^1:",[]],536870918]],["^15",[3592,"^F",472,536870918]],["^15",[3592,"^X",472,536870918]],["^15",[3592,"^V",472,536870918]],["^15",[3592,"^U",186,536870918]],["^15",[3592,"^U",472,536870918]],["^15",[3592,"^U",2859,536870918]],["^15",[3592,"^U",2861,536870918]],["^15",[3592,"^U",2863,536870918]],["^15",[3592,"^:",true,536870918]],["^15",[3592,"^?",["^ ","^19",["^1:",["workshop"]],"^1A","stack","^1;","writing","^1B","novel"],536870918]],["^15",[3592,"^J",["^19","^1A","^1;","^1B"],536870918]],["^15",[3592,"^4",["^ ","^19","workshop","^1A","stack","^1;","writing","^1B","novel"],536870918]],["^15",[3592,"^H",186,536870918]],["^15",[3592,"^H",2859,536870918]],["^15",[3592,"^H",2861,536870918]],["^15",[3592,"^H",2863,536870918]],["^15",[3592,"^;","~u69a845ea-e263-40b5-9e33-4d9ca2c8c167",536870918]],["^15",[3593,"^Q","Сравение того, что слышали, что было сказано и что было в намерениях. Я пишу письмо, чтобы то, что ты услышишь, а вернее прочитаешь, было ближе к правде.",536870918]],["^15",[3593,"^O","^17",536870918]],["^15",[3593,"^F",3547,536870918]],["^15",[3593,"^X",472,536870918]],["^15",[3593,"^V",3611,536870918]],["^15",[3593,"^U",472,536871724]],["^15",[3593,"^;","~u69a845ea-6383-4c0a-a846-8ee475996fe7",536870918]],["^15",[3594,"^Q","Одно время",536870918]],["^15",[3594,"^O","^17",536870918]],["^15",[3594,"^F",3525,536870918]],["^15",[3594,"^X",472,536870918]],["^15",[3594,"^V",3615,536870918]],["^15",[3594,"^U",472,536871724]],["^15",[3594,"^;","~u69a845ea-2bdd-4e86-ae40-042e2b216312",536870918]],["^15",[3595,"^Q","Присутсвие раба подчёркивает, что \"досуг - это роскошь, а культура и науки - следствие экспуатации классов и других наций.\"",536870918]],["^15",[3595,"^O","^17",536870918]],["^15",[3595,"^F",3562,536870918]],["^15",[3595,"^X",472,536870918]],["^15",[3595,"^V",3518,536870918]],["^15",[3595,"^U",472,536875882]],["^15",[3595,"^;","~u69a845ea-d008-4688-b3c9-58806990b62b",536870918]],["^15",[3596,"^Q","Впервые, я обратил на тебя внимание в нашей Академии, когда учитель попросил у нас пример любимой метафоры. Ты поднял руку и ответил, что для тебя это был феникс. Я в своем уме дал тот же ответ, но постеснялся поднимать руку. Ты вообще всегда претворял только что задуманное в жизнь, пока я анализировал возможные варианты развития событий, их успеха и провала, реакцию на них или ее отсутствие. В твоем сердце всегда пылал палящий зной. Если сейчас он угнетает в чужих руках наших земляков, то раньше этот жар превращался в тепло достигнув сердец тех, кто был рядом. Такие люди могут переродиться с большим пылом как во что-то светлое, так и в темное. Новая фаза луны всегда определяется старой. В этот раз ты сможешь вернуться к старым идеалам с новым опытом. Человек может измениться несколько раз за жизнь, но в отличие от луны и феникса человек он может переродиться в оставленное им однажды только раз.",536870918]],["^15",[3596,"^O","^17",536870918]],["^15",[3596,"^F",3644,536870918]],["^15",[3596,"^X",472,536870918]],["^15",[3596,"^V",3644,536870918]],["^15",[3596,"^U",472,536871724]],["^15",[3596,"^;","~u69a845ea-282a-48f8-9413-2590f6bc6bd5",536870918]],["^15",[3597,"^Q","Пары слов типа поговорок (умереть не встать, part and parcel, thick and thin, ков-керт)",536870918]],["^15",[3597,"^O","^17",536870918]],["^15",[3597,"^F",3587,536870918]],["^15",[3597,"^X",472,536870918]],["^15",[3597,"^V",3561,536870918]],["^15",[3597,"^U",472,536871724]],["^15",[3597,"^;","~u69a845ea-5f2f-4d8b-ab7f-bfd13156c451",536870918]],["^15",[3598,"^Q","Не пленник прошлого, иногда мига, а его хозяин. Он не только разделяет жар ложа с настоящим, но и тепло очага с будущим. Он не ждёт будущего сидя, а шагает навстречу ему с уверенностью.",536870918]],["^15",[3598,"^O","^17",536870918]],["^15",[3598,"^F",3695,536870918]],["^15",[3598,"^X",472,536870918]],["^15",[3598,"^V",3695,536870918]],["^15",[3598,"^U",472,536871724]],["^15",[3598,"^;","~u69a845ea-b849-4e30-b10b-2264338d5ed7",536870918]],["^15",[3599,"^Q","Парод, эпизоды, стасимы",536870918]],["^15",[3599,"^O","^17",536870918]],["^15",[3599,"^F",3668,536870918]],["^15",[3599,"^X",472,536870918]],["^15",[3599,"^V",3668,536870918]],["^15",[3599,"^U",472,536875882]],["^15",[3599,"^;","~u69a845ea-7811-4bb6-b4a3-a70bdf976ee3",536870918]],["^15",[3600,"^Q","Гомер и Псевдо-Гомер",536870918]],["^15",[3600,"^O","^17",536870918]],["^15",[3600,"^F",3632,536870918]],["^15",[3600,"^X",472,536870918]],["^15",[3600,"^V",3632,536870918]],["^15",[3600,"^U",472,536875938]],["^15",[3600,"^;","~u69a845ea-4269-439b-87d2-5b439fd9fbc1",536870918]],["^15",[3601,"^Q","Пропаг",536870918]],["^15",[3601,"^O","^17",536870918]],["^15",[3601,"^F",3518,536870918]],["^15",[3601,"^X",472,536870918]],["^15",[3601,"^V",3518,536870918]],["^15",[3601,"^U",472,536875882]],["^15",[3601,"^;","~u69a845ea-a281-44b4-b891-157d6a618db3",536870918]],["^15",[3602,"^Q","Публицистика",536870918]],["^15",[3602,"^O","^17",536870918]],["^15",[3602,"^F",3651,536870918]],["^15",[3602,"^X",472,536870918]],["^15",[3602,"^V",3690,536870918]],["^15",[3602,"^U",472,536871724]],["^15",[3602,"^;","~u69a845ea-ee4d-4794-8e33-4e3bed63c54c",536870918]],["^15",[3603,"^Q","#+BEGIN_QUOTE\nРазум человеческий владеет тремя ключами, открывающими все: цифрой, буквой, нотой. Знать, думать, мечтать. Все в этом.\n#+END_QUOTE\nВиктор Гюго",536870918]],["^15",[3603,"^O","^17",536870918]],["^15",[3603,"^F",3632,536870918]],["^15",[3603,"^X",472,536870918]],["^15",[3603,"^V",3659,536870918]],["^15",[3603,"^U",472,536875938]],["^15",[3603,"^;","~u69a845ea-fb51-47a8-90fd-f49aefe43e63",536870918]],["^15",[3604,"^Q","Курируется Минкультом.",536870918]],["^15",[3604,"^O","^17",536870918]],["^15",[3604,"^F",3721,536870918]],["^15",[3604,"^X",472,536870918]],["^15",[3604,"^V",3721,536870918]],["^15",[3604,"^U",472,536875938]],["^15",[3604,"^;","~u69a845ea-b102-42f6-8afd-f58c77048ef5",536870918]],["^15",[3605,"^Q","Чтение нараспев как предпосылка музыки",536870918]],["^15",[3605,"^O","^17",536870918]],["^15",[3605,"^F",3586,536870918]],["^15",[3605,"^X",472,536870918]],["^15",[3605,"^V",3586,536870918]],["^15",[3605,"^U",472,536875938]],["^15",[3605,"^;","~u69a845ea-8038-4925-a1ce-4612ad734fd3",536870918]],["^15",[3606,"^Q","Ребенок пришел с театра домой, где и произошла встреча.",536870918]],["^15",[3606,"^O","^17",536870918]],["^15",[3606,"^F",3668,536870918]],["^15",[3606,"^X",472,536870918]],["^15",[3606,"^V",3739,536875881]],["^15",[3606,"^U",472,536875878]],["^15",[3606,"^;","~u69a845ea-23f8-4f07-8aca-ea9c3dde8226",536870918]],["^15",[3607,"^Q","Alice chess",536870918]],["^15",[3607,"^O","^17",536870918]],["^15",[3607,"^F",3511,536870918]],["^15",[3607,"^X",472,536870918]],["^15",[3607,"^V",3511,536870918]],["^15",[3607,"^U",472,536875994]],["^15",[3607,"^;","~u69a845ea-05e6-4082-8e0f-9756cb077e73",536870918]],["^15",[3608,"^Q","Если бы не последняя глава, для которой эта служит контекстом, от нее можно было бы избавиться.",536870918]],["^15",[3608,"^O","^17",536870918]],["^15",[3608,"^F",4031,536875941]],["^15",[3608,"^X",472,536870918]],["^15",[3608,"^V",3739,536870918]],["^15",[3608,"^U",472,536875878]],["^15",[3608,"^;","~u69a845ea-e189-41c0-ac4b-a42c90e5243d",536870918]],["^15",[3609,"^Q","Προπᾰγής /pro.pa.ɡɛ̌ːs/ from [πρό] (*pró*, “before”) +‎ [πήγνυμι] (*pḗgnumi*, “set\").",536870918]],["^15",[3609,"^O","^17",536870918]],["^15",[3609,"^F",3601,536870918]],["^15",[3609,"^X",472,536870918]],["^15",[3609,"^V",3601,536870918]],["^15",[3609,"^U",472,536875882]],["^15",[3609,"^;","~u69a845ea-9f06-4997-b692-897f62dbcd97",536870918]],["^15",[3610,"^Q","Письменное слово",536870918]],["^15",[3610,"^O","^17",536870918]],["^15",[3610,"^F",3676,536870918]],["^15",[3610,"^X",472,536870918]],["^15",[3610,"^V",3676,536870918]],["^15",[3610,"^U",472,536875938]],["^15",[3610,"^;","~u69a845ea-4bdf-4883-91c0-eeb331b1fb64",536870918]],["^15",[3611,"^M",true,536879325]],["^15",[3611,"^Q","Пролог эпилога",536870918]],["^15",[3611,"^O","^17",536870918]],["^15",[3611,"^F",3678,536870918]],["^15",[3611,"^X",472,536870918]],["^15",[3611,"^V",3679,536870918]],["^15",[3611,"^U",472,536871724]],["^15",[3611,"^;","~u69a845ea-89c8-4660-bb63-9a0a96e34d9c",536870918]],["^15",[3612,"^Q","Гендерное",536870918]],["^15",[3612,"^O","^17",536870918]],["^15",[3612,"^F",3724,536870918]],["^15",[3612,"^X",472,536870918]],["^15",[3612,"^V",3537,536870918]],["^15",[3612,"^U",472,536871724]],["^15",[3612,"^;","~u69a845ea-7917-4c7d-906f-c783ada80838",536870918]],["^15",[3613,"^Q","Гекатей Абдерский прав, что она находится в Британии.",536870918]],["^15",[3613,"^O","^17",536870918]],["^15",[3613,"^F",3718,536870918]],["^15",[3613,"^X",472,536870918]],["^15",[3613,"^V",3718,536870918]],["^15",[3613,"^U",472,536871724]],["^15",[3613,"^;","~u69a845ea-ddd5-4179-900f-7e22911284d6",536870918]],["^15",[3615,"^Q","Время",536870918]],["^15",[3615,"^O","^17",536870918]],["^15",[3615,"^F",3707,536870918]],["^15",[3615,"^X",472,536870918]],["^15",[3615,"^V",3707,536870918]],["^15",[3615,"^U",472,536871724]],["^15",[3615,"^;","~u69a845ea-2632-4826-b3eb-8e0b90de34e9",536870918]],["^15",[3616,"^Q","Отрывки",536870918]],["^15",[3616,"^O","^17",536870918]],["^15",[3616,"^F",3611,536870918]],["^15",[3616,"^X",472,536870918]],["^15",[3616,"^V",3679,536870918]],["^15",[3616,"^U",472,536871724]],["^15",[3616,"^;","~u69a845ea-46e8-4fde-8429-f10a2572bb4c",536870918]],["^15",[3617,"^Q","Хаос 3",536870918]],["^15",[3617,"^O","^17",536870918]],["^15",[3617,"^F",3627,536876000]],["^15",[3617,"^X",472,536870918]],["^15",[3617,"^V",3627,536870918]],["^15",[3617,"^U",472,536875938]],["^15",[3617,"^;","~u69a845ea-8155-4e15-a5d3-ce79b110efe6",536870918]],["^15",[3618,"^Q","На Крите сегрегация полов. Мужчины - носители прогресса, а женщины - хранительници природы и очага. К этому пришли, потому что разделение полов и труда между ними было реализовать легче, чем предитовать одинаковые права мужчинам и женщнам в общем пространстве.",536870918]],["^15",[3618,"^O","^17",536870918]],["^15",[3618,"^F",3565,536870918]],["^15",[3618,"^X",472,536870918]],["^15",[3618,"^V",3532,536870918]],["^15",[3618,"^U",472,536879486]],["^15",[3618,"^;","~u69a845ea-9fc8-4ef0-9085-fc587c0e6e81",536870918]],["^15",[3619,"^Q","Аналогия с грамматическим временем?",536870918]],["^15",[3619,"^O","^17",536870918]],["^15",[3619,"^F",3594,536870918]],["^15",[3619,"^X",472,536870918]],["^15",[3619,"^V",3615,536870918]],["^15",[3619,"^U",472,536871724]],["^15",[3619,"^;","~u69a845ea-6c2e-4f30-9248-e787b9a568c2",536870918]],["^15",[3620,"^Q","Современник перевёл с древнегреческого.",536870918]],["^15",[3620,"^O","^17",536870918]],["^15",[3620,"^F",4054,536878030]],["^15",[3620,"^X",472,536870918]],["^15",[3620,"^V",4054,536878027]],["^15",[3620,"^U",472,536878024]],["^15",[3620,"^;","~u69a845ea-9792-4e7d-a678-2178a194737e",536870918]],["^15",[3621,"^Q","Насилуют последнюю Вторую Потнию, Персефону, и расчленяют первого Диониса, Загрея. В конце отдают священному быку, Минотавру. Появляется прототип орфиков, дионсийский культ. Для имитации катабасиса они употребляют мак.",536870918]],["^15",[3621,"^O","^17",536870918]],["^15",[3621,"^F",3654,536870918]],["^15",[3621,"^X",472,536870918]],["^15",[3621,"^V",3669,536870918]],["^15",[3621,"^U",472,536879486]],["^15",[3621,"^;","~u69a845ea-b631-4983-bf0e-3ff47afde78a",536870918]],["^15",[3622,"^Q","\"Потому что он герой, которого Готэм заслуживает, но не тот, который нужен городу сейчас.\" Неважно, какой герой превращается в созвездие, главное, чтобы людям было куда смотреть.",536870918]],["^15",[3622,"^O","^17",536870918]],["^15",[3622,"^F",3708,536870918]],["^15",[3622,"^X",472,536870918]],["^15",[3622,"^V",3672,536870918]],["^15",[3622,"^U",472,536871724]],["^15",[3622,"^;","~u69a845ea-1491-4656-8f4b-232b33ba2071",536870918]],["^15",[3623,"^Q","-- Почему аллегория?\n-- Потому что не герой.",536870918]],["^15",[3623,"^O","^17",536870918]],["^15",[3623,"^F",3499,536870918]],["^15",[3623,"^X",472,536870918]],["^15",[3623,"^V",3499,536870918]],["^15",[3623,"^U",472,536875882]],["^15",[3623,"^;","~u69a845ea-2997-493e-b041-4147f9b35efd",536870918]],["^15",[3624,"^Q","Заученные оправдания, заимствованные из нового круга друзей.",536870918]],["^15",[3624,"^O","^17",536870918]],["^15",[3624,"^F",3735,536870918]],["^15",[3624,"^X",472,536870918]],["^15",[3624,"^V",3711,536870918]],["^15",[3624,"^U",472,536871724]],["^15",[3624,"^;","~u69a845ea-4346-4e56-b873-7698d2b19dcd",536870918]],["^15",[3625,"^Q","\"Пусть себе поют гимны Олимпу. О делах житейских им не надо беспокоиться. Не их дело, а наше. Всех и каждого жизни научим. Если на том свете они ждут Орфея, то на этом их хоть в зад дери - не почешутся. Но есть такие, которым одного мира мало. И тут, и там им надо успеть. Вот их я больше спартанцев боюсь.\"",536870918]],["^15",[3625,"^O","^17",536870918]],["^15",[3625,"^F",3723,536870918]],["^15",[3625,"^X",472,536870918]],["^15",[3625,"^V",3723,536870918]],["^15",[3625,"^U",472,536875938]],["^15",[3625,"^;","~u69a845ea-4cd7-473a-8d02-0170d5b845f3",536870918]],["^15",[3626,"^Q","id:: 68714778-26c9-43f1-acf5-4d28c3cf93b7\n#+BEGIN_QUOTE\nCivilization is a stream with banks. The stream is sometimes filled with blood from people killing, stealing, shouting and doing things historians usually record; while on the banks, unnoticed, people build homes, make love, raise children, sing songs, write poetry and even whittle statues. The story of civilization is the story of what happened on the banks.\n#+END_QUOTE\nУилл Дюрант",536870918]],["^15",[3626,"^O","^17",536870918]],["^15",[3626,"^F",3732,536870918]],["^15",[3626,"^X",472,536870918]],["^15",[3626,"^V",3542,536870918]],["^15",[3626,"^U",472,536871724]],["^15",[3626,"^?",["^ ","^1>","68714778-26c9-43f1-acf5-4d28c3cf93b7"],536870918]],["^15",[3626,"^J",["^1>"],536870918]],["^15",[3626,"^4",["^ ","^1>","68714778-26c9-43f1-acf5-4d28c3cf93b7"],536870918]],["^15",[3626,"^;","~u68714778-26c9-43f1-acf5-4d28c3cf93b7",536870918]],["^15",[3627,"^M",false,536879340]],["^15",[3627,"^Q","По кругу вверх или дежавю анахронизма: Классическая Греция",536875937]],["^15",[3627,"^O","^17",536870918]],["^15",[3627,"^F",3704,536870918]],["^15",[3627,"^X",472,536870918]],["^15",[3627,"^V",3679,536870918]],["^15",[3627,"^U",472,536871724]],["^15",[3627,"^?",["^ "],536875937]],["^15",[3627,"^;","~u69a845ea-4853-4666-bf11-ec20fa8b282a",536870918]],["^15",[3628,"^Q","((686be35a-d2e6-46f7-ad49-19606fe3c613))",536870918]],["^15",[3628,"^O","^17",536870918]],["^15",[3628,"^F",3713,536870918]],["^15",[3628,"^X",472,536870918]],["^15",[3628,"^V",3587,536870918]],["^15",[3628,"^U",472,536871724]],["^15",[3628,"^U",783,536871724]],["^15",[3628,"^H",783,536870918]],["^15",[3628,"^;","~u69a845ea-1c5f-464d-a769-a909fedc0094",536870918]],["^15",[3629,"^Q","Прометей - кумир его отца, который нарёк сына Пропагом. Как и каждый отец, он надеялся, что сын превзойдёт его. Он будет не только думать заранее, но и действовать так.",536870918]],["^15",[3629,"^O","^17",536870918]],["^15",[3629,"^F",3609,536870918]],["^15",[3629,"^X",472,536870918]],["^15",[3629,"^V",3601,536870918]],["^15",[3629,"^U",472,536875882]],["^15",[3629,"^;","~u69a845ea-13b8-473c-baf6-8eb640e1f7f0",536870918]],["^15",[3630,"^Q","Обыграно в фильме Оппенгеймер.",536870918]],["^15",[3630,"^O","^17",536870918]],["^15",[3630,"^F",3555,536870918]],["^15",[3630,"^X",472,536870918]],["^15",[3630,"^V",3555,536870918]],["^15",[3630,"^U",472,536871724]],["^15",[3630,"^;","~u69a845ea-de06-4aeb-baa3-1ef3d09e9d35",536870918]],["^15",[3631,"^Q","Лишь тот, кто боится, использует в качестве оружия страх. Вместо битвы на равных условиях он лишает противника силы. Даже если тот не собирается нападать, тиран предполагает, что это случится. Поэтому паранойя - его привычное состояние.",536870918]],["^15",[3631,"^O","^17",536870918]],["^15",[3631,"^F",3667,536870918]],["^15",[3631,"^X",472,536870918]],["^15",[3631,"^V",3659,536870918]],["^15",[3631,"^U",472,536875938]],["^15",[3631,"^;","~u69a845ea-ef10-47d9-873b-49224b696e3b",536870918]],["^15",[3632,"^Q","Устное слово",536870918]],["^15",[3632,"^O","^17",536870918]],["^15",[3632,"^F",3631,536870918]],["^15",[3632,"^X",472,536870918]],["^15",[3632,"^V",3659,536870918]],["^15",[3632,"^U",472,536875938]],["^15",[3632,"^;","~u69a845ea-0db0-49e5-ad49-681934b5a663",536870918]],["^15",[3633,"^Q","В соревновании поэтов Гесиод побеждает, потому что он поёт о мире, а Гомер - о войне. На самом деле, не Труды и дни выигрывают, а Теогония. Гесиод просто желал, чтобы люди запомнили его автором первого произведения.",536870918]],["^15",[3633,"^O","^17",536870918]],["^15",[3633,"^F",3567,536870918]],["^15",[3633,"^X",472,536870918]],["^15",[3633,"^V",3600,536870918]],["^15",[3633,"^U",472,536875938]],["^15",[3633,"^;","~u69a845ea-397e-4ab2-9f91-d72f854c5776",536870918]],["^15",[3634,"^Q","Infinite chess",536870918]],["^15",[3634,"^O","^17",536870918]],["^15",[3634,"^F",3672,536870918]],["^15",[3634,"^X",472,536870918]],["^15",[3634,"^V",3672,536870918]],["^15",[3634,"^U",472,536871724]],["^15",[3634,"^;","~u69a845ea-4f9c-41f6-807f-2d3d6221bb8e",536870918]],["^15",[3635,"^Q","- Мы знаем с кем из них мы смогли бы сыграть в шахматы, будь они даже игроками получше нас с тобой, но не в жизнь не разделили бы амфору вина.",536879460]],["^15",[3635,"^O","^17",536870918]],["^15",[3635,"^F",3502,536870918]],["^15",[3635,"^X",472,536870918]],["^15",[3635,"^V",3678,536870918]],["^15",[3635,"^U",472,536871724]],["^15",[3635,"^?",["^ "],536879460]],["^15",[3635,"^;","~u69a845ea-62f5-4678-8d40-bb71718f8137",536870918]],["^15",[3636,"^Q","Я себе противен, когда я рядом с тобой. Ведь если ты не чуешь, что поющие оды не по заслугам, - говно, значит, от тебя несёт тем же.",536870918]],["^15",[3636,"^O","^17",536870918]],["^15",[3636,"^F",3541,536870918]],["^15",[3636,"^X",472,536870918]],["^15",[3636,"^V",3541,536870918]],["^15",[3636,"^U",472,536871724]],["^15",[3636,"^;","~u69a845ea-80e5-488a-b017-02eb09f514e3",536870918]],["^15",[3637,"^Q","Гомер и Псевдо-Гомер - стоик и поющий оды кормилец семьи",536870918]],["^15",[3637,"^O","^17",536870918]],["^15",[3637,"^F",3584,536870918]],["^15",[3637,"^X",472,536870918]],["^15",[3637,"^V",3584,536870918]],["^15",[3637,"^U",472,536871724]],["^15",[3637,"^;","~u69a845ea-c279-4407-960d-dc94b3b3cdce",536870918]],["^15",[3638,"^Q","Ты не нырнул в канаву. Сначала ты постоял рядом. Не стал спускаться, потому что чувствовал запах. Привыкнув к нему, ты спустился в канаву. Подружился с теми, кто там. А друзья ведь не могут быть подлецами.",536870918]],["^15",[3638,"^O","^17",536870918]],["^15",[3638,"^F",3675,536870918]],["^15",[3638,"^X",472,536870918]],["^15",[3638,"^V",3675,536870918]],["^15",[3638,"^U",472,536871724]],["^15",[3638,"^;","~u69a845ea-0afc-4ece-b32d-e9dad60c91cb",536870918]],["^15",[3639,"^Q","\"Плевать мне на этих блаженных, а им на нас тем паче.\"",536870918]],["^15",[3639,"^O","^17",536870918]],["^15",[3639,"^F",3660,536870918]],["^15",[3639,"^X",472,536870918]],["^15",[3639,"^V",3660,536870918]],["^15",[3639,"^U",472,536875938]],["^15",[3639,"^;","~u69a845ea-aec6-4b88-b307-5d66917d46d0",536870918]],["^15",[3640,"^Q","Тералексий",536870918]],["^15",[3640,"^O","^17",536870918]],["^15",[3640,"^F",3523,536870918]],["^15",[3640,"^X",472,536870918]],["^15",[3640,"^V",3504,536870918]],["^15",[3640,"^U",472,536871724]],["^15",[3640,"^;","~u69a845ea-745d-42b7-80c2-2d8adbf31647",536870918]],["^15",[3641,"^Q","-- Мы сыграем в игру, которую люди еще не придумали.\nid:: 68dc5870-132d-4e2c-bb4c-0fd1f9084334",536870918]],["^15",[3641,"^O","^17",536870918]],["^15",[3641,"^F",3647,536870918]],["^15",[3641,"^X",472,536870918]],["^15",[3641,"^V",3712,536870918]],["^15",[3641,"^U",472,536871724]],["^15",[3641,"^?",["^ ","^1>","68dc5870-132d-4e2c-bb4c-0fd1f9084334"],536870918]],["^15",[3641,"^J",["^1>"],536870918]],["^15",[3641,"^4",["^ ","^1>","68dc5870-132d-4e2c-bb4c-0fd1f9084334"],536870918]],["^15",[3641,"^;","~u68dc5870-132d-4e2c-bb4c-0fd1f9084334",536870918]],["^15",[3642,"^Q","Потомки Гераклидов, дорийцы, уничтожают Микены и превращают их пантеон в своих илотов. Арес нагнул Эниалия. Позже распространяется миф о дорийском нашествии и их расовом превосходстве.",536870918]],["^15",[3642,"^O","^17",536870918]],["^15",[3642,"^F",3521,536870918]],["^15",[3642,"^X",472,536870918]],["^15",[3642,"^V",3521,536870918]],["^15",[3642,"^U",472,536879486]],["^15",[3642,"^;","~u69a845ea-c930-4156-b79e-82408c88ea45",536870918]],["^15",[3643,"^Q","Минимализм",536870918]],["^15",[3643,"^O","^17",536870918]],["^15",[3643,"^F",3690,536870918]],["^15",[3643,"^X",472,536870918]],["^15",[3643,"^V",3690,536870918]],["^15",[3643,"^U",472,536871724]],["^15",[3643,"^;","~u69a845ea-2b74-46b2-ae61-21c4b53a8102",536870918]],["^15",[3644,"^Q","То, что выше, я написал тебе впопыхах и с обидой две недели назад. Я хотел его передать моему соседу, который уезжал в Афины на следующее. Боясь что он уедет без письма, я отправился к нему передать его в полночь. Громкими стуками в дверь я разбудил его. Он вышел в гневе и отпинал меня. Я рад, что он сделал это. Хоть и побои не зажили, мой рассудок вернулся. Стыдно перечитывать письмо, и первым порывом было сжечь его и переписать. Но можем ли мы меняться в лучшую сторону, если не будем признавать свои ошибки?",536870918]],["^15",[3644,"^O","^17",536870918]],["^15",[3644,"^F",3509,536870918]],["^15",[3644,"^X",472,536870918]],["^15",[3644,"^V",3711,536870918]],["^15",[3644,"^U",472,536871724]],["^15",[3644,"^;","~u69a845ea-581f-4fc6-914f-abb5623e0e9e",536870918]],["^15",[3645,"^Q","Эвиденциальность чеченского языка и письмо",536870918]],["^15",[3645,"^O","^17",536870918]],["^15",[3645,"^F",3619,536870918]],["^15",[3645,"^X",472,536870918]],["^15",[3645,"^V",3619,536870918]],["^15",[3645,"^U",472,536871724]],["^15",[3645,"^;","~u69a845ea-5de8-479d-b54d-ed0b84da2f1f",536870918]],["^15",[3646,"^Q","Священный палимпсест",536870918]],["^15",[3646,"^O","^17",536870918]],["^15",[3646,"^F",3704,536870918]],["^15",[3646,"^X",472,536870918]],["^15",[3646,"^V",3704,536870918]],["^15",[3646,"^U",472,536871724]],["^15",[3646,"^;","~u69a845ea-39b9-45d8-ab2b-293678a1bc9a",536870918]],["^15",[3647,"^Q","Ходят по-разному.",536870918]],["^15",[3647,"^O","^17",536870918]],["^15",[3647,"^F",3712,536870918]],["^15",[3647,"^X",472,536870918]],["^15",[3647,"^V",3712,536870918]],["^15",[3647,"^U",472,536871724]],["^15",[3647,"^;","~u69a845ea-db39-49da-9139-640e521fd24a",536870918]],["^15",[3648,"^Q","Гефест и Прометей - терпила-добряк и самоотверженный идеалист, горе семье",536870918]],["^15",[3648,"^O","^17",536870918]],["^15",[3648,"^F",3563,536870918]],["^15",[3648,"^X",472,536870918]],["^15",[3648,"^V",3563,536870918]],["^15",[3648,"^U",472,536871724]],["^15",[3648,"^;","~u69a845ea-8c07-42bf-9046-1034e11530b6",536870918]],["^15",[3649,"^Q","Хаос 2",536870918]],["^15",[3649,"^O","^17",536870918]],["^15",[3649,"^F",3727,536870918]],["^15",[3649,"^X",472,536870918]],["^15",[3649,"^V",3679,536870918]],["^15",[3649,"^U",472,536871724]],["^15",[3649,"^;","~u69a845ea-5289-45fb-8ea4-952d62b55f59",536870918]],["^15",[3650,"^Q","Когда был в Александрийской библиотеке, Пропаг посвятил поэму Птолемею и преклонился перед статуей его и его сестры-жены Theoi Adelphoi.",536870918]],["^15",[3650,"^O","^17",536870918]],["^15",[3650,"^F",3569,536870918]],["^15",[3650,"^X",472,536870918]],["^15",[3650,"^V",3518,536870918]],["^15",[3650,"^U",472,536875882]],["^15",[3650,"^;","~u69a845ea-e921-40ca-a882-f50560b77727",536870918]],["^15",[3651,"^Q","Лирицизм",536870918]],["^15",[3651,"^O","^17",536870918]],["^15",[3651,"^F",3738,536870918]],["^15",[3651,"^X",472,536870918]],["^15",[3651,"^V",3690,536870918]],["^15",[3651,"^U",472,536871724]],["^15",[3651,"^;","~u69a845ea-9560-40a6-b9ce-cd20165cde20",536870918]],["^15",[3652,"^Q","Размышления о переводе",536870918]],["^15",[3652,"^O","^17",536870918]],["^15",[3652,"^F",3697,536870918]],["^15",[3652,"^X",472,536870918]],["^15",[3652,"^V",3610,536870918]],["^15",[3652,"^U",472,536875938]],["^15",[3652,"^;","~u69a845ea-6d0b-46b8-9a80-ca4793d4ba94",536870918]],["^15",[3653,"^Q","-- Я вижу иногда как мы с тобой сидим за этим столом за кружкой вина цвета моря. А вино, разбавленное дружеской беседой, слаще нектара. Мы спорим о том, голоса каких рапсодов подходят нашим поэмам. Но есть Олимп... Правдолюбу даже храп тирана на его далёкой горе мешает.\nid:: 680560d8-f44e-4a73-9ca1-6514323cd80d\n-- Вину я вкуса не прибавлю. Но поболтать я с тобой всегда рад. Ты царь слова и на земле, и на Олимпе.\n-- Всем известно, что это звание присудили тебе. Загвоздки же суть в непубличном.",536870918]],["^15",[3653,"^O","^17",536870918]],["^15",[3653,"^F",3520,536870918]],["^15",[3653,"^X",472,536870918]],["^15",[3653,"^V",3600,536870918]],["^15",[3653,"^U",472,536875938]],["^15",[3653,"^?",["^ ","^1>","680560d8-f44e-4a73-9ca1-6514323cd80d"],536870918]],["^15",[3653,"^J",["^1>"],536870918]],["^15",[3653,"^4",["^ ","^1>","680560d8-f44e-4a73-9ca1-6514323cd80d"],536870918]],["^15",[3653,"^;","~u680560d8-f44e-4a73-9ca1-6514323cd80d",536870918]],["^15",[3654,"^Q","Микенцы украдкой добираются до артефактов. Они не могут его использовать, потому что не умеют читать. Они кидают жребий, кто будет учиться грамоте. Ключ достаётся самому слабому, а диск самому хитрому. Самый \"тупой\", не будучи готовым учить картинки, лишает всех возможности сделать это, отобрав ключ и разбив его.",536870918]],["^15",[3654,"^O","^17",536870918]],["^15",[3654,"^F",3669,536870918]],["^15",[3654,"^X",472,536870918]],["^15",[3654,"^V",3669,536870918]],["^15",[3654,"^U",472,536879486]],["^15",[3654,"^;","~u69a845ea-b494-4be5-969f-5f745243fe44",536870918]],["^15",[3655,"^Q","Мораль сей басни - занавес неведения или версия кольца Гига.",536870918]],["^15",[3655,"^O","^17",536870918]],["^15",[3655,"^F",3543,536870918]],["^15",[3655,"^X",472,536870918]],["^15",[3655,"^V",3683,536877936]],["^15",[3655,"^U",472,536870918]],["^15",[3655,"^;","~u69a845ea-f9fa-4e76-8c2a-5636e51f1511",536870918]],["^15",[3656,"^Q","Культ Диониса был предверием Орфизма. Власть использует религию, как шулер алкоголь - чтобы сидящие напротив не загадывали вперёд.",536870918]],["^15",[3656,"^O","^17",536870918]],["^15",[3656,"^F",3625,536870918]],["^15",[3656,"^X",472,536870918]],["^15",[3656,"^V",3723,536870918]],["^15",[3656,"^U",472,536875938]],["^15",[3656,"^;","~u69a845ea-0fdf-45c1-a732-b1f0d118d7dd",536870918]],["^15",[3657,"^Q","В виде признания, где много \"он\".",536870918]],["^15",[3657,"^O","^17",536870918]],["^15",[3657,"^F",3700,536870918]],["^15",[3657,"^X",472,536870918]],["^15",[3657,"^V",3700,536870918]],["^15",[3657,"^U",472,536871724]],["^15",[3657,"^;","~u69a845ea-0b55-4cfe-9abd-59153e67985b",536870918]],["^15",[3658,"^Q","-- Трагедия обо мне?\n-- Я виноват, что ты сподвиг меня на написание пьесы? Если бы тебя в ней не было, я бы солгал себе и читателям. Мне стоиля написать книгу ради одного лишь эпиграфа.\n-- Значит, обо мне.\n-- Прошлое можно переписать, но всё равно ты будешь знать правду. Правда будущего создаётся сегодня в настоящем. Если ты не занимаешься больше воспеванием тех, кого ты когда-то презирал, и раскаялся, что сделать никогда не поздно, то нет. Если же к твоей душе всё ещё привязан ценник и останется там, то я тебя увековечил.",536870918]],["^15",[3658,"^O","^17",536870918]],["^15",[3658,"^F",3698,536870918]],["^15",[3658,"^X",472,536870918]],["^15",[3658,"^V",3509,536870918]],["^15",[3658,"^U",472,536871724]],["^15",[3658,"^;","~u69a845ea-0c85-4b53-9154-cb9ce851dd6f",536870918]],["^15",[3659,"^Q","Цензура",536870918]],["^15",[3659,"^O","^17",536870918]],["^15",[3659,"^F",3498,536870918]],["^15",[3659,"^X",472,536870918]],["^15",[3659,"^V",3674,536870918]],["^15",[3659,"^U",472,536875938]],["^15",[3659,"^;","~u69a845ea-35dd-4f55-80b0-2174b50b78bb",536870918]],["^15",[3660,"^Q","Фундаментальная математика",536870918]],["^15",[3660,"^O","^17",536870918]],["^15",[3660,"^F",3513,536870918]],["^15",[3660,"^X",472,536870918]],["^15",[3660,"^V",3703,536870918]],["^15",[3660,"^U",472,536875938]],["^15",[3660,"^;","~u69a845ea-53b1-4924-ad1c-d4dab65d0703",536870918]],["^15",[3661,"^Q","Peasants' Revolt",536870918]],["^15",[3661,"^O","^17",536870918]],["^15",[3661,"^F",3608,536875885]],["^15",[3661,"^X",472,536870918]],["^15",[3661,"^V",3739,536875881]],["^15",[3661,"^U",472,536875878]],["^15",[3661,"^;","~u69a845ea-3241-4751-9f7f-aefc805094ab",536870918]],["^15",[3662,"^Q","Если ты уже изменился, то я, к счастью, зря написал это письмо. Но, может, прочитав имя отправителя, ты кинешь его в костер. Наверняка, я об этом не узнаю. Но тебе будет оно известно. Даже если письмо не дойдет до тебя. Или дойдет, но ты его не прочтешь. Или ты увидишь мою драму. Или ее поставят, но ты не придешь.",536870918]],["^15",[3662,"^O","^17",536870918]],["^15",[3662,"^F",3684,536879182]],["^15",[3662,"^X",472,536870918]],["^15",[3662,"^V",3596,536870918]],["^15",[3662,"^U",472,536871724]],["^15",[3662,"^;","~u69a845ea-ea9e-461e-845d-e7f92bd86c86",536870918]],["^15",[3663,"^Q","Будущее",536870918]],["^15",[3663,"^O","^17",536870918]],["^15",[3663,"^F",3619,536870918]],["^15",[3663,"^X",472,536870918]],["^15",[3663,"^V",3615,536870918]],["^15",[3663,"^U",472,536871724]],["^15",[3663,"^;","~u69a845ea-927d-419b-9b56-289524c736a4",536870918]],["^15",[3664,"^Q","El Truco por Jorge Luis Borges - настоящее настоящее.",536870918]],["^15",[3664,"^O","^17",536870918]],["^15",[3664,"^F",3740,536870918]],["^15",[3664,"^X",472,536870918]],["^15",[3664,"^V",3616,536870918]],["^15",[3664,"^U",472,536871724]],["^15",[3664,"^;","~u69a845ea-fc7a-46b4-b66e-a4dbc27ec973",536870918]],["^15",[3665,"^Q","\"It was a moment of sweet revenge for Hephaestus, but his essential good nature kept him from gloating. Despite – or perhaps because of – the pangs of rejection he had endured all his life, he was motivated not by anger or resentment but only by a desire to please, to make himself useful and give delight. He knew that he was ugly and he knew Aphrodite did not love him. He knew that if he claimed her as his prize she would betray him and slip often into the bed of his brother Ares. But he was simply happy to be home.\" (Fry, Stephen. *Mythos*)",536870918]],["^15",[3665,"^O","^17",536870918]],["^15",[3665,"^F",3538,536870918]],["^15",[3665,"^X",472,536870918]],["^15",[3665,"^V",3583,536870918]],["^15",[3665,"^U",472,536871724]],["^15",[3665,"^;","~u69a845ea-1207-4be1-af35-dd9fef347b19",536870918]],["^15",[3666,"^Q","Ребенок после театра",536870918]],["^15",[3666,"^O","^17",536870918]],["^15",[3666,"^F",3640,536870918]],["^15",[3666,"^X",472,536870918]],["^15",[3666,"^V",3504,536870918]],["^15",[3666,"^U",472,536871724]],["^15",[3666,"^;","~u69a845ea-b8d4-4265-8aa1-0e9bba554925",536870918]],["^15",[3667,"^Q","Если ресурс не экслюзивен как Фестский диск, а общедоступен, то государство будет его контролировать.",536870918]],["^15",[3667,"^O","^17",536870918]],["^15",[3667,"^F",3659,536870918]],["^15",[3667,"^X",472,536870918]],["^15",[3667,"^V",3659,536870918]],["^15",[3667,"^U",472,536875938]],["^15",[3667,"^;","~u69a845ea-5bf0-48f1-a267-09e0eeec4fe6",536870918]],["^15",[3668,"^Q","Структура древнегреческого театра",536870918]],["^15",[3668,"^O","^17",536870918]],["^15",[3668,"^F",3661,536870918]],["^15",[3668,"^X",472,536870918]],["^15",[3668,"^V",3739,536875881]],["^15",[3668,"^U",472,536875878]],["^15",[3668,"^;","~u69a845ea-b41a-4167-9251-e381f0db1724",536870918]],["^15",[3669,"^Q","Микенская эра",536870918]],["^15",[3669,"^O","^17",536870918]],["^15",[3669,"^F",3532,536870918]],["^15",[3669,"^X",472,536870918]],["^15",[3669,"^V",3691,536870918]],["^15",[3669,"^U",472,536879486]],["^15",[3669,"^;","~u69a845ea-64d6-4ef9-a289-17b7fde676b2",536870918]],["^15",[3670,"^Q","Августин",536870918]],["^15",[3670,"^O","^17",536870918]],["^15",[3670,"^F",3542,536870918]],["^15",[3670,"^X",472,536870918]],["^15",[3670,"^V",3542,536870918]],["^15",[3670,"^U",472,536871724]],["^15",[3670,"^;","~u69a845ea-2f6a-44a5-9250-8515fc0f29d1",536870918]],["^15",[3671,"^Q","Теролексий соврал, что приехал с якобы подаренным кельтским вождём торквесом,  который на самом деле нашёл его на поле сражения, когда на них напало соседнее племя, только в Греции поняв, что обладаеля обезглавили. Он не сбежал и не бился, а просто стоял как вкопанный.",536870918]],["^15",[3671,"^O","^17",536870918]],["^15",[3671,"^F",3613,536870918]],["^15",[3671,"^X",472,536870918]],["^15",[3671,"^V",3718,536870918]],["^15",[3671,"^U",472,536871724]],["^15",[3671,"^;","~u69a845ea-c4f5-4048-a63d-9368a812fb35",536870918]],["^15",[3672,"^Q","Олимп и человечество - до летоисчисления вместо до вашей эры или до огня",536870918]],["^15",[3672,"^O","^17",536870918]],["^15",[3672,"^F",3710,536870918]],["^15",[3672,"^X",472,536870918]],["^15",[3672,"^V",3727,536870918]],["^15",[3672,"^U",472,536871724]],["^15",[3672,"^;","~u69a845ea-0d70-455d-9955-79cccdef95ff",536870918]],["^15",[3673,"^Q","Параллельный ход событий",536870918]],["^15",[3673,"^O","^17",536870918]],["^15",[3673,"^F",3637,536870918]],["^15",[3673,"^X",472,536870918]],["^15",[3673,"^V",3584,536870918]],["^15",[3673,"^U",472,536871724]],["^15",[3673,"^;","~u69a845ea-87df-4994-985b-6624530e484d",536870918]],["^15",[3674,"^M",false,536879328]],["^15",[3674,"^Q","Древняя Греция, архаический период, или Римская Греция",536870918]],["^15",[3674,"^O","^17",536870918]],["^15",[3674,"^F",3617,536870918]],["^15",[3674,"^X",472,536870918]],["^15",[3674,"^V",3627,536870918]],["^15",[3674,"^U",472,536875938]],["^15",[3674,"^;","~u69a845ea-28ce-4bc2-8856-9c90fe7b86b5",536870918]],["^15",[3675,"^Q","\"Главное, не пересекать красные границы.\"",536870918]],["^15",[3675,"^O","^17",536870918]],["^15",[3675,"^F",3681,536870918]],["^15",[3675,"^X",472,536870918]],["^15",[3675,"^V",3681,536870918]],["^15",[3675,"^U",472,536871724]],["^15",[3675,"^;","~u69a845ea-ee6e-4823-b5b1-23a4c28ca070",536870918]],["^15",[3676,"^Q","Кадм научил фивян алфавиту.",536870918]],["^15",[3676,"^O","^17",536870918]],["^15",[3676,"^F",3586,536870918]],["^15",[3676,"^X",472,536870918]],["^15",[3676,"^V",3603,536870918]],["^15",[3676,"^U",472,536875938]],["^15",[3676,"^;","~u69a845ea-6330-4162-8c7c-3cbf4fc344ef",536870918]],["^15",[3677,"^Q","Император постановил, что Пропаг не имеет права где-либо зваться по имени или должности - иначе пропаганда не будет эффективной. Противодействие начинается с определения того, против чего ты. Поэтому он использовал имена для каждых собеседников или публики разные, зачастую оскорбляющие слушающих или издевающиеся над именами тех. Например, \"Спарта-имела-Фивы\". Его единственной сверхсилой, за которую он заплатил чувством запаха, был запрет на упоминание его другим именем, поэтому об этих беседах умалчивали. Отчитывается перед Гермесом как представителем интересов Олимпа на Земле.",536870918]],["^15",[3677,"^O","^17",536870918]],["^15",[3677,"^F",3629,536870918]],["^15",[3677,"^X",472,536870918]],["^15",[3677,"^V",3601,536870918]],["^15",[3677,"^U",472,536875882]],["^15",[3677,"^;","~u69a845ea-143d-4a3e-8d37-d96a6874adff",536870918]],["^15",[3678,"^Q","Хаос 5",536870918]],["^15",[3678,"^O","^17",536870918]],["^15",[3678,"^F",3739,536870918]],["^15",[3678,"^X",472,536870918]],["^15",[3678,"^V",3679,536870918]],["^15",[3678,"^U",472,536871724]],["^15",[3678,"^;","~u69a845ea-4636-4605-851c-aae3f09b8de3",536870918]],["^15",[3679,"^M",false,536877471]],["^15",[3679,"^Q","Черновик",536870918]],["^15",[3679,"^O","^17",536870918]],["^15",[3679,"^F",3921,536871723]],["^15",[3679,"^X",472,536870918]],["^15",[3679,"^V",472,536870918]],["^15",[3679,"^U",472,536870918]],["^15",[3679,"^;","~u69a845ea-dfe2-4e02-a37f-9fa8671e60cd",536870918]],["^15",[3680,"^Q","Важно, чтобы человечество знало, что он страдает. Поначалу он, наверное, даже получал удовольствие от своих мучений.",536870918]],["^15",[3680,"^O","^17",536870918]],["^15",[3680,"^F",3500,536870918]],["^15",[3680,"^X",472,536870918]],["^15",[3680,"^V",3571,536870918]],["^15",[3680,"^U",472,536871724]],["^15",[3680,"^;","~u69a845ea-d321-400c-b9bf-c52d125775b3",536870918]],["^15",[3681,"^Q","По части морали вы в помойке. Но новые блага и привилегии позволяют вам смотреть на остальных сверху вниз. Но даже в в плане морали некоторым из вас важно видеть себя в выгодном ключе.",536870918]],["^15",[3681,"^O","^17",536870918]],["^15",[3681,"^F",3624,536870918]],["^15",[3681,"^X",472,536870918]],["^15",[3681,"^V",3624,536870918]],["^15",[3681,"^U",472,536871724]],["^15",[3681,"^;","~u69a845ea-e600-4256-9fb2-ed4cf5db5e33",536870918]],["^15",[3682,"^Q","\"Вот полетит стрела по прямой линии, вот станет она больше во сто крат... Настолько огромной, что приземлившись будет сметать фалангу. Да хоть полис. Суть лишь в том, в чьих руках лук.\"",536870918]],["^15",[3682,"^O","^17",536870918]],["^15",[3682,"^F",3689,536870918]],["^15",[3682,"^X",472,536870918]],["^15",[3682,"^V",3689,536870918]],["^15",[3682,"^U",472,536875938]],["^15",[3682,"^;","~u69a845ea-1607-4a79-8e90-6b7b327cda0f",536870918]],["^15",[3683,"^Q","Мета",536877930]],["^15",[3683,"^O","^17",536870918]],["^15",[3683,"^F",3741,536870918]],["^15",[3683,"^X",472,536870918]],["^15",[3683,"^V",472,536870918]],["^15",[3683,"^U",472,536870918]],["^15",[3683,"^?",["^ "],536877930]],["^15",[3683,"^;","~u69a845ea-8f15-4962-870a-afd68ff3a252",536870918]],["^15",[3684,"^Q","Я всегда называл твои литературные вкусы эзоповскими. Если книгу нельзя было закончить словами: \"Мораль сей басни такова.\", то зря читал, выходило. В каждой сатире есть мораль, поэтому ты зачитывался и перечитывал Аристофана. Ты же всегда подшучивал, что для меня слово имеет смысл, только если я увижу его там. Каждое такое слово - кирпич, предложение - ряд из них, страница - стена. И после того, как я прочту книгу, я не смогу заснуть без крыши над головой. Поэтому я любил n, так как он недвусмысленно разрешал x. Но провидцем для меня был Аристотель, у которого все по полочкам. Мы вечно спорили, какой Аристо лучше, кто видит этот мир правильней.",536879177]],["^15",[3684,"^O","^17",536870918]],["^15",[3684,"^F",3596,536870918]],["^15",[3684,"^X",472,536870918]],["^15",[3684,"^V",3596,536870918]],["^15",[3684,"^U",472,536871724]],["^15",[3684,"^?",["^ "],536879177]],["^15",[3684,"^;","~u69a845ea-ccb7-4003-9482-41a9e453d8f9",536870918]],["^15",[3685,"^Q","Играет свадьбу в день свадьбы сына императора, потому что в тот день раздавали молодожёнам деньги. Он как посвящённый в закулисные секреты, знал об этом. В свою брачную ночь зачал сына, которого назвал в честь своего учителя риторики, который часто цитировал Платона: \"...я только и делаю то, что хожу и убеждаю вас, и молодых и старых, не заботиться ни о теле, ни о деньгах прежде всего и так сильно, как заботиться о душе, чтобы она была, как можно лучше. И говорю я вам: „Не от денег добродетель рождается, а от добродетели и деньги, и все прочие блага для людей и в частной жизни и в общественной\". (Апология Сократа, 30b)",536870918]],["^15",[3685,"^O","^17",536870918]],["^15",[3685,"^F",3677,536870918]],["^15",[3685,"^X",472,536870918]],["^15",[3685,"^V",3601,536870918]],["^15",[3685,"^U",472,536875882]],["^15",[3685,"^;","~u69a845ea-9394-4ee5-928f-a2a69bb6b676",536870918]],["^15",[3686,"^Q","Эволюция цивилизации посредством диалектики или повторение этапов, винт или цикл. Хронос выигрывает в этой шахматной партии, но Эон предупреждает, что цивилизация не несёт позитивного содержания и вектор спирали не движется вверх. Развивается медицина, искусство, но и оружие и войны тоже. Хронос отвечает ему: \"Люди запрягли тебя в плуг и точно знают, когда Персефона вернётся к ним. Что толку от твоего движения по кругам, если это цикл разложения и возрождения, который с новым витком не захватывает больше пространства.\"",536870918]],["^15",[3686,"^O","^17",536870918]],["^15",[3686,"^F",3617,536870918]],["^15",[3686,"^X",472,536870918]],["^15",[3686,"^V",3617,536870918]],["^15",[3686,"^U",472,536875938]],["^15",[3686,"^;","~u69a845ea-e5fb-46d7-97c6-3fee71412040",536870918]],["^15",[3687,"^Q","Тиран-демагог дарит внушительную сумму денег празднующим свадьбу в день женитьбы своего сына. Те, кто ближе к нему, узнают о такой будущей щедрости и приурачивают свою свадьбу подобным образом. Возможно, зачатие некоторых детей случилось на деньги тирана. Тиран умрет, а род Пропага продолжится.",536870918]],["^15",[3687,"^O","^17",536870918]],["^15",[3687,"^F",3650,536870918]],["^15",[3687,"^X",472,536870918]],["^15",[3687,"^V",3518,536870918]],["^15",[3687,"^U",472,536875882]],["^15",[3687,"^;","~u69a845ea-0e65-4620-a78c-e0bf56685375",536870918]],["^15",[3688,"^Q","Катабасис",536870918]],["^15",[3688,"^O","^17",536870918]],["^15",[3688,"^F",3721,536870918]],["^15",[3688,"^X",472,536870918]],["^15",[3688,"^V",3586,536870918]],["^15",[3688,"^U",472,536875938]],["^15",[3688,"^;","~u69a845ea-221d-49cc-a44c-8eeec2a3f80f",536870918]],["^15",[3689,"^Q","Прикладная математика",536870918]],["^15",[3689,"^O","^17",536870918]],["^15",[3689,"^F",3660,536870918]],["^15",[3689,"^X",472,536870918]],["^15",[3689,"^V",3703,536870918]],["^15",[3689,"^U",472,536875938]],["^15",[3689,"^;","~u69a845ea-876e-42b2-b9ba-40ebaad5d0d3",536870918]],["^15",[3690,"^Q","Стили прозы",536870918]],["^15",[3690,"^O","^17",536870918]],["^15",[3690,"^F",3504,536870918]],["^15",[3690,"^X",472,536870918]],["^15",[3690,"^V",3707,536870918]],["^15",[3690,"^U",472,536871724]],["^15",[3690,"^;","~u69a845ea-066f-4793-8ef2-f1e4b2e339eb",536870918]],["^15",[3691,"^M",false,536877480]],["^15",[3691,"^Q","Эры\ncollapsed:: true",536870918]],["^15",[3691,"^O","^17",536870918]],["^15",[3691,"^F",4094,536879485]],["^15",[3691,"^X",472,536870918]],["^15",[3691,"^V",3511,536870918]],["^15",[3691,"^U",472,536875994]],["^15",[3691,"^?",["^ "],536870918]],["^15",[3691,"^J",[],536870918]],["^15",[3691,"^4",["^ "],536870918]],["^15",[3691,"^;","~u69a845ea-a00f-40b9-8497-b8f78a422f03",536870918]],["^15",[3692,"^Q","\"Любому, кто переведёт это на греческий, я оторву голову.\"",536870918]],["^15",[3692,"^O","^17",536870918]],["^15",[3692,"^F",3652,536870918]],["^15",[3692,"^X",472,536870918]],["^15",[3692,"^V",3652,536870918]],["^15",[3692,"^U",472,536875938]],["^15",[3692,"^;","~u69a845ea-ec7c-4d69-9bc3-862e91aa5717",536870918]],["^15",[3693,"^Q","Со времени разговора все могло поменяться. Когда ты прочитал трагедию, ты был раздосадован. Месяц спустя я уехал из Афин, попрощался с тобой и сказал тебе, что нас больше ничего не объединяет. Ты ответил, что я не первый с кем твои пути разошлись. Возможно, уже в тот день была тебе смешна твоя реакция на трагедию. Вдруг, узнав о моей болезни, ты нашел объяснение таким нелепым промахам в моей работе, вплоть до орфографических ошибок. Что я не смогу закончить начатое. Может, к тому дню тебе стало наплевать на меня, на свои былые принципы и на то, что ты посчитал свое новое призвание по молодой наивности как компромисс с совестью, а не как само собой разумеющееся. Я искал в твоем лице доказательств об обратном, но не нашел ничего кроме равнодушия, как впрочем и на главных воротах нашего некогда великого города.",536870918]],["^15",[3693,"^O","^17",536870918]],["^15",[3693,"^F",3658,536870918]],["^15",[3693,"^X",472,536870918]],["^15",[3693,"^V",3658,536870918]],["^15",[3693,"^U",472,536871724]],["^15",[3693,"^;","~u69a845ea-889b-4597-9724-6124e71fd879",536870918]],["^15",[3694,"^Q","Диалог Платона «Федр»",536870918]],["^15",[3694,"^O","^17",536870918]],["^15",[3694,"^F",3585,536870918]],["^15",[3694,"^X",472,536870918]],["^15",[3694,"^V",3585,536870918]],["^15",[3694,"^U",472,536877491]],["^15",[3694,"^;","~u69a845ea-e470-42b2-9fd9-449d8603b524",536870918]],["^15",[3695,"^Q","Не принимаю. Люди, живущие исключительно в настоящем аполитичны, в общем, безучастны и не влияют на будущее. Мы создаем будущее.",536870918]],["^15",[3695,"^O","^17",536870918]],["^15",[3695,"^F",3581,536870918]],["^15",[3695,"^X",472,536870918]],["^15",[3695,"^V",3581,536870918]],["^15",[3695,"^U",472,536871724]],["^15",[3695,"^;","~u69a845ea-5483-4b30-b2bf-d611b0667dec",536870918]],["^15",[3696,"^Q","\"Читал я тут Платона. Людям легко: конский член не меж возничих ног.\"",536870918]],["^15",[3696,"^O","^17",536870918]],["^15",[3696,"^F",3734,536870918]],["^15",[3696,"^X",472,536870918]],["^15",[3696,"^V",3734,536870918]],["^15",[3696,"^U",472,536877491]],["^15",[3696,"^;","~u69a845ea-5fff-4aa2-abfa-7a5cd8b9793a",536870918]],["^15",[3697,"^Q","Письмо - это мост не только между людьми одного языка, но и разных.",536870918]],["^15",[3697,"^O","^17",536870918]],["^15",[3697,"^F",3733,536870918]],["^15",[3697,"^X",472,536870918]],["^15",[3697,"^V",3610,536870918]],["^15",[3697,"^U",472,536875938]],["^15",[3697,"^;","~u69a845ea-8d65-4d4e-b7c4-f708345a9982",536870918]],["^15",[3698,"^Q","Я хотел написать трагедию под псведонимом. Под ним я был адептом, врал о красной гривне, под ней пишу трагедию и письмо.",536870918]],["^15",[3698,"^O","^17",536870918]],["^15",[3698,"^F",3509,536870918]],["^15",[3698,"^X",472,536870918]],["^15",[3698,"^V",3509,536870918]],["^15",[3698,"^U",472,536871724]],["^15",[3698,"^;","~u69a845ea-95a0-4720-bb42-85253cb715a4",536870918]],["^15",[3699,"^Q","((b6329711-bd47-434b-8e33-fcd78b787bad))",536870918]],["^15",[3699,"^O","^17",536870918]],["^15",[3699,"^F",3530,536870918]],["^15",[3699,"^X",472,536870918]],["^15",[3699,"^V",3530,536870918]],["^15",[3699,"^U",472,536871724]],["^15",[3699,"^U",2328,536871724]],["^15",[3699,"^H",2328,536870918]],["^15",[3699,"^;","~u69a845ea-db06-4448-9401-3aa68328fb36",536870918]],["^15",[3700,"^Q","Жена или дочь Прометея",536870918]],["^15",[3700,"^O","^17",536870918]],["^15",[3700,"^F",3504,536870918]],["^15",[3700,"^X",472,536870918]],["^15",[3700,"^V",3504,536870918]],["^15",[3700,"^U",472,536871724]],["^15",[3700,"^;","~u69a845ea-5a5e-43c7-916a-50ed282b90ed",536870918]],["^15",[3701,"^Q","У них изначально не было принципов, и им нечего было продавать. Ты же продал свои. Это не смена парадигмы, а сделка.",536870918]],["^15",[3701,"^O","^17",536870918]],["^15",[3701,"^F",3675,536870918]],["^15",[3701,"^X",472,536870918]],["^15",[3701,"^V",3681,536870918]],["^15",[3701,"^U",472,536871724]],["^15",[3701,"^;","~u69a845ea-305d-4ad3-ada7-a80319efddfa",536870918]],["^15",[3702,"^Q","Вода камень точит - в его щелях история волн.",536870918]],["^15",[3702,"^O","^17",536870918]],["^15",[3702,"^F",3691,536870918]],["^15",[3702,"^X",472,536870918]],["^15",[3702,"^V",3511,536870918]],["^15",[3702,"^U",472,536875994]],["^15",[3702,"^;","~u69a845ea-6c9a-4e13-be1c-8410f01b783b",536870918]],["^15",[3703,"^Q","Письменное слово + цифра",536870918]],["^15",[3703,"^O","^17",536870918]],["^15",[3703,"^F",3705,536870918]],["^15",[3703,"^X",472,536870918]],["^15",[3703,"^V",3705,536870918]],["^15",[3703,"^U",472,536875938]],["^15",[3703,"^;","~u69a845ea-2604-4c2c-a4a6-18aec6524491",536870918]],["^15",[3704,"^Q","Пролог",536870918]],["^15",[3704,"^O","^17",536870918]],["^15",[3704,"^F",3707,536870918]],["^15",[3704,"^X",472,536870918]],["^15",[3704,"^V",3679,536870918]],["^15",[3704,"^U",472,536871724]],["^15",[3704,"^;","~u69a845ea-76d8-486b-9501-d4dfae3b068b",536870918]],["^15",[3705,"^Q","Король Ливии Данай убежал от брата Египта в Аргос, раскрыв местным коммерческие тайны исчисления и судоходства.",536870918]],["^15",[3705,"^O","^17",536870918]],["^15",[3705,"^F",3676,536870918]],["^15",[3705,"^X",472,536870918]],["^15",[3705,"^V",3603,536870918]],["^15",[3705,"^U",472,536875938]],["^15",[3705,"^;","~u69a845ea-08eb-4ae0-9632-f7f3f516722f",536870918]],["^15",[3706,"^Q","Слог палимпсеста меняется в зависимости от читателя.",536877996]],["^15",[3706,"^O","^17",536870918]],["^15",[3706,"^F",3620,536878030]],["^15",[3706,"^X",472,536870918]],["^15",[3706,"^V",4054,536878023]],["^15",[3706,"^U",472,536870918]],["^15",[3706,"^?",["^ "],536877996]],["^15",[3706,"^;","~u69a845ea-b636-4432-b24a-f8fe8a195e38",536870918]],["^15",[3707,"^M",false,536879466]],["^15",[3707,"^Q","Рамка",536870918]],["^15",[3707,"^O","^17",536870918]],["^15",[3707,"^F",3679,536870918]],["^15",[3707,"^X",472,536870918]],["^15",[3707,"^V",3679,536870918]],["^15",[3707,"^U",472,536871724]],["^15",[3707,"^;","~u69a845ea-cc69-4b04-851f-64670811f602",536870918]],["^15",[3708,"^Q","((66d3325b-6610-42cf-9cca-88c34afc0264))",536870918]],["^15",[3708,"^O","^17",536870918]],["^15",[3708,"^F",3737,536870918]],["^15",[3708,"^X",472,536870918]],["^15",[3708,"^V",3672,536870918]],["^15",[3708,"^U",472,536871724]],["^15",[3708,"^U",2218,536871724]],["^15",[3708,"^H",2218,536870918]],["^15",[3708,"^;","~u69a845ea-7f30-46b3-b04e-8bd584c5ee31",536870918]],["^15",[3709,"^Q","Варвар-фракиец, которого внешне не отличить от грека, но разговаривающий на греческом с акцентом",536870918]],["^15",[3709,"^O","^17",536870918]],["^15",[3709,"^F",3573,536870918]],["^15",[3709,"^X",472,536870918]],["^15",[3709,"^V",3504,536870918]],["^15",[3709,"^U",472,536871724]],["^15",[3709,"^;","~u69a845ea-ac0e-4eb9-8167-0a7685121adb",536870918]],["^15",[3710,"^Q","Не должна быть первой главой, чтобы не решили, что вся книга - это феминистская ревизия истории.",536870918]],["^15",[3710,"^O","^17",536870918]],["^15",[3710,"^F",3712,536870918]],["^15",[3710,"^X",472,536870918]],["^15",[3710,"^V",3727,536870918]],["^15",[3710,"^U",472,536871724]],["^15",[3710,"^;","~u69a845ea-3d0c-4f34-a059-93b2cc306cd7",536870918]],["^15",[3711,"^Q","Письмо",536870918]],["^15",[3711,"^O","^17",536870918]],["^15",[3711,"^F",3593,536870918]],["^15",[3711,"^X",472,536870918]],["^15",[3711,"^V",3611,536870918]],["^15",[3711,"^U",472,536871724]],["^15",[3711,"^;","~u69a845ea-162b-4fd1-b59c-fd67165d0c54",536870918]],["^15",[3712,"^Q","Хаос 1",536870918]],["^15",[3712,"^O","^17",536870918]],["^15",[3712,"^F",3727,536870918]],["^15",[3712,"^X",472,536870918]],["^15",[3712,"^V",3727,536870918]],["^15",[3712,"^U",472,536871724]],["^15",[3712,"^;","~u69a845ea-f31b-4a40-8d41-59c752d94575",536870918]],["^15",[3713,"^Q","((686825ec-ad7e-488c-9340-0984b58a03f1))",536870918]],["^15",[3713,"^O","^17",536870918]],["^15",[3713,"^F",3587,536870918]],["^15",[3713,"^X",472,536870918]],["^15",[3713,"^V",3587,536870918]],["^15",[3713,"^U",472,536871724]],["^15",[3713,"^U",704,536871724]],["^15",[3713,"^H",704,536870918]],["^15",[3713,"^;","~u69a845ea-f384-46f0-a72b-862538afe1e6",536870918]],["^15",[3714,"^Q","Псевдо-Гомер - лизоблюд Олимпа, автор гомеровских гимнов. Гомеру выкололи глаза за освещение Троянской войны.",536870918]],["^15",[3714,"^O","^17",536870918]],["^15",[3714,"^F",3600,536870918]],["^15",[3714,"^X",472,536870918]],["^15",[3714,"^V",3600,536870918]],["^15",[3714,"^U",472,536875938]],["^15",[3714,"^;","~u69a845ea-5a7a-4d3d-a64f-9ada0e09fbe4",536870918]],["^15",[3715,"^Q","Туманный",536870918]],["^15",[3715,"^O","^17",536870918]],["^15",[3715,"^F",3651,536870918]],["^15",[3715,"^X",472,536870918]],["^15",[3715,"^V",3651,536870918]],["^15",[3715,"^U",472,536871724]],["^15",[3715,"^;","~u69a845ea-9b8b-4895-a6e9-10ac948db192",536870918]],["^15",[3716,"^Q","5D Chess with Multiverse Time Travel",536870918]],["^15",[3716,"^O","^17",536870918]],["^15",[3716,"^F",3611,536870918]],["^15",[3716,"^X",472,536870918]],["^15",[3716,"^V",3611,536870918]],["^15",[3716,"^U",472,536871724]],["^15",[3716,"^;","~u69a845ea-15f4-469e-aa22-6b8aed136939",536870918]],["^15",[3717,"^Q","Цельный",536870918]],["^15",[3717,"^O","^17",536870918]],["^15",[3717,"^F",3643,536870918]],["^15",[3717,"^X",472,536870918]],["^15",[3717,"^V",3690,536870918]],["^15",[3717,"^U",472,536871724]],["^15",[3717,"^;","~u69a845ea-69a7-4577-bb68-d0cd19e66d72",536870918]],["^15",[3718,"^Q","Путешествие в Гиперборею.",536870918]],["^15",[3718,"^O","^17",536870918]],["^15",[3718,"^F",3711,536870918]],["^15",[3718,"^X",472,536870918]],["^15",[3718,"^V",3611,536870918]],["^15",[3718,"^U",472,536871724]],["^15",[3718,"^;","~u69a845ea-5507-41ad-b1e7-e94a7d7dc248",536870918]],["^15",[3719,"^Q","Однокашники Пропаг и Теролексий - малодушный продажный своих принципов и остов круговой поруки в контрасте со словоблудом, для кого слово важнее дела, тоже не страдающим отвагой",536870918]],["^15",[3719,"^O","^17",536870918]],["^15",[3719,"^F",3552,536870918]],["^15",[3719,"^X",472,536870918]],["^15",[3719,"^V",3552,536870918]],["^15",[3719,"^U",472,536871724]],["^15",[3719,"^;","~u69a845ea-1fa2-4055-a718-d9b40c7b12c8",536870918]],["^15",[3720,"^Q","-- Скромность - не твоя добродетель. Думаешь, какой-то грек купит это говно, прочитает его, а затем станет переписывать на варварский, чтобы ещё больше людей восторгалось им?\n-- Иначе и не сел бы писать.",536870918]],["^15",[3720,"^O","^17",536870918]],["^15",[3720,"^F",3503,536870918]],["^15",[3720,"^X",472,536870918]],["^15",[3720,"^V",3692,536870918]],["^15",[3720,"^U",472,536875938]],["^15",[3720,"^;","~u69a845ea-897c-45b3-bc8e-6e120f8fa01a",536870918]],["^15",[3721,"^Q","Устное слово + нота",536870918]],["^15",[3721,"^O","^17",536870918]],["^15",[3721,"^F",3605,536870918]],["^15",[3721,"^X",472,536870918]],["^15",[3721,"^V",3586,536870918]],["^15",[3721,"^U",472,536875938]],["^15",[3721,"^;","~u69a845ea-e79e-4c62-a93f-1ad233911fd9",536870918]],["^15",[3722,"^Q","Вернулся, чтобы зажечь в народе порыв к свободе. Ему даже не сказали \"Спасибо\". А ему оно было так нужно.",536870918]],["^15",[3722,"^O","^17",536870918]],["^15",[3722,"^F",3737,536870918]],["^15",[3722,"^X",472,536870918]],["^15",[3722,"^V",3737,536870918]],["^15",[3722,"^U",472,536871724]],["^15",[3722,"^;","~u69a845ea-925d-4c86-81ea-5e30e00e5111",536870918]],["^15",[3723,"^Q","Орфические гимны, т.е. религия",536870918]],["^15",[3723,"^O","^17",536870918]],["^15",[3723,"^F",3605,536870918]],["^15",[3723,"^X",472,536870918]],["^15",[3723,"^V",3605,536870918]],["^15",[3723,"^U",472,536875938]],["^15",[3723,"^;","~u69a845ea-7124-4b0f-b591-b1760815b63a",536870918]],["^15",[3724,"^Q","Классовое",536870918]],["^15",[3724,"^O","^17",536870918]],["^15",[3724,"^F",3537,536870918]],["^15",[3724,"^X",472,536870918]],["^15",[3724,"^V",3537,536870918]],["^15",[3724,"^U",472,536871724]],["^15",[3724,"^;","~u69a845ea-1b7c-4242-9cdf-7db6b4136a80",536870918]],["^15",[3725,"^Q","Женщина высокого социального стиля, но не в словах",536870918]],["^15",[3725,"^O","^17",536870918]],["^15",[3725,"^F",3657,536870918]],["^15",[3725,"^X",472,536870918]],["^15",[3725,"^V",3700,536870918]],["^15",[3725,"^U",472,536871724]],["^15",[3725,"^;","~u69a845ea-cdcd-412e-946e-bbaf0ddbd64d",536870918]],["^15",[3726,"^Q","Басня о солдате, потерявшем богов и которому всё стало дозволено",536870918]],["^15",[3726,"^O","^17",536870918]],["^15",[3726,"^F",3688,536870918]],["^15",[3726,"^X",472,536870918]],["^15",[3726,"^V",3586,536870918]],["^15",[3726,"^U",472,536875938]],["^15",[3726,"^;","~u69a845ea-2124-4df8-9064-fdbab19f3949",536870918]],["^15",[3727,"^M",true,536875641]],["^15",[3727,"^Q","Пока он был прикован",536870918]],["^15",[3727,"^O","^17",536870918]],["^15",[3727,"^F",3627,536870918]],["^15",[3727,"^X",472,536870918]],["^15",[3727,"^V",3679,536870918]],["^15",[3727,"^U",472,536871724]],["^15",[3727,"^;","~u69a845ea-ae59-4bf4-b4f2-1a3da8fe19ed",536870918]],["^15",[3728,"^Q","Хаос 4",536870918]],["^15",[3728,"^O","^17",536870918]],["^15",[3728,"^F",3511,536877503]],["^15",[3728,"^X",472,536870918]],["^15",[3728,"^V",3679,536875715]],["^15",[3728,"^U",472,536871724]],["^15",[3728,"^;","~u69a845ea-f586-4c8e-8e1c-138a0dae51b8",536870918]],["^15",[3729,"^Q","Антикитерский механизм использовался, чтобы просматривать историю согласно разным источникам. Путём введения имени правителя получали доступ к его нарративу, а напечатав \"Хаос\" - к виду с высоты космоса.",536870918]],["^15",[3729,"^O","^17",536870918]],["^15",[3729,"^F",3646,536870918]],["^15",[3729,"^X",472,536870918]],["^15",[3729,"^V",3646,536870918]],["^15",[3729,"^U",472,536871724]],["^15",[3729,"^;","~u69a845ea-0a6a-41cd-89cc-9b00e2a72e47",536870918]],["^15",[3731,"^Q","Сначала было слово. Нет, сначала была немая истина.",536870918]],["^15",[3731,"^O","^17",536870918]],["^15",[3731,"^F",3607,536870918]],["^15",[3731,"^X",472,536870918]],["^15",[3731,"^V",3511,536870918]],["^15",[3731,"^U",472,536875994]],["^15",[3731,"^;","~u69a845ea-9d0f-48fa-ab25-ed375bd654c8",536870918]],["^15",[3732,"^Q","#+BEGIN_QUOTE\nВ истории всегда есть четыре стороны: ваша сторона, их сторона, правда и то, что произошло на самом деле.\n#+END_QUOTE\nякобы Жан-Жак Руссо",536870918]],["^15",[3732,"^O","^17",536870918]],["^15",[3732,"^F",3591,536870918]],["^15",[3732,"^X",472,536870918]],["^15",[3732,"^V",3542,536870918]],["^15",[3732,"^U",472,536871724]],["^15",[3732,"^;","~u69a845ea-3685-4394-9247-2d12743dea05",536870918]],["^15",[3733,"^Q","Рукописи воспроизводимы, поэтому их нужно изымать и сжигать.",536870918]],["^15",[3733,"^O","^17",536870918]],["^15",[3733,"^F",3610,536870918]],["^15",[3733,"^X",472,536870918]],["^15",[3733,"^V",3610,536870918]],["^15",[3733,"^U",472,536875938]],["^15",[3733,"^;","~u69a845ea-39f0-4ba8-8830-7098d23ff17e",536870918]],["^15",[3734,"^Q","Во время гона время выходит из-под их контроля.",536870918]],["^15",[3734,"^O","^17",536870918]],["^15",[3734,"^F",3694,536870918]],["^15",[3734,"^X",472,536870918]],["^15",[3734,"^V",3694,536870918]],["^15",[3734,"^U",472,536877491]],["^15",[3734,"^;","~u69a845ea-2da6-4f77-9a9c-2cdc555653b9",536870918]],["^15",[3735,"^Q","Разбить многоточиями на несколько дней.",536870918]],["^15",[3735,"^O","^17",536870918]],["^15",[3735,"^F",3711,536870918]],["^15",[3735,"^X",472,536870918]],["^15",[3735,"^V",3711,536870918]],["^15",[3735,"^U",472,536871724]],["^15",[3735,"^;","~u69a845ea-2425-47ae-b559-417162644ccd",536870918]],["^15",[3736,"^Q","Минойская цивилизация - это эксперимент наивного Прометея.",536870918]],["^15",[3736,"^O","^17",536870918]],["^15",[3736,"^F",3532,536870918]],["^15",[3736,"^X",472,536870918]],["^15",[3736,"^V",3532,536870918]],["^15",[3736,"^U",472,536879486]],["^15",[3736,"^;","~u69a845ea-5893-4bef-8f8b-0e6c93db66e1",536870918]],["^15",[3737,"^Q","Навальный",536870918]],["^15",[3737,"^O","^17",536870918]],["^15",[3737,"^F",3577,536870918]],["^15",[3737,"^X",472,536870918]],["^15",[3737,"^V",3672,536870918]],["^15",[3737,"^U",472,536871724]],["^15",[3737,"^;","~u69a845ea-0880-42e8-a78c-e247c607a98a",536870918]],["^15",[3738,"^Q","Потоковый",536870918]],["^15",[3738,"^O","^17",536870918]],["^15",[3738,"^F",3717,536870918]],["^15",[3738,"^X",472,536870918]],["^15",[3738,"^V",3690,536870918]],["^15",[3738,"^U",472,536871724]],["^15",[3738,"^;","~u69a845ea-9a02-409f-9727-b56f297fa071",536870918]],["^15",[3739,"^M",true,536879475]],["^15",[3739,"^Q","Дежавю анахронизма: эллинская цивлизация",536875877]],["^15",[3739,"^O","^17",536870918]],["^15",[3739,"^F",3728,536875715]],["^15",[3739,"^X",472,536870918]],["^15",[3739,"^V",3679,536870918]],["^15",[3739,"^U",472,536871724]],["^15",[3739,"^?",["^ "],536875877]],["^15",[3739,"^;","~u69a845ea-1fec-4608-9d2a-d17682c82d02",536870918]],["^15",[3740,"^Q","- Аресу стоило бы научиться играть в полис у своей сестры.",536870918]],["^15",[3740,"^O","^17",536870918]],["^15",[3740,"^F",3616,536870918]],["^15",[3740,"^X",472,536870918]],["^15",[3740,"^V",3616,536870918]],["^15",[3740,"^U",472,536871724]],["^15",[3740,"^;","~u69a845ea-03ae-4a84-be33-70ba787b7966",536870918]],["^15",[3741,"^Q","#+BEGIN_QUOTE\nПосвящается тем, кто пишет историю моей жизни: маме и сестре.\n#+END_QUOTE",536870918]],["^15",[3741,"^O","^17",536870918]],["^15",[3741,"^F",3592,536870918]],["^15",[3741,"^X",472,536870918]],["^15",[3741,"^V",472,536870918]],["^15",[3741,"^U",472,536870918]],["^15",[3741,"^;","~u69a845ea-7337-4c9d-a778-12d7ba94873f",536870918]],["^15",[3742,"^Q","В виде признания, где много \"я\" под видом \"ты\"",536870918]],["^15",[3742,"^O","^17",536870918]],["^15",[3742,"^F",3640,536870918]],["^15",[3742,"^X",472,536870918]],["^15",[3742,"^V",3640,536870918]],["^15",[3742,"^U",472,536871724]],["^15",[3742,"^;","~u69a845ea-9885-4119-8920-8fb3474e9538",536870918]],["^15",[3743,"^?",["^ ","^1D","embed","^1E",["((685eaedb-34cd-42f0-9388-03df01503d72))"]],536870918]],["^15",[3743,"^W","macro",536870918]],["^15",[3743,"^T","embed ((685eaedb-34cd-42f0-9388-03df01503d72))",536870918]],["^15",[3744,"^3","- Я жена Прометея, бросившего вызов Зевсу, похитившему с Олимпа огонь, передавшему этот запретный дар человечеству, прикованному за это к горе далекого Кавказа к вечным терзаниям. Я мать его детей.\n  \n  Единственным памятником мне будет мое надгробие, на котором будет высечено Гесиона.",536870918]],["^15",[3744,"^16",1772635626768,536870918]],["^15",[3744,"^Z","pages/Палимпсест времени___черновик.md",536870918]],["^15",[3745,"^K",1772635626767,536870918]],["^15",[3745,"^[",3744,536870918]],["^15",[3745,"^@",false,536870918]],["^15",[3745,"^Y","палимпсест времени/черновик",536870918]],["^15",[3745,"^A",472,536870918]],["^15",[3745,"^11","Палимпсест времени/черновик",536870918]],["^15",[3745,"^B",1772635626767,536870918]],["^15",[3745,"^;","~u69a845ea-2dc0-47a4-8f4b-8cc14a55e84b",536870918]],["^15",[3746,"^Q","Я жена Прометея, бросившего вызов Зевсу, похитившему с Олимпа огонь, передавшему этот запретный дар человечеству, прикованному за это к горе далекого Кавказа к вечным терзаниям. Я мать его детей.\n\nЕдинственным памятником мне будет мое надгробие, на котором будет высечено Гесиона.",536870918]],["^15",[3746,"^O","^17",536870918]],["^15",[3746,"^F",3745,536870918]],["^15",[3746,"^X",3745,536870918]],["^15",[3746,"^V",3745,536870918]],["^15",[3746,"^U",3745,536870918]],["^15",[3746,"^;","~u69a845ea-c7ec-485a-b5b4-0b878aecf6bf",536870918]],["^15",[3747,"^3","tags:: workshop\nstatus:: backlog\ntype:: writing\nform:: novel\n\n- В отличие от открытого мира космоса тут появляются рамки и соответственно возможности. В Древней Греции метрополисы и колонии поддерживали символические отношения, если вообще это делали. В Мирмидонее же каждый метрополис находится на поверхности и контролирует доступ своих колоний к ней.\n- Приложение\n\t- Идея заимствована из рассказа Азимова \"Штрейкбрехер\", где такая планета называется Elsevere.\n\t- [[real history]]\n\t\t- https://en.wikipedia.org/wiki/Israeli_settlement",536870918]],["^15",[3747,"^16",1772635626783,536870918]],["^15",[3747,"^Z","pages/Планета-муравейник.md",536870918]],["^15",[3748,"^Q","tags:: workshop\nstatus:: backlog\ntype:: writing\nform:: novel\n\n",536870918]],["^15",[3748,"^O","^17",536870918]],["^15",[3748,"^1=",["^1:",[]],536870918]],["^15",[3748,"^F",3361,536870918]],["^15",[3748,"^X",3361,536870918]],["^15",[3748,"^V",3361,536870918]],["^15",[3748,"^U",186,536870918]],["^15",[3748,"^U",2859,536870918]],["^15",[3748,"^U",2861,536870918]],["^15",[3748,"^U",2863,536870918]],["^15",[3748,"^U",3361,536870918]],["^15",[3748,"^:",true,536870918]],["^15",[3748,"^?",["^ ","^19",["^1:",["workshop"]],"^1A","backlog","^1;","writing","^1B","novel"],536870918]],["^15",[3748,"^J",["^19","^1A","^1;","^1B"],536870918]],["^15",[3748,"^4",["^ ","^19","workshop","^1A","backlog","^1;","writing","^1B","novel"],536870918]],["^15",[3748,"^H",186,536870918]],["^15",[3748,"^H",2859,536870918]],["^15",[3748,"^H",2861,536870918]],["^15",[3748,"^H",2863,536870918]],["^15",[3748,"^;","~u69a845ea-f00c-4c83-8c78-5555b267d676",536870918]],["^15",[3749,"^Q","В отличие от открытого мира космоса тут появляются рамки и соответственно возможности. В Древней Греции метрополисы и колонии поддерживали символические отношения, если вообще это делали. В Мирмидонее же каждый метрополис находится на поверхности и контролирует доступ своих колоний к ней.",536870918]],["^15",[3749,"^O","^17",536870918]],["^15",[3749,"^F",3748,536870918]],["^15",[3749,"^X",3361,536870918]],["^15",[3749,"^V",3361,536870918]],["^15",[3749,"^U",3361,536870918]],["^15",[3749,"^;","~u69a845ea-7a76-45b9-b71c-4dca3757c56b",536870918]],["^15",[3750,"^Q","Приложение",536870918]],["^15",[3750,"^O","^17",536870918]],["^15",[3750,"^F",3749,536870918]],["^15",[3750,"^X",3361,536870918]],["^15",[3750,"^V",3361,536870918]],["^15",[3750,"^U",3361,536870918]],["^15",[3750,"^;","~u69a845ea-7920-4a26-9aa0-8fbf8c71d656",536870918]],["^15",[3751,"^Q","Идея заимствована из рассказа Азимова \"Штрейкбрехер\", где такая планета называется Elsevere.",536870918]],["^15",[3751,"^O","^17",536870918]],["^15",[3751,"^F",3750,536870918]],["^15",[3751,"^X",3361,536870918]],["^15",[3751,"^V",3750,536870918]],["^15",[3751,"^U",3361,536870918]],["^15",[3751,"^;","~u69a845ea-0e1d-4992-be08-30f0ce199780",536870918]],["^15",[3752,"^Q","[[real history]]",536870918]],["^15",[3752,"^O","^17",536870918]],["^15",[3752,"^F",3751,536870918]],["^15",[3752,"^X",3361,536870918]],["^15",[3752,"^V",3750,536870918]],["^15",[3752,"^U",3361,536870918]],["^15",[3752,"^U",3363,536870918]],["^15",[3752,"^H",3363,536870918]],["^15",[3752,"^;","~u69a845ea-39d8-4ea6-8a3f-9179ad8acdcd",536870918]],["^15",[3753,"^Q","https://en.wikipedia.org/wiki/Israeli_settlement",536870918]],["^15",[3753,"^O","^17",536870918]],["^15",[3753,"^F",3752,536870918]],["^15",[3753,"^X",3361,536870918]],["^15",[3753,"^V",3752,536870918]],["^15",[3753,"^U",3361,536870918]],["^15",[3753,"^U",3363,536870918]],["^15",[3753,"^;","~u69a845ea-2fa5-4441-934a-58e4f2d02c41",536870918]],["^15",[3754,"^3","tags:: workshop\nstatus:: backlog\ntype:: writing\nform:: novel\n\n- Можо написать историю написания [палимпсеста]([[Палимпсест времени]]), когда выздоровешь, чтобы показать психологию автора и когнитивную сторону творчества.\n- Я рассеивал мысли и отрывки в затуманенном рассудке, а потом в уме ясном их уже собирал.\n- Как я пробирался сквозь мозговой туман\n- Включить\n\t- [[Между лучами и волнами]]\n\t- [[Пять счастий]]\n\t- [[Свобода невыбора]]\n\t- [[Everybody Wants Some!!]]\n\t\t- Однако нужны наблюдатели и соперники. Скажем, катание квадратного камня, пятясь назад. А где есть соперники, там есть проигравшие, которые, возможно, будут переживатъ больше, чем если бы катили обычный камень.\n\t\t\t- Мировой рекорд важнее личного.\n- См.\n\t- Рафтинг",536873139]],["^15",[3754,"^16",1772635626803,536870918]],["^15",[3754,"^18","~m1773348138878",536873138]],["^15",[3754,"^Z","pages/Пороги.md",536870918]],["^15",[3755,"^K",1772635626800,536870918]],["^15",[3755,"^[",3754,536870918]],["^15",[3755,"^@",false,536870918]],["^15",[3755,"^Y","пороги",536870918]],["^15",[3755,"^11","Пороги",536870918]],["^15",[3755,"^?",["^ ","^19",["^1:",["workshop"]],"^1A","backlog","^1;","writing","^1B","novel"],536870918]],["^15",[3755,"^4",["^ ","^19","workshop","^1A","backlog","^1;","writing","^1B","novel"],536870918]],["^15",[3755,"^P",2863,536870918]],["^15",[3755,"^B",1773348138308,536873137]],["^15",[3755,"^;","~u69a845ea-971d-489a-939e-6be1b2015568",536870918]],["^15",[3756,"^K",1772635626818,536870918]],["^15",[3756,"^[",3769,536870918]],["^15",[3756,"^@",false,536870918]],["^15",[3756,"^Y","пять счастий",536870918]],["^15",[3756,"^11","Пять счастий",536870918]],["^15",[3756,"^B",1772635626818,536870918]],["^15",[3756,"^;","~u69a845ea-b2ae-441c-bbb6-b2485218cb87",536870918]],["^15",[3757,"^Q","См.",536870918]],["^15",[3757,"^O","^17",536870918]],["^15",[3757,"^F",3768,536870918]],["^15",[3757,"^X",3755,536870918]],["^15",[3757,"^V",3755,536870918]],["^15",[3757,"^U",3755,536870918]],["^15",[3757,"^;","~u69a845ea-7563-4764-9dec-833ecce2518f",536870918]],["^15",[3758,"^Q","[[Свобода невыбора]]",536870918]],["^15",[3758,"^O","^17",536870918]],["^15",[3758,"^F",3767,536870918]],["^15",[3758,"^X",3755,536870918]],["^15",[3758,"^V",3768,536870918]],["^15",[3758,"^U",1318,536873080]],["^15",[3758,"^U",3755,536873080]],["^15",[3758,"^H",1318,536870918]],["^15",[3758,"^;","~u69a845ea-99b7-46cd-9dcc-dc48f122881b",536870918]],["^15",[3759,"^Q","Мировой рекорд важнее личного.",536870918]],["^15",[3759,