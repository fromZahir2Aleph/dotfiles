536870917]],["^15",[1582,"^F",1579,536870917]],["^15",[1582,"^X",1579,536870917]],["^15",[1582,"^V",1579,536870917]],["^15",[1582,"^U",1146,536870917]],["^15",[1582,"^U",1579,536870917]],["^15",[1582,"^U",1580,536870917]],["^15",[1582,"^U",1581,536870917]],["^15",[1582,"^:",true,536870917]],["^15",[1582,"^?",["^ ","^19",["^1:",["grounding/motivational grounding","Anzhela"]]],536870917]],["^15",[1582,"^J",["^19"],536870917]],["^15",[1582,"^4",["^ ","^19","grounding/motivational grounding, Anzhela"],536870917]],["^15",[1582,"^H",1146,536870917]],["^15",[1582,"^H",1580,536870917]],["^15",[1582,"^H",1581,536870917]],["^15",[1582,"^;","~u69a845e5-b2b8-4ba7-b365-5c2f54e21ea9",536870917]],["^15",[1583,"^Q","![🖼 photo_5242706874619513704_y.jpg](../assets/photo_5242706874619513704_y.jpg)",536870917]],["^15",[1583,"^O","^17",536870917]],["^15",[1583,"^F",1582,536870917]],["^15",[1583,"^X",1579,536870917]],["^15",[1583,"^V",1579,536870917]],["^15",[1583,"^U",1579,536870917]],["^15",[1583,"^;","~u69a845e5-f2a3-419c-b5ac-72503cc4f19c",536870917]],["^15",[1584,"^3","- [[personality psychology/introversion|extraversion]] Появился термин отроверт. Было бы про меня, если бы не мой эгоцентризм.\n\t- [[personality psychology/egocentrism]]\n\t\t- В начале был только я. Потом появился зритель в виде Валида.\n\t\t- После Ростова вышел из машины Нозика и стал общаться. Только вот это были монологи. Для Анжелы это была аудиокнига, где она со свойственной ей горячностью влюбилась в актёра озвучки.\n\t\t- Затем они, то есть люди вокруг приобрели вдруг чувства и черты. Я осознал необходимость диалога, но разница в взглядах, интересах и характере, моё плохое самочувствие помешало прогрессу.\n\t\t- Мой след в обществе - это обращение в ислам одного и попытка самоубийста другой.",536870917]],["^15",[1584,"^16",1772635621758,536870917]],["^15",[1584,"^Z","journals/2025_01_14.md",536870917]],["^15",[1585,"^K",1772635621757,536870917]],["^15",[1585,"^[",1584,536870917]],["^15",[1585,"^N",20250114,536870917]],["^15",[1585,"^@",true,536870917]],["^15",[1585,"^Y","jan 14th, 2025",536870917]],["^15",[1585,"^11","Jan 14th, 2025",536870917]],["^15",[1585,"^B",1772635621757,536870917]],["^15",[1585,"^;","~u69a845e5-0615-459b-821a-9b3a655feb7a",536870917]],["^15",[1586,"^K",1772635621757,536870917]],["^15",[1586,"^@",false,536870917]],["^15",[1586,"^Y","personality psychology/introversion|extraversion",536870917]],["^15",[1586,"^A",150,536870917]],["^15",[1586,"^11","personality psychology/introversion|extraversion",536870917]],["^15",[1586,"^B",1772635621757,536870917]],["^15",[1586,"^;","~u69a845e5-12e5-41b4-bb5d-d8f81feb92d2",536870917]],["^15",[1587,"^K",1772635621758,536870917]],["^15",[1587,"^@",false,536870917]],["^15",[1587,"^Y","personality psychology/egocentrism",536870917]],["^15",[1587,"^A",150,536870917]],["^15",[1587,"^11","personality psychology/egocentrism",536870917]],["^15",[1587,"^B",1772635621758,536870917]],["^15",[1587,"^;","~u69a845e5-8c9d-48ed-b28d-9a83a4b8f310",536870917]],["^15",[1588,"^Q","[[personality psychology/introversion|extraversion]] Появился термин отроверт. Было бы про меня, если бы не мой эгоцентризм.",536870917]],["^15",[1588,"^O","^17",536870917]],["^15",[1588,"^F",1585,536870917]],["^15",[1588,"^X",1585,536870917]],["^15",[1588,"^V",1585,536870917]],["^15",[1588,"^U",150,536870917]],["^15",[1588,"^U",1585,536870917]],["^15",[1588,"^U",1586,536870917]],["^15",[1588,"^H",150,536870917]],["^15",[1588,"^H",1586,536870917]],["^15",[1588,"^;","~u69a845e5-2034-4d10-b3ff-8e8b13321ff1",536870917]],["^15",[1589,"^Q","[[personality psychology/egocentrism]]",536870917]],["^15",[1589,"^O","^17",536870917]],["^15",[1589,"^F",1588,536870917]],["^15",[1589,"^X",1585,536870917]],["^15",[1589,"^V",1588,536870917]],["^15",[1589,"^U",150,536870917]],["^15",[1589,"^U",1585,536870917]],["^15",[1589,"^U",1586,536870917]],["^15",[1589,"^U",1587,536870917]],["^15",[1589,"^H",150,536870917]],["^15",[1589,"^H",1587,536870917]],["^15",[1589,"^;","~u69a845e5-97e7-4906-8890-7a31ed2337d8",536870917]],["^15",[1590,"^Q","В начале был только я. Потом появился зритель в виде Валида.",536870917]],["^15",[1590,"^O","^17",536870917]],["^15",[1590,"^F",1589,536870917]],["^15",[1590,"^X",1585,536870917]],["^15",[1590,"^V",1589,536870917]],["^15",[1590,"^U",150,536870917]],["^15",[1590,"^U",1585,536870917]],["^15",[1590,"^U",1586,536870917]],["^15",[1590,"^U",1587,536870917]],["^15",[1590,"^;","~u69a845e5-d442-4720-8346-a86d4a696285",536870917]],["^15",[1591,"^Q","После Ростова вышел из машины Нозика и стал общаться. Только вот это были монологи. Для Анжелы это была аудиокнига, где она со свойственной ей горячностью влюбилась в актёра озвучки.",536870917]],["^15",[1591,"^O","^17",536870917]],["^15",[1591,"^F",1590,536870917]],["^15",[1591,"^X",1585,536870917]],["^15",[1591,"^V",1589,536870917]],["^15",[1591,"^U",150,536870917]],["^15",[1591,"^U",1585,536870917]],["^15",[1591,"^U",1586,536870917]],["^15",[1591,"^U",1587,536870917]],["^15",[1591,"^;","~u69a845e5-5f99-43cd-8e87-203129124095",536870917]],["^15",[1592,"^Q","Затем они, то есть люди вокруг приобрели вдруг чувства и черты. Я осознал необходимость диалога, но разница в взглядах, интересах и характере, моё плохое самочувствие помешало прогрессу.",536870917]],["^15",[1592,"^O","^17",536870917]],["^15",[1592,"^F",1591,536870917]],["^15",[1592,"^X",1585,536870917]],["^15",[1592,"^V",1589,536870917]],["^15",[1592,"^U",150,536870917]],["^15",[1592,"^U",1585,536870917]],["^15",[1592,"^U",1586,536870917]],["^15",[1592,"^U",1587,536870917]],["^15",[1592,"^;","~u69a845e5-5f4c-4af4-96f8-55ef3c17c11a",536870917]],["^15",[1593,"^Q","Мой след в обществе - это обращение в ислам одного и попытка самоубийста другой.",536870917]],["^15",[1593,"^O","^17",536870917]],["^15",[1593,"^F",1592,536870917]],["^15",[1593,"^X",1585,536870917]],["^15",[1593,"^V",1589,536870917]],["^15",[1593,"^U",150,536870917]],["^15",[1593,"^U",1585,536870917]],["^15",[1593,"^U",1586,536870917]],["^15",[1593,"^U",1587,536870917]],["^15",[1593,"^;","~u69a845e5-5b53-4a13-a630-b03bed6a18a3",536870917]],["^15",[1594,"^3","- #kenophobia Тишина в присутствии других оглушает, а шум будоражит. Нужно инициировать, реагировать и при отсутствии реакции просто менять направление или замолчать. Но не убегай в себя, а ищи чем занять себя, не стыдясь других, их молчания или шума.",536870917]],["^15",[1594,"^16",1772635621769,536870917]],["^15",[1594,"^Z","journals/2025_01_13.md",536870917]],["^15",[1595,"^K",1772635621768,536870917]],["^15",[1595,"^[",1594,536870917]],["^15",[1595,"^N",20250113,536870917]],["^15",[1595,"^@",true,536870917]],["^15",[1595,"^Y","jan 13th, 2025",536870917]],["^15",[1595,"^11","Jan 13th, 2025",536870917]],["^15",[1595,"^B",1772635621768,536870917]],["^15",[1595,"^;","~u69a845e5-087b-4016-8982-23ffe6967755",536870917]],["^15",[1596,"^Q","#kenophobia Тишина в присутствии других оглушает, а шум будоражит. Нужно инициировать, реагировать и при отсутствии реакции просто менять направление или замолчать. Но не убегай в себя, а ищи чем занять себя, не стыдясь других, их молчания или шума.",536870917]],["^15",[1596,"^O","^17",536870917]],["^15",[1596,"^F",1595,536870917]],["^15",[1596,"^X",1595,536870917]],["^15",[1596,"^V",1595,536870917]],["^15",[1596,"^U",307,536870917]],["^15",[1596,"^U",1595,536870917]],["^15",[1596,"^H",307,536870917]],["^15",[1596,"^;","~u69a845e5-5a2b-4c06-86eb-46bf659a89df",536870917]],["^15",[1597,"^3","- [[focus areas/themes]]\n\t- Незанятые...\n\t\t- Руки\n\t\t\t- Anki\n\t\t- Голова\n\t\t\t- Стихи\n\t- Во время\n\t\t- Чтения\n\t\t\t- Проза\n\t\t- Просмотра фильма\n\t\t\t- Операторская работа",536870917]],["^15",[1597,"^16",1772635621781,536870917]],["^15",[1597,"^Z","journals/2025_01_06.md",536870917]],["^15",[1598,"^K",1772635621780,536870917]],["^15",[1598,"^[",1597,536870917]],["^15",[1598,"^N",20250106,536870917]],["^15",[1598,"^@",true,536870917]],["^15",[1598,"^Y","jan 6th, 2025",536870917]],["^15",[1598,"^11","Jan 6th, 2025",5368709