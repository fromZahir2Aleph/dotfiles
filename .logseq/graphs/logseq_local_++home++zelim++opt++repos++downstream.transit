[316,"^;","~u69a845e3-240a-4a83-9d60-494d391fd3e7",536870915]],["^15",[317,"^K",1772635619044,536870915]],["^15",[317,"^O","^17",536870927]],["^15",[317,"^@",false,536870915]],["^15",[317,"^Y","linguistics/phonetics/prosody",536870915]],["^15",[317,"^A",318,536870915]],["^15",[317,"^11","linguistics/phonetics/prosody",536870915]],["^15",[317,"^B",1772635619044,536870915]],["^15",[317,"^;","~u69a845e3-09a6-4209-b854-3e8c118612df",536870915]],["^15",[318,"^K",1772635619044,536870915]],["^15",[318,"^@",false,536870915]],["^15",[318,"^Y","linguistics/phonetics",536870915]],["^15",[318,"^A",23,536870915]],["^15",[318,"^11","linguistics/phonetics",536870915]],["^15",[318,"^B",1772635619044,536870915]],["^15",[318,"^;","~u69a845e3-8f19-481c-a96b-4f35a8564dcc",536870915]],["^15",[319,"^3","- #writing Для большинства писателей книги - это не основной заработок. Даже в случае успеха мне надо работать где-то, потому что мои книги - не в коммерческом сегменте.",536870915]],["^15",[319,"^16",1772635619057,536870915]],["^15",[319,"^Z","journals/2025_12_21.md",536870915]],["^15",[320,"^K",1772635619056,536870915]],["^15",[320,"^[",319,536870915]],["^15",[320,"^N",20251221,536870915]],["^15",[320,"^@",true,536870915]],["^15",[320,"^Y","dec 21st, 2025",536870915]],["^15",[320,"^11","Dec 21st, 2025",536870915]],["^15",[320,"^B",1772635619056,536870915]],["^15",[320,"^;","~u69a845e3-5dfb-408c-b685-d0271811af87",536870915]],["^15",[321,"^Q","#writing Для большинства писателей книги - это не основной заработок. Даже в случае успеха мне надо работать где-то, потому что мои книги - не в коммерческом сегменте.",536870915]],["^15",[321,"^O","^17",536870915]],["^15",[321,"^F",320,536870915]],["^15",[321,"^X",320,536870915]],["^15",[321,"^V",320,536870915]],["^15",[321,"^U",197,536870915]],["^15",[321,"^U",320,536870915]],["^15",[321,"^H",197,536870915]],["^15",[321,"^;","~u69a845e3-bfb5-49e0-9590-e3257a11f4f7",536870915]],["^15",[322,"^3","- #her #me|cfs Пока я болен и без работы, нет смысла искать ее. Если выздоровеешь, то первым делом ищи работу.",536870915]],["^15",[322,"^16",1772635619070,536870915]],["^15",[322,"^Z","journals/2025_12_18.md",536870915]],["^15",[323,"^K",1772635619070,536870915]],["^15",[323,"^[",322,536870915]],["^15",[323,"^N",20251218,536870915]],["^15",[323,"^@",true,536870915]],["^15",[323,"^Y","dec 18th, 2025",536870915]],["^15",[323,"^11","Dec 18th, 2025",536870915]],["^15",[323,"^B",1772635619070,536870915]],["^15",[323,"^;","~u69a845e3-83ae-482e-8838-1bc9253f5e78",536870915]],["^15",[324,"^Q","#her #me|cfs Пока я болен и без работы, нет смысла искать ее. Если выздоровеешь, то первым делом ищи работу.",536870915]],["^15",[324,"^O","^17",536870915]],["^15",[324,"^F",323,536870915]],["^15",[324,"^X",323,536870915]],["^15",[324,"^V",323,536870915]],["^15",[324,"^U",247,536870915]],["^15",[324,"^U",255,536870915]],["^15",[324,"^U",323,536870915]],["^15",[324,"^H",247,536870915]],["^15",[324,"^H",255,536870915]],["^15",[324,"^;","~u69a845e3-f440-4030-aa32-7e60c192e6d2",536870915]],["^15",[325,"^3","- #communication Я часто продолжаю беседу со скучными девушками, просто потому что они привлекательны. С другой стороны, я слишком быстро делаю вывод об их отношении ко мне. Они пользуются вниманием, и чтобы они заметили тебя, нужно подумать как заинтересовать их мне собой. А дальше суди по тому, отвечают ли они тебе тем же или нет.\n\t- В основном ты сразу можешь легко исключить тех, с кем тебе не по пути. Общение с ними должо быть подобающим.",536870915]],["^15",[325,"^16",1772635619083,536870915]],["^15",[325,"^Z","journals/2025_12_17.md",536870915]],["^15",[326,"^K",1772635619082,536870915]],["^15",[326,"^[",325,536870915]],["^15",[326,"^N",20251217,536870915]],["^15",[326,"^@",true,536870915]],["^15",[326,"^Y","dec 17th, 2025",536870915]],["^15",[326,"^11","Dec 17th, 2025",536870915]],["^15",[326,"^B",1772635619082,536870915]],["^15",[326,"^;","~u69a845e3-c3f4-42b3-9ea6-df07fd36f7aa",536870915]],["^15",[327,"^K",1772635619207,536870915]],["^15",[327,"^@",false,536870915]],["^15",[327,"^Y","communication",536870915]],["^15",[327,"^11","communication",536870915]],["^15",[327,"^B",1772635619207,536870915]],["^15",[327,"^;","~u69a845e3-c6d6-433f-96d0-24a4edd4a0dd",536870915]],["^15",[328,"^Q","#communication Я часто продолжаю беседу со скучными девушками, просто потому что они привлекательны. С другой стороны, я слишком быстро делаю вывод об их отношении ко мне. Они пользуются вниманием, и чтобы они заметили тебя, нужно подумать как заинтересовать их мне собой. А дальше суди по тому, отвечают ли они тебе тем же или нет.",536870915]],["^15",[328,"^O","^17",536870915]],["^15",[328,"^F",326,536870915]],["^15",[328,"^X",326,536870915]],["^15",[328,"^V",326,536870915]],["^15",[328,"^U",326,536870915]],["^15",[328,"^U",327,536870915]],["^15",[328,"^H",327,536870915]],["^15",[328,"^;","~u69a845e3-a101-458b-915c-d655dab0eb0f",536870915]],["^15",[329,"^Q","В основном ты сразу можешь легко исключить тех, с кем тебе не по пути. Общение с ними должо быть подобающим.",536870915]],["^15",[329,"^O","^17",536870915]],["^15",[329,"^F",328,536870915]],["^15",[329,"^X",326,536870915]],["^15",[329,"^V",328,536870915]],["^15",[329,"^U",326,536870915]],["^15",[329,"^U",327,536870915]],["^15",[329,"^;","~u69a845e3-e2b7-435a-82f1-c543784185e0",536870915]],["^15",[330,"^3","tags:: diary\ntype:: reflection\nmood:: neutral\n\n- #her Если я вылечусь, все равно остается высокая вероятность рецидива. Если я найду свою любовь, она должна об этом знать. Но от заведения детей я должен отказаться, если только я не стану вдруг очень богатым. В этом случае, если болезнь вернется, то моей семье не придется брать на себя уход за мной, а мои финансовые обязаности отца и супруга будут исполняться, но в остальном меня не будет в их жизни.",536870915]],["^15",[330,"^16",1772635619104,536870915]],["^15",[330,"^Z","journals/2025_12_15.md",536870915]],["^15",[331,"^K",1772635619103,536870915]],["^15",[331,"^[",330,536870915]],["^15",[331,"^N",20251215,536870915]],["^15",[331,"^@",true,536870915]],["^15",[331,"^Y","dec 15th, 2025",536870915]],["^15",[331,"^11","Dec 15th, 2025",536870915]],["^15",[331,"^?",["^ ","^19",["^1:",["diary"]],"^1;","reflection","^1<","neutral"],536870915]],["^15",[331,"^4",["^ ","^19","diary","^1;","reflection","^1<","neutral"],536870915]],["^15",[331,"^P",185,536870915]],["^15",[331,"^B",1772635619103,536870915]],["^15",[331,"^;","~u69a845e3-fd2f-4a1b-9dbd-31c3f8933af9",536870915]],["^15",[332,"^Q","tags:: diary\ntype:: reflection\nmood:: neutral\n\n",536870915]],["^15",[332,"^O","^17",536870915]],["^15",[332,"^1=",["^1:",[]],536870915]],["^15",[332,"^F",331,536870915]],["^15",[332,"^X",331,536870915]],["^15",[332,"^V",331,536870915]],["^15",[332,"^U",185,536870915]],["^15",[332,"^U",186,536870915]],["^15",[332,"^U",187,536870915]],["^15",[332,"^U",331,536870915]],["^15",[332,"^:",true,536870915]],["^15",[332,"^?",["^ ","^19",["^1:",["diary"]],"^1;","reflection","^1<","neutral"],536870915]],["^15",[332,"^J",["^19","^1;","^1<"],536870915]],["^15",[332,"^4",["^ ","^19","diary","^1;","reflection","^1<","neutral"],536870915]],["^15",[332,"^H",185,536870915]],["^15",[332,"^H",186,536870915]],["^15",[332,"^H",187,536870915]],["^15",[332,"^;","~u69a845e3-38bf-4872-96dc-c1d4863561aa",536870915]],["^15",[333,"^Q","#her Если я вылечусь, все равно остается высокая вероятность рецидива. Если я найду свою любовь, она должна об этом знать. Но от заведения детей я должен отказаться, если только я не стану вдруг очень богатым. В этом случае, если болезнь вернется, то моей семье не придется брать на себя уход за мной, а мои финансовые обязаности отца и супруга будут исполняться, но в остальном меня не будет в их жизни.",536870915]],["^15",[333,"^O","^17",536870915]],["^15",[333,"^F",332,536870915]],["^15",[333,"^X",331,536870915]],["^15",[333,"^V",331,536870915]],["^15",[333,"^U",247,536870915]],["^15",[333,"^U",331,536870915]],["^15",[333,"^H",247,536870915]],["^15",[333,"^;","~u69a845e3-1bea-49e2-b564-161f2c3dab64",536870915]],["^15",[334,"^3","tags:: diary\ntype:: reflection\nmood:: neutral\n\n- Если я так много думаю, о других, то я сравниваю себя с ними. Например, мысли последних лет крутятся вокруг неприязни к Рамзану, Амиру и Сайд-Магомеду. Я не имею социального присутствия в отличие от них. Моя самооценка не должна зависеть от того, останутся ли дела в статусе кво, или я вернусь в игру.",536870915]],["^15",[334,"^16",1772635619119,536870915]],["^15",[334,"^Z","journals/2025_12_14.md",536870915]],["^15",[335,"^K",1772635619118,536870915]],["^15",[335,"^[",334,536870915]],["^15",[335,"^N",20251214,536870915]],["^15",[335,"^@",true,536870915]],["^15",[335,"^Y","dec 14th, 2025",536870915]],["^15",[335,"^11","Dec 14th, 2025",536870915]],["^15",[335,"^?",["^ ","^19",["^1:",["diary"]],"^1;","reflection","^1<","neutral"],536870915]],["^15",[335,"^4",["^ ","^19","diary","^1;","reflection","^1<","neutral"],536870915]],["^15",[335,"^P",185,536870915]],["^15",[335,"^B",1772635619118,536870915]],["^15",[335,"^;","~u69a845e3-bd97-4bb3-9799-e8f901875abe",536870915]],["^15",[336,"^Q","tags:: diary\ntype:: reflection\nmood:: neutral\n\n",536870915]],["^15",[336,"^O","^17",536870915]],["^15",[336,"^1=",["^1:",[]],536870915]],["^15",[336,"^F",335,536870915]],["^15",[336,"^X",335,536870915]],["^15",[336,"^V",335,536870915]],["^15",[336,"^U",185,536870915]],["^15",[336,"^U",186,536870915]],["^15",[336,"^U",187,536870915]],["^15",[336,"^U",335,536870915]],["^15",[336,"^:",true,536870915]],["^15",[336,"^?",["^ ","^19",["^1:",["diary"]],"^1;","reflection","^1<","neutral"],536870915]],["^15",[336,"^J",["^19","^1;","^1<"],536870915]],["^15",[336,"^4",["^ ","^19","diary","^1;","reflection","^1<","neutral"],536870915]],["^15",[336,"^H",185,536870915]],["^15",[336,"^H",186,536870915]],["^15",[336,"^H",187,536870915]],["^15",[336,"^;","~u69a845e3-e795-477a-8da7-2dbbf9794884",536870915]],["^15",[337,"^Q","Если я так много думаю, о других, то я сравниваю себя с ними. Например, мысли последних лет крутятся вокруг неприязни к Рамзану, Амиру и Сайд-Магомеду. Я не имею социального присутствия в отличие от них. Моя самооценка не должна зависеть от того, останутся ли дела в статусе кво, или я вернусь в игру.",536870915]],["^15",[337,"^O","^17",536870915]],["^15",[337,"^F",336,536870915]],["^15",[337,"^X",335,536870915]],["^15",[337,"^V",335,536870915]],["^15",[337,"^U",335,536870915]],["^15",[337,"^;","~u69a845e3-f48f-4af1-8176-7926e667fd59",536870915]],["^15",[338,"^3","tags:: diary\ntype:: reflection\nmood:: neutral\n\n- Мама любила его.",536870915]],["^15",[338,"^16",1772635619137,536870915]],["^15",[338,"^Z","journals/2025_12_13.md",536870915]],["^15",[339,"^K",1772635619136,536870915]],["^15",[339,"^[",338,536870915]],["^15",[339,"^N",20251213,536870915]],["^15",[339,"^@",true,536870915]],["^15",[339,"^Y","dec 13th, 2025",536870915]],["^15",[339,"^11","Dec 13th, 2025",536870915]],["^15",[339,"^?",["^ ","^19",["^1:",["diary"]],"^1;","reflection","^1<","neutral"],536870915]],["^15",[339,"^4",["^ ","^19","diary","^1;","reflection","^1<","neutral"],536870915]],["^15",[339,"^P",185,536870915]],["^15",[339,"^B",1772635619136,536870915]],["^15",[339,"^;","~u69a845e3-ba10-4e3c-982f-b8a45e96a58d",536870915]],["^15",[340,"^Q","tags:: diary\ntype:: reflection\nmood:: neutral\n\n",536870915]],["^15",[340,"^O","^17",536870915]],["^15",[340,"^1=",["^1:",[]],536870915]],["^15",[340,"^F",339,536870915]],["^15",[340,"^X",339,536870915]],["^15",[340,"^V",339,536870915]],["^15",[340,"^U",185,536870915]],["^15",[340,"^U",186,536870915]],["^15",[340,"^U",187,536870915]],["^15",[340,"^U",339,536870915]],["^15",[340,"^:",true,536870915]],["^15",[340,"^?",["^ ","^19",["^1:",["diary"]],"^1;","reflection","^1<","neutral"],536870915]],["^15",[340,"^J",["^19","^1;","^1<"],536870915]],["^15",[340,"^4",["^ ","^19","diary","^1;","reflection","^1<","neutral"],536870915]],["^15",[340,"^H",185,536870915]],["^15",[340,"^H",186,536870915]],["^15",[340,"^H",187,536870915]],["^15",[340,"^;","~u69a845e3-c66b-4cee-9ec2-f074e60d789c",536870915]],["^15",[341,"^Q","Мама любила его.",536870915]],["^15",[341,"^O","^17",536870915]],["^15",[341,"^F",340,536870915]],["^15",[341,"^X",339,536870915]],["^15",[341,"^V",339,536870915]],["^15",[341,"^U",339,536870915]],["^15",[341,"^;","~u69a845e3-2eb2-4419-8190-3605c0298b7b",536870915]],["^15",[342,"^3","tags:: [[quiz]]\nplayed:: no\n\n- Этот термин описывает решение совершить действие, основанное на доверии и вере, а не на логике или доказательствах. Так же называется игровое действие в игре Assasin's Creed.\n\t- Прыжок веры\n- Римская империя просуществовала века, а её система счисления ещё дольше. Но один символ поставил на ней крест. Назовите этот символ.\n\t- Ноль. Прим. именно ноль позволяет нам пользоваться десятичной системой исчисления. А слово \"крест\" - это намек на игру крестики-нолики.\n- Для этого предмета, исчезнувшего из повседневной жизни, предназначен маленький кармашек в джинсах. Ответьте в двух словах, первое из которых очевидно.\n\t- Карманные часы. Прим.: вопрос в картинке.",536875347]],["^15",[342,"^16",1772635619153,536870915]],["^15",[342,"^18","~m1774115740616",536875346]],["^15",[342,"^Z","journals/2025_12_12.md",536870915]],["^15",[343,"^K",1772635619153,536870915]],["^15",[343,"^[",342,536870915]],["^15",[343,"^N",20251212,536870915]],["^15",[343,"^@",true,536870915]],["^15",[343,"^Y","dec 12th, 2025",536870915]],["^15",[343,"^11","Dec 12th, 2025",536870915]],["^15",[343,"^?",["^ ","^19",["^1:",["quiz"]],"~:played","no"],536870915]],["^15",[343,"^4",["^ ","^19","[[quiz]]","^1?","no"],536870915]],["^15",[343,"^P",344,536870915]],["^15",[343,"^B",1774115740088,536875344]],["^15",[343,"^;","~u69a845e3-5b22-40ca-a140-8a67c8c53f61",536870915]],["^15",[344,"^K",1772635619967,536870915]],["^15",[344,"^[",4085,536879137]],["^15",[344,"^O","^17",536874876]],["^15",[344,"^@",false,536870915]],["^15",[344,"^Y","quiz",536870915]],["^15",[344,"^11","quiz",536870915]],["^15",[344,"^B",1775161566655,536879140]],["^15",[344,"^;","~u69a845e5-fa63-48ba-b4f3-76fc351db5bb",536870917]],["^15",[345,"^K",1772635620468,536870915]],["^15",[345,"^@",false,536870915]],["^15",[345,"^Y","played",536870915]],["^15",[345,"^11","played",536870915]],["^15",[345,"^B",1772635620468,536870915]],["^15",[345,"^;","~u69a845e5-c7dc-4225-a74f-3701343872dc",536870917]],["^15",[346,"^Q","tags:: [[quiz]]\nplayed:: no\n\n",536870915]],["^15",[346,"^O","^17",536870915]],["^15",[346,"^1=",["^1:",[]],536870915]],["^15",[346,"^F",343,536870915]],["^15",[346,"^X",343,536870915]],["^15",[346,"^V",343,536870915]],["^15",[346,"^U",343,536870915]],["^15",[346,"^U",344,536870915]],["^15",[346,"^U",345,536870915]],["^15",[346,"^:",true,536870915]],["^15",[346,"^?",["^ ","^19",["^1:",["quiz"]],"^1?","no"],536870915]],["^15",[346,"^J",["^19","^1?"],536870915]],["^15",[346,"^4",["^ ","^19","[[quiz]]","^1?","no"],536870915]],["^15",[346,"^H",344,536870915]],["^15",[346,"^H",345,536870915]],["^15",[346,"^;","~u69a845e3-660b-4ca3-ac31-f3bef1fb1112",536870915]],["^15",[347,"^Q","Этот термин описывает решение совершить действие, основанное на доверии и вере, а не на логике или доказательствах. Так же называется игровое действие в игре Assasin's Creed.",536874702]],["^15",[347,"^O","^17",536870915]],["^15",[347,"^F",346,536870915]],["^15",[347,"^X",343,536870915]],["^15",[347,"^V",343,536870915]],["^15",[347,"^U",343,536870915]],["^15",[347,"^?",["^ "],536874702]],["^15",[347,"^;","~u69a845e3-3b8d-43b8-bde4-959a42209365",536870915]],["^15",[348,"^Q","Прыжок веры",536870915]],["^15",[348,"^O","^17",536870915]],["^15",[348,"^F",347,536870915]],["^15",[348,"^X",343,536870915]],["^15",[348,"^V",347,536870915]],["^15",[348,"^U",343,536874703]],["^15",[348,"^;","~u69a845e3-e069-4798-b3ba-18b802e12cd8",536870915]],["^15",[349,"^3","- #nicknames\n\t- Антибрык\n\t- Козопас\n\t- Der Agent des Wille\n\t- недоПсевдосноб\n\t- criptoateo",536875430]],["^15",[349,"^16",1772635619168,536870915]],["^15",[349,"^1