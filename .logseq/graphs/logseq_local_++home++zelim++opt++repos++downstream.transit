-41a9-9d8f-811e910ad384",536870917]],["^15",[1866,"^Q","Ничего не прочитано.",536870917]],["^15",[1866,"^O","^17",536870917]],["^15",[1866,"^F",1856,536870917]],["^15",[1866,"^X",1845,536870917]],["^15",[1866,"^V",1856,536870917]],["^15",[1866,"^U",174,536870917]],["^15",[1866,"^U",176,536870917]],["^15",[1866,"^U",1845,536870917]],["^15",[1866,"^U",1846,536870917]],["^15",[1866,"^;","~u69a845e6-eb6f-4240-a1cd-4d42a5c77952",536870917]],["^15",[1867,"^3","- #[[liar paradox]] Задачи о рыцарях и плутах решаются сверкой их ответов. Однако моё сознание - и рыцарь, и плут в одном пространстве, в голове, но не в одном и том же времени. Поэтому я не могу знать, адекватен ли я в определённый момент. В обоих состояниях мозг даст  утвердительный ответ. Каждый раз я на распутье, где, не доходя до развилки, повесили вывеску Welcome. И это уже не задача, а парадокс. Назову-ка я его парадокс лжеца-правдеца.\n\t- #conditioning Как мне контролировать себя, меняться, если я не могу доверять собственному сознанию? Обусловленное поведение - одно из возможных решений.",536870917]],["^15",[1867,"^16",1772635622180,536870917]],["^15",[1867,"^Z","journals/2023_10_16.md",536870917]],["^15",[1868,"^K",1772635622179,536870917]],["^15",[1868,"^[",1867,536870917]],["^15",[1868,"^N",20231016,536870917]],["^15",[1868,"^@",true,536870917]],["^15",[1868,"^Y","oct 16th, 2023",536870917]],["^15",[1868,"^11","Oct 16th, 2023",536870917]],["^15",[1868,"^B",1772635622179,536870917]],["^15",[1868,"^;","~u69a845e6-3c7b-4d94-986e-850a85947082",536870917]],["^15",[1869,"^K",1772635622179,536870917]],["^15",[1869,"^@",false,536870917]],["^15",[1869,"^Y","liar paradox",536870917]],["^15",[1869,"^11","liar paradox",536870917]],["^15",[1869,"^B",1772635622179,536870917]],["^15",[1869,"^;","~u69a845e6-15f4-412a-bf88-1ecfb26f59bf",536870917]],["^15",[1870,"^K",1772635622202,536870917]],["^15",[1870,"^@",false,536870917]],["^15",[1870,"^Y","conditioning",536870917]],["^15",[1870,"^11","conditioning",536870917]],["^15",[1870,"^B",1772635622202,536870917]],["^15",[1870,"^;","~u69a845e6-08fc-4eef-9cd2-cd717eb98bca",536870917]],["^15",[1871,"^Q","#[[liar paradox]] Задачи о рыцарях и плутах решаются сверкой их ответов. Однако моё сознание - и рыцарь, и плут в одном пространстве, в голове, но не в одном и том же времени. Поэтому я не могу знать, адекватен ли я в определённый момент. В обоих состояниях мозг даст  утвердительный ответ. Каждый раз я на распутье, где, не доходя до развилки, повесили вывеску Welcome. И это уже не задача, а парадокс. Назову-ка я его парадокс лжеца-правдеца.",536870917]],["^15",[1871,"^O","^17",536870917]],["^15",[1871,"^F",1868,536870917]],["^15",[1871,"^X",1868,536870917]],["^15",[1871,"^V",1868,536870917]],["^15",[1871,"^U",1868,536870917]],["^15",[1871,"^U",1869,536870917]],["^15",[1871,"^H",1869,536870917]],["^15",[1871,"^;","~u69a845e6-8bce-4597-a4e2-04720a895c86",536870917]],["^15",[1872,"^Q","#conditioning Как мне контролировать себя, меняться, если я не могу доверять собственному сознанию? Обусловленное поведение - одно из возможных решений.",536870917]],["^15",[1872,"^O","^17",536870917]],["^15",[1872,"^F",1871,536870917]],["^15",[1872,"^X",1868,536870917]],["^15",[1872,"^V",1871,536870917]],["^15",[1872,"^U",1868,536870917]],["^15",[1872,"^U",1869,536870917]],["^15",[1872,"^U",1870,536870917]],["^15",[1872,"^H",1870,536870917]],["^15",[1872,"^;","~u69a845e6-7dcc-45ab-af02-951c86d9f9e2",536870917]],["^15",[1873,"^3","- #[[personality psychology/anxiety]]\n\t- Твоя основная тревога состоит из тревоги исполнения, которая у тебя зиждется на [предвосхищении]([[personality psychology/anxiety/anticipatory anxiety]]) ответственности, неоправдания ожиданий и неудачи. Но последнее не имеет веса, так как ты гораздо больше боишься ответственности и чужого осуждения. Дорога к себе избавит от зависимости от мнения других, а вот для первого нужно обрести покой.\n\t  id:: 655011be-f3fa-4370-bac4-416fc924d79e\n\t\t- Производные\n\t\t\t- #kenophobia\n\t\t\t\t- В пустоте тебе ещё страшнее, а эхо одиночества ещё громче. Научись для начала справляться с тишиной, затем с пустотой, потом с тем, что впереди, и наконец с тем, что в конце.\n\t\t\t- #[[personality psychology/anxiety/fulfilment-anxiety]]\n\t\t\t\t- Термин, обобщающий open loops и performance anxiety.\n\t\t- Сопутствующие\n\t\t\t- #procrastination\n\t\t- Решения\n\t\t\t- лекарства\n\t\t\t- #[[action/anticipatory commitment]]\n\t\t\t- #conditioning\n\t\t\t- #orthogonality\n\t\t\t- #authenticity\n\t\t\t- #metacogintion\n\t\t\t- #grounding\n\t\t\t- #catharsis\n\t\t\t- #CBT\n-",536870917]],["^15",[1873,"^16",1772635622204,536870917]],["^15",[1873,"^Z","journals/2023_10_14.md",536870917]],["^15",[1874,"^K",1772635622201,536870917]],["^15",[1874,"^@",false,536870917]],["^15",[1874,"^Y","personality psychology/anxiety/fulfilment-anxiety",536870917]],["^15",[1874,"^A",148,536870917]],["^15",[1874,"^11","personality psychology/anxiety/fulfilment-anxiety",536870917]],["^15",[1874,"^B",1772635622201,536870917]],["^15",[1874,"^;","~u69a845e6-17f7-4a4e-b634-453073b39f72",536870917]],["^15",[1875,"^K",1772635622200,536870917]],["^15",[1875,"^[",1873,536870917]],["^15",[1875,"^N",20231014,536870917]],["^15",[1875,"^@",true,536870917]],["^15",[1875,"^Y","oct 14th, 2023",536870917]],["^15",[1875,"^11","Oct 14th, 2023",536870917]],["^15",[1875,"^B",1772635622200,536870917]],["^15",[1875,"^;","~u69a845e6-4790-44e8-a29e-557beab6a0fc",536870917]],["^15",[1876,"^K",1772635622203,536870917]],["^15",[1876,"^@",false,536870917]],["^15",[1876,"^Y","cbt",536870917]],["^15",[1876,"^11","CBT",536870917]],["^15",[1876,"^B",1772635622203,536870917]],["^15",[1876,"^;","~u69a845e6-9236-40bb-808c-71f249d50c5c",536870917]],["^15",[1877,"^K",1772635623167,536870917]],["^15",[1877,"^@",false,536870917]],["^15",[1877,"^Y","metacogintion",536870917]],["^15",[1877,"^11","metacogintion",536870917]],["^15",[1877,"^B",1772635623167,536870917]],["^15",[1877,"^;","~u69a845e7-e5df-41d7-b52e-7684e454e8d2",5368709