6,"^J",["^19","^1;","^1<"],536870915]],["^15",[1236,"^4",["^ ","^19","diary","^1;","reflection","^1<","neutral"],536870915]],["^15",[1236,"^H",185,536870915]],["^15",[1236,"^H",186,536870915]],["^15",[1236,"^H",187,536870915]],["^15",[1236,"^;","~u69a845e4-892a-4591-9760-d66ee513bdb1",536870915]],["^15",[1237,"^Q","Социальная тревога не есть интровертизм. Ты тянешься всеми фибрами к компании, но тревога делает общение сложным.",536870915]],["^15",[1237,"^O","^17",536870915]],["^15",[1237,"^F",1236,536870915]],["^15",[1237,"^X",1235,536870915]],["^15",[1237,"^V",1235,536870915]],["^15",[1237,"^U",1235,536870915]],["^15",[1237,"^;","~u69a845e4-4760-4241-a0ee-d1b57b607b78",536870915]],["^15",[1238,"^3","- [[personality psychology/self-concept]] [[cognitive bias/splitting]] [[cognitive dialectic]] Расщепление эго и когнитивная диалектика размывают твою „я“-концепцию.",536870915]],["^15",[1238,"^16",1772635620265,536870915]],["^15",[1238,"^Z","journals/2025_04_12.md",536870915]],["^15",[1239,"^K",1772635620265,536870915]],["^15",[1239,"^[",1238,536870915]],["^15",[1239,"^N",20250412,536870915]],["^15",[1239,"^@",true,536870915]],["^15",[1239,"^Y","apr 12th, 2025",536870915]],["^15",[1239,"^11","Apr 12th, 2025",536870915]],["^15",[1239,"^B",1772635620265,536870915]],["^15",[1239,"^;","~u69a845e4-37ff-4fe6-bb93-668f51c520dc",536870915]],["^15",[1240,"^K",1772635620264,536870915]],["^15",[1240,"^@",false,536870915]],["^15",[1240,"^Y","personality psychology/self-concept",536870915]],["^15",[1240,"^A",150,536870915]],["^15",[1240,"^11","personality psychology/self-concept",536870915]],["^15",[1240,"^B",1772635620264,536870915]],["^15",[1240,"^;","~u69a845e5-53a7-4273-a4f7-2cc58839d006",536870917]],["^15",[1241,"^Q","[[personality psychology/self-concept]] [[cognitive bias/splitting]] [[cognitive dialectic]] Расщепление эго и когнитивная диалектика размывают твою „я“-концепцию.",536870915]],["^15",[1241,"^O","^17",536870915]],["^15",[1241,"^F",1239,536870915]],["^15",[1241,"^X",1239,536870915]],["^15",[1241,"^V",1239,536870915]],["^15",[1241,"^U",150,536870915]],["^15",[1241,"^U",440,536870915]],["^15",[1241,"^U",441,536870915]],["^15",[1241,"^U",1211,536870915]],["^15",[1241,"^U",1239,536870915]],["^15",[1241,"^U",1240,536870915]],["^15",[1241,"^H",150,536870915]],["^15",[1241,"^H",440,536870915]],["^15",[1241,"^H",441,536870915]],["^15",[1241,"^H",1211,536870915]],["^15",[1241,"^H",1240,536870915]],["^15",[1241,"^;","~u69a845e4-f58c-4cb3-9fe6-c171a44f5e23",536870915]],["^15",[1242,"^3","- [[personality psychology/toxicity]] Во мне всегда был этот тролль. Вспомни спор с Горягиным в школе и подшучивание над Галбацевым. Над Никой даже пытался стебаться. Просто раньше из-за смущения я не мог связать два слова вместе и некому кроме было присесть на уши. На других замахнуться кишка тонка.",536870915]],["^15",[1242,"^16",1772635620276,536870915]],["^15",[1242,"^Z","journals/2025_04_11.md",536870915]],["^15",[1243,"^K",1772635620276,536870915]],["^15",[1243,"^[",1242,536870915]],["^15",[1243,"^N",20250411,536870915]],["^15",[1243,"^@",true,536870915]],["^15",[1243,"^Y","apr 11th, 2025",536870915]],["^15",[1243,"^11","Apr 11th, 2025",536870915]],["^15",[1243,"^B",1772635620276,536870915]],["^15",[1243,"^;","~u69a845e4-aa76-47d7-b021-b87f463e5469",536870915]],["^15",[1244,"^K",1772635620276,536870915]],["^15",[1244,"^@",false,536870915]],["^15",[1244,"^Y","personality psychology/toxicity",536870915]],["^15",[1244,"^A",150,536870915]],["^15",[1244,"^11","personality psychology/toxicity",536870915]],["^15",[1244,"^B",1772635620276,536870915]],["^15",[1244,"^;","~u69a845e4-c108-4008-a040-3052debf4d02",536870915]],["^15",[1245,"^Q","[[personality psychology/toxicity]] Во мне всегда был этот тролль. Вспомни спор с Горягиным в школе и подшучивание над Галбацевым. Над Никой даже пытался стебаться. Просто раньше из-за смущения я не мог связать два слова вместе и некому кроме было присесть на уши. На других замахнуться кишка тонка.",536870915]],["^15",[1245,"^O","^17",536870915]],["^15",[1245,"^F",1243,536870915]],["^15",[1245,"^X",1243,536870915]],["^15",[1245,"^V",1243,536870915]],["^15",[1245,"^U",150,536870915]],["^15",[1245,"^U",1243,536870915]],["^15",[1245,"^U",1244,536870915]],["^15",[1245,"^H",150,536870915]],["^15",[1245,"^H",1244,536870915]],["^15",[1245,"^;","~u69a845e4-ba54-4b70-89c2-e8b6131f7f45",536870915]],["^15",[1246,"^3","- [[cognitive bias/splitting]] [[personality psychology/independence]] Самые тяжёлые последствия расщепление имеет, когда ты применяешь его к людям. В начале общения ты идеализируешь человека. Потом, когда видишь доказательства несоотвествия его выдуманному идеалу, ты начинаешь к нему относится отрицательно и отталкиваешь. Избегай этого искажения, вместе с тем сохраняя свою самодостаточность в общении.",536870915]],["^15",[1246,"^16",1772635620291,536870915]],["^15",[1246,"^Z","journals/2025_04_09.md",536870915]],["^15",[1247,"^K",1772635620291,536870915]],["^15",[1247,"^[",1246,536870915]],["^15",[1247,"^N",20250409,536870915]],["^15",[1247,"^@",true,536870915]],["^15",[1247,"^Y","apr 9th, 2025",536870915]],["^15",[1247,"^11","Apr 9th, 2025",536870915]],["^15",[1247,"^B",1772635620291,536870915]],["^15",[1247,"^;","~u69a845e4-8b3c-4104-bdeb-d7519c1ed32c",536870915]],["^15",[1248,"^Q","[[cognitive bias/splitting]] [[personality psychology/independence]] Самые тяжёлые последствия расщепление имеет, когда ты применяешь его к людям. В начале общения ты идеализируешь человека. Потом, когда видишь доказательства несоотвествия его выдуманному идеалу, ты начинаешь к нему относится отрицательно и отталкиваешь. Избегай этого искажения, вместе с тем сохраняя свою самодостаточность в общении.",536870915]],["^15",[1248,"^O","^17",536870915]],["^15",[1248,"^F",1247,536870915]],["^15",[1248,"^X",1247,536870915]],["^15",[1248,"^V",1247,536870915]],["^15",[1248,"^U",150,536870915]],["^15",[1248,"^U",219,536870915]],["^15",[1248,"^U",440,536870915]],["^15",[1248,"^U",441,536870915]],["^15",[1248,"^U",1247,536870915]],["^15",[1248,"^H",150,536870915]],["^15",[1248,"^H",219,536870915]],["^15",[1248,"^H",440,536870915]],["^15",[1248,"^H",441,536870915]],["^15",[1248,"^;","~u69a845e4-3c56-465f-b9aa-7c6aef438196",536870915]],["^15",[1249,"^3","- #[[opportunity cost]] Держи в голове, что каждое распределение ресурсов, например, денег или времени, есть альтернативные издержки. Говоря одному последствию \"да\", ты скажешь другому \"нет\".",536870915]],["^15",[1249,"^16",1772635620305,536870915]],["^15",[1249,"^Z","journals/2025_03_18.md",536870915]],["^15",[1250,"^K",1772635620305,536870915]],["^15",[1250,"^[",1249,536870915]],["^15",[1250,"^N",20250318,536870915]],["^15",[1250,"^@",true,536870915]],["^15",[1250,"^Y","mar 18th, 2025",536870915]],["^15",[1250,"^11","Mar 18th, 2025",536870915]],["^15",[1250,"^B",1772635620305,536870915]],["^15",[1250,"^;","~u69a845e4-02e2-421b-990d-89db5ad194c3",536870915]],["^15",[1251,"^K",1772635620328,536870915]],["^15",[1251,"^@",false,536870915]],["^15",[1251,"^Y","opportunity cost",536870915]],["^15",[1251,"^11","opportunity cost",536870915]],["^15",[1251,"^B",1772635620328,536870915]],["^15",[1251,"^;","~u69a845e4-209d-45a4-bb47-b17cee332c9a",536870915]],["^15",[1252,"^Q","#[[opportunity cost]] Держи в голове, что каждое распределение ресурсов, например, денег или времени, есть альтернативные издержки. Говоря одному последствию \"да\", ты скажешь другому \"нет\".",536870915]],["^15",[1252,"^O","^17",536870915]],["^15",[1252,"^F",1250,536870915]],["^15",[1252,"^X",1250,536870915]],["^15",[1252,"^V",1250,536870915]],["^15",[1252,"^U",1250,536870915]],["^15",[1252,"^U",1251,536870915]],["^15",[1252,"^H",1251,536870915]],["^15",[1252,"^;","~u69a845e4-3d12-4c04-877e-7c4708580611",536870915]],["^15",[1253,"^3","- #[[mind wandering/maladaptive daydreaming]]\n\t- Причины\n\t\t- отсутствие #[[personality psychology/independence]]\n\t\t- Средства противодействия\n\t\t\t- Первый ряд\n\t\t- #[[personality psychology/anxiety]]\n\t- Средства противодействия\n\t\t- Первый ряд\n\t\t\t- #[[opportunity cost]]\n\t\t\t\t- Ты теряешь не только время затраченное на саму фантазию, но и на застраиваемый ей воздушный замок. Отказавшись от фантазии ты получишь как кратко- так и долгосрочную выгоду.\n\t\t\t- #authenticity\n\t\t\t- #[[grounding/breathing]]\n\t\t\t- Как бы всё случилось на самом деле.\n\t\t\t- Прекрати...\n\t\t\t\t- отвлекать своё внимание от ответственности.\n- #insomnia\n\t- Причины\n\t\t- #[[personality psychology/anxiety]]\n\t- Средства противодействия\n\t\t- Первый ряд\n\t\t\t- #orthogonality\n\t\t\t- #[[opportunity cost]]\n\t\t\t- #grounding/breathing\n\t\t\t- Прекрати\n\t\t\t\t- #[[mind wandering/maladaptive daydreaming]]",536879755]],["^15",[1253,"^16",1772635620328,536870915]],["^15",[1253,"^18","~m1775842160468",536879754]],["^15",[1253,"^Z","journals/2025_03_16.md",536870915]],["^15",[1254,"^K",1772635620326,536870915]],["^15",[1254,"^[",2941,536870917]],["^15",[1254,"^@",false,536870915]],["^15",[1254,"^Y","authenticity",536870915]],["^15",[1254,"^11","authenticity",536870915]],["^15",[1254,"^?",["^ ","~:filters","{}"],536870917]],["^15",[1254,"^4",["^ ","^1F","{}"],536870917]],["^15",[1254,"^B",1772635620326,536870915]],["^15",[1254,"^;","~u69a845ea-922c-48ce-a07e-639c50e9350b",536870918]],["^15",[1255,"^K",1772635620328,536870915]],["^15",[1255,"^[",3207,536870917]],["^15",[1255,"^@",false,536870915]],["^15",[1255,"^Y","orthogonality",536870915]],["^15",[1255,"^11","orthogonality",536870915]],["^15",[1255,"^B",1772635620328,536870915]],["^15",[1255,"^;","~u69a845e8-ead3-4911-89fd-e42bc6fe6fd1",536870917]],["^15",[1256,"^K",1772635620324,536870915]],["^15",[1256,"^[",1253,536870915]],["^15",[1256,"^N",20250316,536870915]],["^15",[1256,"^@",true,536870915]],["^15",[1256,"^Y","mar 16th, 2025",536870915]],["^15",[1256,"^11","Mar 16th, 2025",536870915]],["^15",[1256,"^B",1772635620324,536870915]],["^15",[1256,"^;","~u69a845e4-97c2-4e7e-9edd-8d48bd751982",536870915]],["^15",[1257,"^Q","#[