ще это делали. В Мирмидонее же каждый метрополис находится на поверхности и контролирует доступ своих колоний к ней.\n- Приложение\n\t- Идея заимствована из рассказа Азимова \"Штрейкбрехер\", где такая планета называется Elsevere.\n\t- [[real history]]\n\t\t- https://en.wikipedia.org/wiki/Israeli_settlement",536870996]],["^15",[2491,"^16",1752169832301,536870920]],["^15",[2491,"^17","~m1752176407426",536870995]],["^15",[2491,"^Z","pages/Планета-муравейник.md",536870920]],["^15",[2492,"^K",1752169832300,536870920]],["^15",[2492,"^[",2491,536870920]],["^15",[2492,"^@",false,536870920]],["^15",[2492,"^Y","планета-муравейник",536870920]],["^15",[2492,"^11","Планета-муравейник",536870920]],["^15",[2492,"^?",["^ ","^18",["^19",["workshop"]],"^1?","backlog","^1=","writing","^1@","novel"],536870920]],["^15",[2492,"^4",["^ ","^18","workshop","^1?","backlog","^1=","writing","^1@","novel"],536870920]],["^15",[2492,"^P",963,536870920]],["^15",[2492,"^B",1752169832300,536870920]],["^15",[2492,"^;","~u686ffd68-2b6e-4573-8e00-e74e1fc3c9f1",536870920]],["^15",[2493,"^Q","tags:: workshop\nstatus:: backlog\ntype:: writing\nform:: novel\n\n",536870920]],["^15",[2493,"^O","^1;",536870920]],["^15",[2493,"^1<",["^19",[]],536870920]],["^15",[2493,"^F",2492,536870920]],["^15",[2493,"^X",2492,536870920]],["^15",[2493,"^V",2492,536870920]],["^15",[2493,"^U",70,536870920]],["^15",[2493,"^U",963,536870920]],["^15",[2493,"^U",964,536870920]],["^15",[2493,"^U",965,536870920]],["^15",[2493,"^U",2492,536870920]],["^15",[2493,"^:",true,536870920]],["^15",[2493,"^?",["^ ","^18",["^19",["workshop"]],"^1?","backlog","^1=","writing","^1@","novel"],536870920]],["^15",[2493,"^J",["^18","^1?","^1=","^1@"],536870920]],["^15",[2493,"^4",["^ ","^18","workshop","^1?","backlog","^1=","writing","^1@","novel"],536870920]],["^15",[2493,"^H",70,536870920]],["^15",[2493,"^H",963,536870920]],["^15",[2493,"^H",964,536870920]],["^15",[2493,"^H",965,536870920]],["^15",[2493,"^;","~u686ffd68-a972-4806-bd7f-2d75a221bb20"