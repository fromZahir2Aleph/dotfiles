ty psychology/independence]]\n\t- Самые сильные как позитивные, так и негативные чувства у меня являются реакцией на других людей. Научись быть стартером в цепи обратной связи, а не шестерёнкой.",536870919]],["^15",[628,"^16",1752169829113,536870919]],["^15",[628,"^Z","journals/2024_01_16.md",536870919]],["^15",[629,"^K",1752169829112,536870919]],["^15",[629,"^[",628,536870919]],["^15",[629,"^N",20240116,536870919]],["^15",[629,"^@",true,536870919]],["^15",[629,"^Y","jan 16th, 2024",536870919]],["^15",[629,"^11","Jan 16th, 2024",536870919]],["^15",[629,"^B",1752169829112,536870919]],["^15",[629,"^;","~u686ffd65-0632-444c-b2ac-7ceddd784592",536870919]],["^15",[630,"^Q","[[personality psychology/independence]]",536870919]],["^15",[630,"^O","^1;",536870919]],["^15",[630,"^F",629,536870919]],["^15",[630,"^X",629,536870919]],["^15",[630,"^V",629,536870919]],["^15",[630,"^U",34,536870919]],["^15",[630,"^U",145,536870919]],["^15",[630,"^U",629,536870919]],["^15",[630,"^H",34,536870919]],["^15",[630,"^H",145,536870919]],["^15",[630,"^;","~u686ffd65-36ad-4aa8-9eda-b9372f3918bb",536870919]],["^15",[631,"^Q","Самые сильные как позитивные, так и негативные чувства у меня являются реакцией на других людей. Научись быть стартером в цепи обратной связи, а не шестерёнкой.",536870919]],["^15",[631,"^O","^1;",536870919]],["^15",[631,"^F",630,536870919]],["^15",[631,"^X",629,536870919]],["^15",[631,"^V",630,536870919]],["^15",[631,"^U",34,536870919]],["^15",[631,"^U",145,536870919]],["^15",[631,"^U",629,536870919]],["^15",[631,"^;","~u686ffd65-4f0a-42b5-b817-f98bbbc5e7ff",536870919]],["^15",[632,"^3","- #[[personality psychology/self-worth]] #self-control Чувство достоинства требует самоконтроля без метакогнитивности. Легче держать осанку, дышать ровно и проецировать себя, чем постоянно корректировать свои мысли и действия. К тому же последнее мешает плыть по течению жизни или ловить ценные её моменты.\n\t- #[[[[personality psychology/experience seeking]]]] Воспитывай в себе хорошие качества которые повысят самоуважение, и тогда надобность в самоконроле понизится, а хороших моментов в жизни прибавится.",536870919]],["^15",[632,"^16",1752169829127,536870919]],["^15",[632,"^Z","journals/2024_01_15.md",536870919]],["^15",[633,"^K",1752169829124,536870919]],["^15",[633,"^[",632,536870919]],["^15",[633,"^N",20240115,536870919]],["^15",[633,"^@",true,536870919]],["^15",[633,"^Y","jan 15th, 2024",536870919]],["^15",[633,"^11","Jan 15th, 2024",536870919]],["^15",[633,"^B",1752169829124,536870919]],["^15",[633,"^;","~u686ffd65-a652-4fe4-861b-6d4b45f16f0e",536870919]],["^15",[634,"^K",1752169829124,536870919]],["^15",[634,"^@",false,536870919]],["^15",[634,"^Y","personality psychology/self-worth",536870919]],["^15",[634,"^A",34,536870919]],["^15",[634,"^11","personality psychology/self-worth",536870919]],["^15",[634,"^B",1752169829124,536870919]],["^15",[634,"^;","~u686ffd65-a086-4484-9b04-0353ca9de6f9",536870919]],["^15",[635,"^K",1752169829125,536870919]],["^15",[635,"^@",false,536870919]],["^15",[635,"^Y","[[personality psychology/experience seeking",536870919]],["^15",[635,"^A",637,536870919]],["^15",[635,"^11","[[personality psychology/experience seeking",536870919]],["^15",[635,"^B",1752169829125,536870919]],["^15",[635,"^;","~u686ffd65-1e65-4821-ae0c-b7d2d06d5926",536870919]],["^15",[636,"^K",1752169829126,536870919]],["^15",[636,"^@",false,536870919]],["^15",[636,"^Y","[[personality psychology/experience seeking]]",536870919]],["^15",[636,"^11","[[personality psychology/experience seeking]]",536870919]],["^15",[636,"^B",1752169829126,536870919]],["^15",[636,"^;","~u686ffd65-8cd3-48fd-8104-7b6a4712a45d",536870919]],["^15",[637,"^K",1752169829126,536870919]],["^15",[637,"^@",false,536870919]],["^15",[637,"^Y","[[personality psychology",536870919]],["^15",[637,"^11","[[personality psychology",536870919]],["^15",[637,"^B",1752169829126,536870919]],["^15",[637,"^;","~u686ffd65-8ebb-41e6-9dc2-4b433667747d",536870919]],["^15",[638,"^Q","#[[personality psychology/self-worth]] #self-control Чувство достоинства требует самоконтроля без метакогнитивности. Легче держать осанку, дышать ровно и проецировать себя, чем постоянно корректировать свои мысли и действия. К тому же последнее мешает плыть по течению жизни или ловить ценные её моменты.",536870919]],["^15",[638,"^O","^1;",536870919]],["^15",[638,"^F",633,536870919]],["^15",[638,"^X",633,536870919]],["^15",[638,"^V",633,536870919]],["^15",[638,"^U",34,536870919]],["^15",[638,"^U",195,536870919]],["^15",[638,"^U",633,536870919]],["^15",[638,"^U",634,536870919]],["^15",[638,"^H",34,536870919]],["^15",[638,"^H",195,536870919]],["^15",[638,"^H",634,536870919]],["^15",[638,"^;","~u686ffd65-cfe9-4a68-b3ee-197c1c2a0397",536870919]],["^15",[639,"^Q","#[[[[personality psychology/experience seeking]]]] Воспитывай в себе хорошие качества которые повысят самоуважение, и тогда надобность в самоконроле понизится, а хороших моментов в жизни прибавится.",536870919]],["^15",[639,"^O","^1;",536870919]],["^15",[639,"^F",638,536870919]],["^15",[639,"^X",633,536870919]],["^15",[639,"^V",638,536870919]],["^15",[639,"^U",34,536870919]],["^15",[639,"^U",35,536870919]],["^15",[639,"^U",195,536870919]],["^15",[639,"^U",633,536870919]],["^15",[639,"^U",634,536870919]],["^15",[639,"^U",635,536870919]],["^15",[639,"^U",636,536870919]],["^15",[639,"^U",637,536870919]],["^15",[639,"^H",34,536870919]],["^15",[639,"^H",35,536870919]],["^15",[639,"^H",635,536870919]],["^15",[639,"^H",636,536870919]],["^15",[639,"^H",637,536870919]],["^15",[639,"^;","~u686ffd65-4bdc-46c5-8f9d-0f987ff6a53a",536870919]],["^15",[640,"^3","- [[self-reference/autological]]\n\t- В автологических произведениях форма описывает сущность, напр., в музыке, поэзии и изобразительных искусствах. Примеры из прозы: Волны Вирджинии Вульф. Если брать шире то слог Борхеса и Толстого тоже описывает философию этих авторов и содержание их работ.\n",536870919]],["^15",[640,"^16",1752169829138,536870919]],["^15",[640,"^Z","journals/2023_12_2