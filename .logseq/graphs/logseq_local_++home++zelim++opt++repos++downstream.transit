5-3e7b-42c2-9ef1-b295f6b2dcdf",536870919]],["^15",[781,"^3","- #[[stack management]]\n\t- #[[daily stack]]\n\t\t- Распределение стека и тревога\n\t\t\t- Управляй стеком, а не бэклогом\n\t\t\t- Нeправильно задействованный кадр стека или вовсе свободное его пространство повышает тревогу, в частности, [предвосхищающую]([[personality psychology/anxiety/anticipatory anxiety]]).\n\t\t- Размер стека\n\t\t\t- #metacogintion Каждый раз когда [заглядываешь к себе](((65154fbd-5b43-4fe2-b5d3-f7dbc7b2f4f7))), оценивай размер стека, и, если все текущие кадры не помещаются, то убери наименее приоритетные.\n\t\t\t- Сон - это зарядка батареи следующего дня, которая обратно пропорциональна [предвосхищающей тревоге]([[personality psychology/anxiety/anticipatory anxiety]]) дня текущего.\n\t\t- Выбор кадра стека зависит от\n\t\t\t- Мощности твоего процессора\n\t\t\t- Времени на исполнение его в целом или целесообразной его части\n\t\t- Инструменты\n\t\t\t- Журнал в Logseq\n\t\t\t- #metacogintion Интервальный таймер",536870919]],["^15",[781,"^16",1752169829295,536870919]],["^15",[781,"^Z","journals/2023_10_08.md",536870919]],["^15",[782,"^K",1752169829293,536870919]],["^15",[782,"^[",781,536870919]],["^15",[782,"^N",20231008,536870919]],["^15",[782,"^@",true,536870919]],["^15",[782,"^Y","oct 8th, 2023",536870919]],["^15",[782,"^11","Oct 8th, 2023",536870919]],["^15",[782,"^B",1752169829293,536870919]],["^15",[782,"^;","~u686ffd65-2fb4-4141-9f5a-9c903fb11e5f",536870919]],["^15",[783,"^K",1752169829308,536870919]],["^15",[783,"^[",2335,536870920]],["^15",[783,"^@",false,536870919]],["^15",[783,"^Y","stack management",536870919]],["^15",[783,"^11","stack management",536870919]],["^15",[783,"^B",1752169829308,536870919]],["^15",[783,"^;","~u686ffd68-1254-480b-b425-5eeda818132b",536870920]],["^15",[784,"^K",1752169829294,536870919]],["^15",[784,"^[",2209,536870920]],["^15",[784,"^@",false,536870919]],["^15",[784,"^Y","daily stack",536870919]],["^15",[784,"^11","daily stack",536870919]],["^15"