авить на передний план, т.е. главное предложение, а какой на задний, т.е. придаточное.",536870915]],["^15",[574,"^O","^17",536870915]],["^15",[574,"^F",631,536870915]],["^15",[574,"^X",503,536870915]],["^15",[574,"^V",696,536870915]],["^15",[574,"^U",503,536870915]],["^15",[574,"^;","~u69a845e3-89cb-49e9-9a6c-8804c4271c0b",536870915]],["^15",[575,"^Q","длина определения",536870915]],["^15",[575,"^O","^17",536870915]],["^15",[575,"^F",634,536870915]],["^15",[575,"^X",503,536870915]],["^15",[575,"^V",990,536870915]],["^15",[575,"^U",503,536870915]],["^15",[575,"^;","~u69a845e3-6bb7-4d67-9936-cf10bad6ba3d",536870915]],["^15",[576,"^Q","#+BEGIN_QUOTE\nThe periodic style works diﬀerently. It encloses time into a single, syntactically controllable unit, treats experience synchronically rather than diachronically. Here, arrangement controls, not time. In it, order triumphs; in the running style, order operates. The running style surprises the mind operating; in the periodic style, the mind has ﬁnished its work.\n#+END_QUOTE",536870915]],["^15",[576,"^O","^17",536870915]],["^15",[576,"^F",717,536870915]],["^15",[576,"^X",503,536870915]],["^15",[576,"^V",617,536870915]],["^15",[576,"^U",503,536870915]],["^15",[576,"^;","~u69a845e3-dc82-4fd6-98b1-f790f69028ac",536870915]],["^15",[577,"^Q","*Объект* или *комлемент* или *определение* V S.",536870915]],["^15",[577,"^O","^17",536870915]],["^15",[577,"^F",874,536870915]],["^15",[577,"^X",503,536870915]],["^15",[577,"^V",583,536870915]],["^15",[577,"^U",503,536870915]],["^15",[577,"^;","~u69a845e3-5c32-4eef-a1c3-0f8b4092abe5",536870915]],["^15",[578,"^Q","9, 11",536870915]],["^15",[578,"^O","^17",536870915]],["^15",[578,"^F",646,536870915]],["^15",[578,"^X",503,536870915]],["^15",[578,"^V",590,536870915]],["^15",[578,"^U",503,536870915]],["^15",[578,"^;","~u69a845e3-c9a2-449b-af47-5f6ebfab724d",536870915]],["^15",[579,"^Q","Простое предложение - ядро длинного.",536870915]],["^15",[579,"^O","^17",536870915]],["^15",[579,"^F",715,536