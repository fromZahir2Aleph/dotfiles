"^U",503,536870915]],["^15",[648,"^;","~u69a845e3-65e8-4e25-bf85-52ce71a421f8",536870915]],["^15",[649,"^Q","Профессиональные писатели заканчивают предложения два из трёх раз.",536870915]],["^15",[649,"^O","^17",536870915]],["^15",[649,"^F",744,536870915]],["^15",[649,"^X",503,536870915]],["^15",[649,"^V",605,536870915]],["^15",[649,"^U",503,536870915]],["^15",[649,"^;","~u69a845e3-9ec2-48d0-9a27-f91b9a4583a4",536870915]],["^15",[650,"^Q","сопоставление",536870915]],["^15",[650,"^O","^17",536870915]],["^15",[650,"^F",706,536870915]],["^15",[650,"^X",503,536870915]],["^15",[650,"^V",706,536870915]],["^15",[650,"^U",503,536870915]],["^15",[650,"^;","~u69a845e3-45cb-44ad-8005-ddca723a6208",536870915]],["^15",[651,"^Q","*Ряд приложений* - *обобщающее слово* (иногда S, иногда определение S) V.",536870915]],["^15",[651,"^O","^17",536870915]],["^15",[651,"^F",702,536870915]],["^15",[651,"^X",503,536870915]],["^15",[651,"^V",702,536870915]],["^15",[651,"^U",503,536870915]],["^15",[651,"^;","~u69a845e3-0556-4231-8cd3-71e881b129c4",536870915]],["^15",[652,"^Q","Плоскости",536870915]],["^15",[652,"^O","^17",536870915]],["^15",[652,"^F",591,536870915]],["^15",[652,"^X",503,536870915]],["^15",[652,"^V",926,536870915]],["^15",[652,"^U",503,536870915]],["^15",[652,"^;","~u69a845e3-2953-4777-9a91-f7fd2f3d8f6d",536870915]],["^15",[653,"^Q","Вершина - глагольная группа.",536870915]],["^15",[653,"^O","^17",536870915]],["^15",[653,"^F",1003,536870915]],["^15",[653,"^X",503,536870915]],["^15",[653,"^V",1003,536870915]],["^15",[653,"^U",503,536870915]],["^15",[653,"^;","~u69a845e3-c493-4024-ab41-8847f35c7ac6",536870915]],["^15",[654,"^Q","#+BEGIN_QUOTE\nWe often observe this contrast between the absence of nominal inﬂection and the richness of the verbal inﬂection. This is due to the nature of the noun and the verb. The noun indicates an idea of permanent nature: a thing, a person, or a quality; the verb indicates a process. . . . For the very reason that it indicates a permanent notion, the noun has a sole form or at most a principal form from which the others are derived. On the other hand, the verb, which indicates a process, has personal forms and the expression of nuances which vary with languages, but can be numerous. The fact that the forms of the noun and verb obey divergent tendencies thus results from the nature of things.\n#+END_QUOTE\nA. Meillet, The Comparative Method in Historical Linguistics, p. 114",536870915]],["^15",[654,"^O","^17",536870915]],["^15",[654,"^F",786,536870915]],["^15",[654,"^X",503,536870915]],["^15",[654,"^V",713,536870915]],["^15",[654,"^U",503,536870915]],["^15",[654,"^;","~u69a845e3-36be-4b00-b62e-ff4a08517fca",536870915]],["^15",[655,"^Q","Виды развёртывания предложения",536870915]],["^15",[655,"^O","^17",536870915]],["^15",[655,"^F",695,536870915]],["^15",[655,"^X",503,536870915]],["^15",[655,"^V",842,536870915]],["^15",[655,"^U",503,536870915]],["^15",[655,"^;","~u69a845e3-8cf9-4504-a68c-22e41e99cf8b",536870915]],["^15",[656,"^Q","Синтагматичный",536870915]],["^15",[656,"^O","^17",536870915]],["^15",[656,"^F",547,536870915]],["^15",[656,"^X",503,536870915]],["^15",[656,"^V",637,536870915]],["^15",[656,"^U",503,536870915]],["^15",[656,"^;","~u69a845e3-d0e3-4558-a005-609dd28b635f",536870915]],["^15",[657,"^Q","У каждого языка свой ритм.",536870915]],["^15",[657,"^O","^17",536870915]],["^15",[657,"^F",843,536870915]],["^15",[657,"^X",503,536870915]],["^15",[657,"^V",719,536870915]],["^15",[657,"^U",503,536870915]],["^15",[657,"^;","~u69a845e3-4fd5-494c-b189-d2717a16de0e",536870915]],["^15",[658,"^Q","S, одно или два приложения с возможными определениями, V.",536870915]],["^15",[658,"^O","^17",536870915]],["^15",[658,"^F",943,536870915]],["^15",[658,"^X",503,536870915]],["^15",[658,"^V",943,536870915]],["^15",[658,"^U",503,536870915]],["^15",[658,"^;","~u69a845e3-97b6-4133-90a5-f6b38a5deee2",536870915]],["^15",[659,"^Q","Повторение",536870915]],["^15",[659,"^O","^17",536870915]],["^15",[659,"^F",782,536870915]],[