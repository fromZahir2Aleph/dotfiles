,"^H",2158,536870917]],["^15",[2274,"^H",2162,536870917]],["^15",[2274,"^H",2164,536870917]],["^15",[2274,"^H",2166,536870917]],["^15",[2274,"^H",2167,536870917]],["^15",[2274,"^;","~u64e64a87-5607-4ebc-ad26-47231557940f",536870917]],["^15",[2275,"^Q","Желая отомстить Зевсу за заключение в Тартар своих Титанов [Гея](((64e64a87-5607-4ebc-ad26-47231557940f))) натравила других детей, сначала гигантов Гигантомахии, а потом Тифона.",536870917]],["^15",[2275,"^O","^17",536870917]],["^15",[2275,"^F",2291,536870917]],["^15",[2275,"^X",2161,536870917]],["^15",[2275,"^V",2255,536870917]],["^15",[2275,"^U",2161,536870917]],["^15",[2275,"^H",2274,536870917]],["^15",[2275,"^;","~u69a845e6-1b8b-4f6e-b1c5-c54a136bacdc",536870917]],["^15",[2276,"^Q","Переверни сюжет Пигмалиона, где каждый из богов учит её своей фирменной мерзости, чтобы она, собственно, и стала тем ящиком, и с другой стороны и чтобы навсегда подорвать доверие к женщине у мужчин и патриархия царила не только на Олимпе, но и внизу.",536870917]],["^15",[2276,"^O","^17",536870917]],["^15",[2276,"^F",2278,536870917]],["^15",[2276,"^X",2161,536870917]],["^15",[2276,"^V",2278,536870917]],["^15",[2276,"^U",2157,536870917]],["^15",[2276,"^U",2158,536870917]],["^15",[2276,"^U",2159,536870917]],["^15",[2276,"^U",2161,536870917]],["^15",[2276,"^U",2162,536870917]],["^15",[2276,"^U",2164,536870917]],["^15",[2276,"^U",2166,536870917]],["^15",[2276,"^U",2167,536870917]],["^15",[2276,"^;","~u69a845e6-f0b9-4a12-8737-dd5ce0103594",536870917]],["^15",[2277,"^Q","Разжалование бога по функциям и регионам",536870917]],["^15",[2277,"^O","^17",536870917]],["^15",[2277,"^F",2280,536870917]],["^15",[2277,"^X",2161,536870917]],["^15",[2277,"^V",2280,536870917]],["^15",[2277,"^U",2159,536870917]],["^15",[2277,"^U",2161,536870917]],["^15",[2277,"^;","~u69a845e6-704b-4f0a-9054-6e80ac9003bf",536870917]],["^15",[2278,"^Q","[[Alternate mythology]]",536870917]],["^15",[2278,"^O","^17",536870917]],["^15",[2278,"^F",2299,536870917]],["^15",[2278,"^X"