а имеет лишь тот смысл, который можно извлечь из высказываний на поверхности. Его главным содержанием может быть то, на что они намекают.",536870915]],["^15",[722,"^O","^17",536870915]],["^15",[722,"^F",815,536870915]],["^15",[722,"^X",503,536870915]],["^15",[722,"^V",996,536870915]],["^15",[722,"^U",503,536870915]],["^15",[722,"^;","~u69a845e3-8e70-40c0-b044-2c733c8eb923",536870915]],["^15",[723,"^Q","Наречие",536870915]],["^15",[723,"^O","^17",536870915]],["^15",[723,"^F",539,536870915]],["^15",[723,"^X",503,536870915]],["^15",[723,"^V",539,536870915]],["^15",[723,"^U",503,536870915]],["^15",[723,"^;","~u69a845e3-0ef9-4276-a09f-6a4507331b20",536870915]],["^15",[724,"^Q","Наречие только. Можно иногда.",536870915]],["^15",[724,"^O","^17",536870915]],["^15",[724,"^F",827,536870915]],["^15",[724,"^X",503,536870915]],["^15",[724,"^V",952,536870915]],["^15",[724,"^U",503,536870915]],["^15",[724,"^;","~u69a845e3-975e-4672-aa52-0007227d1fb2",536870915]],["^15",[725,"^Q","Недостаток баланса",536870915]],["^15",[725,"^O","^17",536870915]],["^15",[725,"^F",1012,536870915]],["^15",[725,"^X",503,536870915]],["^15",[725,"^V",704,536870915]],["^15",[725,"^U",503,536870915]],["^15",[725,"^;","~u69a845e3-0392-408e-b674-60593078561c",536870915]],["^15",[726,"^Q","Парные конструкции только для контраста",536870915]],["^15",[726,"^O","^17",536870915]],["^15",[726,"^F",727,536870915]],["^15",[726,"^X",503,536870915]],["^15",[726,"^V",727,536870915]],["^15",[726,"^U",503,536870915]],["^15",[726,"^;","~u69a845e3-9e28-4630-8807-7ada96271fb3",536870915]],["^15",[727,"^Q","16a",536870915]],["^15",[727,"^O","^17",536870915]],["^15",[727,"^F",824,536870915]],["^15",[727,"^X",503,536870915]],["^15",[727,"^V",824,536870915]],["^15",[727,"^U",503,536870915]],["^15",[727,"^;","~u69a845e3-ac42-47d5-ae09-f533bb73f41f",536870915]],["^15",[728,"^Q","Стилистические приёмы всегда могут быть перевёрнуты, чтобы обмануть ожидания читателя.",536870915]],["^15",[728,"^O","^17",536870915]],["^15",[728,"^F",