3946,536870917]],["^15",[3050,"^18","~m1772638799143",536871111]],["^15",[3050,"^Z","pages/languages.md",536870917]],["^15",[3052,"^3","-",536871119]],["^15",[3052,"^16",1772635623961,536870917]],["^15",[3052,"^18","~m1772638816245",536871118]],["^15",[3052,"^Z","pages/languages___Chechen language.md",536870917]],["^15",[3070,"^3","- Ingush Grammar by J. Nichols\n- A Grammar of Chechen by Z. Dotton\n- Scope properties of Chechen converbs\n  Zarina Molochieva\n- Clause combining in Chechen by Jeff Good\n- What is cosubordination?\n\t- https://linguistics.stackexchange.com/questions/3241/what-is-cosubordination\n- Switch-reference on Wiki\n- Converb on Wiki",536870917]],["^15",[3070,"^16",1772635624026,536870917]],["^15",[3070,"^Z","pages/languages___Chechen language___to read.md",536870917]],["^15",[3071,"^K",1772635624024,536870917]],["^15",[3071,"^[",3070,536870917]],["^15",[3071,"^@",false,536870917]],["^15",[3071,"^Y","languages/chechen language/to read",536870917]],["^15",[3071,"^A",20,536870917]],["^15",[3071,"^11","languages/Chechen language/to read",536870917]],["^15",[3071,"^B",1772635624024,536870917]],["^15",[3071,"^;","~u69a845e8-b7d0-4d22-901a-dc4cea7968f0",536870917]],["^15",[3072,"^Q","Ingush Grammar by J. Nichols",536870917]],["^15",[3072,"^O","^17",536870917]],["^15",[3072,"^F",3071,536870917]],["^15",[3072,"^X",3071,536870917]],["^15",[3072,"^V",3071,536870917]],["^15",[3072,"^U",3071,536870917]],["^15",[3072,"^;","~u69a845e8-3602-44bd-9d5d-2e0b510005f2",536870917]],["^15",[3073,"^Q","A Grammar of Chechen by Z. Dotton",536870917]],["^15",[3073,"^O","^17",536870917]],["^15",[3073,"^F",3072,536870917]],["^15",[3073,"^X",3071,536870917]],["^15",[3073,"^V",3071,536870917]],["^15",[3073,"^U",3071,536870917]],["^15",[3073,"^;","~u69a845e8-d001-48df-8ae8-0942e0b6c808",536870917]],["^15",[3074,"^Q","Scope properties of Chechen converbs\nZarina Molochieva",536870917]],["^15",[3074,"^O","^17",536870917]],["^15",[3074,"^F",3073,536870917]],["^15",[3074,"^X",3071,536870917]],["^15",[3074,"^V",3071,536870917]],["^15",[3074,"^U",3071,536870917]],["^15",[3074,"^;","~u69a845e8-ad11-4320-9cb5-810c948d5e7d",536870917]],["^15",[3075,"^Q","Clause combining in Chechen by Jeff Good",536870917]],["^15",[3075,"^O","^17",536870917]],["^15",[3075,"^F",3074,536870917]],["^15",[3075,"^X",3071,536870917]],["^15",[3075,"^V",3071,536870917]],["^15",[3075,"^U",3071,536870917]],["^15",[3075,"^;","~u69a845e8-212e-4a52-93cf-3f969e8ccff8",536870917]],["^15",[3076,"^Q","What is cosubordination?",536870917]],["^15",[3076,"^O","^17",536870917]],["^15",[3076,"^F",3075,536870917]],["^15",[3076,"^X",3071,536870917]],["^15",[3076,"^V",3071,536870917]],["^15",[3076,"^U",3071,536870917]],["^15",[3076,"^;","~u69a845e8-9cd8-4143-a5f1-3c61d339d23a",536870917]],["^15",[3077,"^Q","https://linguistics.stackexchange.com/questions/3241/what-is-cosubordination",536870917]],["^15",[3077,"^O","^17",536870917]],["^15",[3077,"^F",3076,536870917]],["^15",[3077,"^X",3071,536870917]],["^15",[3077,"^V",3076,536870917]],["^15",[3077,"^U",3071,536870917]],["^15",[3077,"^;","~u69a845e8-7ae8-4af0-b79a-b0a75342c7c0",536870917]],["^15",[3078,"^Q","Switch-reference on Wiki",536870917]],["^15",[3078,"^O","^17",536870917]],["^15",[3078,"^F",3076,536870917]],["^15",[3078,"^X",3071,536870917]],["^15",[3078,"^V",3071,536870917]],["^15",[3078,"^U",3071,536870917]],["^15",[3078,"^;","~u69a845e8-5004-4a30-92f2-6b7da1aa7419",536870917]],["^15",[3079,"^Q","Converb on Wiki",536870917]],["^15",[3079,"^O","^17",536870917]],["^15",[3079,"^F",3078,536870917]],["^15",[3079,"^X",3071,536870917]],["^15",[3079,"^V",3071,536870917]],["^15",[3079,"^U",3071,536870917]],["^15",[3079,"^;","~u69a845e8-710e-4e9d-a419-1e45c5a68e03",536870917]],["^15",[3080,"^3","- Сохранение кириллицы\n\t- ӏ - Ъ\n\t\t- Бӏ - бъ, тӏ - тъ и др.\n\t\t- Гӏ - Гъ, хӏ  - Хъ\n\t\t- Къ - Кхъ\n\t\t- Гортанная смычка ъ - ы\n\t\t\t- кхаъ, хъаъ\n\t- Сохранение палатализирующих букв Ё, Ю и Я\n\t\t- Мациев испольует\n\t\t- \"Й\" для согласования префикса второго класса й- в единственном числе и третьего класса й- II в единственном и множественном числе\n\t\t\t- Ю - йу: йула.\n\t\t\t- Е - йе: еза - йе:за.\n\t\t\t- Ё - йо: йовха - йовха.\n\t\t\t- Я - йа: яжа - йа:жа\n\t\t\t- Е - йе: елха - йелха\n\t\t- Оставить там, где согласования не нужно\n\t\t\t- юргъа, юкхъ, ё:ма, ёвлакх, ялх, еза\n\t- Ф, Щ и при полном избавления от палатализирух букв Я,  Ю и Ё становятся нужными только для слов, заимствованных с русского.\n\t\t- Можно заменить на П., Ш.\n\t\t- Я - йа, ю - йу, ё - йо\n\t- Гласные, отсутсвующие в русском языке\n\t\t- Краткие гласные -  [yː], [ɛ], [æ], [yø̯], [ə]\n\t\t\t- Е, э - [ɛ]\n\t\t\t\t- лекха, бекхъ, тъе-\n\t\t\t- Э - ударное [ǝ], А как есть - редуцированное [ǝ]\n\t\t\t\t- лэм, бэрт, эрсаш\n\t\t\t\t- кхоллархо, толам, чъепалг\n\t\t\t- Аь - [æ]\n\t\t\t- Уь - [y]\n\t\t- Долгие гласные - двоеточие после гласной или дефис после нее.\n\t\t\t- А. Г. Мациев ипсользует тильду для долгих гласных, но обычно применяют макрон.\n\t\t\t- Ā, a - [a:]\n\t\t\t  id:: 6935bff2-bb41-4447-a452-a674cb946f0d\n\t\t\t\t- ларам - ла:рам, гъала - гъа:ла, да - да:, нана - на:на\n\t\t\t- О̄, о - [o:]\n\t\t\t\t- олуш - о:луш\n\t\t\t\t  id:: 6935deff-bb82-4bb3-819d-95f07ba3da2e\n\t\t\t- Ӯь, уьй - [yː]\n\t\t\t\t- можно оставить как есть\n\t\t\t\t- ӏуьйре - ӏуь:йре\n\t\t\t- Ӣ, ий - [i:]\n\t\t\t\t- можно оставить как есть\n\t\t\t\t- мийр - ми:р, кийра - ки:ра\n\t\t\t- Е̄, э - [е:]\n\t\t\t\t- эса - эьса, эчиг - эьчиг\n\t\t- Дифтонги\n\t\t\t- [little w to the upper left of o] по З. Даттон или [u:o] по Дж. Николс\n\t\t\t\t- ло - луо:, вон - вуо:н\n\t\t\t- Оь - [yø̯]\n\t\t\t- О̄ь, оь - [yːø̯]\n\t\t\t\t- боьхалла - боь:халла\n\t\t\t- [i:ɛ]\n\t\t\t\t- Е̄, е:\n\t\t\t\t\t- зе̄заг - зе:заг, бе̄зам - бе:зам, ме̄чиг - м:ечиг\n\t\t\t\t- Е̄ в начале слова - э:\n\t\t\t\t\t- эца - э:ца, эхь - э:хь, эрна - э:рна\n- Изменение кириллицы\n\t- Ə - [ə]\n\t- Əь - [е] в начале слова\n\t- Удаление палатализирующих гласных Ё, Ю, Я\n\t\t- \"Й\" элп\n\t\t\t- Яха - йа:ха, ялта - йəлта, ю - йу, ёвлакх - йовлакх\n- Сохранение латинницы\n\t- Аь - a., Оь - o., Уь - u.\n\t\t- На немецкой раскладкой есть умлауты.\n\t- ӏ - ', Бӏ - b', тӏ - t', etc.\n\t- Гӏ - gh\n\t- Хь  - hy\n\t- Х - hj\n\t- Й - y\n\t- Къ - q\n\t- Ə - eh\n\t- Ъ - \"\n\t- Лишние транслитерациии\n\t\t- C, X - и чеченского, и русского\n\t\t- F, V - чеченского\n\t\t- W - русского\n\t- Не хватает для транслитерациии английского\n\t\t- Ь - в чеченском\n\t\t- палатализации в русском",536870917]],["^15",[3080,"^16",1772635624078,536870917]],["^15",[3080,"^Z","pages/languages___Chechen language___writing.md",536870917]],["^15",[3081,"^K",1772635624077,536870917]],["^15",[3081,"^[",3080,536870917]],["^15",[3081,"^@",false,536870917]],["^15",[3081,"^Y","languages/chechen language/writing",536870917]],["^15",[3081,"^A",20,536870917]],["^15",[3081,"^11","languages/Chechen language/writing",536870917]],["^15",[3081,"^B",1772635624077,536870917]],["^15",[3081,"^;","~u69a845e8-9ce9-4952-a8bb-d325342f6b2a",536870917]],["^15",[3082,"^Q","Е - йе: еза - йе:за.",536870917]],["^15",[3082,"^O","^17",536870917]],["^15",[3082,"^F",3091,536870917]],["^15",[3082,"^X",3081,536870917]],["^15",[3082,"^V",3152,536870917]],["^15",[3082,"^U",3081,536870917]],["^15",[3082,"^;","~u69a845e8-3cd7-419d-a5c3-430250f8cac5",536870917]],["^15",[3083,"^Q","Ъ - \"",536870917]],["^15",[3083,"^O","^17",536870917]],["^15",[3083,"^F",3118,536870917]],["^15",[3083,"^X",3081,536870917]],["^15",[3083,"^V",3096,536870917]],["^15",[3083,"^U",3081,536870917]],["^15",[3083,"^;","~u69a845e8-3b5e-4d07-acec-c800dc6d8e5b",536870917]],["^15",[3084,"^Q","лекха, бекхъ, тъе-",536870917]],["^15",[3084,"^O","^17",536870917]],["^15",[3084,"^F",3095,536870917]],["^15",[3084,"^X",3081,536870917]],["^15",[3084,"^V",3095,536870917]],["^15",[3084,"^U",3081,536870917]],["^15",[3084,"^;","~u69a845e8-e544-4c07-bdd3-f601271865ce",536870917]],["^15",[3085,"^Q","Е̄, е:",536870917]],["^15",[3085,"^O","^17",536870917]],["^15",[