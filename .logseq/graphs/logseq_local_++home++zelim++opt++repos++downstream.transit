36870919]],["^15",[1190,"^;","~u647e4286-eb1f-4076-8a7d-e32e6d2020cb",536870919]],["^15",[1191,"^Q","Диалог Платона «Федр»",536870919]],["^15",[1191,"^O","^1;",536870919]],["^15",[1191,"^F",1065,536870919]],["^15",[1191,"^X",1003,536870919]],["^15",[1191,"^V",1065,536870919]],["^15",[1191,"^U",1003,536870919]],["^15",[1191,"^;","~u686ffd65-c9c5-4037-a897-a874c78dcf4e",536870919]],["^15",[1192,"^Q","Железный век",536870919]],["^15",[1192,"^O","^1;",536870919]],["^15",[1192,"^F",1087,536870919]],["^15",[1192,"^X",1003,536870919]],["^15",[1192,"^V",1101,536870919]],["^15",[1192,"^U",1003,536870919]],["^15",[1192,"^;","~u686ffd65-7c18-45a8-9c5f-f9aa81ab83e3",536870919]],["^15",[1193,"^Q","[Гефест](((66ba0f9a-fa8e-429f-aaef-bca6524c1fe8))) был правой рукой Зевса. Его свержение было [бесщадным](((66d3325b-a10c-4876-a064-70e45a456087))). На Олимпе его не зовут по имени, а кличут Копчёным или Кривым.",536870919]],["^15",[1193,"^O","^1;",536870919]],["^15",[1193,"^F",1122,536870919]],["^15",[1193,"^X",1003,536870919]],["^15",[1193,"^V",1088,536870919]],["^15",[1193,"^U",1003,536870919]],["^15",[1193,"^U",1034,536870919]],["^15",[1193,"^H",1050,536870919]],["^15",[1193,"^H",1116,536870919]],["^15",[1193,"^;","~u686ffd65-d49b-49b8-bec5-bd76d637de00",536870919]],["^15",[1194,"^Q","А вдруг Тифоня и [гиганты-антиолимпийцы](((64b4613c-6f4b-4166-929c-b7711cb73c7d))) были хорошими, а историки победителей их просто оклеветали.",536870919]],["^15",[1194,"^O","^1;",536870919]],["^15",[1194,"^F",1132,536870919]],["^15",[1194,"^X",1003,536870919]],["^15",[1194,"^V",1132,536870919]],["^15",[1194,"^U",1003,536870919]],["^15",[1194,"^U",1034,536870919]],["^15",[1194,"^H",1113,536870919]],["^15",[1194,"^;","~u686ffd65-21af-491a-b4a8-6aae2337f57a",536870919]],["^15",[1195,"^Q","5. \"The god who protects the flocks and cattle",536870919]],["^15",[1195,"^O","^1;",536870919]],["^15",[1195,"^F",1169,536870919]],["^15",[1195,"^X",1003,536870919]],["^15",[1195,"^V",1090,536870919]],["^15",[1195,"^U",1003,536870919]],["^15",[1195,"^;","~u686ffd65-334b-4aaf-9a91-f4a5f6c9224a",536870919]],["^15",[1196,"^Q","Ἀπόλλων\n.tags::\n.being:: god\n.mythology:: Greece\n.transcription:: /a.pól.lɔːn/\n.translation:: Аполлон\n.flags:: Olympian\nid:: 3755fb37-1121-4a9c-a22d-2fee9141dc8e",536870919]],["^15",[1196,"^O","^1;",536870919]],["^15",[1196,"^F",1115,536870919]],["^15",[1196,"^X",1003,536870919]],["^15",[1196,"^V",1159,536870919]],["^15",[1196,"^U",1003,536870919]],["^15",[1196,"^U",1032,536870919]],["^15",[1196,"^U",1033,536870919]],["^15",[1196,"^U",1036,536870919]],["^15",[1196,"^U",1038,536870919]],["^15",[1196,"^U",1040,536870919]],["^15",[1196,"^U",1041,536870919]],["^15",[1196,"^?",["^ ","^1S","","^1T","god","^1U","Greece","^1V","/a.pól.lɔːn/","^1W","Аполлон","^1X","Olympian","^1D","3755fb37-1121-4a9c-a22d-2fee9141dc8e"],536870919]],["^15",[1196,"^J",["^1S","^1T","^1U","^1V","^1W","^1X","^1D"],536870919]],["^15",[1196,"^4",["^ ","^1S","","^1T","god","^1U","Greece","^1V","/a.pól.lɔːn/","^1W","Аполлон","^1X","Olympian","^1D","3755fb37-1121-4a9c-a22d-2fee9141dc8e"],536870919]],["^15",[1196,"^H",1032,536870919]],["^15",[1196,"^H",1033,536870919]],["^15",[1196,"^H",1036,536870919]],["^15",[1196,"^H",1038,536870919]],["^15",[1196,"^H",1040,536870919]],["^15",[1196,"^H",1041,536870919]],["^15",[1196,"^;","~u3755fb37-1121-4a9c-a22d-2fee9141dc8e",536870919]],["^15",[1197,"^Q","Братьям [Эпиметею](((655011bf-7aae-4201-abaa-518f4486a711))) (Апослею) и [Прометею](((655011bf-202c-4765-a16c-404b43766587))) (Предвидею) было поручено создание людей и животных. Эпиметей раздал всем по орудию к выживанию: корни, клыки и т.д., а про человека по глупости забыл. Прометей, пожалев людей, своровал у Афины и Гефеста инструменты и огонь, без которых они бесполезны. За это наказали и Прометея, приковав к горе на Кавказе, и человечество, подослав к нему [первую женщину](((654bc199-217e-45ee-963f-fed1e320e9c7))).",536870919]],["^15",[1197,"^O","^1;",536870919]],["^15",[1197,"^F",1165,536870