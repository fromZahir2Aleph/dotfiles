30,536870915]],["^15",[433,"^V",432,536870915]],["^15",[433,"^U",205,536870915]],["^15",[433,"^U",430,536870915]],["^15",[433,"^;","~u69a845e3-80e3-429f-b5ab-b7a97ec42e82",536870915]],["^15",[434,"^3","- [[personality psychology/percentile problem]] Для меня было бы красным флагом у западной девушки, когда она никогда не предлагает разделить счет пополам. Но если на 50/50 идет русская или тем более кавказка, то тут уже флаг в их руках.",536870915]],["^15",[434,"^16",1772635619339,536870915]],["^15",[434,"^Z","journals/2025_11_05.md",536870915]],["^15",[435,"^K",1772635619339,536870915]],["^15",[435,"^[",434,536870915]],["^15",[435,"^N",20251105,536870915]],["^15",[435,"^@",true,536870915]],["^15",[435,"^Y","nov 5th, 2025",536870915]],["^15",[435,"^11","Nov 5th, 2025",536870915]],["^15",[435,"^B",1772635619339,536870915]],["^15",[435,"^;","~u69a845e3-da6c-489a-9d22-e7484d6a26f0",536870915]],["^15",[436,"^Q","[[personality psychology/percentile problem]] Для меня было бы красным флагом у западной девушки, когда она никогда не предлагает разделить счет пополам. Но если на 50/50 идет русская или тем более кавказка, то тут уже флаг в их руках.",536870915]],["^15",[436,"^O","^17",536870915]],["^15",[436,"^F",435,536870915]],["^15",[436,"^X",435,536870915]],["^15",[436,"^V",435,536870915]],["^15",[436,"^U",150,536870915]],["^15",[436,"^U",276,536870915]],["^15",[436,"^U",435,536870915]],["^15",[436,"^H",150,536870915]],["^15",[436,"^H",276,536870915]],["^15",[436,"^;","~u69a845e3-1a1e-483b-8211-bc1fda5068b2",536870915]],["^15",[437,"^3","- [[perfectionism]] [[cognitive bias/splitting]] [[writing/improvement]]\n\t- Перфекционизм - это следствие расщепления и привязки результата к самооценке. Это страх оказаться ниже своих притязаний. Здоровая альтернатива - это совершенствование как процесс, как обучение на ошибках. Не забывай получать удовольствие и введи понятие \"достаточно хорошо для сегодня\".\n\t- Раздели созидание на два режима: создание (поток, интуиция) и редактирование (анализ, улучшение). Перфекционизм возникает, когда пытаешься делать оба одновременно.\n\t\t- Берись за редактирование через некоторое время.",536871234]],["^15",[437,"^16",1772635619369,536870915]],["^15",[437,"^18","~m1772889626891",536871233]],["^15",[437,"^Z","journals/2025_10_31.md",536870915]],["^15",[438,"^K",1772635619369,536870915]],["^15",[438,"^[",437,536870915]],["^15",[438,"^N",20251031,536870915]],["^15",[438,"^@",true,536870915]],["^15",[438,"^Y","oct 31st, 2025",536870915]],["^15",[438,"^11","Oct 31st, 2025",536870915]],["^15",[438,"^B",1772889626488,536871231]],["^15",[438,"^;","~u69a845e3-bc30-4389-995e-1178652c9208",536870915]],["^15",[439,"^K",1772635619367,536870915]],["^15",[439,"^@",false,536870915]],["^15",[439,"^Y","writing/improvement",536870915]],["^15",[439,"^A",197,536870915]],["^15",[439,"^11","writing/improvement",536870915]],["^15",[439,"^B",1772635619367,536870915]],["^15",[439,"^;","~u69a845e3-8f65-4810-ae05-f2e0d84283ba",536870915]],["^15",[440,"^K",1772635620290,536870915]],["^15",[440,"^@",false,536870915]],["^15",[440,"^Y","cognitive bias/splitting",536870915]],["^15",[440,"^A",441,536870915]],["^15",[440,"^11","cognitive bias/splitting",536870915]],["^15",[440,"^B",1772635620290,536870915]],["^15",[440,"^;","~u69a845e4-2757-4c4c-8068-e1be06b602c1",536870915]],["^15",[441,"^K",1772635620290,536870915]],["^15",[441,"^@",false,536870915]],["^15",[441,"^Y","cognitive bias",536870915]],["^15",[441,"^11","cognitive bias",536870915]],["^15",[441,"^B",1772635620290,536870915]],["^15",[441,"^;","~u69a845e4-ed06-4b2c-ae6b-3bf0b013ca48",536870915]],["^15",[442,"^Q","[[perfectionism]] [[cognitive bias/splitting]] [[writing/improvement]]",536871231]],["^15",[442,"^O","^17",536870915]],["^15",[442,"^F",438,536870915]],["^15",[442,"^X",438,536870915]],["^15",[442,"^V",438,536870915]],["^15",[442,"^U",197,536871232]],["^15",[442,"^U",438,536871232]],["^15",[442,"^U",439,536871232]],["^15",[442,"^U",440,536871232]],["^15",[442,"^U",441,53