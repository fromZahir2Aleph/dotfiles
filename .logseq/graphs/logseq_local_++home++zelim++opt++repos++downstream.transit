5",[3977,"^H",205,536873444]],["^15",[3977,"^;","~u69baeba8-2b1c-4ba8-bda8-b1648d4d3c34",536873278]],["^15",[3978,"^3","- #[[personality psychology/anxiety]] #exit Нужно принять смерть. Я умру. Мама и Седа тоже. Если я смирюсь с самым страшным, остальное станет меня тревожить намного меньше.",536873447]],["^15",[3978,"^18","~m1773858509561",536873446]],["^15",[3978,"^Z","journals/2026_03_18.md",536873282]],["^15",[3979,"^12",2,536873449]],["^15",[3980,"^K",1774105680896,536873450]],["^15",[3980,"^[",3987,536874125]],["^15",[3980,"^O","^17",536873450]],["^15",[3980,"^N",20260321,536873450]],["^15",[3980,"^@",true,536873450]],["^15",[3980,"^Y","mar 21st, 2026",536873450]],["^15",[3980,"^11","Mar 21st, 2026",536873450]],["^15",[3980,"^B",1774109210745,536874597]],["^15",[3980,"^;","~u69c00b58-5b26-4a4c-885e-748f610b2e12",536875364]],["^15",[3983,"^K",1774106652427,536873478]],["^15",[3983,"^@",false,536873478]],["^15",[3983,"^Y","personality psychology/virtue",536873478]],["^15",[3983,"^A",150,536873478]],["^15",[3983,"^11","personality psychology/virtue",536873478]],["^15",[3983,"^B",1774106652427,536873478]],["^15",[3983,"^;","~u69beb81c-f545-44a6-b54a-6473c6500222",536873478]],["^15",[3984,"^Q","Мне ближе аллегория колесничего из платоновского диалога Федр, чем аристотелевская этика. В ней человек должен стать лучше, воспитывая в себе добродетель и прилагая ее к жизни. Я же должен держать в уздах  свои пороки с помощью сознательности, заученных поведений или фармацевтики.",536873654]],["^15",[3984,"^O","^17",536873654]],["^15",[3984,"^F",497,536873654]],["^15",[3984,"^X",494,536873654]],["^15",[3984,"^V",497,536873658]],["^15",[3984,"^U",150,536873659]],["^15",[3984,"^U",494,536873659]],["^15",[3984,"^U",496,536873659]],["^15",[3984,"^U",3983,536873659]],["^15",[3984,"^?",["^ "],536873654]],["^15",[3984,"^;","~u69beb8af-ae40-4d55-b1c9-1756cffdc288",536873654]],["^15",[3986,"^Q","Я прочитал кучу книг, чтобы стать лучше: самопомощь, пикап, буддизм. В пикаперском сообществе я увидел, что в разговоре есть грамматика, и я хотел научаться общаться. В конце концов помогла мне фармацевтика: антипсихотики, нормотимики и антидепрессанты. Моей заслуги в этом нет никакой.",536874120]],["^15",[3986,"^O","^17",536873669]],["^15",[3986,"^F",3984,536873669]],["^15",[3986,"^X",494,536873669]],["^15",[3986,"^V",497,536873669]],["^15",[3986,"^U",150,536873670]],["^15",[3986,"^U",494,536873670]],["^15",[3986,"^U",496,536873670]],["^15",[3986,"^U",3983,536873670]],["^15",[3986,"^?",["^ "],536874120]],["^15",[3986,"^;","~u69beb8bb-089d-42b2-b4d0-4a98b4d88455",536873669]],["^15",[3987,"^3","- [[Meisner technique]] #[[writing/AI]] Используй ответ на промпт как подачу реплики, которая в свою очерередь будет зачинной репликой. Череда таких репликом может навести тебя на новый промпт, и цикл начнется заново.\n\t- В твоем состоянии только так ты можешь написать книгу, если это тебе вообще по плечу.\n\t- Формы реплик\n\t\t- Письменные\n\t\t\t- Предложение\n\t\t\t- Абзац\n\t\t- Разговорные\n\t\t\t- Фраза\n\t\t- Мысленные\n\t\t\t- Большой и маленький куски\n\t\t\t- Beat\n\t- Задачи",536875364]],["^15",[3987,"^18","~m1774190893952",536875365]],["^15",[3987,"^Z","journals/2026_03_21.md",536874125]],["^15",[3988,"^Q","",536874129]],["^15",[3988,"^O","^17",536874129]],["^15",[3988,"^@",false,536874129]],["^15",[3988,"^F",148,536874129]],["^15",[3988,"^X",148,536874129]],["^15",[3988,"^V",148,536874129]],["^15",[3988,"^U",148,536874130]],["^15",[3988,"^?",["^ "],536874129]],["^15",[3988,"^;","~u69bebe1a-869a-4727-bf11-fc7f9de03fac",536874129]],["^15",[3989,"^K",1774108406165,536874132]],["^15",[3989,"^@",false,536874132]],["^15",[3989,"^Y","writing/ai",536874132]],["^15",[3989,"^A",197,536874132]],["^15",[3989,"^11","writing/AI",536874132]],["^15",[3989,"^B",1774108406165,536874132]],["^15",[3989,"^;","~u69c00b58-6edd-47a0-9e8b-abf9dab914f4",536875364]],["^15",[3990,"^Q","[[Meisner technique]] #[[writing/AI]] Используй ответ на промпт как подачу реплики, которая в свою очерередь будет зачинной репликой. Череда таких репликом может навести тебя на новый промпт, и цикл начнется заново.",536874597]],["^15",[3990,"^O","^17",536874132]],["^15",[3990,"^@",true,536874132]],["^15",[3990,"^F",3980,536874132]],["^15",[3990,"^X",3980,536874132]],["^15",[3990,"^V",3980,536874132]],["^15",[3990,"^U",197,536874233]],["^15",[3990,"^U",456,536874233]],["^15",[3990,"^U",3980,536874217]],["^15",[3990,"^U",3989,536874233]],["^15",[3990,"^H",197,536875364]],["^15",[3990,"^H",456,536875364]],["^15",[3990,"^H",3989,536875364]],["^15",[3990,"^;","~u69bebef6-28f7-4657-9a8c-dec4ac6cc195",536874132]],["^15",[3992,"^Q","В твоем состоянии только так ты можешь написать книгу, если это тебе вообще по плечу.",536874561]],["^15",[3992,"^O","^17",536874438]],["^15",[3992,"^@",true,536874438]],["^15",[3992,"^F",3990,536874438]],["^15",[3992,"^X",3980,536874438]],["^15",[3992,"^V",3990,536874440]],["^15",[3992,"^U",197,536874598]],["^15",[3992,"^U",456,536874598]],["^15",[3992,"^U",3980,536874598]],["^15",[3992,"^U",3989,536874598]],["^15",[3992,"^;","~u69bec19b-68d9-4705-8f82-8d83b1ee6a48",536874438]],["^15",[3994,"^Q","Римская империя просуществовала века, а её система счисления ещё дольше. Но один символ поставил на ней крест. Назовите этот символ.",536875344]],["^15",[3994,"^O","^17",536874706]],["^15",[3994,"^F",347,536874710]],["^15",[3994,"^X",343,536874706]],["^15",[3994,"^V",343,536874710]],["^15",[3994,"^U",343,536874707]],["^15",[3994,"^?",["^ "],536875344]],["^15",[3994,"^;","~u69bec2aa-20f7-4baa-83a8-dcb012bf8407",536874706]],["^15",[3995,"^Q","Ноль. Прим. именно ноль позволяет нам пользоваться десятичной системой исчисления. А слово \"крест\" - это намек на игру крестики-нолики.",536874873]],["^15",[3995,"^O","^17",536874719]],["^15",[3995,"^F",3994,536874719]],["^15",[3995,"^X",343,536874719]],["^15",[3995,"^V",3994,536874723]],["^15",[3995,"^U",343,536875345]],["^15",[3995,"^?",["^ "],536874873]],["^15",[3995,"^;","~u69bec373-cb83-4c5d-a02a-560cb4d8c0de",536874719]],["^15",[3996,"^Q","humahuma",536879140]],["^15",[3996,"^O","^17",536874877]],["^15",[3996,"^@",false,536874877]],["^15",[3996,"^F",344,536874877]],["^15",[3996,"^X",344,536874877]],["^15",[3996,"^V",344,536874877]],["^15",[3996,"^U",344,536874878]],["^15",[3996,"^?",["^ "],536879140]],["^15",[3996,"^;","~u69bec453-f40e-4059-93bd-c0e6c3cdd617",536874877]],["^15",[3997,"^Q","Название Пакистана - акроним этих регионов.",536874905]],["^15",[3997,"^O","^17",536874905]],["^15",[3997,"^F",1419,536874905]],["^15",[3997,"^X",1400,536874905]],["^15",[3997,"^V",1478,536874905]],["^15",[3997,"^U",1400,536874906]],["^15",[3997,"^?",["^ "],536874905]],["^15",[3997,"^;","~u69bec527-86ba-4daa-8225-191940e6c322",536874905]],["^15",[3999,"^Q","Для этого предмета, исчезнувшего из повседневной жизни, предназначен маленький кармашек в джинсах. Ответьте в двух словах, первое из которых очевидно.",536875340]],["^15",[3999,"^O","^17",536874984]],["^15",[3999,"^F",3994,536874988]],["^15",[3999,"^X",343,536874984]],["^15",[3999,"^V",343,536874988]],["^15",[3999,"^U",343,536874985]],["^15",[3999,"^?",["^ "],536875340]],["^15",[3999,"^;","~u69bec5bc-b11a-43f4-86cc-0a5cd334fdfd",536874984]],["^15",[4001,"^Q","Карманные часы. Прим.: вопрос в картинке.",536875308]],["^15",[4001,"^O","^17",536875261]],["^15",[4001,"^F",3999,536875261]],["^15",[4001,"^X",343,536875261]],["^15",[4001,"^V",3999,536875261]],["^15",[4001,"^U",343,536875341]],["^15",[4001,"^?",["^ "],536875308]],["^15",[4001,"^;","~u69bec9bb-81bd-49f1-85cb-bb8436b94388",536875261]],["^15",[4002,"^K",1774129271619,536875354]],["^15",[4002,"^[",4005,536875359]],["^15",[4002,"^O","^17",536875354]],["^15",[4002,"^N",20260322,536875354]],["^15",[4002,"^@",true,536875354]],["^15",[4002,"^Y","mar 22nd, 2026",536875354]],["^15",[4002,"^11","Mar 22nd, 2026",536875354]],["^15",[4002,"^?",["^ ","^19",["^1:",["diary"]],"^1;","event","^1<","sad"],536875634]],["^15",[4002,"^4",["^ ","^19","diary","^1;","event","^1<","sad"],5