                        :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 398.609375,\n                                   :y1 916.3125,\n                                   :x2 450.4375,\n                                   :y2 944.3125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 464.703125,\n                                   :y1 916.3125,\n                                   :x2 535.71875,\n                                   :y2 944.3125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 549.96875,\n                                   :y1 916.3125,\n                                   :x2 621.90625,\n                                   :y2 944.3125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 636.171875,\n                                   :y1 916.3125,\n                                   :x2 669.125,\n                                   :y2 944.3125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 683.390625,\n                                   :y1 916.3125,\n                                   :x2 729,\n                                   :y2 944.3125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 743.265625,\n                                   :y1 916.3125,\n                                   :x2 817.125,\n                                   :y2 944.3125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 831.5,\n                                   :y1 916.3125,\n                                   :x2 862.109375,\n                                   :y2 944.3125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 876.484375,\n                                   :y1 916.3125,\n                                   :x2 890.390625,\n                                   :y2 944.3125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 949.96875,\n                                   :x2 891.8729248046875,\n                                   :y2 977.96875,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 983.765625,\n                                   :x2 890.615234375,\n                                   :y2 1011.765625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1017.5625,\n                                   :x2 891.372802734375,\n                                   :y2 1045.5625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1051.359375,\n                                   :x2 891.826171875,\n                                   :y2 1079.359375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1085.015625,\n                                   :x2 891.4693603515625,\n                                   :y2 1113.015625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1118.796875,\n                                   :x2 891.323974609375,\n                                   :y2 1146.796875,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 1152.59375,\n                                   :x2 659.845703125,\n                                   :y2 1180.59375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}),\n                          :page 365},\n               :content {:text \"In language, one sees category membership shifting in a striking fashion thanks to the phenomenon of marking, which allows an entity to shift its category membership without changing its lexical label, but simply by changing the level of abstraction that applies to that label. Marking is the phenomenon whereby a word is used sometimes as the name of a general category and other times as the name of a subcategory of the general one. When such a word is used in its broader sense, it is said to have its unmarked meaning, while the narrower sense is the marked meaning. Marking is worth careful scrutiny, for above and beyond being an intriguing aspect of language, it is the linguistic trace of a mechanism that goes well beyond words, and on which our cognitive system depends totally: the mechanism of conceptual growth.\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"67a64c04-68af-41f8-887b-acb54c1bd58e\",\n               :page 372,\n               :position {:bounding {:x1 143.65625,\n                                     :y1 1152.15625,\n                                     :x2 998.1702880859375,\n                                     :y2 1334.359375,\n                                     :width 1142.3999999999999,\n                                     :height 1478.3999999999999},\n                          :rects ({:x1 185.6875,\n                                   :y1 1152.15625,\n                                   :x2 302.75,\n                                   :y2 1183.15625,\n                                   :width 1142.3999999999999,\n                                   :height 1478.3999999999999}\n                                  {:x1 318.15625,\n                                   :y1 1152.15625,\n                                   :x2 346.609375,\n                                   :y2 1183.15625,\n                                   :width 1142.3999999999999,\n                                   :height 1478.3999999999999}\n                                  {:x1 362,\n                                   :y1 1152.15625,\n                                   :x2 470.734375,\n                                   :y2 1183.15625,\n                                   :width 1142.3999999999999,\n                                   :height 1478.3999999999999}\n                                  {:x1 486.140625,\n                                   :y1 1152.15625,\n                                   :x2 509.6875,\n                                   :y2 1183.15625,\n                                   :width 1142.3999999999999,\n                                   :height 1478.3999999999999}\n                                  {:x1 525.078125,\n                                   :y1 1152.15625,\n                                   :x2 703.015625,\n      