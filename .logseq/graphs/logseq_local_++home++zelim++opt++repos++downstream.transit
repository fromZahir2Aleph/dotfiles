870919]],["^15",[74,"^?",["^ ","^18",["^19",["diary"]],"^1=","recognition","^1>","neutral"],536870919]],["^15",[74,"^J",["^18","^1=","^1>"],536870919]],["^15",[74,"^4",["^ ","^18","diary","^1=","recognition","^1>","neutral"],536870919]],["^15",[74,"^H",69,536870919]],["^15",[74,"^H",70,536870919]],["^15",[74,"^H",71,536870919]],["^15",[74,"^;","~u686ffd64-e5ac-446a-89a3-bbdd36218175",536870919]],["^15",[75,"^Q","Псевдоним для [Священного палимпсеста]([[Палимпсест летописи]]) - это всего лишь ещё одно проявление твоего [эскапизма]([[escapism]]).",536883589]],["^15",[75,"^O","^1;",536870919]],["^15",[75,"^F",74,536870919]],["^15",[75,"^X",68,536870919]],["^15",[75,"^V",68,536870919]],["^15",[75,"^U",68,536870919]],["^15",[75,"^U",72,536870919]],["^15",[75,"^U",73,536870919]],["^15",[75,"^H",72,536870919]],["^15",[75,"^H",73,536870919]],["^15",[75,"^;","~u686ffd64-921a-46e7-bc80-7aa19a93025e",536870919]],["^15",[76,"^3","tags:: diary\ntype:: event\nmood:: sad\n\n- #isolation Вчера побежал за кинувшими мяч в окно. Это и последние два визита в библиотеку, что я снова асоциален. Уже во второй раз, не включая изначальное состояние. Если шизотипическая неприсособленность - из-за нейробиологии мозга, то асоциальность последних пяти лет исходит из моей изоляции. И в этот раз я не вижу выхода, если только мне не станет лучше.",536870919]],["^15",[76,"^16",1752169828460,536870919]],["^15",[76,"^Z","journals/2025_05_14.md",536870919]],["^15",[77,"^K",1752169828459,536870919]],["^15",[77,"^[",76,536870919]],["^15",[77,"^N",20250514,536870919]],["^15",[77,"^@",true,536870919]],["^15",[77,"^Y","may 14th, 2025",536870919]],["^15",[77,"^11","May 14th, 2025",536870919]],["^15",[77,"^?",["^ ","^18",["^19",["diary"]],"^1=","event","^1>","sad"],536870919]],["^15",[77,"^4",["^ ","^18","diary","^1=","event","^1>","sad"],536870919]],["^15",[77,"^P",69,536870919]],["^15",[77,"^B",1752169828459,536870919]],["^15",[77,"^;","~u686ffd64-f679-4b6d-8ab7-4d0c2487242c",536870919]],["^15",[78,"^Q","tags:: diary\ntype:: event\nmood:: sad\n\n",536870919]],["^15",[78,"^O","^1;",536870919]],["^15",[78,"^1<",["^19",[]],536870919]],["^15",[78,"^F",77,536870919]],["^15",[78,"^X",77,536870919]],["^15",[78,"^V",77,536870919]],["^15",[78,"^U",69,536870919]],["^15",[78,"^U",70,536870919]],["^15",[78,"^U",71,536870919]],["^15",[78,"^U",77,536870919]],["^15",[78,"^:",true,536870919]],["^15",[78,"^?",["^ ","^18",["^19",["diary"]],"^1=","event","^1>","sad"],536870919]],["^15",[78,"^J",["^18","^1=","^1>"],536870919]],["^15",[78,"^4",["^ ","^18","diary","^1=","event","^1>","sad"],536870919]],["^15",[78,"^H",69,536870919]],["^15",[78,"^H",70,536870919]],["^15",[78,"^H",71,536870919]],["^15",[78,"^;","~u686ffd64-09ee-4a02-bc53-a5187a8cfd63",536870919]],["^15",[79,"^Q","#isolation Вчера побежал за кинувшими мяч в окно. Это и последние два визита в библиотеку, что я снова асоциален. Уже во второй раз, не включая изначальное состояние. Если шизотипическая неприсособленность - из-за нейробиологии мозга, то асоциальность последних пяти лет исходит из моей изоляции. И в этот раз я не вижу выхода, если только мне не станет лучше.",536870919]],["^15",[79,"^O","^1;",536870919]],["^15",[79,"^F",78,536870919]],["^15",[79,"^X",77,536870919]],["^15",[79,"^V",77,536870919]],["^15",[79,"^U",39,536870919]],["^15",[79,"^U",77,536870919]],["^15",[79,"^H",39,536870919]],["^15",[79,"^;","~u686ffd64-67e2-4efa-a571-08108d3da6cf",536870919]],["^15",[80,"^3","- #stoicism Теперь, когда ты остался без амбиций, своего ума и просто-напросто трудоспособности, стоицизм - оптимальное мировоззрение для тебя. Терпи до конца, и надейся на технологический прогресс.",536870919]],["^15",[80,"^16",1752169828472,536870919]],["^15",[80,"^Z","journals/2025_05_13.md",536870919]],["^15",[81,"^K",1752169828472,536870919]],["^15",[81,"^[",80,536870919]],["^15",[81,"^N",20250513,536870919]],["^15",[81,"^@",true,536870919]],["^15",[81,"^Y","may 13th, 2025",536870919]],["^15",[81,"^11","May 13th, 2025",536870919]],["^15",[81,"^B",1752169828472,536870919]],["^15",[81,"^;","~u686ffd64-73cc-4fe9-8315-f45dceb7d202",536870919]],["^15",[82,"^K",1752169828471,536870919]],["^15",[82,"^@",false,536870919]],["^15",[82,"^Y","stoicism",536870919]],["^15",[82,"^11","stoicism",536870919]],["^15",[82,"^B",1752169828471,536870919]],["^15",[82,"^;","~u686ffd64-5575-456e-9304-ef5c0f2283d0",536870919]],["^15",[83,"^Q","#stoicism Теперь, когда ты остался без амбиций, своего ума и просто-напросто трудоспособности, стоицизм - оптимальное мировоззрение для тебя. Терпи до конца, и надейся на технологический прогресс.",536870919]],["^15",[83,"^O","^1;",536870919]],["^15",[83,"^F",81,536870919]],["^15",[83,"^X",81,536870919]],["^15",[83,"^V",81,536870919]],["^15",[83,"^U",81,536870919]],["^15",[83,"^U",82,536870919]],["^15",[83,"^H",82,536870919]],["^15",[83,"^;","~u686ffd64-e842-4f32-adef-5214848cff54",536870919]],["^15",[84,"^3","- [[personality psychology/accentuation]]\n\t- [[affect display]]\n\t\t- [[sign language]]\n\t\t- Регистры\n\t\t\t- На улице\n\t\t\t\t- Я слишком вежлив, и у этой вежливости элемент [[personality psychology/self-deception/riya]].\n\t\t- Речь\n\t\t\t- Замени мат неручными и неречевыми сигналами.\n\t\t\t- Не подчёркивай ударение на незнакомых словах. Это выдаёт твоё незнакомство с ними.\n\t- Внешность\n\t\t- Одежда\n\t- Смотри youtube *каналы* с молодыми людьми.",536870919]],["^15",[84,"^16",1752169828487,536870919]],["^15",[84,"^Z","journals/2025_05_12.md",536870919]],["^15",[85,"^K",1752169828484,536870919]],["^15",[85,"^[",84,536870919]],["^15",[85,"^N",20250512,536870919]],["^15",[85,"^@",true,536870919]],["^15",[85,"^Y","may 12th, 2025",536870919]],["^15",[85,"^11","May 12th, 2025",536870919]],["^15",[85,"^B",1752169828484,536870919]],["^15",[85,"^;","~u686ffd64-940d-4084-8eb0-124202241fba",536870919]],["^15",[86,"^K",1752169828723,536870919]],["^15",[86,"^@",false,536870919]],["^15",[86,"^Y","personality psychology/accentuation",536870919]],["^15",[86,"^A",34,536870919]],["^15",[86