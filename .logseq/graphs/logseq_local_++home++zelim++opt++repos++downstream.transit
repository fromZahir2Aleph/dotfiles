-981b-f705d16f82e7\",\n               :page 39,\n               :position {:bounding {:x1 0,\n                                     :y1 496,\n                                     :x2 857,\n                                     :y2 2229.046875,\n                                     :width 857.0000000000002,\n                                     :height 1109.058823529412},\n                          :rects ({:x1 0,\n                                   :y1 496,\n                                   :x2 857,\n                                   :y2 496,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 107.796875,\n                                   :y1 983.71875,\n                                   :x2 749.1487426757812,\n                                   :y2 1006.71875,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 0,\n                                   :y1 995.25,\n                                   :x2 857,\n                                   :y2 1109.046875,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 0,\n                                   :y1 1110,\n                                   :x2 857,\n                                   :y2 2219.046875,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 0,\n                                   :y1 1117.046875,\n                                   :x2 0,\n                                   :y2 1136.046875,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 0,\n                                   :y1 1119.046875,\n                                   :x2 857,\n                                   :y2 2229.046875,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}),\n                          :page 39},\n               :content {:text \"The act of categorization is the tentative and gradated, grayshaded linking of an entity or a situation to a prior category in one’s mind.\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"64fb9fb7-b778-4512-81e8-a7b63c990615\",\n               :page 46,\n               :position {:bounding {:x1 0,\n                                     :y1 174,\n                                     :x2 748.6839599609375,\n                                     :y2 496.328125,\n                                     :width 857.0000000000002,\n                                     :height 1109.058823529412},\n                          :rects ({:x1 0,\n                                   :y1 174,\n                                   :x2 0,\n                                   :y2 193,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 0,\n                                   :y1 190,\n                                   :x2 0,\n                                   :y2 209,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 512.3125,\n                                   :y1 416.546875,\n                                   :x2 748.265625,\n                                   :y2 439.546875,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 235.40625,\n                                   :y1 444.9375,\n                                   :x2 310.328125,\n                                   :y2 467.9375,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 327.96875,\n                                   :y1 444.9375,\n                                   :x2 366.203125,\n                                   :y2 467.9375,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 383.84375,\n                                   :y1 444.9375,\n                                   :x2 481.8125,\n                                   :y2 467.9375,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 499.453125,\n                                   :y1 444.9375,\n                                   :x2 602.3125,\n                                   :y2 467.9375,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 619.953125,\n                                   :y1 444.9375,\n                                   :x2 645.671875,\n                                   :y2 467.9375,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 663.3125,\n                                   :y1 444.9375,\n                                   :x2 748.6839599609375,\n                                   :y2 467.9375,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 107.796875,\n                                   :y1 445.9375,\n                                   :x2 218.3740997314453,\n                                   :y2 468.9375,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}\n                                  {:x1 107.796875,\n                                   :y1 473.328125,\n                                   :x2 254.80160522460938,\n                                   :y2 496.328125,\n                                   :width 857.0000000000002,\n                                   :height 1109.058823529412}),\n                          :page 46},\n               :content {:text \"analogy-making is the machinery behind the pulsating heartbeat of thought: categorization.\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"64fba21e-5f7b-454a-b38a-bfda542f638b\",\n               :page 50,\n               :position {:bounding {:x1 0,\n                                     :y1 0,\n                                     :x2 891.7716064453125,\n                                     :y2 658.015625,\n                                     :width 1019.9999999999999,\n                                     :height 1319.9999999999998},\n                          :rects ({:x1 0,\n                                   :y1 0,\n                                   :x2 0,\n                                   :y2 0,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 158,\n                                   :x2 0,\n                                   :y2 178,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 174,\n                                   :x2 0,\n                                   :y2 194,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 190,\n                                   :x2 0,\n                                   :y2 210,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 0,\n                                   :y1 206,\n                                   :x2 0,\n                                   :y2 226,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 393.1009521484375,\n                                   :y1 461.3125,\n                                   :x2 891.0501098632812,\n                                   :y2 489.3125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 495.046875,\n                                   :x2 891.4285888671875,\n                                   :y2 523.046875,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 528.765625,\n                                   :x2 890.9505615234375,\n                                   :y2 556.765625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 562.5625,\n                                   :x2 891.619873046875,\n                                   :y2 590.5625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 596.34375,\n                                   :x2 891.7716064453125,\n                                   :y2 624.34375,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 630.015625,\n                                   :x2 357.52783203125,\n                                   :y2 658.015625,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}),\n                          :page 50},\n               :content {:text \"cognition takes place thanks to a constantﬂow of categorizations, and that at the base of it all is found, in contrast to classiﬁcation (which aims to put all things into ﬁxed and rigid mental boxes), the phenomenon of categorization through analogy-making, which endows human thinking with its remarkable ﬂuidity.\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"64fba2dd-ed27-4cfd-8d45-5a163fb0ab9b\",\n               :page 51,\n               :position {:bounding {:x1 0,\n                                     :y1 46,\n                                     :x2 891.643310546875,\n                                     :y2 286.828125,\n                                     :width 1019.9999999999999,\n                                     :height 1319.9999999999998},\n                          :rects ({:x1 0,\n                                   :y1 46,\n                                   :x2 0,\n                                   :y2 66,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 248.29547119140625,\n                                   :y1 225.03125,\n                                   :x2 891.643310546875,\n                                   :y2 253.03125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}\n                                  {:x1 128.3125,\n                                   :y1 258.828125,\n                                   :x2 263.55206298828125,\n                                   :y2 286.828125,\n                                   :width 1019.9999999999999,\n                                   :height 1319.9999999999998}),\n                          :page 51},\n               :content {:text \"we think only thanks to analogies that link our present to our past.\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"6502222f-95ec-44bf-938e-5876f0837a79\",\n               :page 67,\n               :position {:bounding {:x1 451.765625,\n                                     :y1 948.390625,\n                                     :x2 771.8077392578125,\n                                     :y2 981.390625,\n                                     :width 1224,\n                                     :height 1584},\n                          :rects ({:x1 451.765625,\n                                   :y1 948.390625,\n                                   :x2 771.8077392578125,\n                                   :y2 981.390625,\n                                   :width 1224,\n                                   :height 1584}),\n                          :page 67},\n               :content {:text \"Synopsis of This Book\"},\n               :properties {:color \"yellow\"}}\n              {:id #uuid \"6509d51a-bad3-4712-9219-b9222eae3373\",\n               :page 61,\n               :position {:bounding {:x1 0,\n                                     :y1 0,\n                                     :x2 1020,\n                                     :y2 2650,\n                          