^X",1094,536870915]],["^15",[1099,"^V",1097,536870915]],["^15",[1099,"^U",1094,536870915]],["^15",[1099,"^;","~u69a845e3-aaa1-4c88-a3f5-752988e89a5a",536870915]],["^15",[1100,"^Q","Этический",536870915]],["^15",[1100,"^O","^17",536870915]],["^15",[1100,"^F",1099,536870915]],["^15",[1100,"^X",1094,536870915]],["^15",[1100,"^V",1097,536870915]],["^15",[1100,"^U",1094,536870915]],["^15",[1100,"^;","~u69a845e3-43a7-4a4a-9e6b-33d4dd2d6296",536870915]],["^15",[1101,"^Q","Практический",536870915]],["^15",[1101,"^O","^17",536870915]],["^15",[1101,"^F",1100,536870915]],["^15",[1101,"^X",1094,536870915]],["^15",[1101,"^V",1097,536870915]],["^15",[1101,"^U",1094,536870915]],["^15",[1101,"^;","~u69a845e3-8ea8-40b7-bb24-21ade38c5305",536870915]],["^15",[1102,"^Q","Академический",536870915]],["^15",[1102,"^O","^17",536870915]],["^15",[1102,"^F",1101,536870915]],["^15",[1102,"^X",1094,536870915]],["^15",[1102,"^V",1097,536870915]],["^15",[1102,"^U",1094,536870915]],["^15",[1102,"^;","~u69a845e3-db1a-43ca-88cf-7bb3226a0116",536870915]],["^15",[1103,"^Q","Мотивы создания намного сложнее и могут включать деньги, самоутверждение и др.",536870915]],["^15",[1103,"^O","^17",536870915]],["^15",[1103,"^F",1097,536870915]],["^15",[1103,"^X",1094,536870915]],["^15",[1103,"^V",1094,536870915]],["^15",[1103,"^U",1094,536870915]],["^15",[1103,"^;","~u69a845e3-aa95-46d8-86d8-01fb1230de2d",536870915]],["^15",[1104,"^3","- #holism|atomism\n\t- #[[TV Tropes]] Для успешного комбинирования нужно видеть тропы как сетку тегов как на сайтах BoardGameGeek или Rate Your Music. Атом можно подчеркнуть, вычеркнуть или спрятать, то есть сделать пустым или подразумевающимся.\n\t- Формула эмергентности\n\t\t- Переменные в формуле эмергентности по степени важности:\n\t\t\t- вероятность открытия другими атома или комбинациии, в частности синергии, атомов\n\t\t\t\t- обратно степени изученности сферы\n\t\t\t- количество синергий в области\n\t\t\t- количество атомов\n\t\t- Больше применима к играм и жанровому искусству.\n\t\t- Простейший паттерн\n\t\t\t- x встречает y\n\t\t- #defamiliarisation #sakoku Если я вернусь в жизнь, мои три периода [Сакоку]([[sakoku]]) могут принести свою пользу. Новый взгляд на обыденное и всё такое.\n\t\t\t- Моя биография жалка, но в ней много уникальных переменных. К тому же они могут привести к открытию новых, но уже априори.\n\t\t-\n\t- #[[creative limitation]] Балансируй между интересными ограничениями и обещающими комбинациями тегов и между их уникальностью, возможностью воплощения и потенциалом заинтересовать публику.",536870915]],["^15",[1104,"^16",1772635620014,536870915]],["^15",[1104,"^Z","journals/2025_07_14.md",536870915]],["^15",[1105,"^K",1772635620010,536870915]],["^15",[1105,"^[",1104,536870915]],["^15",[1105,"^N",20250714,536870915]],["^15",[1105,"^@",true,536870915]],["^15",[1105,"^Y","jul 14th, 2025",536870915]],["^15",[1105,"^11","Jul 14th, 2025",536870915]],["^15",[1105,"^B",1772635620010,536870915]],["^15",[1105,"^;","~u69a845e4-32fa-4f70-8969-3798dcc6b1c4",536870915]],["^15",[1106,"^K",1772635620010,536870915]],["^15",[1106,"^@",false,536870915]],["^15",[1106,"^Y","holism|atomism",536870915]],["^15",[1106,"^11","holism|atomism",536870915]],["^15",[1106,"^B",1772635620010,536870915]],["^15",[1106,"^;","~u69a845e6-356c-45eb-9b8c-eca4e7371729",536870917]],["^15",[1107,"^K",1772635620011,536870915]],["^15",[1107,"^[",2847,536870917]],["^15",[1107,"^@",false,536870915]],["^15",[1107,"^Y","tv tropes",536870915]],["^15",[1107,"^11","TV Tropes",536870915]],["^15",[1107,"^B",1772635620011,536870915]],["^15",[1107,"^;","~u69a845e7-4335-42e3-a58c-e21b87952840",536870917]],["^15",[1108,"^K",1772635620012,536870915]],["^15",[1108,"^@",false,536870915]],["^15",[1108,"^Y","sakoku",536870915]],["^15",[1108,"^11","sakoku",536870915]],["^15",[1108,"^B",1772635620012,536870915]],["^15",[1108,"^;","~u69a845e4-9ca0-4190-8a09-d10e7ce8e8d8",536870915]],["^15",[1109,"^K",1772635620013,536870915]],["^15",[1109,"^@",false,536870915]],["^15",[1109,"^Y",