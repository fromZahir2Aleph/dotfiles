Аполлону и Артемиде и возложил на себя ношу религиозных, административных и геометрических обязанностей. И долго затем грустил по океанам и грезил о неизведанных морях.",536870919]],["^15",[1102,"^O","^1;",536870919]],["^15",[1102,"^F",1154,536870919]],["^15",[1102,"^X",1003,536870919]],["^15",[1102,"^V",1154,536870919]],["^15",[1102,"^U",1003,536870919]],["^15",[1102,"^;","~u686ffd65-661e-457e-a2fb-41e55dd3e4dd",536870919]],["^15",[1103,"^Q","Серебряный век",536870919]],["^15",[1103,"^O","^1;",536870919]],["^15",[1103,"^F",1051,536870919]],["^15",[1103,"^X",1003,536870919]],["^15",[1103,"^V",1101,536870919]],["^15",[1103,"^U",1003,536870919]],["^15",[1103,"^;","~u686ffd65-4a64-4b9a-9a09-aef1bb1f8cff",536870919]],["^15",[1104,"^M",true,536870919]],["^15",[1104,"^Q","Титаномахия\ncollapsed:: true",536870919]],["^15",[1104,"^O","^1;",536870919]],["^15",[1104,"^F",1063,536870919]],["^15",[1104,"^X",1003,536870919]],["^15",[1104,"^V",1079,536870919]],["^15",[1104,"^U",1003,536870919]],["^15",[1104,"^?",["^ "],536870919]],["^15",[1104,"^J",[],536870919]],["^15",[1104,"^4",["^ "],536870919]],["^15",[1104,"^;","~u686ffd65-2413-4ba9-be54-679a902b529b",536870919]],["^15",[1105,"^M",true,536870919]],["^15",[1105,"^Q","Калечение Гефеста\ncollapsed:: true",536870919]],["^15",[1105,"^O","^1;",536870919]],["^15",[1105,"^F",1075,536870919]],["^15",[1105,"^X",1003,536870919]],["^15",[1105,"^V",1075,536870919]],["^15",[1105,"^U",1003,536870919]],["^15",[1105,"^U",1034,536870919]],["^15",[1105,"^?",["^ "],536870919]],["^15",[1105,"^J",[],536870919]],["^15",[1105,"^4",["^ "],536870919]],["^15",[1105,"^;","~u686ffd65-aa32-4a99-8b03-a399778cee33",536870919]],["^15",[1106,"^Q","Ἑρμῆς\n.tags::\n.being:: god\n.mythology:: Greece\n.transcription:: /her.mɛ̂ːs/\n.translation:: Гермес\n.flags:: Olympian",536870919]],["^15",[1106,"^O","^1;",536870919]],["^15",[1106,"^F",1178,536870919]],["^15",[1106,"^X",1003,536870919]],["^15",[1106,"^V",1159,536870919]],["^15",[1106,"^U",1003,536870919]],["^1