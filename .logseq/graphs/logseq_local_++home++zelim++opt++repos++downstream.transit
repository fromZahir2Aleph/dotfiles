70919]],["^15",[1205,"^J",["^1L","^1G","^1M"],536870919]],["^15",[1205,"^4",["^ ","^1L","block","^1G","false","^1M","false"],536870919]],["^15",[1205,"^;","~u686ffd65-c300-4fa9-811d-c8c7cebcbc13",536870919]],["^15",[1206,"^Q","первый [Дионис](((2f675fa9-98a6-470c-93e3-a065e08759ef)))",536870919]],["^15",[1206,"^O","^1;",536870919]],["^15",[1206,"^F",1070,536870919]],["^15",[1206,"^X",1003,536870919]],["^15",[1206,"^V",1070,536870919]],["^15",[1206,"^U",1003,536870919]],["^15",[1206,"^U",1032,536870919]],["^15",[1206,"^U",1033,536870919]],["^15",[1206,"^U",1036,536870919]],["^15",[1206,"^U",1038,536870919]],["^15",[1206,"^U",1040,536870919]],["^15",[1206,"^U",1041,536870919]],["^15",[1206,"^H",1178,536870919]],["^15",[1206,"^;","~u686ffd65-4e48-400f-b9bc-681577cde025",536870919]],["^15",[1207,"^3","- ![The Philosopher's Toolkit_ A Compendium of - Peter S. Fosl.pdf](../assets/The_Philosopher's_Toolkit_A_Compendium_of_-_Peter_S._Fosl_1694722392332_0.pdf)\n- Argument\n\t- Deduction\n\t\t- Follows from premises with necessity\n\t- Induction\n\t\t- Follows from premises with probability, because the following is not conclusive\n\t\t\t- Most X have Y\n\t\t\t  This is X\n\t\t\t  Therefore, this X has Y\n\t\t- Is mostly but not necessarily in form of generalization\n\t\t- Limitations\n\t\t\t- Future\n\t\t\t- Intractable past\n\t\t\t- Unobservable nature and universe\n\t\t\t- Extent of human observation: cognition, memory, etc.\n\t- Validity and soundness\n\t\t- Validity is the topic-neutral property of argument's structure. Basically \"if the premise is true\", the conclusion of which can be:\n\t\t\t- Probable\n\t\t\t  collapsed:: true\n\t\t\t\t- If I get flush on river, I probably will win.\n\t\t\t\t  I got flush.\n\t\t\t\t  I probably won\n\t\t\t- Certain\n\t\t\t  collapsed:: true\n\t\t\t\t- If the lines are parallel, they don't intersect.\n\t\t\t\t- The lines are parallel.\n\t\t\t\t- They don't intersect.\n\t\t- If the premise of a valid argument is actually true it's sound.\n\t- Refutations of an argument\n\t\t- The argument is invalid\n\t\t- One or more of the premises are false\n\t\t- The conclusion is false as in *reductio ad absurdum*\n\t\t\t- Just shows that the conclusion must be false but doesn't refute the argument itself, because it doesn't indicate *what* is wrong with the argument, only that *something* must be wrong with it.\n\t- Abduction or inference to the best explanation\n\t  collapsed:: true\n\t\t- Similarity to Induction\n\t\t\t- Doesn't necessarily follow from the premises like deduction does\n\t\t- Difference from Induction\n\t\t\t- Appeals implicitly or explicitly to additional reasoning whereas induction *only* appeals to frequency or statistics\n\t- Hypothetico‐deductive method\n\t\t- Start with a hypothesis\n\t\t  logseq.order-list-type:: number\n\t\t- Deduce which facts follow\n\t\t  logseq.order-list-type:: number\n\t\t- Make an experiment to test them\n\t\t  logseq.order-list-type:: number\n\t\t- Make a deduction whether the hypothesis is true or false\n\t\t  logseq.order-list-type:: number\n\t-\n- Paragraph markers\n  id:: 65677c5b-9d97-4bc0-b2b7-75c75bd7dca6\n\t- Explication\n\t\t- XPL\n\t- In other words\n\t\t- IE\n\t- Example\n\t\t- EG\n\t- My commentary\n\t\t- Commetary",536870919]],["^15",[1207,"^16",1752169829941,536870919]],["^15",[1207,"^Z","pages/Philosopher's Toolkit.md",536870919]],["^15",[1208,"^Q","Validity is the topic-neutral property of argument's structure. Basically \"if the premise is true\", the conclusion of which can be:",536870919]],["^15",[1208,"^O","^1;",536870919]],["^15",[1208,"^F",1214,536870919]],["^15",[1208,"^X",1001,536870919]],["^15",[1208,"^V",1214,536870919]],["^15",[1208,"^U",1001,536870919]],["^15",[1208,"^;","~u686ffd65-b69c-431b-9537-5fd9ff07f60f",536870919]],["^15",[1209,"^Q","Follows from premises with necessity",536870919]],["^15",[1209,"^O","^1;",536870919]],["^15",[1209,"^F",1250,536870919]],["^15",[1209,"^X",1001,536870919]],["^15",[1209,"^V",1250,536870919]]