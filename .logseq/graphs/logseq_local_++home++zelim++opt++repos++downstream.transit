"^18"],536870919]],["^15",[458,"^4",["^ ","^18","grounding/motivational grounding, Anzhela, Paris"],536870919]],["^15",[458,"^H",43,536870919]],["^15",[458,"^H",455,536870919]],["^15",[458,"^H",456,536870919]],["^15",[458,"^H",457,536870919]],["^15",[458,"^;","~u686ffd64-a7a7-443c-b3d9-540b5db38ea7",536870919]],["^15",[459,"^Q","![🖼 photo_5242706874619513704_y.jpg](../assets/photo_5242706874619513704_y.jpg)",536870919]],["^15",[459,"^O","^1;",536870919]],["^15",[459,"^F",458,536870919]],["^15",[459,"^X",454,536870919]],["^15",[459,"^V",454,536870919]],["^15",[459,"^U",454,536870919]],["^15",[459,"^;","~u686ffd64-8e5e-4083-8ba4-09e044a28d65",536870919]],["^15",[460,"^3","- [[personality psychology/egocentrism]]\n\t- В начале был только я. Потом появился зритель в виде Валида.\n\t- После Ростова вышел из машины Нозика и стал общаться. Только вот это были монологи. Для Анжелы это была аудиокнига, где она со свойственной ей горячностью влюбилась в актёра озвучки.\n\t- Затем они, то есть люди вокруг приобрели вдруг чувства и черты. Я осознал необходимость диалога, но разница в взглядах, интересах и характере, моё плохое самочувствие помешало прогрессу.\n\t- Мой след в обществе - это обращение в ислам одного и попытка самоубийста другой.",536870919]],["^15",[460,"^16",1752169828875,536870919]],["^15",[460,"^Z","journals/2025_01_14.md",536870919]],["^15",[461,"^K",1752169828875,536870919]],["^15",[461,"^[",460,536870919]],["^15",[461,"^N",20250114,536870919]],["^15",[461,"^@",true,536870919]],["^15",[461,"^Y","jan 14th, 2025",536870919]],["^15",[461,"^11","Jan 14th, 2025",536870919]],["^15",[461,"^B",1752169828875,536870919]],["^15",[461,"^;","~u686ffd64-1987-4a84-806f-0e9187508e86",536870919]],["^15",[462,"^K",1752169828874,536870919]],["^15",[462,"^@",false,536870919]],["^15",[462,"^Y","personality psychology/egocentrism",536870919]],["^15",[462,"^A",34,536870919]],["^15",[462,"^11","personality psychology/egocentrism",536870919]],["^15",[462,"^B",1752169828874,536870919]],["^15",[462,"^;","~u686ffd64-c93a-4699-80b9-2623f3894706",536870919]],["^15",[463,"^Q","[[personality psychology/egocentrism]]",536870919]],["^15",[463,"^O","^1;",536870919]],["^15",[463,"^F",461,536870919]],["^15",[463,"^X",461,536870919]],["^15",[463,"^V",461,536870919]],["^15",[463,"^U",34,536870919]],["^15",[463,"^U",461,536870919]],["^15",[463,"^U",462,536870919]],["^15",[463,"^H",34,536870919]],["^15",[463,"^H",462,536870919]],["^15",[463,"^;","~u686ffd64-d02a-41ff-b5fa-881f0e4811f3",536870919]],["^15",[464,"^Q","В начале был только я. Потом появился зритель в виде Валида.",536870919]],["^15",[464,"^O","^1;",536870919]],["^15",[464,"^F",463,536870919]],["^15",[464,"^X",461,536870919]],["^15",[464,"^V",463,536870919]],["^15",[464,"^U",34,536870919]],["^15",[464,"^U",461,536870919]],["^15",[464,"^U",462,536870919]],["^15",[464,"^;","~u686ffd64-703f-4793-80b9-f39a0c94be8f",536870919]],["^15",[465,"^Q","После Ростова вышел из машины Нозика и стал общаться. Только вот это были монологи. Для Анжелы это была аудиокнига, где она со свойственной ей горячностью влюбилась в актёра озвучки.",536870919]],["^15",[465,"^O","^1;",536870919]],["^15",[465,"^F",464,536870919]],["^15",[465,"^X",461,536870919]],["^15",[465,"^V",463,536870919]],["^15",[465,"^U",34,536870919]],["^15",[465,"^U",461,536870919]],["^15",[465,"^U",462,536870919]],["^15",[465,"^;","~u686ffd64-f564-4edd-84e1-5cfd377f621a",536870919]],["^15",[466,"^Q","Затем они, то есть люди вокруг приобрели вдруг чувства и черты. Я осознал необходимость диалога, но разница в взглядах, интересах и характере, моё плохое самочувствие помешало прогрессу.",536870919]],["^15",[466,"^O","^1;",536870919]],["^15",[466,"^F",465,536870919]],["^15",[466,"^X",461,536870919]],["^15",[466,"^V",463,536870919]],["^15",[466,"^U",34,536870919]],["^15",[466,"^U",461,536870919]],["^15",[466,"^U",462,536870919]],["^15",[466,"^;","~u686ffd64-e1dc-4802-a3fb-278ce50f9a9a",536870919]],["^15",[467,"^Q","Мой след в обществе - это обращение в ислам одного и попытка самоубийста другой.",536870919]],["^15",[467,"^O","^1;",536870919]],["^15",[467,"^F",466,536870919]],["^15",[467,"^X",461,536870919]],["^15",[467,"^V",463,536870919]],["^15",[467,"^U",34,536870919]],["^15",[467,"^U",461,536870919]],["^15",[467,"^U",462,536870919]],["^15",[467,"^;","~u686ffd64-bcd7-47cd-adab-044d201aea3d",536870919]],["^15",[468,"^3","- #kenophobia Тишина в присутствии других оглушает, а шум будоражит. Нужно инициировать, реагировать и при отсутствии реакции просто менять направление или замолчать. Но не убегай в себя, а ищи чем занять себя, не стыдясь других, их молчания или шума.",536870919]],["^15",[468,"^16",1752169828882,536870919]],["^15",[468,"^Z","journals/2025_01_13.md",536870919]],["^15",[469,"^K",1752169828882,536870919]],["^15",[469,"^[",468,536870919]],["^15",[469,"^N",20250113,536870919]],["^15",[469,"^@",true,536870919]],["^15",[469,"^Y","jan 13th, 2025",536870919]],["^15",[469,"^11","Jan 13th, 2025",536870919]],["^15",[469,"^B",1752169828882,536870919]],["^15",[469,"^;","~u686ffd64-102a-4c4d-8012-757e00453aa4",536870919]],["^15",[470,"^K",1752169829273,536870919]],["^15",[470,"^@",false,536870919]],["^15",[470,"^Y","kenophobia",536870919]],["^15",[470,"^11","kenophobia",536870919]],["^15",[470,"^B",1752169829273,536870919]],["^15",[470,"^;","~u686ffd65-bc4c-4be4-a368-93bf4aac56b8",536870919]],["^15",[471,"^Q","#kenophobia Тишина в присутствии других оглушает, а шум будоражит. Нужно инициировать, реагировать и при отсутствии реакции просто менять направление или замолчать. Но не убегай в себя, а ищи чем занять себя, не стыдясь других, их молчания или шума.",536870919]],["^15",[471,"^O","^1;",536870919]],["^15",[471,"^F",469,536870919]],["^15",[471,"^X",469,536870919]],["^15",[471,"^V",469,536870919]],["^15",[471,"^U",469,536870919]],["^15",[471,"^U",470,536870919]],["^15",[471,"^H",470,536870919]],["^15",[471,"^;","~u686ffd64-575d-4587-9038-905368e97b36",536870919]],["^15",[472,"^3","- [[focus areas/themes]]\n\t- Нез