],["^15",[50,"^;","~u686ffd64-8421-4b99-9614-944781a8d60e",536870919]],["^15",[51,"^K",1752169828410,536870919]],["^15",[51,"^@",false,536870919]],["^15",[51,"^Y","exposure",536870919]],["^15",[51,"^11","exposure",536870919]],["^15",[51,"^B",1752169828410,536870919]],["^15",[51,"^;","~u686ffd64-0249-4f08-9acd-c8b99bfb6b03",536870919]],["^15",[52,"^K",1752169829062,536870919]],["^15",[52,"^@",false,536870919]],["^15",[52,"^Y","personality psychology/self-awareness",536870919]],["^15",[52,"^A",34,536870919]],["^15",[52,"^11","personality psychology/self-awareness",536870919]],["^15",[52,"^B",1752169829062,536870919]],["^15",[52,"^;","~u686ffd65-abb8-42fb-82cf-e5c38cf76167",536870919]],["^15",[53,"^Q","#[[personality psychology/self-awareness]] #exposure Будь осторожным в незнакомых ситуациях, для которых у тебя нет плана действий. Особенно когда они вызывают стресс. Оцени насколько он серьёзен и меру экспозицию к нему. Не иди по краю перед сном или в присутствии людей.",536870919]],["^15",[53,"^O","^1;",536870919]],["^15",[53,"^F",50,536870919]],["^15",[53,"^X",50,536870919]],["^15",[53,"^V",50,536870919]],["^15",[53,"^U",34,536870919]],["^15",[53,"^U",50,536870919]],["^15",[53,"^U",51,536870919]],["^15",[53,"^U",52,536870919]],["^15",[53,"^H",34,536870919]],["^15",[53,"^H",51,536870919]],["^15",[53,"^H",52,536870919]],["^15",[53,"^;","~u686ffd64-2f0a-4f29-830b-cb0ae2ffb8d1",536870919]],["^15",[54,"^3","- #Gloomhaven\n\t- Синергии\n\t\t- https://boardgamegeek.com/thread/2456458/poll-best-2-player-character-combo\n\t\t- Looks like Demo has synergies only with Hatchet\n\t\t- Voidwarden is support only with some synergy with Guard.\n\t\t- Попробуй Hatchet, Demo и Voidwarden на высокой сложности. Потом RG, V, D на самой высокой сложности. Чередуй с RG, H, D и RG, H, V и, возможно, опять H, D, V.\n\t- Игровая механика\n\t\t- Abilities on a monster card, like SHIELD or RETALIATE, only take effect on the monster's turn, so any attacks made BEFORE the monster's turn aren't affected by them.\n\t\t- (Double Throw \\* (Power Pitch + The Favorite token + Poison)) \\* critical Attack Modifier. DT doubles the next attack, which is PP + TF + Poi. All of that is doubled by the Attack Modifier. If the boss happens to have any armor, you'd subtract that at the end.\n\t\t- Рана применяется в начале хода, а лечение в течение.",536870919]],["^15",[54,"^16",1752169828431,536870919]],["^15",[54,"^Z","journals/2025_06_21.md",536870919]],["^15",[55,"^K",1752169828429,536870919]],["^15",[55,"^[",54,536870919]],["^15",[55,"^N",20250621,536870919]],["^15",[55,"^@",true,536870919]],["^15",[55,"^Y","jun 21st, 2025",536870919]],["^15",[55,"^11","Jun 21st, 2025",536870919]],["^15",[55,"^B",1752169828429,536870919]],["^15",[55,"^;","~u686ffd64-012c-405d-a83e-2ec1ada90d8c",536870919]],["^15",[56,"^K",1752169828429,536870919]],["^15",[56,"^@",false,536870919]],["^15",[56,"^Y","gloomhaven",536870919]],["^15",[56,"^11","Gloomhaven",536870919]],["^15",[56,"^B",1752169828429,536870919]],["^15",[56,"^;","~u686ffd64-5cc8-44ac-9266-70e86fa90d7e",536870919]],["^15",[57,"^Q","Игровая механика",536870919]],["^15",[57,"^O","^1;",536870919]],["^15",[57,"^F",60,536870919]],["^15",[57,"^X",55,536870919]],["^15",[57,"^V",63,536870919]],["^15",[57,"^U",55,536870919]],["^15",[57,"^U",56,536870919]],["^15",[57,"^;","~u686ffd64-f405-4664-8811-7e954e2f77b9",536870919]],["^15",[58,"^Q","Voidwarden is support only with some synergy with Guard.",536870919]],["^15",[58,"^O","^1;",536870919]],["^15",[58,"^F",65,536870919]],["^15",[58,"^X",55,536870919]],["^15",[58,"^V",60,536870919]],["^15",[58,"^U",55,536870919]],["^15",[58,"^U",56,536870919]],["^15",[58,"^;","~u686ffd64-876f-494f-9fd2-128e0bb80680",536870919]],["^15",[59,"^Q","https://boardgamegeek.com/thread/2456458/poll-best-2-player-character-combo",536870919]],["^15",[59,"^O","^1;",536870919]],["^15",[59,"^F",60,536870919]],["^15",[59,"^X",55,536870919]],["^15",[59,"^V",60,536870919]],["^15",[59,"^U",55,536870919]],["^15",[59,"^U",