,536870917]],["^15",[2045,"^O","^17",536870917]],["^15",[2045,"^F",2044,536870917]],["^15",[2045,"^X",2040,536870917]],["^15",[2045,"^V",2044,536870917]],["^15",[2045,"^U",169,536870917]],["^15",[2045,"^U",172,536870917]],["^15",[2045,"^U",175,536870917]],["^15",[2045,"^U",1255,536870917]],["^15",[2045,"^U",2040,536870917]],["^15",[2045,"^;","~u69a845e6-1e7b-4bd4-a9df-36db4fbd35cd",536870917]],["^15",[2046,"^Q","Обозначь контрольные точки для разбора действий или пересмотра всего плана. #metacogintion",536870917]],["^15",[2046,"^O","^17",536870917]],["^15",[2046,"^F",2045,536870917]],["^15",[2046,"^X",2040,536870917]],["^15",[2046,"^V",2045,536870917]],["^15",[2046,"^U",169,536870917]],["^15",[2046,"^U",172,536870917]],["^15",[2046,"^U",175,536870917]],["^15",[2046,"^U",1255,536870917]],["^15",[2046,"^U",1877,536870917]],["^15",[2046,"^U",2040,536870917]],["^15",[2046,"^H",1877,536870917]],["^15",[2046,"^;","~u69a845e6-69b4-431c-bfb9-8e35387a15ed",536870917]],["^15",[2047,"^3","- #PIM\n\t- ### Переплетённые иерархии\n\t\t- Trees do grow,\n\t\t  id:: 64b9bd7a-b308-4305-b197-a107adc889df\n\t\t  Web does stick:\n\t\t  Logseq's slow,\n\t\t  But does the trick.\n\t\t\t- Без контекста сеть концепций - это решето.\n\t\t\t  collapsed:: true\n\t\t\t\t- Иерархия - далеко не самая важный элемент контекста, но единственный, который можно себе навязать.\n\t\t\t\t\t- При работе с источниками её легко воспроизвести - спускайся сверху вниз: оглавление, главы, работа с блоками и ссылками на них.\n\t\t\t\t\t- А вот на уровне единичных заметок, иерархическое дерево должно вырасти само с самого низа с помощью тэгов и ссылок на уже созданные таким путём страницы и блоки.",536870917]],["^15",[2047,"^16",1772635622418,536870917]],["^15",[2047,"^Z","journals/2023_06_19.md",536870917]],["^15",[2048,"^K",1772635622417,536870917]],["^15",[2048,"^[",2047,536870917]],["^15",[2048,"^N",20230619,536870917]],["^15",[2048,"^@",true,536870917]],["^15",[2048,"^Y","jun 19th, 2023",536870917]],["^15",[2048,"^11","Jun 19th, 2023",536870917]],["^15",[2048,"^B",1772635622417,536870917]],["^15",[2048,"^;","~u69a845e6-f0b7-4ab5-ac02-d24ee18ead40",536870917]],["^15",[2049,"^Q","#PIM",536870917]],["^15",[2049,"^O","^17",536870917]],["^15",[2049,"^F",2048,536870917]],["^15",[2049,"^X",2048,536870917]],["^15",[2049,"^V",2048,536870917]],["^15",[2049,"^U",1985,536870917]],["^15",[2049,"^U",2048,536870917]],["^15",[2049,"^H",1985,536870917]],["^15",[2049,"^;","~u69a845e6-7152-4c08-8de0-196ed08f76fe",536870917]],["^15",[2050,"^Q","### Переплетённые иерархии",536870917]],["^15",[2050,"^O","^17",536870917]],["^15",[2050,"^F",2049,536870917]],["^15",[2050,"^X",2048,536870917]],["^15",[2050,"^V",2049,536870917]],["^15",[2050,"^U",1985,536870917]],["^15",[2050,"^U",2048,536870917]],["^15",[2050,"^?",["^ ","^1H",3],536870917]],["^15",[2050,"^J",[],536870917]],["^15",[2050,"^;","~u69a845e6-5a34-4763-a90b-e34d848fe899",536870917]],["^15",[2051,"^M",true,536870917]],["^15",[2051,"^Q","Без контекста сеть концепций - это решето.\ncollapsed:: true",536870917]],["^15",[2051,"^O","^17",536870917]],["^15",[2051,"^F",2013,536870917]],["^15",[2051,"^X",2048,536870917]],["^15",[2051,"^V",2013,536870917]],["^15",[2051,"^U",1985,536870917]],["^15",[2051,"^U",2048,536870917]],["^15",[2051,"^?",["^ "],536870917]],["^15",[2051,"^J",[],536870917]],["^15",[2051,"^4",["^ "],536870917]],["^15",[2051,"^;","~u69a845e6-e763-42d6-a4b8-dd6463bebbc6",536870917]],["^15",[2052,"^Q","Иерархия - далеко не самая важный элемент контекста, но единственный, который можно себе навязать.",536870917]],["^15",[2052,"^O","^17",536870917]],["^15",[2052,"^F",2051,536870917]],["^15",[2052,"^X",2048,536870917]],["^15",[2052,"^V",2051,536870917]],["^15",[2052,"^U",1985,536870917]],["^15",[2052,"^U",2048,536870917]],["^15",[2052,"^;","~u69a845e6-0dd3-4b53-a4be-c0f5fb3a2bbd",536870917]],["^15",[2053,"^Q","При работе с источниками её легко воспроизвести - спускайся сверху вниз: оглавление, главы, работа с блоками и ссылками на них.",536870917]],["^15",[2053,"^O","^17",536870917]],["^15",[2053,"^F",2052,536870917]],["^15",[2053,"^X",2048,536870917]],["^15",[2053,"^V",2052,536870917]],["^15",[2053,"^U",1985,536870917]],["^15",[2053,"^U",2048,536870917]],["^15",[2053,"^;","~u69a845e6-9ad8-4005-a2b0-84adb965774a",536870917]],["^15",[2054,"^Q","А вот на уровне единичных заметок, иерархическое дерево должно вырасти само с самого низа с помощью тэгов и ссылок на уже созданные таким путём страницы и блоки.",536870917]],["^15",[2054,"^O","^17",536870917]],["^15",[2054,"^F",2053,536870917]],["^15",[2054,"^X",2048,536870917]],["^15",[2054,"^V",2052,536870917]],["^15",[2054,"^U",1985,536870917]],["^15",[2054,"^U",2048,536870917]],["^15",[2054,"^;","~u69a845e6-8499-471e-a27a-a29e56a81af5",536870917]],["^15",[2055,"^3","- [[Ударение в древнегреческом языке]]\n  id:: 648f1fab-91e8-4290-a5b5-b4da2733f087\n\t- В древнегреческом языке словесное ударение было музыкальным, то есть характеризовалось изменением тона подударного гласного. Краткий (одноморный) ударный гласный мог иметь только восходящий тон, обозначающийся знаком острого ударения ´, двухморный (долгий) гласный или дифтонг мог иметь как острое ударение (с поднимающимся на второй море тоном), так и облегчённое ˜ или ῀ с преломленным тоном, восходящим на первой море и нисходящим на второй.",536870917]],["^15",[2055,"^16",1772635622431,536870917]],["^15",[2055,"^Z","journals/2023_06_05.md",536870917]],["^15",[2056,"^K",1772635622430,536870917]],["^15",[2056,"^[",2055,536870917]],["^15",[2056,"^N",20230605,536870917]],["^15",[2056,"^@",true,536870917]],["^15",[2056,"^Y","jun 5th, 2023",536870917]],["^15",[2056,"^11","Jun 5th, 2023",536870917]],["^15",[2056,"^B",1772635622430,536870917]],["^15",[2056,"^;","~u69a845e6-ee96-4ba4-8dbf-0c6eb0715629",536870917]],["^15",[2057,"^K",1772635622429,536870917]],["^15",[2057,"^@",false,536870917]],["^15",[2057,"^Y","ударение в древнегреческом языке",536870917]],["^15",[2057,"^11","Ударение в древнегреческом языке",536870917]],["^15",[2057,"^B",1772635622429,536870917]],["^15",[2057,"^;","~u69a845e6-6c65-4f58-a204-48a25de1917f",536870917]],["^15",[2058,"^Q","[[Ударение в древнегреческом языке]]\nid:: 648f1fab-91e8-4290-a5b5-b4da2733f087",536870917]],["^15",[2058,"^O","^17",536870917]],["^15",[2058,"^F",2056,536870917]],["^15",[2058,"^X",2056,536870917]],["^15",[2058,"^V",2056,536870917]],["^15",[2058,"^U",2056,536870917]],["^15",[2058,"^U",2057,536870917]],["^15",[2058,"^?",["^ ","^1>","648f1fab-91e8-4290-a5b5-b4da2733f087"],536870917]],["^15",[2058,"^J",["^1>"],536870917]],["^15",[2058,"^4",["^ ","^1>","648f1fab-91e8-4290-a5b5-b4da2733f087"],536870917]],["^15",[2058,"^H",2057,536870917]],["^15",[2058,"^;","~u648f1fab-91e8-4290-a5b5-b4da2733f087",536870917]],["^15",[2059,"^Q","В древнегреческом языке словесное ударение было музыкальным, то есть характеризовалось изменением тона подударного гласного. Краткий (одноморный) ударный гласный мог иметь только восходящий тон, обозначающийся знаком острого ударения ´, двухморный (долгий) гласный или дифтонг мог иметь как острое ударение (с поднимающимся на второй море тоном), так и облегчённое ˜ или ῀ с преломленным тоном, восходящим на первой море и нисходящим на второй.",536870917]],["^15",[2059,"^O","^17",536870917]],["^15",[2059,"^F",2058,536870917]],["^15",[2059,"^X",2056,536870917]],["^15",[2059,"^V",2058,536870917]],["^15",[2059,"^U",2056,536870917]],["^15",[2059,"^U",2057,536870917]],["^15",[2059,"^;","~u69a845e6-2004-49c3-a116-6346b9eeba4d",536870917]],["^15",[2060,"^3","tags:: diary\ntype:: reflection\nmood:: sad\n\n\t- #Седа \"Ты чаще дома, чем я.\"",536870917]],["^15",[2060,"^16",1772635622443,536870917]],["^15",[2060,"^Z","journals/2023_05_20.md",536870917]],["^15",[2061,"^K",1772635622441,536870917]],["^15",[2061,"^[",2060,536870917]],["^15",[2061,"^N",20230520,536870917]],["^15",[2061,"^@",true,536870917]],["^15",[2061,"^Y","may 20th, 2023",536870917]],["^15",[2061,"^11","May 20th, 2023",536870917]],["^15",[2061,"^?",[